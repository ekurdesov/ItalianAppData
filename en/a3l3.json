          "it": "Il mio indirizzo email è mario.rossi@gmail.com.",
          "translation": "My email address is mario.rossi@gmail.com."
        },
        {
          "context": "spelling",
          "it": "Chiocciola, punto, trattino basso.",
          "translation": "At sign, dot, underscore."
        }
