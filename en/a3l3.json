  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Regular verbs in -ere",
      "description": "Many common Italian verbs ending in -ere follow the present-tense pattern -o, -i, -e, -iamo, -ete, -ono.",
      "conjugations": {
        "io": "scrivo",
        "tu": "scrivi",
        "lui/lei/Lei": "scrive",
        "noi": "scriviamo",
        "voi": "scrivete",
        "loro": "scrivono"
      },
      "examples": [
        {
          "it": "Mario scrive una lettera d'amore.",
          "translation": "Mario writes a love letter."
        },
        {
          "it": "Giorgio vende molti gelati.",
          "translation": "Giorgio sells many ice creams."
        },
        {
          "it": "Noi prendiamo l'autobus delle 7.",
          "translation": "We take the bus at seven."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Regular verbs in -ire",
      "description": "Regular verbs in -ire commonly form the present with -o, -i, -e, -iamo, -ite, -ono.",
      "conjugations": {
        "io": "parto",
        "tu": "parti",
        "lui/lei/Lei": "parte",
        "noi": "partiamo",
        "voi": "partite",
        "loro": "partono"
      },
      "examples": [
        {
          "it": "Luca presenta gli amici all'insegnante.",
          "translation": "Luca introduces the friends to the teacher."
        },
        {
          "it": "Gli amici di Andrea arrivano alle 10.",
          "translation": "Andrea's friends arrive at ten."
        },
        {
          "it": "Io compio gli anni in America.",
          "translation": "I celebrate my birthday in America."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking and giving an email address",
      "description": "Italian commonly asks for an email with 'Qual è il tuo indirizzo email?' and states it with 'Il mio indirizzo email è...'.",
      "examples": [
        {
          "context": "informal",
          "it": "Qual è il tuo indirizzo email?",
          "translation": "What is your email address?"
