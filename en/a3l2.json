  "lesson_info": {
    "id": "A1-L3-2",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Ripasso: Intervista doppia",
      "Grammatica: Dove abiti?",
      "Comprensione orale: Una strana coppia",
      "Chiedere e dire l'indirizzo e lo stato civile"
    ]
  },
  "language_rules": [
    {
      "category": "Pragmatics",
      "rule": "Asking about civil status",
      "description": "Italian uses adjective-based questions to ask whether someone is married, single, engaged, separated, divorced or widowed.",
      "examples": [
        {
          "context": "informal",
          "it": "Sei sposato/a?",
          "translation": "Are you married?"
        },
        {
          "context": "formal",
          "it": "È sposato/a?",
          "translation": "Are you married? (formal)"
        },
        {
          "it": "Sono sposata con Marco da vent'anni.",
          "translation": "I have been married to Marco for twenty years."
        },
        {
          "it": "Ho un ragazzo. / Ho una ragazza.",
          "translation": "I have a boyfriend. / I have a girlfriend."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking for an address: informal vs formal",
      "description": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking where someone lives and what their address is.",
      "examples": [
        {
          "context": "informal",
          "it": "Dove abiti?",
          "translation": "Where do you live?"
        },
        {
          "context": "formal",
          "it": "Dove abita?",
          "translation": "Where do you live? (formal)"
        },
        {
          "context": "informal",
          "it": "Qual è il tuo indirizzo?",
          "translation": "What is your address?"
        },
        {
          "context": "formal",
          "it": "Qual è il Suo indirizzo?",
          "translation": "What is your address? (formal)"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Saying an address",
      "description": "Addresses are commonly given with the pattern 'abitare a + city + in + street + number' or by stating the address directly.",
      "examples": [
        {
          "it": "Abito a Roma in via Garibaldi, 8.",
          "translation": "I live in Rome at Via Garibaldi 8."
        },
        {
          "it": "Il mio indirizzo è via Garibaldi, 8.",
          "translation": "My address is Via Garibaldi 8."
        },
        {
          "it": "Alice abita a Roma in via Brescia, 68.",
          "translation": "Alice lives in Rome at Via Brescia 68."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Useful address words",
      "description": "Italian addresses often include road-type nouns and a house number.",
      "examples": [
        {
          "it": "via",
          "translation": "street"
        },
        {
          "it": "piazza",
          "translation": "square"
        },
        {
          "it": "corso",
          "translation": "avenue"
        },
        {
          "it": "vicolo",
          "translation": "lane, alley"
        },
        {
          "it": "numero civico",
          "translation": "house number"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Neighbour and household context",
      "description": "The lesson introduces vocabulary for neighbours and everyday building-life interactions.",
      "examples": [
        {
          "it": "vicino di casa",
