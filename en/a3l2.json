      "id": "D-A1L3-2-01",
      "title": "Intervista doppia",
      "register": "neutral",
      "context": "Two people answer questions about civil status and relationship situation.",
      "turns": [
        {
          "speaker": "A",
          "it": "Sei sposata?",
          "translation": "Are you married?"
        },
        {
          "speaker": "B",
          "it": "Sì, sono sposata con Marco da vent'anni.",
          "translation": "Yes, I have been married to Marco for twenty years."
        },
        {
          "speaker": "A",
          "it": "E tua sorella?",
          "translation": "And your sister?"
        },
        {
          "speaker": "B",
          "it": "No, è single, ma ha un ragazzo.",
          "translation": "No, she is single, but she has a boyfriend."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask if someone is married",
          "expected_it": "Sei sposato/a?"
        },
        {
          "cue": "Say you are single",
          "expected_it": "Sono single."
        },
        {
          "cue": "Say you have a boyfriend/girlfriend",
          "expected_it": "Ho un ragazzo. / Ho una ragazza."
        }
      ]
    },
    {
      "id": "D-A1L3-2-02",
