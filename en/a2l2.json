  "dialogues": [
    {
      "id": "D-A1L2-2-01",
      "title": "È una città bellissima!",
      "register": "informal",
      "context": "Two students meet for the first time and talk about their origins — the key model dialogue from the lesson",
      "turns": [
        {
          "speaker": "Pierre",
          "it": "Ciao, mi chiamo Pierre. E tu, come ti chiami?",
          "translation": "Hi, my name is Pierre. And you, what's your name?"
        },
        {
          "speaker": "Mariana",
          "it": "Io sono Mariana. Piacere.",
          "translation": "I am Mariana. Pleased to meet you."
        },
        {
          "speaker": "Pierre",
          "it": "Di dove sei?",
          "translation": "Where are you from?"
        },
        {
          "speaker": "Mariana",
          "it": "Sono italiana, di Livorno. E tu? Non sei italiano, vero?",
          "translation": "I am Italian, from Livorno. And you? You're not Italian, right?"
        },
        {
          "speaker": "Pierre",
          "it": "No, sono francese, di Parigi.",
          "translation": "No, I am French, from Paris."
        },
        {
          "speaker": "Mariana",
          "it": "Parigi?! È una città bellissima!",
          "translation": "Paris?! It is a beautiful city!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask where they are from using a negative tag question",
          "expected_it": "Non sei [nazionalità], vero?"
        },
        {
          "cue": "Confirm your nationality and city",
          "expected_it": "No, sono [nazionalità], di [città]."
        },
        {
          "cue": "Exclaim that a city is beautiful",
          "expected_it": "[Città]?! È una città bellissima!"
        }
      ]
    },
    {
      "id": "D-A1L2-2-02",
      "title": "Ti presento Giorgio (informale)",
      "register": "informal",
      "context": "A friend introduces a third person informally",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, Vittoria! Ti presento Giorgio. È italiano, di Milano.",
          "translation": "Hi, Vittoria! Let me introduce Giorgio. He is Italian, from Milan."
        },
        {
          "speaker": "Vittoria",
          "it": "Ciao, Giorgio! Piacere di conoscerti!",
          "translation": "Hi, Giorgio! Nice to meet you!"
        },
        {
          "speaker": "Giorgio",
          "it": "Piacere mio!",
          "translation": "The pleasure is mine!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Introduce a third person informally with their nationality",
          "expected_it": "Ti presento [nome]. È [nazionalità], di [città]."
        },
        {
          "cue": "React to the introduction (informal)",
          "expected_it": "Piacere di conoscerti!"
        }
      ]
    },
    {
      "id": "D-A1L2-2-03",
      "title": "Le presento il signor Bocelli (formale)",
      "register": "formal",
      "context": "A formal introduction at a professional event",
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno, signor Eugenio! Le presento il signor Bocelli. È italiano, di Lajatico.",
          "translation": "Good morning, Mr. Eugenio! Let me introduce Mr. Bocelli. He is Italian, from Lajatico."
        },
        {
          "speaker": "Eugenio",
          "it": "Buongiorno, signor Bocelli! Molto lieto!",
          "translation": "Good morning, Mr. Bocelli! Very pleased!"
        },
        {
          "speaker": "Bocelli",
          "it": "Piacere di conoscerla.",
          "translation": "Nice to meet you."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Introduce someone formally with a courtesy title",
          "expected_it": "Le presento il signor/la signora [cognome]."
        },
        {
          "cue": "React to a formal introduction",
          "expected_it": "Molto lieto/a!"
        },
        {
          "cue": "Express pleasure formally",
          "expected_it": "Piacere di conoscerla."
        }
      ]
    }
  ]
