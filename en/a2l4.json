    "id": "A1-L2-4",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": [
      "Comprensione orale: Ha il ragazzo?",
      "Grammatica: verbo avere",
      "Lessico: i numeri da 10 a 100",
      "Attività comunicativa: Quanti anni hai?"
    ]
