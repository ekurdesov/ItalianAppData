  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Present tense of avere",
      "description": "The verb 'avere' is used to express possession and age.",
      "conjugations": {
        "io": "ho",
        "tu": "hai",
        "lui/lei/Lei": "ha",
        "noi": "abbiamo",
        "voi": "avete",
        "loro": "hanno"
      }
    },
    {
      "category": "Grammar",
      "rule": "Essere vs avere",
      "description": "Italian uses 'essere' for identity and description, and 'avere' for possession and age.",
      "examples": [
        {
          "it": "Carla è bella.",
          "translation": "Carla is beautiful."
        },
        {
          "it": "Carla ha 27 anni.",
          "translation": "Carla is 27 years old."
        },
        {
          "it": "Ho vent'anni.",
          "translation": "I am twenty years old."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking and saying age: formal vs informal",
      "description": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking age.",
      "examples": [
        {
          "context": "informal",
          "it": "Quanti anni hai?",
          "translation": "How old are you?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "translation": "And you?"
        },
        {
          "context": "formal",
          "it": "Quanti anni ha?",
          "translation": "How old are you? (formal)"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "translation": "And you? (formal)"
        },
        {
          "context": "answer",
          "it": "Ho ... anni.",
          "translation": "I am ... years old."
        },
        {
          "context": "answer",
          "it": "Ne ho ...",
          "translation": "I am ... years old."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Talking about same age and age groups",
      "description": "Italian has common expressions for being the same age and describing age.",
      "examples": [
        {
          "it": "coetaneo / coetanea",
          "translation": "peer; person of the same age"
        },
        {
          "it": "Siamo coetanei.",
          "translation": "We are the same age."
        },
        {
          "it": "Abbiamo la stessa età.",
          "translation": "We are the same age."
        },
        {
          "it": "giovane / anziano",
          "translation": "young / elderly"
        }
      ]
    }
  ],
