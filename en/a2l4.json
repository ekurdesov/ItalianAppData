  "classroom_instructions": [
    {
      "it": "Chiudete il libro e ascoltate il dialogo.",
      "translation": "Close the book and listen to the dialogue."
    },
    {
      "it": "Rispondete.",
      "translation": "Answer."
    },
    {
      "it": "Di chi parlano i due ragazzi?",
      "translation": "Who are the two boys talking about?"
    },
    {
      "it": "Quali aggettivi usano per descrivere questa persona?",
      "translation": "Which adjectives do they use to describe this person?"
    },
    {
      "it": "Abbinate.",
      "translation": "Match."
    },
    {
      "it": "Leggete e verificate.",
      "translation": "Read and check."
    },
    {
      "it": "Completate.",
      "translation": "Complete."
    },
    {
      "it": "Completate con avere.",
      "translation": "Complete with 'avere'."
    },
    {
      "it": "Completate con essere.",
      "translation": "Complete with 'essere'."
    },
    {
      "it": "Rimettete in ordine.",
      "translation": "Put in order."
    },
    {
      "it": "Cancellate i numeri sulle schede.",
      "translation": "Cross out the numbers on the cards."
    },
    {
      "it": "Dove si completa una riga?",
      "translation": "Where do you complete a row?"
    }
  ],
  "dialogues": [
    {
      "id": "D-A1L2-4-01",
      "title": "Quanti anni hai? (informal)",
      "register": "informal",
      "context": "Two students compare their ages during a class break",
      "turns": [
        {
          "speaker": "A",
          "it": "Quanti anni hai?",
          "translation": "How old are you?"
        },
        {
          "speaker": "B",
          "it": "Ho venticinque anni. E tu?",
          "translation": "I am twenty-five. And you?"
        },
        {
          "speaker": "A",
          "it": "Ho ventisei anni. Siamo quasi coetanei!",
          "translation": "I am twenty-six. We are almost the same age!"
        },
        {
          "speaker": "B",
          "it": "Sì, abbiamo quasi la stessa età!",
          "translation": "Yes, we are almost the same age!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask how old someone is (informal)",
          "expected_it": "Quanti anni hai?"
        },
        {
          "cue": "Say your age using 'ho'",
          "expected_it": "Ho [numero] anni."
        },
        {
          "cue": "Say you are (almost) the same age",
          "expected_it": "Siamo coetanei! / Abbiamo la stessa età."
        }
      ]
    },
    {
      "id": "D-A1L2-4-02",
      "title": "Ha il ragazzo? — Carla",
      "register": "informal",
      "context": "Two male friends talk about Carla — the listening dialogue from the lesson",
      "turns": [
        {
          "speaker": "Gianni",
          "it": "Bella Carla, no?",
          "translation": "Carla is beautiful, isn't she?"
        },
        {
          "speaker": "Bruno",
          "it": "Sì, è molto bella e carina.",
          "translation": "Yes, she is very beautiful and pretty."
        },
        {
          "speaker": "Gianni",
          "it": "Quanti anni ha?",
          "translation": "How old is she?"
        },
        {
          "speaker": "Bruno",
          "it": "Mah... 26-27. Boh, perché?",
          "translation": "Hmm... 26-27. I don't know, why?"
        },
        {
          "speaker": "Gianni",
          "it": "Ha il ragazzo?",
          "translation": "Does she have a boyfriend?"
        },
        {
          "speaker": "Bruno",
          "it": "No. Ma è troppo bella per te!",
          "translation": "No. But she is too beautiful for you!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask how old a third person is",
          "expected_it": "Quanti anni ha?"
        },
        {
          "cue": "Ask if someone has a boyfriend/girlfriend",
          "expected_it": "Ha il ragazzo? / Ha la ragazza?"
        },
        {
          "cue": "Say someone is 27 years old",
          "expected_it": "Ha 27 anni."
        }
      ]
    },
    {
      "id": "D-A1L2-4-03",
      "title": "Quanti anni ha? (formale)",
      "register": "formal",
      "context": "A formal exchange about age",
      "turns": [
        {
          "speaker": "A",
          "it": "Quanti anni ha, signora Rossi?",
