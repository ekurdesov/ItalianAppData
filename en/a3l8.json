{
  "lesson_info": {
    "id": "A1-L3-8",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Ripasso: Com'è?",
      "Comprensione orale: Nomi e cognomi italiani",
      "Grammatica: essere VS esserci",
      "Attività comunicativa: Quante domande!"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "essere vs esserci — contrast",
      "description": "'È/sono' locates or identifies something already known. 'C'è/ci sono' introduces or announces the existence of something.",
      "examples": [
        {
          "it": "L'orologio è nel cassetto.",
          "translation": "The watch is in the drawer."
        },
        {
          "it": "Nel cassetto c'è l'orologio.",
          "translation": "There is a watch in the drawer."
        },
        {
          "it": "Gli amici sono al bar.",
          "translation": "The friends are at the bar."
        },
        {
          "it": "Al bar ci sono gli amici.",
          "translation": "There are friends at the bar."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Question words (interrogativi)",
      "description": "Italian question words used to ask about people, things, places, time, and reasons.",
      "examples": [
        {
          "it": "Come ti chiami?",
          "translation": "What is your name?"
        },
        {
          "it": "Chi è il nuovo professore?",
          "translation": "Who is the new professor?"
        },
        {
          "it": "Di dove sei?",
          "translation": "Where are you from?"
        },
        {
          "it": "Quanti anni hai?",
          "translation": "How old are you?"
        },
        {
          "it": "Dove vivi?",
          "translation": "Where do you live?"
        },
        {
          "it": "Che cosa studi?",
          "translation": "What do you study?"
        },
        {
          "it": "Qual è il tuo numero di telefono?",
          "translation": "What is your phone number?"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Italian names and surnames",
      "description": "Common Italian first names and the most widespread Italian surnames.",
      "examples": [
        {
          "it": "Luca, Marco, Francesco, Alessandro",
          "translation": "Common Italian male names"
        },
        {
          "it": "Sofia, Giulia, Martina, Sara",
          "translation": "Common Italian female names"
        },
        {
          "it": "Rossi, Ferrari, Esposito, Bianchi",
          "translation": "Most common Italian surnames"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Describing body features with c'è",
      "description": "Use 'c'è' to point out a specific feature on a person's body.",
      "examples": [
        {
          "it": "Vicino al naso di Silvia c'è un piccolo neo.",
          "translation": "Near Silvia's nose there is a small mole."
        },
        {
          "it": "Sulla gamba destra di Luca c'è un piccolo tatuaggio.",
          "translation": "On Luca's right leg there is a small tattoo."
        },
        {
          "it": "Il neo è vicino al naso di Silvia.",
          "translation": "The mole is near Silvia's nose."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Quante domande! — asking personal questions",
      "description": "A communicative activity where students ask and answer a range of personal questions using all the question words learned.",
      "examples": [
        {
          "it": "Perché studi l'italiano?",
          "translation": "Why do you study Italian?"
        },
        {
          "it": "Quando parti per le vacanze?",
          "translation": "When do you leave for the holidays?"
        },
        {
          "it": "Dove vai in vacanza quest'anno?",
          "translation": "Where are you going on holiday this year?"
        },
        {
          "it": "Qual è il tuo indirizzo?",
          "translation": "What is your address?"
        }
      ]
    }
  ],
