{
  "lesson_info": {
    "id": "A1-L3-6",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Ripasso: Presentiamoci!",
      "Comprensione orale: Indovina chi...",
      "Grammatica: nome + aggettivo",
      "Descrivere l'aspetto fisico: Com'è?"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Noun + adjective agreement",
      "description": "In Italian, adjectives agree in gender and number with the noun they describe. Masculine adjectives typically end in -o (singular) / -i (plural); feminine in -a (singular) / -e (plural).",
      "examples": [
        {
          "it": "un ragazzo alto",
          "translation": "a tall boy"
        },
        {
          "it": "una ragazza alta",
          "translation": "a tall girl"
        },
        {
          "it": "i capelli lunghi",
          "translation": "long hair"
        },
        {
          "it": "gli occhi neri",
          "translation": "black eyes"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Physical appearance adjectives",
      "description": "Key adjectives for describing a person's build, height, and general appearance.",
      "examples": [
        {
          "it": "alto / basso",
          "translation": "tall / short"
        },
        {
          "it": "magro / grasso",
          "translation": "thin / fat"
        },
        {
          "it": "giovane / anziano",
          "translation": "young / elderly"
        },
        {
          "it": "calvo",
          "translation": "bald"
        },
        {
          "it": "di media statura",
          "translation": "of medium height"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Hair and eye descriptions",
      "description": "Italian uses 'avere' to describe hair and eyes, and adjectives must agree with the noun.",
      "examples": [
        {
          "it": "Ha i capelli biondi / castani / neri / rossi.",
          "translation": "He/She has blond / brown / black / red hair."
        },
        {
          "it": "Ha i capelli ricci / lisci / corti / lunghi.",
          "translation": "He/She has curly / straight / short / long hair."
        },
        {
          "it": "Ha gli occhi azzurri / verdi / marroni / castani.",
          "translation": "He/She has blue / green / brown / hazel eyes."
        },
        {
          "it": "Ha i baffi.",
          "translation": "He has a moustache."
        },
        {
          "it": "Ha il pizzetto.",
          "translation": "He has a goatee."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking and describing appearance: Com'è?",
      "description": "Use 'Com'è?' to ask what someone looks like. Answers combine essere + adjective and avere + body feature.",
      "examples": [
        {
          "context": "question",
          "it": "Com'è?",
          "translation": "What does he/she look like?"
        },
        {
          "context": "answer",
          "it": "È alto, magro, ha i capelli corti e il pizzetto.",
          "translation": "He is tall, thin, has short hair and a goatee."
        },
        {
          "context": "answer",
          "it": "È una ragazza giovane, di media statura con gli occhi neri e i capelli neri e corti.",
          "translation": "She is a young girl, of medium height with black eyes and short black hair."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Guessing game: Indovina chi",
      "description": "A common classroom activity where students describe a person and others guess who it is, using yes/no questions.",
      "examples": [
        {
          "it": "È alto? — Sì.",
          "translation": "Is he tall? — Yes."
        },
        {
          "it": "È grasso? — No.",
          "translation": "Is he fat? — No."
        },
        {
          "it": "Ha i capelli corti? — Sì.",
          "translation": "Does he have short hair? — Yes."
        },
        {
          "it": "È Marco? — Sì, hai indovinato!",
          "translation": "Is it Marco? — Yes, you guessed it!"
        }
      ]
    }
  ],
