  "dialogues": [
    {
      "id": "D-A1L4-4-01",
      "title": "Offro io!",
      "register": "informal",
      "context": "Two friends at the bar order drinks and food; one offers to pay.",
      "turns": [
        {
          "speaker": "A",
          "it": "Allora, che cosa prendi?",
          "translation": "So, what will you have?"
        },
        {
          "speaker": "B",
          "it": "Prendo un tramezzino con prosciutto cotto e un caffè macchiato.",
          "translation": "I'll have a ham sandwich and a macchiato."
        },
        {
          "speaker": "A",
          "it": "Io prendo una piadina al formaggio e un succo di frutta.",
          "translation": "I'll have a cheese flatbread and a fruit juice."
        },
        {
          "speaker": "B",
          "it": "Quanto costa tutto?",
          "translation": "How much does it all cost?"
        },
        {
          "speaker": "A",
          "it": "6,90 euro. Oggi offro io!",
          "translation": "6.90 euros. Today it's my treat!"
        },
        {
          "speaker": "B",
          "it": "Grazie! La prossima volta offro io.",
          "translation": "Thank you! Next time it's my treat."
        }
      ],
      "practice_prompts": [
