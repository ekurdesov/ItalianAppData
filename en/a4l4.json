{
  "lesson_info": {
    "id": "A1-L4-4",
    "title": "Un incontro",
    "level": "A1",
    "objectives": [
      "Ripasso: Chiedi e rispondo",
      "Comprensione orale: Offro io!",
      "Grammatica: verbi irregolari (bere)",
      "Attività comunicativa: Preferisci...?"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Irregular verb: bere",
      "description": "The verb 'bere' (to drink) is irregular. Its present-tense stem is 'bev-'.",
      "conjugations": {
        "io": "bevo",
        "tu": "bevi",
        "lui/lei/Lei": "beve",
        "noi": "beviamo",
        "voi": "bevete",
        "loro": "bevono"
      },
      "examples": [
        {
          "it": "Io bevo il caffè, e tu che cosa bevi?",
          "translation": "I drink coffee, and what do you drink?"
        },
        {
          "it": "Noi beviamo delle bibite fresche.",
          "translation": "We drink cold drinks."
        },
        {
          "it": "Marisa a colazione beve solo tè e mai latte.",
          "translation": "Marisa only drinks tea for breakfast and never milk."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Review: -isc- verbs (preferire, capire)",
      "description": "Consolidation of -ire verbs with the -isc- infix.",
      "examples": [
        {
          "it": "Preferisci viaggiare in aereo o in treno?",
          "translation": "Do you prefer to travel by plane or by train?"
        },
        {
          "it": "Capite il cinese?",
          "translation": "Do you understand Chinese?"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Treating someone: Offro io!",
      "description": "Expressions for offering to pay at the bar.",
      "examples": [
        {
          "it": "Oggi offro io.",
          "translation": "Today it's my treat."
        },
        {
          "it": "La prossima volta offri tu.",
          "translation": "Next time it's your treat."
        },
        {
          "it": "Che cosa prende Paola?",
          "translation": "What will Paola have?"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Types of coffee and bar food",
      "description": "More specific bar vocabulary for types of coffee and food combinations.",
      "examples": [
        {
          "it": "un caffè macchiato",
          "translation": "espresso with a dash of milk"
        },
        {
          "it": "un caffè doppio",
          "translation": "double espresso"
        },
        {
          "it": "un caffè americano",
          "translation": "Americano (long black)"
        },
        {
          "it": "un tè freddo con limone",
          "translation": "iced tea with lemon"
        },
        {
          "it": "un tramezzino al tonno",
          "translation": "tuna sandwich"
        },
        {
          "it": "un panino al prosciutto",
          "translation": "ham roll"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Expressing preferences: Preferisci…?",
      "description": "Using preferire to ask and state preferences between two options.",
      "examples": [
        {
          "context": "question",
          "it": "Preferisci il mare o la montagna?",
          "translation": "Do you prefer the sea or the mountains?"
        },
        {
          "context": "answer",
          "it": "Preferisco il mare.",
          "translation": "I prefer the sea."
        },
        {
          "context": "formal",
          "it": "Preferisce il mare o la montagna?",
          "translation": "Do you prefer the sea or the mountains? (formal)"
        }
      ]
    }
  ],
