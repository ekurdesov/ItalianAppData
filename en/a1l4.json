  "classroom_instructions": [
    {
      "it": "Completate con essere.",
      "translation": "Complete with 'essere'."
    },
    {
      "it": "Completate con chiamarsi.",
      "translation": "Complete with 'chiamarsi'."
    },
    {
      "it": "Completate con i pronomi.",
      "translation": "Complete with the pronouns."
    },
    {
      "it": "Ascoltate i dialoghi.",
      "translation": "Listen to the dialogues."
    },
    {
      "it": "È formale o informale?",
      "translation": "Is it formal or informal?"
    },
    {
      "it": "Come si chiamano?",
      "translation": "What are their names?"
    },
    {
      "it": "Come si scrive?",
      "translation": "How is it spelled?"
    },
    {
      "it": "Ripetete i dialoghi secondo il modello.",
      "translation": "Repeat the dialogues following the model."
    },
    {
      "it": "Non lo so!",
      "translation": "I don't know!"
    },
    {
      "it": "Cosa vuol dire?",
      "translation": "What does it mean?"
    },
    {
      "it": "Come si traduce?",
      "translation": "How is it translated?"
    },
    {
      "it": "Non ho capito!",
      "translation": "I didn't understand!"
    },
    {
      "it": "Come? Puoi ripetere, per favore?",
      "translation": "Sorry? Can you repeat, please?"
    },
    {
      "it": "Ascoltate e ripetete.",
      "translation": "Listen and repeat."
    },
    {
      "it": "Leggete le parole.",
      "translation": "Read the words."
    },
    {
      "it": "Trovate le parole per salutare.",
      "translation": "Find the words used for greeting."
    },
    {
      "it": "Ascoltate e abbinate.",
      "translation": "Listen and match."
    },
    {
      "it": "Ordinate le frasi.",
      "translation": "Put the sentences in order."
    },
    {
      "it": "Completate con essere o/e chiamarsi.",
      "translation": "Complete with 'essere' and/or 'chiamarsi'."
    }
  ],
  "dialogues": [
    {
      "id": "D-A1L1-4-01",
      "title": "Prima volta: informale",
      "register": "informal",
      "context": "Two people meet for the first time informally",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao. Come ti chiami?",
          "translation": "Hi. What's your name?"
        },
        {
          "speaker": "B",
          "it": "Paolo! E tu?",
          "translation": "Paolo! And you?"
        },
        {
          "speaker": "A",
          "it": "Mi chiamo Carlo, piacere!",
          "translation": "My name is Carlo, pleased to meet you!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Greet and ask for someone's name (informal)",
          "expected_it": "Ciao. Come ti chiami?"
        },
        {
          "cue": "Say your name and ask back",
          "expected_it": "[nome]! E tu?"
        },
        {
          "cue": "Introduce yourself and express pleasure",
          "expected_it": "Mi chiamo [nome], piacere!"
        }
      ]
    },
    {
      "id": "D-A1L1-4-02",
      "title": "Prima volta: formale (sera)",
      "register": "formal",
      "context": "Two adults introduce themselves formally in the evening",
      "turns": [
        {
          "speaker": "A",
          "it": "Buonasera, io sono Clara Boni, e Lei?",
          "translation": "Good evening, I am Clara Boni, and you?"
        },
        {
          "speaker": "B",
          "it": "Buonasera, mi chiamo Giovanni Gori.",
          "translation": "Good evening, my name is Giovanni Gori."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Introduce yourself formally in the evening and ask who they are",
          "expected_it": "Buonasera, io sono [nome], e Lei?"
        },
        {
          "cue": "Give your name formally",
          "expected_it": "Buonasera, mi chiamo [nome]."
        }
      ]
    },
    {
      "id": "D-A1L1-4-03",
      "title": "Conferma del nome (informale)",
      "register": "informal",
      "context": "Someone confirms another person's name",
      "turns": [
        {
          "speaker": "A",
          "it": "Tu sei Marina?",
          "translation": "Are you Marina?"
        },
        {
          "speaker": "B",
          "it": "Sì.",
          "translation": "Yes."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask if someone is [name] (informal)",
          "expected_it": "Tu sei [nome]?"
        },
        {
          "cue": "Confirm you are [name]",
          "expected_it": "Sì."
        }
      ]
    },
    {
      "id": "D-A1L1-4-04",
      "title": "Conferma del nome (formale)",
      "register": "formal",
      "context": "A formal identity check — asking if someone is who you think they are",
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno, Lei è Barbara Raspetti?",
          "translation": "Good morning, are you Barbara Raspetti?"
        },
        {
          "speaker": "B",
          "it": "Sì. E Lei?",
          "translation": "Yes. And you?"
        },
        {
          "speaker": "A",
          "it": "Mi chiamo Antonella Rosi.",
          "translation": "My name is Antonella Rosi."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask if someone is [name] formally",
          "expected_it": "Buongiorno, Lei è [nome]?"
        },
        {
          "cue": "Confirm and ask who they are (formal)",
          "expected_it": "Sì. E Lei?"
        },
        {
          "cue": "Give your full name",
          "expected_it": "Mi chiamo [nome e cognome]."
        }
      ]
    }
  ]
