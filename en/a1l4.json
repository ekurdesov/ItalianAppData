{
  "lesson_info": {
    "id": "A1-L1-4",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Ripasso: essere e chiamarsi",
      "Comprensione orale: 'Scusi, Lei come si chiama?'",
      "Attività comunicativa: presentarsi",
      "Fonetica: lettera G"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Present tense of essere",
      "description": "The verb 'essere' is used to identify people and state who someone is.",
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": "Grammar",
      "rule": "Present tense of chiamarsi",
      "description": "The reflexive verb 'chiamarsi' is used to ask and say names.",
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": "Grammar",
      "rule": "Italian personal pronouns",
      "description": "The lesson reviews the core subject pronouns used with 'essere' and 'chiamarsi'.",
      "examples": [
        {
          "it": "io",
          "translation": "I"
        },
        {
          "it": "tu",
          "translation": "you (informal singular)"
        },
        {
          "it": "lui / lei / Lei",
          "translation": "he / she / you (formal)"
        },
        {
          "it": "noi",
          "translation": "we"
        },
        {
          "it": "voi",
          "translation": "you (plural)"
        },
        {
          "it": "loro",
          "translation": "they"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking and giving names: formal vs informal",
      "description": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking for someone's name and surname.",
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "translation": "What is your name?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "translation": "What is your name? (formal)"
        },
        {
          "context": "informal",
          "it": "E di cognome?",
          "translation": "And your surname?"
        },
        {
          "context": "formal",
          "it": "E il Suo?",
          "translation": "And yours? (formal)"
        },
        {
          "context": "statement",
          "it": "Il mio nome è...",
          "translation": "My name is..."
        },
        {
          "context": "statement",
          "it": "Il mio cognome è...",
          "translation": "My surname is..."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Reacting during introductions",
      "description": "Standard formulas are used when meeting someone for the first time.",
      "examples": [
        {
          "it": "Piacere di conoscerti.",
          "translation": "Nice to meet you. (informal)"
        },
        {
          "it": "Piacere di conoscerla.",
          "translation": "Nice to meet you. (formal)"
        },
        {
          "it": "Molto lieto/a.",
          "translation": "Very pleased."
        },
        {
          "it": "Piacere.",
          "translation": "Pleasure."
        },
        {
          "it": "Piacere mio.",
          "translation": "The pleasure is mine."
        },
        {
          "it": "Altrettanto.",
          "translation": "Likewise."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Formal vs informal greetings",
      "description": "Greetings and leave-taking expressions vary by time of day and level of formality.",
      "examples": [
        {
          "context": "arrival informal",
          "it": "Ciao!",
          "translation": "Hi!"
        },
        {
          "context": "arrival formal",
          "it": "Buongiorno! / Buon dì!",
          "translation": "Good morning / good day!"
        },
        {
          "context": "arrival formal",
          "it": "Buonasera!",
          "translation": "Good evening!"
        },
        {
          "context": "arrival formal",
          "it": "Salve!",
          "translation": "Hello!"
        },
        {
          "context": "departure formal",
          "it": "ArrivederLa!",
          "translation": "Goodbye (formal)"
        },
        {
          "context": "departure",
          "it": "Arrivederci!",
          "translation": "Goodbye"
        },
        {
          "context": "departure",
          "it": "Buona giornata! / Buona serata!",
          "translation": "Have a nice day / evening!"
        }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Pronunciation of letter G",
      "description": "The sound of 'g' changes according to the letters that follow it.",
      "sub_rules": [
        {
          "pattern": "g + a, o, u, consonant",
          "sound": "[g]",
          "examples": [
            {
              "it": "gamba",
              "translation": "leg"
            },
            {
              "it": "gatto",
              "translation": "cat"
            },
            {
              "it": "gusto",
              "translation": "taste"
            },
            {
              "it": "grande",
              "translation": "big"
            }
          ]
        },
        {
          "pattern": "g + e, i",
          "sound": "[dʒ]",
          "examples": [
            {
              "it": "gente",
              "translation": "people"
            },
            {
              "it": "girare",
              "translation": "to turn"
            },
            {
              "it": "ginnastica",
              "translation": "gymnastics"
            },
            {
              "it": "Genova",
              "translation": "Genoa"
            }
          ]
        },
        {
          "pattern": "gh + e, i",
          "sound": "[g]",
          "examples": [
            {
              "it": "ghetto",
              "translation": "ghetto"
            },
            {
              "it": "laghi",
              "translation": "lakes"
            },
            {
              "it": "ghirlanda",
              "translation": "garland"
            },
            {
              "it": "ghiro",
              "translation": "dormouse"
            }
          ]
        },
        {
          "pattern": "gi + a, o, u",
          "sound": "[dʒ]",
          "examples": [
            {
              "it": "già",
              "translation": "already"
            },
            {
              "it": "giorno",
              "translation": "day"
            },
            {
              "it": "giusto",
              "translation": "right, correct"
            },
            {
              "it": "giocare",
              "translation": "to play"
            }
          ]
        }
      ]
    }
  ],
