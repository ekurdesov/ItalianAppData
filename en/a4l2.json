{
  "lesson_info": {
    "id": "A1-L4-2",
    "title": "Un incontro",
    "level": "A1",
    "objectives": [
      "Ripasso: Cosa fanno?",
      "Lessico: Bevande e spuntini",
      "Comprensione orale: Al bar",
      "Attività comunicativa: E tu che cosa prendi?"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Review: fare expressions",
      "description": "The verb 'fare' is used in many fixed expressions about daily activities. Review of all key 'fare + noun' combinations.",
      "examples": [
        {
          "it": "Fate colazione con il caffè o con il tè?",
          "translation": "Do you have breakfast with coffee or tea?"
        },
        {
          "it": "Fate la doccia la mattina o la sera?",
          "translation": "Do you take a shower in the morning or in the evening?"
        },
        {
          "it": "Fate la spesa al mercato o al supermercato?",
          "translation": "Do you do the shopping at the market or at the supermarket?"
        },
        {
          "it": "Fate molte foto in vacanza?",
          "translation": "Do you take many photos on holiday?"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Drinks: bevande",
      "description": "Key vocabulary for drinks ordered at an Italian bar.",
      "examples": [
        {
          "it": "un caffè / un espresso",
          "translation": "an espresso"
        },
        {
          "it": "un cappuccino",
          "translation": "a cappuccino"
        },
        {
          "it": "un tè",
          "translation": "a tea"
        },
        {
          "it": "un'aranciata",
          "translation": "an orange soda"
        },
        {
          "it": "un succo di frutta",
          "translation": "a fruit juice"
        },
        {
          "it": "un bicchiere di acqua minerale",
          "translation": "a glass of mineral water"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Snacks: spuntini",
      "description": "Key vocabulary for food items available at an Italian bar.",
      "examples": [
        {
          "it": "un cornetto",
          "translation": "a croissant"
        },
        {
          "it": "un panino",
          "translation": "a sandwich"
        },
        {
          "it": "un tramezzino",
          "translation": "a triangular sandwich"
        },
        {
          "it": "una piadina",
          "translation": "a flatbread wrap"
        },
        {
          "it": "un toast",
          "translation": "a toasted sandwich"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Ordering at the bar: E tu che cosa prendi?",
      "description": "Asking and saying what you will have at the bar.",
      "examples": [
        {
          "context": "question",
          "it": "Che cosa prendi?",
          "translation": "What will you have?"
        },
        {
          "context": "answer",
          "it": "Prendo un cappuccino e un cornetto.",
          "translation": "I'll have a cappuccino and a croissant."
        },
        {
          "context": "question",
          "it": "Come bevanda prendi…?",
          "translation": "As a drink, will you have…?"
        },
        {
          "context": "answer",
          "it": "Come spuntino prendo un tramezzino.",
          "translation": "As a snack I'll have a triangular sandwich."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Bar furniture and staff",
      "description": "Vocabulary for the physical layout of an Italian bar.",
      "examples": [
        {
          "it": "il banco",
          "translation": "the counter"
        },
        {
          "it": "il tavolino",
          "translation": "the small table"
        },
        {
          "it": "la cassa",
          "translation": "the till / cash desk"
        },
        {
          "it": "il barista",
          "translation": "the barista / bar person"
        },
        {
          "it": "la macchina per il caffè",
          "translation": "the coffee machine"
        }
      ]
    }
  ],
