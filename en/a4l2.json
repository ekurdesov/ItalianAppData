  "dialogues": [
    {
      "id": "D-A1L4-2-01",
      "title": "Al bar",
      "register": "informal",
      "context": "Two friends are at the bar and order drinks and snacks.",
      "turns": [
        {
          "speaker": "A",
          "it": "Allora, che cosa prendi?",
          "translation": "So, what will you have?"
        },
        {
          "speaker": "B",
          "it": "Prendo un cappuccino e un cornetto. E tu?",
          "translation": "I'll have a cappuccino and a croissant. And you?"
        },
        {
          "speaker": "A",
          "it": "Io prendo un caffè e un tramezzino al tonno.",
          "translation": "I'll have an espresso and a tuna sandwich."
        },
        {
          "speaker": "B",
          "it": "Paghiamo alla cassa?",
          "translation": "Shall we pay at the till?"
        },
        {
          "speaker": "A",
          "it": "Sì, oggi offro io!",
          "translation": "Yes, today it's my treat!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask what someone will have",
          "expected_it": "Che cosa prendi?"
        },
        {
          "cue": "Order a drink and a snack",
          "expected_it": "Prendo un/una … e un/una …"
        },
        {
          "cue": "Say it is your treat",
          "expected_it": "Oggi offro io!"
        }
      ]
    }
  ],
