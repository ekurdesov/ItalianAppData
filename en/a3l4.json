    },
    {
      "category": "Reading",
      "rule": "Short ads and profile-style texts",
      "description": "Classified-style descriptions usually combine age, city, job, language skills, and what a person is looking for.",
      "examples": [
        {
          "it": "Mi chiamo David. Ho 28 anni e sono australiano, ma abito e lavoro a Roma.",
          "translation": "My name is David. I am 28 and I am Australian, but I live and work in Rome."
        },
        {
          "it": "Ciao, mi chiamo Cristina. Ho 27 anni, sono tedesca e cerco una ragazza italiana per uno scambio italo-tedesco.",
          "translation": "Hi, my name is Cristina. I am 27, I am German and I am looking for an Italian girl for an Italian-German exchange."
        }
      ]
    }
