  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Indefinite articles in Italian",
      "description": "Italian uses different indefinite articles depending on gender and the sound at the start of the noun.",
      "examples": [
        {
          "it": "un ragazzo",
          "translation": "a boy"
        },
        {
          "it": "uno studente",
          "translation": "a student"
        },
        {
          "it": "una ragazza",
          "translation": "a girl"
        },
        {
          "it": "un'autobus",
          "translation": "a bus"
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Choosing un, uno, una, un'",
      "description": "Use 'un' before most masculine nouns, 'uno' before masculine nouns starting with s+consonant, z, ps, gn, x, and 'una' or 'un'' before feminine nouns.",
      "examples": [
        {
          "it": "uno straniero",
          "translation": "a foreigner"
        },
        {
          "it": "uno zoo",
          "translation": "a zoo"
        },
        {
          "it": "una signora",
          "translation": "a lady"
        },
        {
          "it": "un'amica",
          "translation": "a female friend"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking which languages someone speaks",
      "description": "To ask about languages, Italian commonly uses 'Che lingue parli?' or 'Che lingue studia?'.",
      "examples": [
        {
          "context": "informal",
          "it": "Che lingue parli?",
          "translation": "What languages do you speak?"
        },
        {
          "context": "answer",
          "it": "Parlo l'italiano, il tedesco e un po' lo spagnolo.",
          "translation": "I speak Italian, German and a little Spanish."
        },
        {
          "context": "answer",
          "it": "Parlo bene il francese, ma non lo spagnolo.",
          "translation": "I speak French well, but not Spanish."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Family and personal profile words",
      "description": "This lesson reuses personal-description language together with simple family references.",
      "examples": [
        {
          "it": "padre",
          "translation": "father"
        },
