  "dialogues": [
    {
      "id": "D-A1L2-7-01",
      "title": "L'italiano nel mondo",
      "register": "informal",
      "context": "Two students discuss Italian around the world and practise definite articles.",
      "turns": [
        {
          "speaker": "A",
          "it": "Sai che l'italiano è parlato in molti paesi del mondo?",
          "translation": "Did you know that Italian is spoken in many countries of the world?"
        },
        {
          "speaker": "B",
          "it": "Sì! Per esempio, in Argentina ci sono molti italiani.",
          "translation": "Yes! For example, in Argentina there are many Italians."
        },
        {
          "speaker": "A",
          "it": "E anche negli Stati Uniti. Il cognome Ferrari è molto famoso.",
          "translation": "And also in the United States. The surname Ferrari is very famous."
        },
        {
          "speaker": "B",
          "it": "È vero. Hai il libro di italiano?",
          "translation": "That's true. Do you have the Italian book?"
        },
        {
          "speaker": "A",
          "it": "Sì, ho il libro e il dizionario.",
          "translation": "Yes, I have the book and the dictionary."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask if someone has the book",
          "expected_it": "Hai il libro?"
        },
        {
          "cue": "Say you have the book and the dictionary",
          "expected_it": "Ho il libro e il dizionario."
        },
        {
          "cue": "Use the definite article with a masculine noun",
          "expected_it": "il / lo / l' + noun"
        }
      ]
    }
  ]
