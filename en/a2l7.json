  "language_rules": [
    {
      "category": "Grammar",
      "rule": "essere vs avere in everyday descriptions",
      "description": "Italian uses 'essere' with adjectives and 'avere' with many physical or emotional states expressed as nouns.",
      "examples": [
        {
          "it": "Sono triste.",
          "translation": "I am sad."
        },
        {
          "it": "Sono contento/a.",
          "translation": "I am happy."
        },
        {
          "it": "Ho fame.",
          "translation": "I am hungry."
        },
        {
          "it": "Hai sete?",
          "translation": "Are you thirsty?"
        },
        {
          "it": "Abbiamo fretta.",
          "translation": "We are in a hurry."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Definite articles in the singular",
      "description": "Italian definite articles agree with the noun in gender and number. In the singular, the main forms are 'il', 'lo', 'la' and 'l''.",
      "sub_rules": [
        {
          "pattern": "il + most masculine singular nouns",
          "examples": [
            {
              "it": "il quaderno",
              "translation": "the notebook"
            },
            {
              "it": "il panino",
              "translation": "the sandwich"
            },
            {
              "it": "il treno",
              "translation": "the train"
            }
          ]
        },
        {
          "pattern": "lo + s+consonant, z, ps, gn",
          "examples": [
            {
              "it": "lo zio",
              "translation": "the uncle"
            },
            {
              "it": "lo studente",
              "translation": "the student"
            }
          ]
        },
        {
          "pattern": "la + feminine singular nouns; l' + vowel",
          "examples": [
            {
              "it": "la sigaretta",
              "translation": "the cigarette"
            },
            {
              "it": "la villa",
              "translation": "the villa"
            },
            {
              "it": "l'automobile",
              "translation": "the car"
            },
            {
              "it": "l'amica",
              "translation": "the female friend"
            }
          ]
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Definite articles in the plural",
      "description": "Plural definite articles also agree with the noun. The main forms are 'i', 'gli' and 'le'.",
      "sub_rules": [
        {
          "pattern": "i + most masculine plural nouns",
          "examples": [
            {
              "it": "i quaderni",
              "translation": "the notebooks"
            },
            {
              "it": "i panini",
              "translation": "the sandwiches"
            },
            {
              "it": "i treni",
              "translation": "the trains"
            }
          ]
        },
        {
          "pattern": "gli + vowels or masculine plural nouns that take lo/l'",
          "examples": [
            {
              "it": "gli esami",
              "translation": "the exams"
            },
            {
              "it": "gli zii",
              "translation": "the uncles"
            },
            {
              "it": "gli studenti",
              "translation": "the students"
            },
            {
              "it": "gli amici",
              "translation": "the friends"
            }
          ]
        },
        {
          "pattern": "le + all feminine plural nouns",
          "examples": [
            {
              "it": "le sigarette",
              "translation": "the cigarettes"
            },
            {
              "it": "le lezioni",
              "translation": "the lessons"
            },
            {
              "it": "le ragazze",
              "translation": "the girls"
            }
          ]
        }
      ]
    },
    {
      "category": "Culture",
      "rule": "Italian in the world",
      "description": "The lesson presents Italian as a world language connected with travel, culture, design, food, music and art.",
      "examples": [
        {
          "it": "L'italiano è parlato in tutto il mondo.",
          "translation": "Italian is spoken all over the world."
        },
        {
          "it": "L'italiano è parlato in Europa, in America, in Africa, in Australia e in Giappone.",
          "translation": "Italian is spoken in Europe, America, Africa, Australia and Japan."
        },
        {
          "it": "L'italiano è importante per il design, la letteratura, il cinema e la musica.",
          "translation": "Italian is important for design, literature, cinema and music."
        }
      ]
    }
  ],
