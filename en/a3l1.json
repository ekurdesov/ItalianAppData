{
  "lesson_info": {
    "id": "A1-L3-1",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Comprensione orale: Alla festa di Chiara",
      "Grammatica: preposizioni di, a, in",
      "Chiedere e dire la residenza"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Origin with di + city",
      "description": "To say where a person is from, Italian commonly uses 'essere di' followed by a city.",
      "examples": [
        {
          "it": "Sono di Casinalbo.",
          "translation": "I am from Casinalbo."
        },
        {
          "it": "Stefi è di Prato.",
          "translation": "Stefi is from Prato."
        },
        {
          "it": "Di dov'è Alexia?",
          "translation": "Where is Alexia from?"
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Residence with a + city",
      "description": "To say where someone lives, Italian uses 'abitare a' with cities.",
      "examples": [
        {
          "it": "Abito a Firenze.",
          "translation": "I live in Florence."
        },
        {
          "it": "Paolo abita a Roma.",
          "translation": "Paolo lives in Rome."
        },
        {
          "it": "Patrick e John abitano a Londra.",
          "translation": "Patrick and John live in London."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Residence with in + country, region, continent",
      "description": "Use 'in' with countries, regions and continents.",
      "examples": [
        {
          "it": "Abito in Italia.",
          "translation": "I live in Italy."
        },
        {
          "it": "Abito in Toscana.",
          "translation": "I live in Tuscany."
        },
        {
          "it": "Vivo in Africa.",
          "translation": "I live in Africa."
        },
        {
          "it": "In Inghilterra piove molto.",
          "translation": "In England it rains a lot."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Present tense of abitare",
      "description": "The verb 'abitare' means 'to live' or 'to reside'.",
      "conjugations": {
        "io": "abito",
        "tu": "abiti",
        "lui/lei/Lei": "abita",
        "noi": "abitiamo",
        "voi": "abitate",
        "loro": "abitano"
      }
    },
    {
      "category": "Pragmatics",
      "rule": "Asking and stating residence",
      "description": "Italian uses 'Dove abiti?' and related forms to ask where someone lives. Answers can include city, region and country.",
      "examples": [
        {
          "context": "informal",
          "it": "Dove abiti?",
          "translation": "Where do you live?"
        },
        {
          "context": "formal",
          "it": "Dove abita?",
          "translation": "Where do you live? (formal)"
        },
        {
          "context": "answer",
          "it": "Abito a Pisa, in Toscana, in Italia.",
          "translation": "I live in Pisa, in Tuscany, in Italy."
        }
      ]
    }
  ],
