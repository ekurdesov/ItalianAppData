  "dialogues": [
    {
      "id": "D-A1L3-1-01",
      "title": "Alla festa di Chiara",
      "register": "informal",
      "context": "Two students meet at Chiara's party and talk about origin, university subject and where they live.",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, io sono Claudio. Tu come ti chiami?",
          "translation": "Hi, I'm Claudio. What is your name?"
        },
        {
          "speaker": "B",
          "it": "Stefi. Piacere.",
          "translation": "Stefi. Nice to meet you."
        },
        {
          "speaker": "A",
          "it": "Che cosa studi?",
          "translation": "What do you study?"
        },
        {
          "speaker": "B",
          "it": "Economia. E tu?",
          "translation": "Economics. And you?"
        },
        {
          "speaker": "A",
          "it": "Matematica. Di dove sei?",
          "translation": "Mathematics. Where are you from?"
        },
        {
          "speaker": "B",
          "it": "Sono di Prato. E tu?",
          "translation": "I am from Prato. And you?"
        },
        {
          "speaker": "A",
          "it": "Sono di Casinalbo, ma abito a Firenze, in Italia.",
          "translation": "I am from Casinalbo, but I live in Florence, in Italy."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask where someone is from",
          "expected_it": "Di dove sei?"
        },
        {
          "cue": "Say where you are from",
          "expected_it": "Sono di [città]."
        },
        {
          "cue": "Say where you live",
          "expected_it": "Abito a [città], in [Paese/regione]."
        }
      ]
    },
    {
      "id": "D-A1L3-1-02",
      "title": "Dove abiti?",
      "register": "neutral",
      "context": "Practising city, region and country in a short exchange.",
      "turns": [
        {
          "speaker": "A",
          "it": "Dove abiti?",
          "translation": "Where do you live?"
        },
        {
          "speaker": "B",
          "it": "Abito a Pisa, in Toscana, in Italia.",
          "translation": "I live in Pisa, in Tuscany, in Italy."
        },
        {
          "speaker": "A",
          "it": "E di dove sei?",
          "translation": "And where are you from?"
        },
        {
          "speaker": "B",
          "it": "Sono di Lione, ma adesso abito a Firenze.",
          "translation": "I am from Lyon, but now I live in Florence."
        }
      ],
