  "dialogues": [
    {
      "id": "D-A1L4-3-01",
      "title": "Preferisci il tè o il caffè?",
      "register": "informal",
      "context": "Two students practise expressing preferences using preferire.",
      "turns": [
        {
          "speaker": "A",
          "it": "Preferisci il mare o la montagna?",
          "translation": "Do you prefer the sea or the mountains?"
        },
        {
          "speaker": "B",
          "it": "Preferisco il mare. E tu?",
          "translation": "I prefer the sea. And you?"
        },
        {
          "speaker": "A",
          "it": "Anch'io!",
          "translation": "Me too!"
        },
        {
          "speaker": "A",
          "it": "E al bar, preferisci il caffè o il tè?",
          "translation": "And at the bar, do you prefer coffee or tea?"
        },
        {
          "speaker": "B",
          "it": "Preferisco il caffè. Non capisco come le persone bevono il tè la mattina!",
          "translation": "I prefer coffee. I don't understand how people drink tea in the morning!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Ask if someone prefers the sea or the mountains",
          "expected_it": "Preferisci il mare o la montagna?"
        },
        {
          "cue": "Say you prefer something",
          "expected_it": "Preferisco …"
        },
        {
          "cue": "Say you don't understand a word",
          "expected_it": "Non capisco questa parola."
        }
      ]
    }
