  "lesson_info": {
    "id": "A1-L4-3",
    "title": "Un incontro",
    "level": "A1",
    "objectives": [
      "Ripasso: Perché vai al bar?",
      "Lessico: Bevande e spuntini",
      "Comprensione orale: Al bar",
      "Attività comunicativa: E tu che cosa prendi?"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Verbs in -ire with -isc- infix",
      "description": "Some -ire verbs insert -isc- between the stem and the ending in all singular forms and the 3rd person plural. Common examples: preferire, capire, finire, pulire.",
      "conjugations": {
        "io": "preferisco",
        "tu": "preferisci",
        "lui/lei/Lei": "preferisce",
        "noi": "preferiamo",
        "voi": "preferite",
        "loro": "preferiscono"
      },
      "examples": [
        {
          "it": "Preferisci un succo di frutta o una spremuta d'arancia?",
          "translation": "Do you prefer a fruit juice or a fresh orange juice?"
        },
        {
          "it": "I miei amici preferiscono andare in discoteca.",
          "translation": "My friends prefer going to the disco."
        },
        {
          "it": "A che ora finisce la lezione?",
          "translation": "What time does the lesson finish?"
        },
        {
          "it": "Non capisco questa parola.",
          "translation": "I don't understand this word."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Review: prendere at the bar",
      "description": "The verb 'prendere' is the standard way to order at a bar in Italian.",
      "conjugations": {
        "io": "prendo",
        "tu": "prendi",
        "lui/lei/Lei": "prende",
        "noi": "prendiamo",
        "voi": "prendete",
        "loro": "prendono"
      },
      "examples": [
        {
          "it": "Allora ragazzi, che cosa prendete?",
          "translation": "So, what will you all have?"
        },
        {
          "it": "Io prendo un tramezzino.",
          "translation": "I'll have a triangular sandwich."
        },
        {
          "it": "Tu, Stefano, che cosa prendi?",
          "translation": "Stefano, what will you have?"
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Identifying the odd one out: l'intruso",
      "description": "A vocabulary exercise where students identify which word does not belong to a category and explain why.",
      "examples": [
        {
          "it": "caffè - tè - panino - acqua - coca-cola - cappuccino",
          "translation": "L'intruso è panino perché è uno spuntino, non una bevanda."
        },
        {
          "it": "tè - panino - piadina - tramezzino - toast",
          "translation": "L'intruso è tè perché è una bevanda, non uno spuntino."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Expressing preferences: Preferisci…?",
      "description": "Use 'preferire' to ask and state preferences between two options.",
      "examples": [
        {
          "context": "question",
          "it": "Preferisci il mare o la montagna?",
          "translation": "Do you prefer the sea or the mountains?"
        },
        {
          "context": "answer",
          "it": "Preferisco il mare.",
          "translation": "I prefer the sea."
        },
        {
          "context": "agreement",
          "it": "Anch'io!",
          "translation": "Me too!"
        },
        {
          "context": "disagreement",
          "it": "Io invece preferisco la montagna.",
          "translation": "I on the other hand prefer the mountains."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Daily routine verbs",
      "description": "Common verbs used to describe a daily routine, from the homework solutions slide.",
      "examples": [
