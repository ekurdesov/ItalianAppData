  "language_rules": [
    {
      "category": "Phonetics",
      "rule": "Italian vowel contrast",
      "description": "Italian vowels must be pronounced clearly because small vowel changes can change meaning or even gender.",
      "examples": [
        {
          "it": "colore / calore",
          "translation": "color / heat"
        },
        {
          "it": "Paolo / Paola",
          "translation": "male name / female name"
        }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Stressed final vowels with accents",
      "description": "Some Italian words carry a written accent on the final vowel, which signals the stressed syllable.",
      "examples": [
        {
          "it": "caffè",
          "translation": "coffee"
        },
        {
          "it": "città",
          "translation": "city"
        }
      ]
    },
    {
      "category": "Orthography",
      "rule": "Italian spelling names letters and double consonants explicitly",
      "description": "When spelling aloud, Italian uses letter names and marks double consonants with 'doppia' plus the consonant name.",
      "examples": [
        {
          "it": "cappuccino",
          "translation": "cappuccino",
          "spelling": "ci - a - doppia pi - u - doppia ci - i - enne - o"
        },
        {
          "it": "Bologna",
          "translation": "Bologna",
          "note": "letter-by-letter spelling practice"
        }
      ]
    },
    {
      "category": "Orthography",
      "rule": "The sound of 'ci' in number words",
      "description": "In words like 'cinque', 'dieci', 'undici' and 'dodici', 'ci' is pronounced with the [tʃ] sound.",
      "examples": [
        {
          "it": "cinque",
          "translation": "five"
        },
        {
          "it": "dieci",
          "translation": "ten"
        },
        {
          "it": "undici",
          "translation": "eleven"
        },
        {
          "it": "dodici",
          "translation": "twelve"
        }
      ]
    }
  ],
