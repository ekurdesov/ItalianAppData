{
  "lesson_info": {
    "id": "A1-L1-3",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Ripasso: salutare",
      "Pronomi personali",
      "Essere",
      "Chiamarsi",
      "Attività comunicativa: presentarsi",
      "Fonetica: lettera C"
    ]
  },
  "language_rules": [
    {
      "category": "Pragmatics",
      "rule": "Formal vs informal greetings",
      "description": "Italian uses different greeting and leave-taking forms depending on the situation and level of formality.",
      "examples": [
        {
          "context": "arrival informal",
          "it": "Ciao!",
          "translation": "Hi!"
        },
        {
          "context": "arrival neutral/formal",
          "it": "Buongiorno! / Buon dì!",
          "translation": "Good morning / good day!"
        },
        {
          "context": "arrival neutral/formal",
          "it": "Buonasera!",
          "translation": "Good evening!"
        },
        {
          "context": "arrival formal",
          "it": "Salve!",
          "translation": "Hello!"
        },
        {
          "context": "departure formal",
          "it": "ArrivederLa!",
          "translation": "Goodbye (formal)"
        },
        {
          "context": "departure",
          "it": "Arrivederci!",
          "translation": "Goodbye"
        },
        {
          "context": "departure",
          "it": "A presto! / A dopo!",
          "translation": "See you soon / later!"
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Personal subject pronouns",
      "description": "The lesson practices the basic Italian subject pronouns used with 'essere' and 'chiamarsi'.",
      "examples": [
        {
          "it": "io",
          "translation": "I"
        },
        {
          "it": "tu",
          "translation": "you (informal singular)"
        },
        {
          "it": "lui / lei",
          "translation": "he / she"
        },
        {
          "it": "noi",
          "translation": "we"
        },
        {
          "it": "voi",
          "translation": "you (plural)"
        },
        {
          "it": "loro",
          "translation": "they"
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Present tense of essere",
      "description": "The verb 'essere' is used for identity and basic descriptions.",
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": "Grammar",
      "rule": "Present tense of chiamarsi",
      "description": "The reflexive verb 'chiamarsi' is used to ask and say names.",
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": "Pragmatics",
      "rule": "Introducing yourself and asking names",
      "description": "Italian uses different question and reaction forms for informal 'tu' and formal 'Lei'.",
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "translation": "What is your name?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "translation": "What is your name? (formal)"
        },
        {
          "context": "statement",
          "it": "Mi chiamo Paolo.",
          "translation": "My name is Paolo."
        },
        {
          "context": "statement",
          "it": "Sono Paolo.",
          "translation": "I am Paolo."
        },
        {
          "context": "reaction informal",
          "it": "Piacere di conoscerti.",
          "translation": "Nice to meet you."
        },
        {
          "context": "reaction formal",
          "it": "Piacere di conoscerla.",
          "translation": "Nice to meet you. (formal)"
        }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Pronunciation of letter C",
      "description": "The sound of 'c' changes according to the following letter.",
      "sub_rules": [
        {
          "pattern": "c + a, o, u, consonant",
          "sound": "[k]",
          "examples": [
            {
              "it": "camera",
              "translation": "room/camera"
            },
            {
              "it": "corpo",
              "translation": "body"
            },
            {
              "it": "curare",
              "translation": "to treat"
            },
            {
              "it": "amico",
              "translation": "friend"
            }
          ]
        },
        {
          "pattern": "c + e, i",
          "sound": "[tʃ]",
          "examples": [
            {
              "it": "arrivederci",
              "translation": "goodbye"
            },
            {
              "it": "cinema",
              "translation": "cinema"
            },
            {
              "it": "piacere",
              "translation": "pleasure"
            },
            {
              "it": "centro",
              "translation": "center"
            }
          ]
        },
        {
          "pattern": "ch + e, i",
          "sound": "[k]",
          "examples": [
            {
              "it": "che",
              "translation": "what / that"
            },
            {
              "it": "perché",
              "translation": "why / because"
            },
            {
              "it": "macchina",
              "translation": "car"
            },
            {
              "it": "forchetta",
              "translation": "fork"
            }
          ]
        },
        {
          "pattern": "ci + a, o, u",
          "sound": "[tʃ]",
          "examples": [
            {
              "it": "ciao",
              "translation": "hi"
            },
            {
              "it": "cioccolata",
              "translation": "chocolate"
            },
            {
              "it": "calcio",
              "translation": "football / soccer"
            },
            {
              "it": "faccia",
              "translation": "face"
            }
          ]
        }
      ]
    }
  ],
