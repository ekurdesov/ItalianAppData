{
  "lesson_info": {
    "id": "A1-L2-5",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": [
      "Ripasso: i numeri da 10 a 100",
      "Grammatica: verbi avere ed essere — ripasso e ampliamento",
      "Lessico: avere + sensazioni fisiche ed emotive",
      "Attività comunicativa: Come ti chiami? / Quanti anni hai? / Che numero hai?",
      "Attività comunicativa: Quante domande!",
      "Formale e informale: ripasso"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "avere + noun for physical/emotional states",
      "description": "Italian uses 'avere' (to have) + a noun to express physical sensations and emotions that English expresses with 'to be'. Literal translation: 'to have hunger', 'to have cold', etc.",
      "examples": [
        {
          "it": "Ho fame.",
          "translation": "I am hungry."
        },
        {
          "it": "Hai sete?",
          "translation": "Are you thirsty?"
        },
        {
          "it": "Ha freddo?",
          "translation": "Are you cold? (formal)"
        },
        {
          "it": "Ho fretta!",
          "translation": "I am in a hurry!"
        },
        {
          "it": "Ha paura.",
          "translation": "She/he is afraid."
        },
        {
          "it": "Ho sonno.",
          "translation": "I am sleepy."
        },
        {
          "it": "Non ho tempo.",
          "translation": "I don't have time."
        }
      ],
      "notes": "Key list: avere fame / sete / sonno / caldo / freddo / paura / fretta / tempo"
    },
    {
      "category": "Grammar",
      "rule": "essere vs avere for states — adjective vs noun",
      "description": "Use 'essere' with adjectives (sono stanco) and 'avere' with nouns for sensations (ho fame). Both express states but the structure differs.",
      "examples": [
        {
          "it": "Sono stanco.",
          "translation": "I am tired."
        },
        {
          "it": "Sei arrabbiata?",
          "translation": "Are you angry?"
        },
        {
          "it": "È annoiato.",
          "translation": "He is bored."
        },
        {
          "it": "Siete contenti?",
          "translation": "Are you (all) happy?"
        },
        {
          "it": "Ho fame.",
          "translation": "I am hungry. (lit. I have hunger)"
        },
        {
          "it": "Ha caldo.",
          "translation": "He is hot. (lit. He has heat)"
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Possessive adjectives — singular (il mio, il tuo, il suo)",
      "description": "Italian possessive adjectives agree in gender and number with the noun they modify, not with the owner. They are preceded by the definite article.",
      "examples": [
        {
          "it": "il mio numero",
          "translation": "my number"
        },
        {
          "it": "il tuo cognome",
          "translation": "your surname (informal)"
        },
        {
          "it": "il suo numero",
          "translation": "his/her number; your number (formal)"
        },
        {
          "it": "la mia classe",
          "translation": "my class"
        },
        {
          "it": "la tua professoressa",
          "translation": "your professor (informal)"
        },
        {
          "it": "la sua borsa",
          "translation": "his/her bag; your bag (formal)"
        }
      ],
      "notes": "In this lesson: il mio / il tuo / il suo with numero di telefono and cognome"
    },
    {
      "category": "Grammar",
      "rule": "Vorrei — polite desire",
      "description": "'Vorrei' is the conditional form of 'volere' (to want), used to politely express desire. Equivalent to 'I would like'.",
      "examples": [
        {
          "it": "Vorrei una pizza.",
          "translation": "I would like a pizza."
        },
        {
          "it": "Vorrei andare a letto.",
          "translation": "I would like to go to bed."
        },
        {
          "it": "Vorrei un caffè caldo.",
          "translation": "I would like a hot coffee."
        }
      ],
      "notes": "Used when responding to 'Cosa desideri quando...?' — followed by a noun or infinitive"
    },
    {
      "category": "Pragmatics",
      "rule": "Asking for personal details — formal vs informal",
      "description": "Italian uses different question forms depending on register when asking for name, age, or phone number.",
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "translation": "What is your name?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "translation": "What is your name? (formal)"
        },
        {
          "context": "informal",
          "it": "E di cognome?",
          "translation": "And your surname?"
        },
        {
          "context": "informal",
          "it": "Che numero di cellulare hai?",
          "translation": "What is your mobile number?"
        },
        {
          "context": "formal",
          "it": "Che numero di cellulare ha?",
          "translation": "What is your mobile number? (formal)"
        },
        {
          "context": "answer",
          "it": "Il mio numero è ...",
          "translation": "My number is ..."
        },
        {
          "context": "answer (formal)",
          "it": "Il suo numero è ...",
          "translation": "His/her/your number is ..."
        }
      ]
    }
  ],
