{
  "lesson_info": {
    "id": "A1-L3-7",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Lessico: Com'è?",
      "Comprensione orale: Alla festa",
      "Grammatica: c'è / ci sono",
      "Descrivere l'aspetto fisico: È alto, è moro, ha gli occhiali"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "c'è and ci sono",
      "description": "'C'è' (ci + è) means 'there is' for a single item; 'ci sono' (ci + sono) means 'there are' for multiple items.",
      "examples": [
        {
          "it": "In questa foto c'è un signore calvo.",
          "translation": "In this photo there is a bald man."
        },
        {
          "it": "In questa foto ci sono due persone anziane.",
          "translation": "In this photo there are two elderly people."
        },
        {
          "it": "Nella borsa c'è la chiave di casa.",
          "translation": "In the bag there is the house key."
        },
        {
          "it": "Sul banco ci sono i quaderni di Lucia.",
          "translation": "On the desk there are Lucia's notebooks."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "essere vs esserci",
      "description": "Use 'è/sono' to say what something IS or WHERE it is (known location). Use 'c'è/ci sono' to announce the EXISTENCE of something.",
      "examples": [
        {
          "it": "Il libro è sul tavolo.",
          "translation": "The book is on the table."
        },
        {
          "it": "Sul tavolo c'è un libro.",
          "translation": "There is a book on the table."
        },
        {
          "it": "I soldi sono nel portafoglio.",
          "translation": "The money is in the wallet."
        },
        {
          "it": "Nel portafoglio ci sono i soldi.",
          "translation": "There is money in the wallet."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Describing mood and emotional state",
      "description": "Italian uses 'essere' + adjective to describe how someone feels.",
      "examples": [
        {
          "it": "È arrabbiato.",
          "translation": "He is angry."
        },
        {
          "it": "È felice.",
          "translation": "He/She is happy."
        },
        {
          "it": "È stanco.",
          "translation": "He is tired."
        },
        {
          "it": "È triste.",
          "translation": "He/She is sad."
        },
        {
          "it": "È preoccupata.",
          "translation": "She is worried."
        },
        {
          "it": "È annoiata.",
          "translation": "She is bored."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Describing a person at a party",
      "description": "Combining physical description with c'è/ci sono to identify people in a group.",
      "examples": [
        {
          "it": "Il padrone di casa è il signore calvo, con i baffi.",
          "translation": "The host is the bald man with the moustache."
        },
        {
          "it": "Marco è quello con il maglione a righe e i capelli lunghi.",
          "translation": "Marco is the one with the striped jumper and long hair."
        },
        {
          "it": "Luisa è la ragazza bionda, con i capelli lunghi.",
          "translation": "Luisa is the blond girl with long hair."
        },
        {
          "it": "Sara è quella con gli occhiali e i capelli corti e ricci.",
          "translation": "Sara is the one with glasses and short curly hair."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking about mood: Di che umore sei?",
      "description": "A common question to ask how someone is feeling today.",
      "examples": [
        {
          "context": "question",
          "it": "Di che umore sei oggi?",
          "translation": "What mood are you in today?"
        },
        {
          "context": "answer",
          "it": "Sono stanco/a.",
          "translation": "I am tired."
        },
        {
          "context": "answer",
          "it": "Sono di buon umore.",
          "translation": "I am in a good mood."
        }
      ]
    }
  ],
