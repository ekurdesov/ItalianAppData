  "dialogues": [
    {
      "id": "D-A1L3-7-01",
      "title": "Alla festa",
      "register": "informal",
      "context": "Two people at a party identify the other guests by their appearance.",
      "turns": [
        {
          "speaker": "A",
          "it": "Chi è il padrone di casa?",
          "translation": "Who is the host?"
        },
        {
          "speaker": "B",
          "it": "È il signore calvo, con i baffi.",
          "translation": "He is the bald man with the moustache."
        },
        {
          "speaker": "A",
          "it": "E quella ragazza bionda con i capelli lunghi, chi è?",
          "translation": "And that blond girl with long hair, who is she?"
        },
        {
          "speaker": "B",
          "it": "È Luisa.",
          "translation": "She is Luisa."
        },
        {
          "speaker": "A",
          "it": "C'è anche Marco?",
          "translation": "Is Marco here too?"
        },
        {
          "speaker": "B",
          "it": "Sì, è quello con il maglione a righe e i capelli lunghi.",
          "translation": "Yes, he is the one with the striped jumper and long hair."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Say there is one person",
          "expected_it": "C'è un/una …"
        },
        {
          "cue": "Say there are several people",
          "expected_it": "Ci sono … persone."
        },
        {
          "cue": "Identify someone by appearance",
          "expected_it": "È quello/quella con … / È il/la … con …"
        }
      ]
    }
  ],
