  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Regular verbs in -are (review)",
      "description": "Regular -are verbs follow the pattern -o, -i, -a, -iamo, -ate, -ano in the present tense.",
      "conjugations": {
        "io": "lavoro",
        "tu": "lavori",
        "lui/lei/Lei": "lavora",
        "noi": "lavoriamo",
        "voi": "lavorate",
        "loro": "lavorano"
      },
      "examples": [
        {
          "it": "Stefano lavora al bar.",
          "translation": "Stefano works at the bar."
        },
        {
          "it": "Monica arriva tardi in ufficio.",
          "translation": "Monica arrives late at the office."
        },
        {
          "it": "I vicini di casa litigano spesso.",
          "translation": "The neighbours argue often."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Regular verbs in -ere (review)",
      "description": "Regular -ere verbs follow the pattern -o, -i, -e, -iamo, -ete, -ono.",
      "conjugations": {
        "io": "prendo",
        "tu": "prendi",
        "lui/lei/Lei": "prende",
        "noi": "prendiamo",
        "voi": "prendete",
        "loro": "prendono"
      },
      "examples": [
        {
          "it": "Stefano prende l'autobus per andare al lavoro.",
          "translation": "Stefano takes the bus to go to work."
        },
        {
          "it": "Il bar chiude alle 8.",
          "translation": "The bar closes at 8."
        },
        {
          "it": "La mia famiglia riceve molti pacchi.",
          "translation": "My family receives many parcels."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Irregular verb: andare",
      "description": "The verb 'andare' (to go) is irregular in the present tense.",
      "conjugations": {
        "io": "vado",
        "tu": "vai",
        "lui/lei/Lei": "va",
        "noi": "andiamo",
        "voi": "andate",
        "loro": "vanno"
      },
      "examples": [
        {
          "it": "La mattina Piero va in ufficio alle nove.",
          "translation": "In the morning Piero goes to the office at nine."
        },
        {
          "it": "Ogni sera vado in piscina con Marina.",
          "translation": "Every evening I go to the pool with Marina."
        },
        {
          "it": "Andate a cena al ristorante sabato?",
          "translation": "Are you going to dinner at the restaurant on Saturday?"
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Irregular verb: fare",
      "description": "The verb 'fare' (to do / to make) is irregular. It is used in many fixed expressions.",
      "conjugations": {
        "io": "faccio",
        "tu": "fai",
        "lui/lei/Lei": "fa",
        "noi": "facciamo",
        "voi": "fate",
        "loro": "fanno"
      },
      "examples": [
        {
          "it": "Tutte le mattine Roberto fa colazione con un cornetto e un cappuccino.",
          "translation": "Every morning Roberto has breakfast with a croissant and a cappuccino."
        },
        {
          "it": "Noi facciamo belle fotografie.",
          "translation": "We take beautiful photos."
        },
        {
          "it": "Cosa fate dopo cena?",
          "translation": "What do you do after dinner?"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Saying why you go to the bar",
      "description": "Use 'Vado al bar per + infinitive' to explain the purpose of going to the bar.",
      "examples": [
        {
          "it": "Vado al bar per fare colazione.",
          "translation": "I go to the bar to have breakfast."
        },
        {
          "it": "Vado al bar per incontrare gli amici.",
          "translation": "I go to the bar to meet friends."
        },
        {
          "it": "Vado al bar per fare una pausa.",
          "translation": "I go to the bar to take a break."
        },
        {
          "it": "Vado al bar per leggere il giornale.",
          "translation": "I go to the bar to read the newspaper."
        }
      ]
    }
  ],
