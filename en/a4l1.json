  "dialogues": [
    {
      "id": "D-A1L4-1-01",
      "title": "Vado al bar per...",
      "register": "informal",
      "context": "Students discuss why they go to the bar, using 'per + infinitive'.",
      "turns": [
        {
          "speaker": "A",
          "it": "Perché vai al bar?",
          "translation": "Why do you go to the bar?"
        },
        {
          "speaker": "B",
          "it": "Vado al bar per fare colazione e leggere il giornale. E tu?",
          "translation": "I go to the bar to have breakfast and read the newspaper. And you?"
        },
        {
          "speaker": "A",
          "it": "Io vado al bar per incontrare gli amici e prendere un aperitivo.",
          "translation": "I go to the bar to meet friends and have an aperitif."
        },
        {
          "speaker": "B",
          "it": "Andate spesso al bar?",
          "translation": "Do you go to the bar often?"
        },
        {
          "speaker": "A",
          "it": "Sì, andiamo quasi ogni giorno.",
          "translation": "Yes, we go almost every day."
        }
      ],
      "practice_prompts": [
