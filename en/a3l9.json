{
  "lesson_info": {
    "id": "A1-L3-9",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Ripasso lessico: Parole, parole...",
      "Ripasso grammatica: A lezione",
      "Ripasso fonetica: Che confusione!",
      "Ripasso lezioni 1-3: In giro per Roma"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Review: question words",
      "description": "Consolidation of all question words covered in lessons 1–3.",
      "examples": [
        {
          "it": "Dove abiti? — Abito a Roma.",
          "translation": "Where do you live? — I live in Rome."
        },
        {
          "it": "Come ti chiami? — Mi chiamo Francesco.",
          "translation": "What is your name? — My name is Francesco."
        },
        {
          "it": "Perché studi l'italiano? — Perché è una lingua bellissima.",
          "translation": "Why do you study Italian? — Because it is a beautiful language."
        },
        {
          "it": "Che lingue parli? — Parlo inglese, russo e italiano.",
          "translation": "What languages do you speak? — I speak English, Russian and Italian."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Review: essere, avere, c'è/ci sono",
      "description": "Revision of the three core structures: essere for identity/description, avere for possession/age, c'è/ci sono for existence.",
      "examples": [
        {
          "it": "Ha 23 anni.",
          "translation": "He/She is 23 years old."
        },
        {
          "it": "Sono italiano.",
          "translation": "I am Italian."
        },
        {
          "it": "C'è un libro sul tavolo.",
          "translation": "There is a book on the table."
        },
        {
          "it": "Ci sono molti studenti in classe.",
          "translation": "There are many students in class."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Vocabulary categories: school, nationalities, descriptions",
      "description": "Review of three vocabulary groups: school-related words, nationality adjectives, and physical/personality descriptions.",
      "examples": [
        {
          "it": "la classe, il banco, la lavagna, il quaderno",
          "translation": "classroom, desk, blackboard, notebook"
        },
        {
          "it": "italiano, tedesco, francese, russo, cinese",
          "translation": "Italian, German, French, Russian, Chinese"
        },
        {
          "it": "alto, magro, biondo, simpatico",
          "translation": "tall, thin, blond, nice"
        }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Elision: com'è, dov'è, quant'è vs qual è",
      "description": "Some Italian question words drop the final vowel before 'è' (elision), but 'qual' never takes an apostrophe before 'è'.",
      "examples": [
        {
          "it": "Com'è? (come + è)",
          "translation": "What is it like?"
        },
        {
          "it": "Dov'è? (dove + è)",
          "translation": "Where is it?"
        },
        {
          "it": "Quant'è? (quanto + è)",
          "translation": "How much is it?"
        },
        {
          "it": "Qual è? (no apostrophe)",
          "translation": "Which is? / What is?"
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Talking about plans and preferences",
      "description": "Expressing what you plan to do or prefer using 'penso di + infinitive' and 'preferisco + infinitive'.",
      "examples": [
        {
          "it": "Penso di dormire molto nel week-end.",
          "translation": "I plan to sleep a lot at the weekend."
        },
        {
          "it": "Una serata rilassante per me è…",
          "translation": "A relaxing evening for me is…"
        },
        {
          "it": "Avete cose in comune?",
          "translation": "Do you have things in common?"
        }
      ]
    }
  ],
