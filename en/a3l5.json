  "dialogues": [
    {
      "id": "D-A1L3-5-01",
      "title": "Il mistero",
      "register": "neutral",
      "context": "Bruno and Anna discuss strange things happening in the building.",
      "turns": [
        {
          "speaker": "Bruno",
          "it": "Il signor Ferrari non è mai in casa. Tutti i pacchi arrivano dalla Svizzera.",
          "translation": "Mr Ferrari is never at home. All the packages arrive from Switzerland."
        },
        {
          "speaker": "Anna",
          "it": "Hai ragione... è strano. Ma forse c'è una spiegazione.",
          "translation": "You're right... it's strange. But maybe there is an explanation."
        },
        {
          "speaker": "Bruno",
          "it": "Che vuoi dire?",
          "translation": "What do you mean?"
        },
        {
          "speaker": "Anna",
          "it": "Forse è un medico o un ingegnere e lavora fuori città.",
          "translation": "Maybe he is a doctor or an engineer and works outside the city."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Say that you agree",
          "expected_it": "Sono d'accordo."
        },
        {
          "cue": "Ask for an explanation",
          "expected_it": "Che vuoi dire?"
        }
      ]
    }
  ],
