{
  "lesson_info": {
    "id": "A1-L3-5",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Ripasso: Lingue e paesi",
      "Comprensione orale: Il mistero",
      "Grammatica: articolo indeterminativo",
      "Esprimere d'accordo e chiedere spiegazioni"
    ]
  },
  "language_rules": [
    {
      "category": "Pragmatics",
      "rule": "Agreeing with someone",
      "description": "Italian has short expressions for showing agreement or partial agreement in conversation.",
      "examples": [
        {
          "it": "Hai ragione.",
          "translation": "You are right."
        },
        {
          "it": "Sono d'accordo.",
          "translation": "I agree."
        },
        {
          "it": "È vero.",
          "translation": "It's true."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Expressing doubt or asking for clarification",
      "description": "When something is unclear, Italian often uses short formulas to ask for repetition, explanation, or confirmation.",
      "examples": [
        {
          "it": "Perché?",
          "translation": "Why?"
        },
        {
          "it": "Che vuoi dire?",
          "translation": "What do you mean?"
        },
        {
          "it": "Non ho capito.",
          "translation": "I didn't understand."
        },
        {
          "it": "Puoi ripetere, per favore?",
          "translation": "Can you repeat, please?"
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Indefinite article review in connected text",
      "description": "The lesson revises the indefinite article inside longer sentences and short mystery-style descriptions.",
      "examples": [
        {
          "it": "Anna ha un'amica di Parigi.",
          "translation": "Anna has a friend from Paris."
        },
        {
          "it": "Lo spagnolo usa un articolo.",
          "translation": "Spanish uses an article."
        },
        {
          "it": "Perché in abito parlo l'italiano Italia.",
          "translation": "Because in the sentence I use the article with Italian and Italy."
        }
      ]
    },
    {
      "category": "Listening",
      "rule": "Understanding a short mystery conversation",
      "description": "The listening task focuses on following a simple conversation about a suspicious situation and identifying what happened.",
      "examples": [
        {
          "it": "Bruno chiede informazioni sui vicini di casa di Anna.",
          "translation": "Bruno asks for information about Anna's neighbours."
        },
        {
          "it": "Il signor Ferrari non è mai in casa.",
          "translation": "Mr Ferrari is never at home."
        },
        {
          "it": "Tutti i pacchi arrivano dalla Svizzera.",
          "translation": "All the packages arrive from Switzerland."
        }
      ]
    },
    {
      "category": "Vocabulary",
      "rule": "Words for suspicion and investigation",
      "description": "The lesson introduces everyday words linked to mystery, neighbours, packages, and strange behaviour.",
      "examples": [
        {
          "it": "mistero",
          "translation": "mystery"
        },
        {
          "it": "vicino di casa",
          "translation": "neighbour"
        },
        {
          "it": "pacco",
          "translation": "package"
        },
        {
          "it": "strano",
          "translation": "strange"
        }
      ]
    }
  ],
