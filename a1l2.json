  "classroom_instructions": [
    {
      "it": "Presentate.",
      "en": "Introduce people."
    },
    {
      "it": "Lavorate in coppia.",
      "en": "Work in pairs."
    },
    {
      "it": "Rispondete.",
      "en": "Answer."
    },
    {
      "it": "Leggete e inserite tu e Lei.",
      "en": "Read and insert 'tu' and 'Lei'."
    },
    {
      "it": "Completate.",
      "en": "Complete."
    },
    {
      "it": "Completate alla forma negativa.",
      "en": "Complete in the negative form."
    },
    {
      "it": "Associate.",
      "en": "Match / associate."
    },
    {
      "it": "Costruite le frasi.",
      "en": "Build the sentences."
    },
    {
      "it": "Rimettete in ordine e abbinate.",
      "en": "Put in order and match."
    },
    {
      "it": "Leggete le parole.",
      "en": "Read the words."
    },
    {
      "it": "Completate con il o la dove è necessario.",
      "en": "Complete with 'il' or 'la' where necessary."
    },
    {
      "it": "Mettete in ordine.",
      "en": "Put in order."
    }
