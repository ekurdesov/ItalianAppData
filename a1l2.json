  "dialogues": [
    {
      "id": "D-A1L1-2-01",
      "title": "Come stai? (informal, evening)",
      "register": "informal",
      "context": "Two friends run into each other in the evening",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, come stai?",
          "en": "Hi, how are you?"
        },
        {
          "speaker": "B",
          "it": "Bene, grazie, e tu?",
          "en": "Good, thanks, and you?"
        },
        {
          "speaker": "A",
          "it": "Insomma.",
          "en": "So-so."
        },
        {
          "speaker": "B",
          "it": "Buona notte!",
          "en": "Good night!"
        },
        {
          "speaker": "A",
          "it": "Buona notte a tutti!",
          "en": "Good night everyone!"
        }
      ],
      "practice_prompts": [
        {
          "cue_en": "Ask how your friend is (informal)",
          "expected_it": "Come stai?"
        },
        {
          "cue_en": "Say you're fine and ask back",
          "expected_it": "Bene, grazie, e tu?"
        },
        {
          "cue_en": "Say it's so-so",
          "expected_it": "Insomma."
        }
      ]
    },
    {
      "id": "D-A1L1-2-02",
      "title": "Come sta? (formal, morning)",
      "register": "formal",
      "context": "Two adults greet each other formally in the morning",
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno, come sta?",
          "en": "Good morning, how are you?"
        },
        {
          "speaker": "B",
          "it": "Abbastanza bene, e Lei?",
          "en": "Quite well, and you?"
        },
        {
          "speaker": "A",
          "it": "Benissimo, grazie.",
          "en": "Very well, thank you."
        },
        {
          "speaker": "B",
          "it": "Buone vacanze!",
          "en": "Have a good holiday!"
        },
        {
          "speaker": "A",
          "it": "Buona giornata a Lei!",
          "en": "Have a nice day!"
        }
      ],
      "practice_prompts": [
        {
          "cue_en": "Greet and ask how they are (formal)",
          "expected_it": "Buongiorno, come sta?"
        },
        {
          "cue_en": "Reply 'quite well' and ask back (formal)",
          "expected_it": "Abbastanza bene, e Lei?"
        },
        {
          "cue_en": "Wish them a good holiday",
          "expected_it": "Buone vacanze!"
        }
      ]
    },
    {
      "id": "D-A1L1-2-03",
      "title": "Come stai? con arrivederci (informal, work context)",
      "register": "informal",
      "context": "Two colleagues part ways at the end of the day",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, come stai?",
          "en": "Hi, how are you?"
        },
        {
          "speaker": "B",
          "it": "Bene, grazie, e tu?",
          "en": "Good, thanks, and you?"
        },
        {
          "speaker": "A",
          "it": "Benissimo!",
          "en": "Very well!"
        },
        {
          "speaker": "B",
          "it": "A domani!",
          "en": "See you tomorrow!"
        },
        {
          "speaker": "A",
          "it": "Buon lavoro!",
          "en": "Have a good day at work!"
        }
      ],
      "practice_prompts": [
        {
          "cue_en": "Ask how they are (informal)",
          "expected_it": "Come stai?"
        },
        {
          "cue_en": "Say see you tomorrow",
          "expected_it": "A domani!"
        },
        {
          "cue_en": "Wish them good work",
          "expected_it": "Buon lavoro!"
        }
      ]
    },
    {
      "id": "D-A1L1-2-04",
      "title": "Incontri: colleghi a Milano",
      "register": "mixed",
      "context": "A chance meeting between colleagues; mixing informal and a third-person formal introduction",
      "turns": [
        {
          "speaker": "Matteo",
          "it": "Ciao, Giusi!",
          "en": "Hi, Giusi!"
        },
        {
          "speaker": "Giusi",
          "it": "Ciao, Matteo... Lei è una collega di Milano.",
          "en": "Hi, Matteo... She is a colleague from Milan."
        },
        {
          "speaker": "Anna",
          "it": "Piacere, sono Anna.",
          "en": "Pleased to meet you, I am Anna."
        },
        {
          "speaker": "Matteo",
          "it": "Ciao, Anna.",
          "en": "Hi, Anna."
        },
        {
          "speaker": "Matteo",
          "it": "E tu, di dove sei?",
          "en": "And you, where are you from?"
        },
        {
          "speaker": "Anna",
          "it": "Sono di Orvieto.",
          "en": "I am from Orvieto."
        }
      ],
      "practice_prompts": [
        {
          "cue_en": "Introduce yourself saying you are pleased to meet them",
          "expected_it": "Piacere, sono [name]."
        },
        {
          "cue_en": "Ask where someone is from (informal)",
          "expected_it": "Di dove sei?"
        },
        {
          "cue_en": "Say you are from a city",
          "expected_it": "Sono di [città]."
        }
      ]
    }
  ]
