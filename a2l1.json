  "lesson_info": {
    "id": "A1-L2-1",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": [
      "Comprensione orale: La classe di Carla",
      "Aggettivi di nazionalità",
      "Attività comunicativa: Di dove sei?",
      "Fonetica: lettera S"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Asking and stating origin",
      "description": "Italian distinguishes informal 'tu' and formal 'Lei' when asking where someone is from.",
      "examples": [
        {
          "context": "informal",
          "it": "Di dove sei?",
          "en": "Where are you from?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "en": "And you?"
        },
        {
          "context": "formal",
          "it": "Di dov'è?",
          "en": "Where are you from? (formal)"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "en": "And you? (formal)"
        },
        {
          "context": "answer",
          "it": "Sono di Milano.",
          "en": "I am from Milan."
        },
        {
          "context": "answer",
          "it": "Sono italiano.",
          "en": "I am Italian."
        },
        {
          "context": "answer",
          "it": "Sono italiano, di Milano.",
          "en": "I am Italian, from Milan."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Nationality adjectives agree in gender",
      "description": "Nationality adjectives change endings to agree with masculine or feminine nouns.",
      "sub_rules": [
        {
          "pattern": "-o / -a",
          "description": "Many nationality adjectives have masculine singular in -o and feminine singular in -a.",
          "examples": [
            {
              "it": "americano / americana",
              "en": "American"
            },
            {
              "it": "egiziano / egiziana",
              "en": "Egyptian"
            },
            {
              "it": "austriaco / austriaca",
              "en": "Austrian"
            }
          ]
        },
        {
          "pattern": "-e",
          "description": "Some nationality adjectives have the same singular form for masculine and feminine.",
          "examples": [
            {
              "it": "francese",
              "en": "French"
            },
            {
              "it": "inglese",
              "en": "English"
            },
            {
              "it": "cinese",
              "en": "Chinese"
            },
            {
              "it": "svedese",
              "en": "Swedish"
            }
          ]
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Origin from cities uses 'di'",
      "description": "To say where someone is from, Italian commonly uses 'essere di' plus a city or place.",
      "examples": [
        {
          "it": "Juan è di Madrid.",
          "en": "Juan is from Madrid."
        },
        {
          "it": "John è di New York.",
          "en": "John is from New York."
        }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Letter S can be voiced or voiceless",
      "description": "Italian 's' may be pronounced as [z] or [s] depending on the word.",
      "sub_rules": [
        {
          "sound": "[z]",
          "examples": [
            {
              "it": "caso",
              "en": "case"
            },
            {
              "it": "inglese",
              "en": "English"
            },
            {
              "it": "musica",
              "en": "music"
            },
            {
              "it": "televisione",
              "en": "television"
            }
          ]
        },
        {
          "sound": "[s]",
          "examples": [
            {
              "it": "sì",
              "en": "yes"
            },
            {
              "it": "sedia",
              "en": "chair"
            },
            {
              "it": "salutare",
              "en": "to greet"
            },
            {
              "it": "Sicilia",
              "en": "Sicily"
            }
          ]
        }
      ]
    }
  ],
