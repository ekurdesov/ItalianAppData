  "lesson_info": {
    "id": "A1-L3-2",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Повторение: Intervista doppia",
      "Грамматика: Dove abiti?",
      "Аудирование: Una strana coppia",
      "Спрашивать и говорить об адресе и семейном положении"
    ]
  },
  "language_rules": [
    {
      "category": "Прагматика",
      "rule": "Как спрашивать о семейном положении",
      "description": "В итальянском для вопроса о семейном положении используются формы с прилагательными: married, single, engaged, separated, divorced, widowed.",
      "examples": [
        {
          "context": "неформальный",
          "it": "Sei sposato/a?",
          "translation": "Ты женат / замужем?"
        },
        {
          "context": "официальный / формальный",
          "it": "È sposato/a?",
          "translation": "Вы женаты / замужем?"
        },
        {
          "it": "Sono sposata con Marco da vent'anni.",
          "translation": "Я замужем за Марко уже двадцать лет."
        },
        {
          "it": "Ho un ragazzo. / Ho una ragazza.",
          "translation": "У меня есть парень. / У меня есть девушка."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Как спросить адрес: неформально и официально",
      "description": "В итальянском различаются неформальное 'tu' и официальное 'Lei', когда спрашивают, где человек живёт и каков его адрес.",
      "examples": [
        {
          "context": "неформальный",
          "it": "Dove abiti?",
          "translation": "Где ты живёшь?"
        },
        {
          "context": "официальный / формальный",
          "it": "Dove abita?",
          "translation": "Где Вы живёте?"
        },
        {
          "context": "неформальный",
          "it": "Qual è il tuo indirizzo?",
          "translation": "Какой у тебя адрес?"
        },
        {
          "context": "официальный / формальный",
          "it": "Qual è il Suo indirizzo?",
          "translation": "Какой у Вас адрес?"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Как назвать адрес",
      "description": "Адрес часто сообщается по модели 'abitare a + город + in + улица + номер' или прямой формулой с 'indirizzo'.",
      "examples": [
        {
          "it": "Abito a Roma in via Garibaldi, 8.",
          "translation": "Я живу в Риме, на улице Гарибальди, дом 8."
        },
        {
          "it": "Il mio indirizzo è via Garibaldi, 8.",
          "translation": "Мой адрес: улица Гарибальди, дом 8."
        },
        {
          "it": "Alice abita a Roma in via Brescia, 68.",
          "translation": "Аличе живёт в Риме, на улице Брешиа, дом 68."
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Полезные слова для адреса",
      "description": "В итальянских адресах часто используются существительные для типа улицы и номер дома.",
      "examples": [
        {
          "it": "via",
          "translation": "улица"
        },
        {
          "it": "piazza",
          "translation": "площадь"
        },
        {
          "it": "corso",
          "translation": "проспект"
        },
        {
          "it": "vicolo",
          "translation": "переулок"
        },
        {
          "it": "numero civico",
          "translation": "номер дома"
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Соседи и бытовой контекст дома",
      "description": "В уроке появляется лексика, связанная с соседями и повседневными ситуациями в доме.",
      "examples": [
        {
