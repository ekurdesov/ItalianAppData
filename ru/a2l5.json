        },
        {
          "it": "Ho fretta!",
          "translation": "Я тороплюсь!"
        },
        {
          "it": "Ha paura.",
          "translation": "Она/он боится."
        },
        {
          "it": "Ho sonno.",
          "translation": "Я хочу спать."
        },
        {
          "it": "Non ho tempo.",
          "translation": "У меня нет времени."
