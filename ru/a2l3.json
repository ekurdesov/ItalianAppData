  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола stare",
      "description": "Глагол «stare» используется, чтобы спросить и сказать, как дела у кого-либо, а в некоторых контекстах — чтобы указать на состояние или местонахождение.",
      "conjugations": {
        "io": "sto",
        "tu": "stai",
        "lui/lei/Lei": "sta",
        "noi": "stiamo",
        "voi": "state",
        "loro": "stanno"
      }
    },
    {
      "category": "Прагматика",
      "rule": "Вопрос «как дела»: официально и неформально",
      "description": "В итальянском языке различаются неформальное «tu» и официальное «Lei» при вопросе о самочувствии.",
      "examples": [
        {
          "context": "неформальный / разговорный",
          "it": "Come stai?",
          "translation": "Как ты?"
        },
        {
          "context": "неформальный / разговорный",
          "it": "E tu?",
          "translation": "А ты?"
        },
        {
          "context": "официальный / формальный",
          "it": "Come sta?",
          "translation": "Как вы?"
        },
        {
          "context": "официальный / формальный",
          "it": "E Lei?",
          "translation": "А вы?"
        },
        {
          "context": "нейтральный",
          "it": "Come va?",
          "translation": "Как дела?"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Типичные ответы на «Come stai?» / «Come va?»",
      "description": "Существует несколько устойчивых выражений для ответа на вопросы о самочувствии.",
      "examples": [
        {
          "it": "Benissimo / Molto bene, grazie.",
          "translation": "Очень хорошо, спасибо."
        },
        {
          "it": "Abbastanza bene, grazie.",
          "translation": "Довольно хорошо, спасибо."
        },
        {
          "it": "Va bene, grazie.",
          "translation": "Всё хорошо, спасибо."
        },
        {
          "it": "Non c'è male, grazie.",
          "translation": "Неплохо, спасибо."
        },
        {
          "it": "Così così. / Insomma.",
          "translation": "Так себе."
        },
        {
          "it": "Non mi lamento, grazie.",
          "translation": "Не жалуюсь, спасибо."
        },
        {
          "it": "Si vive, grazie.",
          "translation": "Живём, спасибо."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Представление кого-либо: официально и неформально",
      "description": "В итальянском языке используются разные формулы представления в зависимости от степени формальности.",
      "examples": [
        {
          "context": "неформальный / разговорный",
          "it": "Ti presento Mario.",
          "translation": "Познакомься, это Марио."
