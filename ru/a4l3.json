  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Глаголы на -ire с суффиксом -isc-",
      "description": "Некоторые глаголы на -ire вставляют -isc- между основой и окончанием во всех формах единственного числа и в 3-м лице множественного. Примеры: preferire, capire, finire, pulire.",
      "conjugations": {
        "io": "preferisco",
        "tu": "preferisci",
        "lui/lei/Lei": "preferisce",
        "noi": "preferiamo",
        "voi": "preferite",
        "loro": "preferiscono"
      },
      "examples": [
        {
          "it": "Preferisci un succo di frutta o una spremuta d'arancia?",
          "translation": "Ты предпочитаешь фруктовый сок или свежевыжатый апельсиновый?"
        },
        {
          "it": "I miei amici preferiscono andare in discoteca.",
          "translation": "Мои друзья предпочитают ходить на дискотеку."
        },
        {
          "it": "A che ora finisce la lezione?",
          "translation": "В котором часу заканчивается урок?"
        },
        {
          "it": "Non capisco questa parola.",
          "translation": "Я не понимаю это слово."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Повторение: prendere в баре",
      "description": "Глагол «prendere» — стандартный способ сделать заказ в итальянском баре.",
      "conjugations": {
        "io": "prendo",
        "tu": "prendi",
        "lui/lei/Lei": "prende",
        "noi": "prendiamo",
        "voi": "prendete",
        "loro": "prendono"
      },
      "examples": [
        {
          "it": "Allora ragazzi, che cosa prendete?",
          "translation": "Ну что, ребята, что будете?"
        },
        {
          "it": "Io prendo un tramezzino.",
          "translation": "Я возьму треугольный бутерброд."
        },
        {
          "it": "Tu, Stefano, che cosa prendi?",
          "translation": "Стефано, что ты будешь?"
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Найди лишнее: l'intruso",
      "description": "Лексическое упражнение: студенты определяют, какое слово не подходит к группе, и объясняют почему.",
      "examples": [
        {
          "it": "caffè - tè - panino - acqua - coca-cola - cappuccino",
          "translation": "Лишнее — panino, потому что это закуска, а не напиток."
        },
        {
          "it": "tè - panino - piadina - tramezzino - toast",
          "translation": "Лишнее — tè, потому что это напиток, а не закуска."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Выражение предпочтений: Preferisci…?",
      "description": "Глагол «preferire» используется для вопросов и ответов о предпочтениях между двумя вариантами.",
      "examples": [
        {
          "context": "вопрос",
          "it": "Preferisci il mare o la montagna?",
          "translation": "Ты предпочитаешь море или горы?"
        },
        {
          "context": "ответ",
          "it": "Preferisco il mare.",
          "translation": "Я предпочитаю море."
        },
        {
          "context": "согласие",
          "it": "Anch'io!",
          "translation": "Я тоже!"
        },
        {
          "context": "несогласие",
          "it": "Io invece preferisco la montagna.",
          "translation": "А я, наоборот, предпочитаю горы."
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Глаголы повседневной жизни",
      "description": "Распространённые глаголы для описания распорядка дня.",
      "examples": [
        {
          "it": "Lavoro, torno, dormo, guardo, leggo, navigo, mangio, viaggio.",
          "translation": "Я работаю, возвращаюсь, сплю, смотрю, читаю, сижу в интернете, ем, путешествую."
        }
      ]
    }
