  "dialogues": [
    {
      "id": "D-A1L4-3-01",
      "title": "Preferisci il tè o il caffè?",
      "register": "informal",
      "context": "Два студента тренируются выражать предпочтения с помощью глагола preferire.",
      "turns": [
        {
          "speaker": "A",
          "it": "Preferisci il mare o la montagna?",
          "translation": "Ты предпочитаешь море или горы?"
        },
        {
          "speaker": "B",
          "it": "Preferisco il mare. E tu?",
          "translation": "Я предпочитаю море. А ты?"
        },
        {
          "speaker": "A",
          "it": "Anch'io!",
          "translation": "Я тоже!"
        },
        {
          "speaker": "A",
          "it": "E al bar, preferisci il caffè o il tè?",
          "translation": "А в баре ты предпочитаешь кофе или чай?"
        },
        {
          "speaker": "B",
          "it": "Preferisco il caffè. Non capisco come le persone bevono il tè la mattina!",
          "translation": "Я предпочитаю кофе. Не понимаю, как люди пьют чай по утрам!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросить, что кто-то предпочитает: море или горы",
          "expected_it": "Preferisci il mare o la montagna?"
        },
        {
          "cue": "Сказать, что предпочитаешь",
          "expected_it": "Preferisco …"
        },
        {
          "cue": "Сказать, что не понимаешь слово",
          "expected_it": "Non capisco questa parola."
        }
      ]
    }
  ],
