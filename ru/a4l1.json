  "dialogues": [
    {
      "id": "D-A1L4-1-01",
      "title": "Vado al bar per...",
      "register": "informal",
      "context": "Студенты обсуждают, зачем ходят в бар, используя конструкцию «per + инфинитив».",
      "turns": [
        {
          "speaker": "A",
          "it": "Perché vai al bar?",
          "translation": "Зачем ты ходишь в бар?"
        },
        {
          "speaker": "B",
          "it": "Vado al bar per fare colazione e leggere il giornale. E tu?",
          "translation": "Я хожу в бар позавтракать и почитать газету. А ты?"
        },
        {
          "speaker": "A",
          "it": "Io vado al bar per incontrare gli amici e prendere un aperitivo.",
          "translation": "Я хожу в бар встретиться с друзьями и выпить аперитив."
        },
        {
          "speaker": "B",
          "it": "Andate spesso al bar?",
          "translation": "Вы часто ходите в бар?"
        },
        {
          "speaker": "A",
          "it": "Sì, andiamo quasi ogni giorno.",
          "translation": "Да, мы ходим почти каждый день."
        }
      ],
      "practice_prompts": [
