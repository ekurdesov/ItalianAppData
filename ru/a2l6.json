  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "avere voglia di + инфинитив",
      "description": "«Avere voglia di» означает «хотеть что-то делать; быть в настроении». После него следует инфинитив. Отрицательная форма «non avere voglia di» означает «не хотеть; не быть в настроении».",
      "examples": [
        {
          "it": "Ho voglia di andare al mare.",
          "translation": "Мне хочется пойти на море."
        },
        {
          "it": "Hai voglia di ripassare?",
          "translation": "Тебе хочется повторить материал?"
        },
        {
          "it": "Non ha voglia di studiare.",
          "translation": "Ему/ей не хочется учиться."
        },
        {
          "it": "Non ho voglia di niente.",
          "translation": "Мне ничего не хочется."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "avere paura di + существительное/инфинитив",
      "description": "«Avere paura di» означает «бояться чего-то/кого-то». После него следует существительное (с предлогом di + артикль в слитной форме) или инфинитив.",
      "examples": [
        {
          "it": "Ho paura di parlare in italiano.",
          "translation": "Я боюсь говорить по-итальянски."
        },
        {
          "it": "Ha paura della moglie.",
          "translation": "Он боится своей жены."
        },
        {
          "it": "Hai paura del professore?",
          "translation": "Ты боишься преподавателя?"
        }
      ],
      "notes": "di + определённый артикль образует слитные формы: di + la → della, di + il → del, di + l' → dell'"
