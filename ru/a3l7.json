{
  "lesson_info": {
    "id": "A1-L3-7",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Лексика: Com'è?",
      "Аудирование: Alla festa",
      "Грамматика: c'è / ci sono",
      "Описание внешности: È alto, è moro, ha gli occhiali"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "c'è и ci sono",
      "description": "«C'è» (ci + è) означает «есть» для одного предмета; «ci sono» (ci + sono) — «есть» для нескольких.",
      "examples": [
        {
          "it": "In questa foto c'è un signore calvo.",
          "translation": "На этой фотографии есть лысый мужчина."
        },
        {
          "it": "In questa foto ci sono due persone anziane.",
          "translation": "На этой фотографии есть два пожилых человека."
        },
        {
          "it": "Nella borsa c'è la chiave di casa.",
          "translation": "В сумке есть ключ от дома."
        },
        {
          "it": "Sul banco ci sono i quaderni di Lucia.",
          "translation": "На парте лежат тетради Лючии."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "essere vs esserci",
      "description": "«È/sono» используется, чтобы сказать, что что-то ЕСТЬ или ГДЕ оно находится (известное место). «C'è/ci sono» — чтобы сообщить о СУЩЕСТВОВАНИИ чего-либо.",
      "examples": [
        {
          "it": "Il libro è sul tavolo.",
          "translation": "Книга лежит на столе."
        },
        {
          "it": "Sul tavolo c'è un libro.",
          "translation": "На столе есть книга."
        },
        {
          "it": "I soldi sono nel portafoglio.",
          "translation": "Деньги в кошельке."
        },
        {
          "it": "Nel portafoglio ci sono i soldi.",
          "translation": "В кошельке есть деньги."
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Описание настроения и эмоционального состояния",
      "description": "В итальянском для описания состояния используется essere + прилагательное.",
      "examples": [
        {
          "it": "È arrabbiato.",
          "translation": "Он злой."
        },
        {
          "it": "È felice.",
          "translation": "Он/она счастлив(а)."
        },
        {
          "it": "È stanco.",
          "translation": "Он устал."
        },
        {
          "it": "È triste.",
          "translation": "Он/она грустный(-ая)."
        },
        {
          "it": "È preoccupata.",
          "translation": "Она обеспокоена."
        },
        {
          "it": "È annoiata.",
          "translation": "Ей скучно."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Описание человека на вечеринке",
      "description": "Сочетание описания внешности с c'è/ci sono для идентификации людей в группе.",
      "examples": [
        {
          "it": "Il padrone di casa è il signore calvo, con i baffi.",
          "translation": "Хозяин — лысый мужчина с усами."
        },
        {
          "it": "Marco è quello con il maglione a righe e i capelli lunghi.",
          "translation": "Марко — тот, что в полосатом свитере с длинными волосами."
        },
        {
          "it": "Luisa è la ragazza bionda, con i capelli lunghi.",
          "translation": "Луиза — блондинка с длинными волосами."
        },
        {
          "it": "Sara è quella con gli occhiali e i capelli corti e ricci.",
          "translation": "Сара — та, что в очках с короткими кудрявыми волосами."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Спросить о настроении: Di che umore sei?",
      "description": "Распространённый вопрос о том, в каком настроении человек сегодня.",
      "examples": [
        {
          "context": "вопрос",
          "it": "Di che umore sei oggi?",
          "translation": "В каком ты сегодня настроении?"
        },
        {
          "context": "ответ",
          "it": "Sono stanco/a.",
          "translation": "Я устал(а)."
        },
        {
          "context": "ответ",
          "it": "Sono di buon umore.",
          "translation": "Я в хорошем настроении."
        }
      ]
    }
  ],
