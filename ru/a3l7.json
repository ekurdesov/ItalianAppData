  "dialogues": [
    {
      "id": "D-A1L3-7-01",
      "title": "Alla festa",
      "register": "informal",
      "context": "Двое людей на вечеринке узнают других гостей по внешности.",
      "turns": [
        {
          "speaker": "A",
          "it": "Chi è il padrone di casa?",
          "translation": "Кто хозяин?"
        },
        {
          "speaker": "B",
          "it": "È il signore calvo, con i baffi.",
          "translation": "Это лысый мужчина с усами."
        },
        {
          "speaker": "A",
          "it": "E quella ragazza bionda con i capelli lunghi, chi è?",
          "translation": "А та блондинка с длинными волосами, кто это?"
        },
        {
          "speaker": "B",
          "it": "È Luisa.",
          "translation": "Это Луиза."
        },
        {
          "speaker": "A",
          "it": "C'è anche Marco?",
          "translation": "Марко тоже здесь?"
        },
        {
          "speaker": "B",
          "it": "Sì, è quello con il maglione a righe e i capelli lunghi.",
          "translation": "Да, это тот, что в полосатом свитере с длинными волосами."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Сказать, что есть один человек",
          "expected_it": "C'è un/una …"
        },
        {
          "cue": "Сказать, что есть несколько людей",
          "expected_it": "Ci sono … persone."
        },
        {
          "cue": "Описать кого-то по внешности",
          "expected_it": "È quello/quella con … / È il/la … con …"
        }
      ]
    }
  ],
