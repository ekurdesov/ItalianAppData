  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Вопрос о происхождении и ответ на него",
      "description": "Итальянский язык различает неформальную форму 'tu' и официальную 'Lei' при вопросе о том, откуда человек.",
      "examples": [
        {
          "context": "неформальный",
          "it": "Di dove sei?",
          "translation": "Откуда ты?"
        },
        {
          "context": "неформальный",
          "it": "E tu?",
          "translation": "А ты?"
        },
        {
          "context": "официальный / формальный",
          "it": "Di dov'è?",
          "translation": "Откуда вы? (официальный / формальный)"
        },
        {
          "context": "официальный / формальный",
          "it": "E Lei?",
          "translation": "А вы? (официальный / формальный)"
        },
        {
          "context": "ответ",
          "it": "Sono di Milano.",
          "translation": "Я из Милана."
        },
        {
          "context": "ответ",
          "it": "Sono italiano.",
          "translation": "Я итальянец."
        },
        {
          "context": "ответ",
          "it": "Sono italiano, di Milano.",
          "translation": "Я итальянец, из Милана."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Прилагательные национальности согласуются по роду",
      "description": "Прилагательные национальности меняют окончания в соответствии с родом существительного — мужским или женским.",
      "sub_rules": [
        {
          "pattern": "-o / -a",
          "description": "Многие прилагательные национальности имеют форму мужского рода единственного числа на -o и женского рода на -a.",
          "examples": [
            {
              "it": "americano / americana",
              "translation": "американец / американка"
            },
            {
              "it": "egiziano / egiziana",
              "translation": "египтянин / египтянка"
            },
            {
              "it": "austriaco / austriaca",
              "translation": "австриец / австрийка"
            }
          ]
        },
        {
          "pattern": "-e",
          "description": "Некоторые прилагательные национальности имеют одинаковую форму единственного числа для мужского и женского рода.",
          "examples": [
            {
              "it": "francese",
              "translation": "француз / француженка"
            },
            {
              "it": "inglese",
              "translation": "англичанин / англичанка"
            },
            {
              "it": "cinese",
              "translation": "китаец / китаянка"
            },
            {
              "it": "svedese",
              "translation": "швед / шведка"
            }
          ]
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Происхождение из города с предлогом 'di'",
      "description": "Для указания на то, откуда кто-то, в итальянском языке обычно используется 'essere di' с названием города или места.",
      "examples": [
        {
          "it": "Juan è di Madrid.",
          "translation": "Хуан из Мадрида."
        },
        {
          "it": "John è di New York.",
          "translation": "Джон из Нью-Йорка."
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Буква S может быть звонкой или глухой",
      "description": "Итальянская 's' может произноситься как [z] или [s] в зависимости от слова.",
      "sub_rules": [
        {
          "sound": "[z]",
          "examples": [
            {
              "it": "caso",
              "translation": "случай"
            },
            {
              "it": "inglese",
              "translation": "английский"
            },
            {
              "it": "musica",
              "translation": "музыка"
            },
            {
              "it": "televisione",
              "translation": "телевидение"
            }
          ]
        },
        {
          "sound": "[s]",
          "examples": [
            {
              "it": "sì",
              "translation": "да"
            },
            {
              "it": "sedia",
              "translation": "стул"
            },
            {
              "it": "salutare",
              "translation": "приветствовать"
            },
            {
              "it": "Sicilia",
              "translation": "Сицилия"
            }
          ]
        }
      ]
    }
  ],
