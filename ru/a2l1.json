  "dialogues": [
    {
      "id": "D-A1L2-1-01",
      "title": "Di dove sei? (informal)",
      "register": "неформальный / разговорный",
      "context": "Двое студентов на уроке итальянского рассказывают друг другу о своём происхождении",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao! Mi chiamo Antonio. E tu?",
          "translation": "Привет! Меня зовут Антонио. А тебя?"
        },
        {
          "speaker": "B",
          "it": "Io sono Yuki. Piacere!",
          "translation": "Я Юки. Приятно познакомиться!"
        },
        {
          "speaker": "A",
          "it": "Di dove sei, Yuki?",
          "translation": "Откуда ты, Юки?"
        },
        {
          "speaker": "B",
          "it": "Sono giapponese, di Tokyo. E tu?",
          "translation": "Я японка, из Токио. А ты?"
        },
        {
          "speaker": "A",
          "it": "Sono di Pechino. Sono cinese.",
          "translation": "Я из Пекина. Я китаец."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросите, откуда человек (неформально)",
          "expected_it": "Di dove sei?"
        },
        {
          "cue": "Назовите свою национальность и город происхождения",
          "expected_it": "Sono [nazionalità], di [città]."
        },
        {
          "cue": "Спросите в ответ (неформально)",
          "expected_it": "E tu?"
        }
      ]
    },
    {
      "id": "D-A1L2-1-02",
      "title": "Di dov'è? (formal)",
      "register": "официальный / формальный",
      "context": "Официальный разговор о национальности на профессиональном мероприятии",
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno. Lei è straniero?",
          "translation": "Доброе утро. Вы иностранец?"
        },
        {
          "speaker": "B",
          "it": "Sì, sono americano, di New York. E Lei?",
          "translation": "Да, я американец, из Нью-Йорка. А вы?"
        },
        {
