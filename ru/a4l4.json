  "dialogues": [
    {
      "id": "D-A1L4-4-01",
      "title": "Offro io!",
      "register": "informal",
      "context": "Двое друзей в баре заказывают напитки и еду; один предлагает заплатить.",
      "turns": [
        {
          "speaker": "A",
          "it": "Allora, che cosa prendi?",
          "translation": "Ну что, что ты будешь?"
        },
        {
          "speaker": "B",
          "it": "Prendo un tramezzino con prosciutto cotto e un caffè macchiato.",
          "translation": "Возьму бутерброд с варёной ветчиной и маккиато."
        },
        {
          "speaker": "A",
          "it": "Io prendo una piadina al formaggio e un succo di frutta.",
          "translation": "Я возьму лепёшку с сыром и фруктовый сок."
        },
        {
          "speaker": "B",
          "it": "Quanto costa tutto?",
          "translation": "Сколько всё стоит?"
        },
        {
          "speaker": "A",
          "it": "6,90 euro. Oggi offro io!",
          "translation": "6,90 евро. Сегодня угощаю я!"
        },
        {
          "speaker": "B",
          "it": "Grazie! La prossima volta offro io.",
          "translation": "Спасибо! В следующий раз угощаю я."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Сказать, что пьёшь кофе",
          "expected_it": "Bevo un caffè."
        },
        {
          "cue": "Предложить заплатить",
          "expected_it": "Offro io!"
        },
        {
          "cue": "Спросить, что кто-то предпочитает",
          "expected_it": "Preferisci …?"
        }
      ]
    }
  ],
