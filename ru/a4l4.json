{
  "lesson_info": {
    "id": "A1-L4-4",
    "title": "Un incontro",
    "level": "A1",
    "objectives": [
      "Повторение: Chiedi e rispondo",
      "Аудирование: Offro io!",
      "Грамматика: неправильные глаголы (bere)",
      "Коммуникативная деятельность: Preferisci...?"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Неправильный глагол: bere",
      "description": "Глагол «bere» (пить) неправильный. Основа в настоящем времени — «bev-».",
      "conjugations": {
        "io": "bevo",
        "tu": "bevi",
        "lui/lei/Lei": "beve",
        "noi": "beviamo",
        "voi": "bevete",
        "loro": "bevono"
      },
      "examples": [
        {
          "it": "Io bevo il caffè, e tu che cosa bevi?",
          "translation": "Я пью кофе, а ты что пьёшь?"
        },
        {
          "it": "Noi beviamo delle bibite fresche.",
          "translation": "Мы пьём холодные напитки."
        },
        {
          "it": "Marisa a colazione beve solo tè e mai latte.",
          "translation": "Мариса на завтрак пьёт только чай и никогда молоко."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Повторение: глаголы с -isc- (preferire, capire)",
      "description": "Закрепление глаголов на -ire с суффиксом -isc-.",
      "examples": [
        {
          "it": "Preferisci viaggiare in aereo o in treno?",
          "translation": "Ты предпочитаешь путешествовать на самолёте или на поезде?"
        },
        {
          "it": "Capite il cinese?",
          "translation": "Вы понимаете китайский?"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Угощать: Offro io!",
      "description": "Выражения для предложения заплатить в баре.",
      "examples": [
        {
          "it": "Oggi offro io.",
          "translation": "Сегодня угощаю я."
        },
        {
          "it": "La prossima volta offri tu.",
          "translation": "В следующий раз угощаешь ты."
        },
        {
          "it": "Che cosa prende Paola?",
          "translation": "Что будет Паола?"
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Виды кофе и еда в баре",
      "description": "Более конкретная лексика бара: виды кофе и сочетания блюд.",
      "examples": [
        {
          "it": "un caffè macchiato",
          "translation": "эспрессо с каплей молока"
        },
        {
          "it": "un caffè doppio",
          "translation": "двойной эспрессо"
        },
        {
          "it": "un caffè americano",
          "translation": "американо"
        },
        {
          "it": "un tè freddo con limone",
          "translation": "холодный чай с лимоном"
        },
        {
          "it": "un tramezzino al tonno",
          "translation": "бутерброд с тунцом"
        },
        {
          "it": "un panino al prosciutto",
          "translation": "булочка с ветчиной"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Выражение предпочтений: Preferisci…?",
      "description": "Глагол «preferire» для вопросов и ответов о предпочтениях.",
      "examples": [
        {
          "context": "вопрос",
          "it": "Preferisci il mare o la montagna?",
          "translation": "Ты предпочитаешь море или горы?"
        },
        {
          "context": "ответ",
          "it": "Preferisco il mare.",
          "translation": "Я предпочитаю море."
        },
        {
          "context": "формально",
          "it": "Preferisce il mare o la montagna?",
          "translation": "Вы предпочитаете море или горы?"
        }
      ]
    }
  ],
