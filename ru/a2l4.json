  "dialogues": [
    {
      "id": "D-A1L2-4-01",
      "title": "Quanti anni hai? (informal)",
      "register": "неформальный / разговорный",
      "context": "Два студента сравнивают возраст во время перерыва на уроке",
      "turns": [
        {
          "speaker": "A",
          "it": "Quanti anni hai?",
          "translation": "Сколько тебе лет?"
        },
        {
          "speaker": "B",
          "it": "Ho venticinque anni. E tu?",
          "translation": "Мне двадцать пять. А тебе?"
        },
        {
          "speaker": "A",
          "it": "Ho ventisei anni. Siamo quasi coetanei!",
          "translation": "Мне двадцать шесть. Мы почти ровесники!"
        },
        {
          "speaker": "B",
          "it": "Sì, abbiamo quasi la stessa età!",
          "translation": "Да, мы почти одного возраста!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросите, сколько кому-то лет (неформально)",
          "expected_it": "Quanti anni hai?"
        },
        {
          "cue": "Назовите свой возраст с помощью «ho»",
          "expected_it": "Ho [numero] anni."
        },
        {
          "cue": "Скажите, что вы (почти) ровесники",
          "expected_it": "Siamo coetanei! / Abbiamo la stessa età."
        }
      ]
    },
    {
      "id": "D-A1L2-4-02",
      "title": "Ha il ragazzo? — Carla",
      "register": "неформальный / разговорный",
      "context": "Двое друзей-мужчин разговаривают о Карле — диалог для аудирования из урока",
      "turns": [
        {
          "speaker": "Gianni",
          "it": "Bella Carla, no?",
          "translation": "Карла красивая, правда?"
        },
        {
          "speaker": "Bruno",
          "it": "Sì, è molto bella e carina.",
          "translation": "Да, она очень красивая и милая."
        },
        {
          "speaker": "Gianni",
          "it": "Quanti anni ha?",
          "translation": "Сколько ей лет?"
        },
        {
          "speaker": "Bruno",
          "it": "Mah... 26-27. Boh, perché?",
          "translation": "Хм... 26–27. Не знаю, а почему?"
        },
        {
          "speaker": "Gianni",
          "it": "Ha il ragazzo?",
          "translation": "У неё есть парень?"
        },
        {
          "speaker": "Bruno",
          "it": "No. Ma è troppo bella per te!",
          "translation": "Нет. Но она слишком красивая для тебя!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросите, сколько лет третьему лицу",
          "expected_it": "Quanti anni ha?"
        },
        {
          "cue": "Спросите, есть ли у кого-то парень / девушка",
          "expected_it": "Ha il ragazzo? / Ha la ragazza?"
        },
        {
          "cue": "Скажите, что кому-то 27 лет",
          "expected_it": "Ha 27 anni."
        }
      ]
    },
    {
      "id": "D-A1L2-4-03",
      "title": "Quanti anni ha? (formale)",
      "register": "официальный / формальный",
      "context": "Официальный обмен репликами о возрасте",
      "turns": [
        {
          "speaker": "A",
          "it": "Quanti anni ha, signora Rossi?",
          "translation": "Сколько вам лет, госпожа Росси?"
        },
        {
          "speaker": "B",
          "it": "Ho quarantadue anni. E Lei?",
          "translation": "Мне сорок два. А вам?"
        },
        {
          "speaker": "A",
          "it": "Ne ho quarantacinque.",
          "translation": "Мне сорок пять."
        }
      ],
      "practice_prompts": [
        {
