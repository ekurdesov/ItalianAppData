  "lesson_info": {
    "id": "A1-L2-4",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": [
      "Comprensione orale: Ha il ragazzo?",
      "Grammatica: verbo avere",
      "Lessico: i numeri da 10 a 100",
      "Attività comunicativa: Quanti anni hai?"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола avere",
      "description": "Глагол «avere» используется для выражения обладания и возраста.",
      "conjugations": {
        "io": "ho",
        "tu": "hai",
        "lui/lei/Lei": "ha",
        "noi": "abbiamo",
        "voi": "avete",
        "loro": "hanno"
      }
    },
    {
      "category": "Грамматика",
      "rule": "Essere и avere",
      "description": "В итальянском языке «essere» используется для описания тождества и характеристик, а «avere» — для обладания и возраста.",
      "examples": [
        {
          "it": "Carla è bella.",
          "translation": "Карла красивая."
        },
        {
          "it": "Carla ha 27 anni.",
          "translation": "Карле 27 лет."
        },
        {
          "it": "Ho vent'anni.",
          "translation": "Мне двадцать лет."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Вопрос о возрасте и ответ на него: официально и неформально",
      "description": "В итальянском языке различаются неформальное «tu» и официальное «Lei» при вопросе о возрасте.",
      "examples": [
        {
          "context": "неформальный / разговорный",
          "it": "Quanti anni hai?",
          "translation": "Сколько тебе лет?"
        },
        {
          "context": "неформальный / разговорный",
          "it": "E tu?",
          "translation": "А ты?"
        },
        {
          "context": "официальный / формальный",
          "it": "Quanti anni ha?",
          "translation": "Сколько вам лет? (официально)"
        },
        {
          "context": "официальный / формальный",
          "it": "E Lei?",
          "translation": "А вы? (официально)"
        },
        {
          "context": "ответ",
          "it": "Ho ... anni.",
          "translation": "Мне ... лет."
        },
        {
          "context": "ответ",
          "it": "Ne ho ...",
          "translation": "Мне ... лет."
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Выражения об одном возрасте и возрастных группах",
      "description": "В итальянском языке есть распространённые выражения для описания одинакового возраста и характеристики возраста.",
      "examples": [
        {
          "it": "coetaneo / coetanea",
          "translation": "ровесник / ровесница; человек одного возраста"
        },
        {
          "it": "Siamo coetanei.",
          "translation": "Мы ровесники."
        },
        {
          "it": "Abbiamo la stessa età.",
          "translation": "Мы одного возраста."
        },
        {
          "it": "giovane / anziano",
          "translation": "молодой / пожилой"
        }
      ]
    }
  ],
