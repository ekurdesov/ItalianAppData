{
  "lesson_info": {
    "id": "A1-L1-2",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": [
      "Comprensione orale: incontri",
      "Presentare una persona",
      "Verbo stare",
      "Attività comunicativa: come va?",
      "Fonetica: sc"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола stare",
      "description": "Глагол «stare» используется для того, чтобы спросить и рассказать о самочувствии, а в некоторых контекстах — для обозначения состояния или местонахождения.",
      "conjugations": {
        "io": "sto",
        "tu": "stai",
        "lui/lei/Lei": "sta",
        "noi": "stiamo",
        "voi": "state",
        "loro": "stanno"
      }
    },
    {
      "category": "Прагматика",
      "rule": "Вопрос о самочувствии: официальный и разговорный стиль",
      "description": "В итальянском языке различаются разговорная форма «tu» и официальная «Lei» при вопросе о самочувствии.",
      "examples": [
        {
          "context": "разговорный",
          "it": "Come stai?",
          "translation": "Как дела?"
        },
        {
          "context": "разговорный",
          "it": "E tu?",
          "translation": "А ты?"
        },
        {
          "context": "официальный",
          "it": "Come sta?",
          "translation": "Как дела? (официально)"
        },
        {
          "context": "официальный",
          "it": "E Lei?",
          "translation": "А Вы?"
        },
        {
          "context": "нейтральный",
          "it": "Come va?",
          "translation": "Как поживаете? / Как дела?"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Типичные ответы на «Come stai?» / «Come va?»",
      "description": "Существует ряд устойчивых выражений для ответа на вопросы о самочувствии.",
      "examples": [
        {
          "it": "Benissimo / Molto bene, grazie.",
          "translation": "Очень хорошо, спасибо."
        },
        {
          "it": "Abbastanza bene, grazie.",
          "translation": "Довольно хорошо, спасибо."
        },
        {
          "it": "Va bene, grazie.",
          "translation": "Хорошо, спасибо."
        },
        {
          "it": "Non c'è male, grazie.",
          "translation": "Неплохо, спасибо."
        },
        {
          "it": "Così così. / Insomma.",
          "translation": "Так себе."
        },
        {
          "it": "Non mi lamento, grazie.",
          "translation": "Не жалуюсь, спасибо."
        },
        {
          "it": "Si vive, grazie.",
          "translation": "Живём помаленьку, спасибо."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Представление кого-либо: официальный и разговорный стиль",
      "description": "В итальянском языке формулы представления различаются в зависимости от степени официальности.",
      "examples": [
        {
          "context": "разговорный",
          "it": "Ti presento Mario.",
          "translation": "Познакомься с Марио."
        },
        {
          "context": "разговорный",
          "it": "Lui/Questo è Mario.",
          "translation": "Это Марио."
        },
        {
          "context": "разговорный",
          "it": "Lei/Questa è Maria.",
          "translation": "Это Мария."
        },
        {
          "context": "официальный",
          "it": "Le presento il signor Bianchi.",
          "translation": "Позвольте представить Вам синьора Бьянки."
        },
        {
          "context": "официальный",
          "it": "Lei/Questa è la signora Bianchi.",
          "translation": "Это синьора Бьянки."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Реакция на знакомство",
      "description": "Стандартные вежливые фразы, используемые при знакомстве.",
      "examples": [
        {
          "it": "Piacere di conoscerti.",
          "translation": "Приятно познакомиться. (разговорный)"
        },
        {
          "it": "Piacere di conoscerla.",
          "translation": "Приятно познакомиться. (официальный)"
        },
        {
          "it": "Molto lieto/a.",
          "translation": "Очень рад/рада."
        },
        {
          "it": "Piacere.",
          "translation": "Приятно."
        },
        {
          "it": "Piacere mio.",
          "translation": "Мне приятно."
        },
        {
          "it": "Altrettanto.",
          "translation": "Взаимно."
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Произношение «sc»",
      "description": "Звучание сочетания «sc» меняется в зависимости от следующих за ним букв.",
      "sub_rules": [
        {
          "pattern": "sc + a, o, u, согласная",
          "sound": "[sk]",
          "examples": [
            {
              "it": "scarpe",
              "translation": "туфли, ботинки"
            },
            {
              "it": "scuro",
              "translation": "тёмный"
            },
            {
              "it": "ascoltare",
              "translation": "слушать"
            },
            {
              "it": "bosco",
              "translation": "лес"
            }
          ]
        },
        {
          "pattern": "sc + e, i",
          "sound": "[ʃ]",
          "examples": [
            {
              "it": "scimmia",
              "translation": "обезьяна"
            },
            {
              "it": "pesce",
              "translation": "рыба"
            },
            {
              "it": "uscire",
              "translation": "выходить"
            },
            {
              "it": "scena",
              "translation": "сцена"
            }
          ]
        },
        {
          "pattern": "sch + e, i",
          "sound": "[sk]",
          "examples": [
            {
              "it": "scherzo",
              "translation": "шутка"
            },
            {
              "it": "schermo",
              "translation": "экран"
            },
            {
              "it": "schema",
              "translation": "схема"
            },
            {
              "it": "maschera",
              "translation": "маска"
            }
          ]
        },
        {
          "pattern": "sci + a, o, u",
          "sound": "[ʃ]",
          "examples": [
            {
              "it": "sciopero",
              "translation": "забастовка"
            },
            {
              "it": "sciarpa",
              "translation": "шарф"
            },
            {
              "it": "prosciutto",
              "translation": "ветчина"
            },
            {
              "it": "asciugare",
              "translation": "сушить"
            }
          ]
        }
      ]
    }
  ],
