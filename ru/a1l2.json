  "classroom_instructions": [
    {
      "it": "Presentate.",
      "translation": "Представляйте людей."
    },
    {
      "it": "Lavorate in coppia.",
      "translation": "Работайте в парах."
    },
    {
      "it": "Rispondete.",
      "translation": "Отвечайте."
    },
    {
      "it": "Leggete e inserite tu e Lei.",
      "translation": "Читайте и вставляйте «tu» и «Lei»."
    },
    {
      "it": "Completate.",
      "translation": "Дополните."
    },
    {
      "it": "Completate alla forma negativa.",
      "translation": "Дополните в отрицательной форме."
    },
    {
      "it": "Associate.",
      "translation": "Сопоставьте / соедините."
    },
    {
      "it": "Costruite le frasi.",
      "translation": "Составьте предложения."
    },
    {
      "it": "Rimettete in ordine e abbinate.",
      "translation": "Упорядочьте и соедините."
    },
    {
      "it": "Leggete le parole.",
      "translation": "Читайте слова."
    },
    {
      "it": "Completate con il o la dove è necessario.",
      "translation": "Дополните артиклем «il» или «la» там, где необходимо."
    },
    {
      "it": "Mettete in ordine.",
      "translation": "Упорядочьте."
    }
  ],
