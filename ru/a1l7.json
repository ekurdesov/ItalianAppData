  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Предлог 'di'",
      "description": "Предлог 'di' используется для выражения принадлежности, владения и уточнения.",
      "sub_rules": [
        {
          "usage": "possesso, appartenenza",
          "examples": [
            {
              "it": "il gatto di Fiona",
              "translation": "кот Фионы"
            },
            {
              "it": "il cellulare di Stefano",
              "translation": "телефон Стефано"
            }
          ]
        },
        {
          "usage": "specificazione",
          "examples": [
            {
              "it": "il corso d'italiano",
              "translation": "курс итальянского языка"
            },
            {
              "it": "il numero di telefono",
              "translation": "номер телефона"
            }
          ]
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Указательные местоимения: questo, questa, questi, queste",
      "description": "Указательные местоимения согласуются с родом и числом существительного, к которому относятся.",
      "examples": [
        {
          "it": "questo libro",
          "translation": "эта книга",
          "gender_number": "мужской род, единственное число"
        },
        {
          "it": "questa valigia",
          "translation": "этот чемодан",
          "gender_number": "женский род, единственное число"
        },
        {
          "it": "questi ragazzi",
          "translation": "эти мальчики",
          "gender_number": "мужской род, множественное число"
        },
        {
          "it": "queste scarpe",
          "translation": "эти туфли",
          "gender_number": "женский род, множественное число"
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Предлоги 'a' и 'in'",
      "description": "Урок знакомит с предлогами места 'a' и 'in', особенно в контексте разговора о городах, регионах и местах в Италии.",
      "examples": [
        {
          "it": "a Roma",
          "translation": "в Риме / в Рим"
        },
        {
          "it": "in Italia",
          "translation": "в Италии"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Запрос номера телефона: официальная и неформальная формы",
      "description": "Итальянский язык различает неформальную форму 'tu' и официальную 'Lei' при запросе номера телефона или мобильного телефона.",
      "examples": [
        {
          "context": "неформальный",
          "it": "Qual è il tuo numero di telefono?",
          "translation": "Какой у тебя номер телефона?"
        },
        {
          "context": "официальный / формальный",
          "it": "Qual è il Suo numero di telefono?",
          "translation": "Какой у вас номер телефона? (официальный / формальный)"
        },
        {
          "context": "неформальный",
          "it": "Qual è il tuo numero di cellulare?",
          "translation": "Какой у тебя номер мобильного?"
        },
        {
          "context": "официальный / формальный",
          "it": "Qual è il Suo numero di cellulare?",
          "translation": "Какой у вас номер мобильного? (официальный / формальный)"
        },
        {
          "context": "ответ",
          "it": "Il mio numero di telefono è...",
          "translation": "Мой номер телефона..."
        },
        {
          "context": "ответ",
          "it": "Il mio numero di cellulare è...",
          "translation": "Мой номер мобильного..."
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Буква Q и сочетания qu/gu",
      "description": "На уроке отрабатываются сочетания 'qu' и некоторые сочетания 'gu' перед гласными, которые произносятся как [kw] или [gw].",
      "examples": [
        {
          "it": "questo",
          "translation": "этот / эта"
        },
