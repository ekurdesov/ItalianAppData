{
  "lesson_info": {
    "id": "A1-L3-6",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Повторение: Presentiamoci!",
      "Аудирование: Indovina chi...",
      "Грамматика: существительное + прилагательное",
      "Описание внешности: Com'è?"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Согласование существительного и прилагательного",
      "description": "В итальянском прилагательные согласуются с существительным в роде и числе. Мужской род: -o (ед.ч.) / -i (мн.ч.); женский: -a (ед.ч.) / -e (мн.ч.).",
      "examples": [
        {
          "it": "un ragazzo alto",
          "translation": "высокий парень"
        },
        {
          "it": "una ragazza alta",
          "translation": "высокая девушка"
        },
        {
          "it": "i capelli lunghi",
          "translation": "длинные волосы"
        },
        {
          "it": "gli occhi neri",
          "translation": "чёрные глаза"
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Прилагательные для описания внешности",
      "description": "Основные прилагательные для описания телосложения, роста и общего вида человека.",
      "examples": [
        {
          "it": "alto / basso",
          "translation": "высокий / низкий"
        },
        {
          "it": "magro / grasso",
          "translation": "худой / толстый"
        },
        {
          "it": "giovane / anziano",
          "translation": "молодой / пожилой"
        },
        {
          "it": "calvo",
          "translation": "лысый"
        },
        {
          "it": "di media statura",
          "translation": "среднего роста"
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Описание волос и глаз",
      "description": "Для описания волос и глаз используется глагол avere, прилагательные согласуются с существительным.",
      "examples": [
        {
          "it": "Ha i capelli biondi / castani / neri / rossi.",
          "translation": "У него/неё светлые / каштановые / чёрные / рыжие волосы."
        },
        {
          "it": "Ha i capelli ricci / lisci / corti / lunghi.",
          "translation": "У него/неё кудрявые / прямые / короткие / длинные волосы."
        },
        {
          "it": "Ha gli occhi azzurri / verdi / marroni / castani.",
          "translation": "У него/неё голубые / зелёные / карие / каштановые глаза."
        },
        {
          "it": "Ha i baffi.",
          "translation": "У него усы."
        },
        {
          "it": "Ha il pizzetto.",
          "translation": "У него козлиная бородка."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Как спросить и описать внешность: Com'è?",
      "description": "Вопрос «Com'è?» означает «Как он/она выглядит?». Ответ строится через essere + прилагательное и avere + часть тела.",
      "examples": [
        {
          "context": "вопрос",
          "it": "Com'è?",
          "translation": "Как он/она выглядит?"
        },
        {
          "context": "ответ",
          "it": "È alto, magro, ha i capelli corti e il pizzetto.",
          "translation": "Он высокий, худой, с короткими волосами и козлиной бородкой."
        },
        {
          "context": "ответ",
          "it": "È una ragazza giovane, di media statura con gli occhi neri e i capelli neri e corti.",
          "translation": "Это молодая девушка среднего роста с чёрными глазами и короткими чёрными волосами."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Игра «Угадай кто»: Indovina chi",
      "description": "Распространённое упражнение: один студент описывает человека, другие угадывают, кто это, задавая вопросы «да/нет».",
      "examples": [
        {
          "it": "È alto? — Sì.",
          "translation": "Он высокий? — Да."
        },
        {
          "it": "È grasso? — No.",
          "translation": "Он толстый? — Нет."
        },
        {
          "it": "Ha i capelli corti? — Sì.",
          "translation": "У него короткие волосы? — Да."
        },
        {
          "it": "È Marco? — Sì, hai indovinato!",
          "translation": "Это Марко? — Да, ты угадал!"
        }
      ]
    }
  ],
