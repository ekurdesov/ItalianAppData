  "dialogues": [
    {
      "id": "D-A1L3-6-01",
      "title": "Indovina chi",
      "register": "informal",
      "context": "Два студента играют в игру «Угадай кто», описывая кого-то из класса.",
      "turns": [
        {
          "speaker": "A",
          "it": "È alto?",
          "translation": "Он высокий?"
        },
        {
          "speaker": "B",
          "it": "Sì.",
          "translation": "Да."
        },
        {
          "speaker": "A",
          "it": "È grasso?",
          "translation": "Он толстый?"
        },
        {
          "speaker": "B",
          "it": "No.",
          "translation": "Нет."
        },
        {
          "speaker": "A",
          "it": "È biondo?",
          "translation": "Он блондин?"
        },
        {
          "speaker": "B",
          "it": "No.",
          "translation": "Нет."
        },
        {
          "speaker": "A",
          "it": "Ha i capelli corti?",
          "translation": "У него короткие волосы?"
        },
        {
          "speaker": "B",
          "it": "Sì.",
          "translation": "Да."
        },
        {
          "speaker": "A",
          "it": "È Marco?",
          "translation": "Это Марко?"
        },
        {
          "speaker": "B",
          "it": "Sì, hai indovinato!",
          "translation": "Да, ты угадал!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросить, высокий ли человек",
          "expected_it": "È alto/a?"
        },
        {
          "cue": "Спросить о цвете волос",
          "expected_it": "Ha i capelli biondi/castani/neri?"
        },
        {
          "cue": "Описать себя",
          "expected_it": "Sono … Ho i capelli … e gli occhi …"
        }
      ]
    }
  ],
