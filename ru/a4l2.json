  "dialogues": [
    {
      "id": "D-A1L4-2-01",
      "title": "Al bar",
      "register": "informal",
      "context": "Двое друзей в баре заказывают напитки и закуски.",
      "turns": [
        {
          "speaker": "A",
          "it": "Allora, che cosa prendi?",
          "translation": "Ну что, что ты будешь?"
        },
        {
          "speaker": "B",
          "it": "Prendo un cappuccino e un cornetto. E tu?",
          "translation": "Я возьму капучино и круассан. А ты?"
        },
        {
          "speaker": "A",
          "it": "Io prendo un caffè e un tramezzino al tonno.",
          "translation": "Я возьму эспрессо и бутерброд с тунцом."
        },
        {
          "speaker": "B",
          "it": "Paghiamo alla cassa?",
          "translation": "Платим в кассе?"
        },
        {
          "speaker": "A",
          "it": "Sì, oggi offro io!",
          "translation": "Да, сегодня угощаю я!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросить, что кто-то будет",
          "expected_it": "Che cosa prendi?"
        },
        {
          "cue": "Заказать напиток и закуску",
          "expected_it": "Prendo un/una … e un/una …"
        },
        {
          "cue": "Сказать, что угощаешь",
          "expected_it": "Oggi offro io!"
        }
      ]
    }
  ],
