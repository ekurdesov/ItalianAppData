      "examples": [
        {
          "context": "вопрос",
          "it": "Che cosa prendi?",
          "translation": "Что ты будешь?"
        },
        {
          "context": "ответ",
          "it": "Prendo un cappuccino e un cornetto.",
          "translation": "Я возьму капучино и круассан."
        },
        {
          "context": "вопрос",
          "it": "Come bevanda prendi…?",
          "translation": "Что ты будешь пить?"
        },
        {
          "context": "ответ",
          "it": "Come spuntino prendo un tramezzino.",
