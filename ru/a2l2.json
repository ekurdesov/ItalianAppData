  "dialogues": [
    {
      "id": "D-A1L2-2-01",
      "title": "È una città bellissima!",
      "register": "неформальный / разговорный",
      "context": "Два студента встречаются впервые и говорят о своём происхождении — ключевой диалог-образец из урока",
      "turns": [
        {
          "speaker": "Pierre",
          "it": "Ciao, mi chiamo Pierre. E tu, come ti chiami?",
          "translation": "Привет, меня зовут Пьер. А тебя как зовут?"
        },
        {
          "speaker": "Mariana",
          "it": "Io sono Mariana. Piacere.",
          "translation": "Я Мариана. Приятно познакомиться."
        },
        {
          "speaker": "Pierre",
          "it": "Di dove sei?",
          "translation": "Откуда ты?"
        },
        {
          "speaker": "Mariana",
          "it": "Sono italiana, di Livorno. E tu? Non sei italiano, vero?",
          "translation": "Я итальянка, из Ливорно. А ты? Ты ведь не итальянец, правда?"
        },
        {
          "speaker": "Pierre",
          "it": "No, sono francese, di Parigi.",
          "translation": "Нет, я француз, из Парижа."
        },
        {
          "speaker": "Mariana",
          "it": "Parigi?! È una città bellissima!",
          "translation": "Париж?! Это очень красивый город!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросите, откуда человек, используя разделительный вопрос с отрицанием",
          "expected_it": "Non sei [nazionalità], vero?"
        },
        {
          "cue": "Подтвердите свою национальность и город",
          "expected_it": "No, sono [nazionalità], di [città]."
        },
        {
          "cue": "Воскликните, что какой-то город очень красивый",
          "expected_it": "[Città]?! È una città bellissima!"
        }
      ]
    },
    {
      "id": "D-A1L2-2-02",
      "title": "Ti presento Giorgio (informale)",
