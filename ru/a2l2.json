        },
        {
          "it": "americani / americane",
          "translation": "американцы / американки"
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Вопрос о происхождении и ответ на него",
      "description": "В итальянском языке различаются неформальное обращение «tu» и формальное «Lei» при вопросе о происхождении.",
      "examples": [
