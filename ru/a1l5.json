  "classroom_instructions": [
    {
      "it": "Completate con essere o/e chiamarsi.",
      "translation": "Заполните, используя 'essere' и/или 'chiamarsi'."
    },
    {
      "it": "Osservate e rispondete.",
      "translation": "Посмотрите и ответьте."
    },
    {
      "it": "Secondo me...",
      "translation": "По-моему..."
    },
    {
      "it": "Non lo so.",
      "translation": "Не знаю."
    },
    {
      "it": "Leggete e verificate.",
      "translation": "Прочитайте и проверьте."
    },
    {
      "it": "Mettete in ordine.",
      "translation": "Расставьте по порядку."
    },
    {
      "it": "Lavorate in coppia.",
      "translation": "Работайте в парах."
    },
    {
      "it": "Ascoltate e completate.",
      "translation": "Послушайте и заполните."
    },
    {
      "it": "Abbinate.",
      "translation": "Сопоставьте."
    },
    {
      "it": "Buona lezione!",
      "translation": "Хорошего урока!"
    },
    {
      "it": "Come? Puoi ripetere, per favore?",
      "translation": "Как? Можешь повторить, пожалуйста?"
    }
  ],
  "dialogues": [
    {
      "id": "D-A1L1-5-01",
      "title": "Buona lezione!",
      "register": "неформальный / разговорный",
      "context": "Двое студентов приветствуют друг друга в начале урока итальянского",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, mi chiamo Anna.",
          "translation": "Привет, меня зовут Анна."
        },
        {
          "speaker": "B",
          "it": "Ciao, Anna! Mi chiamo Luca. Buona lezione!",
          "translation": "Привет, Анна! Меня зовут Лука. Хорошего урока!"
        },
        {
          "speaker": "A",
          "it": "Grazie, Luca. Buona lezione anche a te!",
          "translation": "Спасибо, Лука. И тебе хорошего урока!"
        },
        {
          "speaker": "B",
          "it": "Grazie!",
          "translation": "Спасибо!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Представьтесь в начале урока",
          "expected_it": "Ciao, mi chiamo [nome]."
        },
        {
          "cue": "Пожелайте кому-то хорошего урока",
          "expected_it": "Buona lezione!"
        },
        {
          "cue": "Ответьте тем же",
          "expected_it": "Buona lezione anche a te!"
        }
      ]
    },
    {
      "id": "D-A1L1-5-02",
      "title": "Sei la mia collega?",
      "register": "неформальный / разговорный",
      "context": "Двое студентов на курсе итальянского знакомятся и выясняют свою роль",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, come ti chiami?",
          "translation": "Привет, как тебя зовут?"
        },
        {
          "speaker": "B",
          "it": "Mi chiamo Carla. E tu?",
          "translation": "Меня зовут Карла. А тебя?"
        },
        {
          "speaker": "A",
          "it": "Mi chiamo Stefano. Piacere. Tu sei studentessa d'italiano?",
          "translation": "Меня зовут Стефано. Приятно познакомиться. Ты студентка итальянского?"
        },
        {
          "speaker": "B",
          "it": "Sì, e tu sei il mio compagno di gruppo?",
          "translation": "Да, а ты мой одногруппник?"
        },
        {
          "speaker": "A",
          "it": "Sì. Piacere di conoscerti!",
          "translation": "Да. Приятно познакомиться!"
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросите, является ли кто-то студентом итальянского (неформально)",
          "expected_it": "Tu sei studente/studentessa d'italiano?"
        },
        {
          "cue": "Спросите, является ли собеседник вашим одногруппником",
          "expected_it": "Tu sei il mio compagno/la mia compagna di gruppo?"
        },
        {
          "cue": "Выразите радость от знакомства (неформально)",
          "expected_it": "Piacere di conoscerti!"
        }
      ]
    }
  ]
