{
  "lesson_info": {
    "id": "A1-L1-5",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Comprensione orale: 'Lei è Gianni'",
      "Il sostantivo",
      "Attività comunicativa: 'Sei la mia collega?'",
      "Fonetica: lettere D/T"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Утвердительные, вопросительные и отрицательные предложения",
      "description": "В итальянском языке вопросительное предложение сохраняет тот же порядок слов, что и утвердительное, но произносится с восходящей интонацией. Отрицательные предложения образуются путём постановки 'non' перед глаголом.",
      "examples": [
        {
          "it": "Lui è italiano.",
          "translation": "Он итальянец."
        },
        {
          "it": "Lui è italiano?",
          "translation": "Он итальянец?"
        },
        {
          "it": "Lui non è italiano.",
          "translation": "Он не итальянец."
        },
        {
          "it": "Sì. / No, lui non è italiano.",
          "translation": "Да. / Нет, он не итальянец."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Род существительного по окончанию",
      "description": "В итальянском языке существительные часто указывают на род через последнюю гласную.",
      "sub_rules": [
        {
          "pattern": "-o",
          "gender": "мужской род",
          "description": "Существительные, оканчивающиеся на -o, как правило, мужского рода.",
          "examples": [
            {
              "it": "il ragazzo",
              "translation": "мальчик"
            },
            {
              "it": "il treno",
              "translation": "поезд"
            }
          ]
        },
        {
          "pattern": "-a",
          "gender": "женский род",
          "description": "Существительные, оканчивающиеся на -a, как правило, женского рода.",
          "examples": [
            {
              "it": "la ragazza",
              "translation": "девочка"
            },
            {
              "it": "la macchina",
              "translation": "машина"
            }
          ]
        },
        {
          "pattern": "-e",
          "gender": "мужской или женский род",
          "description": "Существительные, оканчивающиеся на -e, могут быть как мужского, так и женского рода.",
          "examples": [
            {
              "it": "il bicchiere",
              "translation": "стакан"
            },
            {
              "it": "il pesce",
              "translation": "рыба"
            },
            {
              "it": "la carne",
              "translation": "мясо"
            },
            {
              "it": "la voce",
              "translation": "голос"
            },
            {
              "it": "l'insegnante",
              "translation": "учитель / учительница"
            }
          ]
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Род существительного по типичным суффиксам",
      "description": "Некоторые суффиксы существительных позволяют уверенно определить грамматический род.",
      "sub_rules": [
        {
          "pattern": "-ore, -ale, -ile, -iere, -tore",
          "gender": "мужской род",
          "examples": [
            {
              "it": "il cameriere",
              "translation": "официант"
            },
            {
              "it": "il ventilatore",
              "translation": "вентилятор"
            }
          ]
        },
        {
          "pattern": "-sione, -zione, -gione, -trice",
          "gender": "женский род",
          "examples": [
            {
              "it": "la colazione",
              "translation": "завтрак"
            },
            {
              "it": "la direttrice",
              "translation": "директриса"
            }
          ]
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Знакомство и вопрос о имени",
      "description": "В итальянском языке для знакомства используются неформальная форма 'tu' и формальная 'Lei'.",
      "examples": [
        {
          "context": "неформальный",
          "it": "Come ti chiami?",
          "translation": "Как тебя зовут?"
        },
        {
          "context": "официальный / формальный",
          "it": "Come si chiama?",
          "translation": "Как вас зовут? (официальный / формальный)"
        },
        {
          "context": "утверждение",
          "it": "Mi chiamo Paolo.",
          "translation": "Меня зовут Паоло."
        },
        {
          "context": "утверждение",
          "it": "Il mio nome è...",
          "translation": "Моё имя..."
        },
        {
          "context": "утверждение",
          "it": "Il mio cognome è...",
          "translation": "Моя фамилия..."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Разговор об одноклассниках и коллегах",
      "description": "Согласование по роду проявляется в названиях ролей и притяжательных конструкциях при знакомстве.",
      "examples": [
        {
          "it": "studente d'italiano / studentessa d'italiano",
          "translation": "студент итальянского / студентка итальянского"
        },
        {
          "it": "il mio collega / la mia collega",
          "translation": "мой коллега / моя коллега"
        },
        {
          "it": "il mio compagno di gruppo / la mia compagna di gruppo",
          "translation": "мой одногруппник / моя одногруппница"
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Буквы D и T",
      "description": "Урок включает практику распознавания и произношения согласных D и T.",
      "examples": [
        {
          "it": "D/T",
          "translation": "противопоставление звуков d и t"
        }
      ]
    }
  ],
