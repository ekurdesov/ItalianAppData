{
  "lesson_info": {
    "id": "A1-L1-6",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Comprensione orale",
      "Numeri da 0 a 10",
      "Il sostantivo",
      "L'aggettivo",
      "Presentarsi",
      "Salutare",
      "Fonetica: lettere D/T"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Род существительного по типичным окончаниям",
      "description": "Некоторые окончания итальянских существительных уверенно указывают на грамматический род.",
      "sub_rules": [
        {
          "pattern": "-ore, -ale, -ile, -iere, -tore",
          "gender": "мужской род",
          "examples": [
            {
              "it": "il cameriere",
              "translation": "официант"
            },
            {
              "it": "il ventilatore",
              "translation": "вентилятор"
            }
          ]
        },
        {
          "pattern": "-sione, -zione, -gione, -trice",
          "gender": "женский род",
          "examples": [
            {
              "it": "la colazione",
              "translation": "завтрак"
            },
            {
              "it": "la direttrice",
              "translation": "директриса"
            }
          ]
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Образование множественного числа существительных",
      "description": "Итальянские существительные, как правило, меняют последнюю гласную во множественном числе.",
      "sub_rules": [
        {
          "singular": "-o",
          "plural": "-i",
          "examples": [
            {
              "it": "ragazzo -> ragazzi",
              "translation": "мальчик -> мальчики"
            },
            {
              "it": "libro -> libri",
              "translation": "книга -> книги"
            }
          ]
        },
        {
          "singular": "-a",
          "plural": "-e",
          "examples": [
            {
              "it": "ragazza -> ragazze",
              "translation": "девочка -> девочки"
            },
            {
              "it": "strada -> strade",
              "translation": "улица -> улицы"
            }
          ]
        },
        {
          "singular": "-e",
          "plural": "-i",
          "examples": [
            {
              "it": "signore -> signori",
              "translation": "мужчина / господин -> мужчины / господа"
            },
            {
              "it": "quartiere -> quartieri",
              "translation": "район -> районы"
            }
          ]
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Прилагательные на -o согласуются по роду и числу",
      "description": "Прилагательные, оканчивающиеся на -o, изменяются в соответствии с существительным: мужской род единственного числа -o, женский род единственного числа -a, мужской род множественного числа -i, женский род множественного числа -e.",
      "examples": [
        {
          "it": "un bambino piccolo",
          "translation": "маленький мальчик"
        },
        {
          "it": "una ragazza educata",
          "translation": "воспитанная девочка"
        },
        {
          "it": "due ragazzi educati",
          "translation": "двое воспитанных мальчиков"
        },
        {
          "it": "due ragazze carine",
          "translation": "две симпатичные девочки"
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола essere",
      "description": "Используется для выражения идентичности и описания.",
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола chiamarsi",
      "description": "Используется для вопроса об имени и представления.",
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": "Прагматика",
      "rule": "Знакомство и вопрос об имени",
      "description": "В итальянском языке используются разные формы для неформального (tu) и официального (Lei) знакомства.",
      "examples": [
        {
          "context": "неформальный",
          "it": "Come ti chiami?",
          "translation": "Как тебя зовут?"
        },
        {
          "context": "официальный / формальный",
          "it": "Come si chiama?",
          "translation": "Как вас зовут?"
        },
        {
          "context": "утверждение",
          "it": "Mi chiamo Paolo.",
          "translation": "Меня зовут Паоло."
        },
        {
          "context": "утверждение",
          "it": "Il mio cognome è...",
          "translation": "Моя фамилия..."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Приветствие и прощание: официальное и неформальное",
      "description": "Формы приветствия зависят от времени суток и степени формальности.",
      "examples": [
        {
          "context": "при встрече",
          "it": "Ciao!",
          "translation": "Привет! / Пока!"
        },
        {
          "context": "при встрече",
          "it": "Buongiorno!",
          "translation": "Доброе утро / добрый день"
        },
        {
          "context": "при встрече",
          "it": "Buonasera!",
          "translation": "Добрый вечер"
        },
        {
          "context": "при прощании",
          "it": "Arrivederci!",
          "translation": "До свидания"
        },
        {
          "context": "при прощании",
          "it": "Arrivederla!",
          "translation": "До свидания (официальный / формальный)"
        },
        {
          "context": "при прощании",
          "it": "A presto!",
          "translation": "До скорого"
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Буквы D и T",
      "description": "Студенты практикуют различение и произношение слов со звуками /d/ и /t/.",
      "examples": [
        {
          "it": "dì / ti",
          "translation": "скажи! / ты"
        },
        {
          "it": "divano / tardi",
          "translation": "диван / поздно"
        },
        {
          "it": "dito / tema",
          "translation": "палец / тема"
        }
      ]
    }
  ],
