{
  "lesson_info": {
    "id": "A1-L1-3",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Ripasso: salutare",
      "Pronomi personali",
      "Essere",
      "Chiamarsi",
      "Attività comunicativa: presentarsi",
      "Fonetica: lettera C"
    ]
  },
  "language_rules": [
    {
      "category": "Прагматика",
      "rule": "Официальные и разговорные приветствия",
      "description": "В итальянском языке формы приветствия и прощания различаются в зависимости от ситуации и степени официальности.",
      "examples": [
        {
          "context": "приход, разговорный",
          "it": "Ciao!",
          "translation": "Привет!"
        },
        {
          "context": "приход, нейтральный/официальный",
          "it": "Buongiorno! / Buon dì!",
          "translation": "Доброе утро / добрый день!"
        },
        {
          "context": "приход, нейтральный/официальный",
          "it": "Buonasera!",
          "translation": "Добрый вечер!"
        },
        {
          "context": "приход, официальный",
          "it": "Salve!",
          "translation": "Здравствуйте!"
        },
        {
          "context": "уход, официальный",
          "it": "ArrivederLa!",
          "translation": "До свидания (официально)"
        },
        {
          "context": "уход",
          "it": "Arrivederci!",
          "translation": "До свидания"
        },
        {
          "context": "уход",
          "it": "A presto! / A dopo!",
          "translation": "До скорого / до встречи!"
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Личные местоимения-подлежащие",
      "description": "В уроке отрабатываются основные итальянские местоимения-подлежащие, используемые с глаголами «essere» и «chiamarsi».",
      "examples": [
        {
          "it": "io",
          "translation": "я"
        },
        {
          "it": "tu",
          "translation": "ты (разговорный, единственное число)"
        },
        {
          "it": "lui / lei",
          "translation": "он / она"
        },
        {
          "it": "noi",
          "translation": "мы"
        },
        {
          "it": "voi",
          "translation": "вы (множественное число)"
        },
        {
          "it": "loro",
          "translation": "они"
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола essere",
      "description": "Глагол «essere» используется для обозначения идентичности и основных характеристик.",
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола chiamarsi",
      "description": "Возвратный глагол «chiamarsi» используется для того, чтобы спросить и сказать имя.",
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": "Прагматика",
      "rule": "Знакомство и вопрос об имени",
      "description": "В итальянском языке используются разные формулы вопроса и реакции для разговорного «tu» и официального «Lei».",
      "examples": [
        {
          "context": "разговорный",
          "it": "Come ti chiami?",
          "translation": "Как тебя зовут?"
        },
        {
          "context": "официальный",
          "it": "Come si chiama?",
          "translation": "Как Вас зовут? (официально)"
        },
        {
          "context": "утверждение",
          "it": "Mi chiamo Paolo.",
          "translation": "Меня зовут Паоло."
        },
        {
          "context": "утверждение",
          "it": "Sono Paolo.",
          "translation": "Я Паоло."
        },
        {
          "context": "реакция, разговорный",
          "it": "Piacere di conoscerti.",
          "translation": "Приятно познакомиться."
        },
        {
          "context": "реакция, официальный",
          "it": "Piacere di conoscerla.",
          "translation": "Приятно познакомиться. (официально)"
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Произношение буквы C",
      "description": "Звучание буквы «c» меняется в зависимости от следующей за ней буквы.",
      "sub_rules": [
        {
          "pattern": "c + a, o, u, согласная",
          "sound": "[k]",
          "examples": [
            {
              "it": "camera",
              "translation": "комната / камера"
            },
            {
              "it": "corpo",
              "translation": "тело"
            },
            {
              "it": "curare",
              "translation": "лечить"
            },
            {
              "it": "amico",
              "translation": "друг"
            }
          ]
        },
        {
          "pattern": "c + e, i",
          "sound": "[tʃ]",
          "examples": [
            {
              "it": "arrivederci",
              "translation": "до свидания"
            },
            {
              "it": "cinema",
              "translation": "кино"
            },
            {
              "it": "piacere",
              "translation": "удовольствие"
            },
            {
              "it": "centro",
              "translation": "центр"
            }
          ]
        },
        {
          "pattern": "ch + e, i",
          "sound": "[k]",
          "examples": [
            {
              "it": "che",
              "translation": "что / который"
            },
            {
              "it": "perché",
              "translation": "почему / потому что"
            },
            {
              "it": "macchina",
              "translation": "машина, автомобиль"
            },
            {
              "it": "forchetta",
              "translation": "вилка"
            }
          ]
        },
        {
          "pattern": "ci + a, o, u",
          "sound": "[tʃ]",
          "examples": [
            {
              "it": "ciao",
              "translation": "привет"
            },
            {
              "it": "cioccolata",
              "translation": "шоколад"
            },
            {
              "it": "calcio",
              "translation": "футбол"
            },
            {
              "it": "faccia",
              "translation": "лицо"
            }
          ]
        }
      ]
    }
  ],
