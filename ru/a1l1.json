  "language_rules": [
    {
      "category": "Фонетика",
      "rule": "Различение итальянских гласных",
      "description": "Итальянские гласные необходимо произносить чётко, поскольку небольшие изменения в звучании гласной могут менять смысл слова или даже его род.",
      "examples": [
        {
          "it": "colore / calore",
          "translation": "цвет / тепло"
        },
        {
          "it": "Paolo / Paola",
          "translation": "мужское имя / женское имя"
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Ударные конечные гласные с акцентом",
      "description": "Некоторые итальянские слова имеют письменный акцент на последней гласной, который указывает на ударный слог.",
      "examples": [
        {
          "it": "caffè",
          "translation": "кофе"
        },
        {
          "it": "città",
          "translation": "город"
        }
      ]
    },
    {
      "category": "Орфография",
      "rule": "Итальянское написание: буквы и двойные согласные",
      "description": "При произнесении по буквам в итальянском используются названия букв, а двойные согласные обозначаются словом «doppia» и названием согласной.",
      "examples": [
        {
          "it": "cappuccino",
          "translation": "капучино",
          "spelling": "ci - a - doppia pi - u - doppia ci - i - enne - o"
        },
        {
          "it": "Bologna",
          "translation": "Болонья",
          "note": "практика побуквенного написания"
        }
      ]
    },
    {
      "category": "Орфография",
      "rule": "Звучание «ci» в числительных",
      "description": "В словах «cinque», «dieci», «undici» и «dodici» сочетание «ci» произносится как звук [tʃ].",
      "examples": [
        {
          "it": "cinque",
          "translation": "пять"
        },
        {
          "it": "dieci",
          "translation": "десять"
        },
        {
          "it": "undici",
          "translation": "одиннадцать"
        },
        {
          "it": "dodici",
          "translation": "двенадцать"
        }
      ]
    }
  ],
