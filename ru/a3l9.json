  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Повторение: вопросительные слова",
      "description": "Закрепление всех вопросительных слов, изученных в уроках 1–3.",
      "examples": [
        {
          "it": "Dove abiti? — Abito a Roma.",
          "translation": "Где ты живёшь? — Я живу в Риме."
        },
        {
          "it": "Come ti chiami? — Mi chiamo Francesco.",
          "translation": "Как тебя зовут? — Меня зовут Франческо."
        },
        {
          "it": "Perché studi l'italiano? — Perché è una lingua bellissima.",
          "translation": "Почему ты изучаешь итальянский? — Потому что это очень красивый язык."
        },
        {
          "it": "Che lingue parli? — Parlo inglese, russo e italiano.",
          "translation": "На каких языках ты говоришь? — Я говорю по-английски, по-русски и по-итальянски."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Повторение: essere, avere, c'è/ci sono",
      "description": "Повторение трёх ключевых конструкций: essere для идентификации/описания, avere для обладания/возраста, c'è/ci sono для существования.",
      "examples": [
        {
          "it": "Ha 23 anni.",
          "translation": "Ему/ей 23 года."
        },
        {
          "it": "Sono italiano.",
          "translation": "Я итальянец."
        },
        {
          "it": "C'è un libro sul tavolo.",
          "translation": "На столе есть книга."
        },
        {
          "it": "Ci sono molti studenti in classe.",
          "translation": "В классе много студентов."
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Тематические группы: школа, национальности, описания",
      "description": "Повторение трёх лексических групп: слова, связанные со школой, прилагательные национальности, описание внешности и характера.",
      "examples": [
        {
          "it": "la classe, il banco, la lavagna, il quaderno",
          "translation": "класс, парта, доска, тетрадь"
        },
        {
          "it": "italiano, tedesco, francese, russo, cinese",
          "translation": "итальянский, немецкий, французский, русский, китайский"
        },
        {
          "it": "alto, magro, biondo, simpatico",
          "translation": "высокий, худой, светловолосый, симпатичный"
        }
      ]
    },
    {
      "category": "Фонетика",
      "rule": "Элизия: com'è, dov'è, quant'è vs qual è",
      "description": "Некоторые вопросительные слова теряют конечную гласную перед «è» (элизия), но «qual» никогда не пишется с апострофом перед «è».",
      "examples": [
        {
          "it": "Com'è? (come + è)",
          "translation": "Какой он/она/оно?"
        },
        {
          "it": "Dov'è? (dove + è)",
          "translation": "Где это?"
        },
        {
          "it": "Quant'è? (quanto + è)",
          "translation": "Сколько стоит?"
        },
        {
          "it": "Qual è? (без апострофа)",
          "translation": "Какой? / Что это?"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Планы и предпочтения",
      "description": "Выражение планов и предпочтений с помощью «penso di + инфинитив» и «preferisco + инфинитив».",
      "examples": [
        {
          "it": "Penso di dormire molto nel week-end.",
          "translation": "Я планирую много спать на выходных."
        },
        {
          "it": "Una serata rilassante per me è…",
          "translation": "Расслабляющий вечер для меня — это…"
        },
        {
          "it": "Avete cose in comune?",
          "translation": "У вас есть что-то общее?"
        }
      ]
    }
