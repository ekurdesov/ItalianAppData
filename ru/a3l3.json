  "dialogues": [
    {
      "id": "D-A1L3-3-01",
      "title": "Mi presento",
      "register": "neutral",
      "context": "Два однокурсника кратко представляются друг другу.",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, mi chiamo Oscar Bellini. Sono argentino e lavoro in un'agenzia immobiliare.",
          "translation": "Привет, меня зовут Оскар Беллини. Я аргентинец и работаю в агентстве недвижимости."
        },
        {
          "speaker": "B",
          "it": "Piacere. Io sono Lidia White, sono cuoca e abito a Londra.",
          "translation": "Очень приятно. Я Лидия Уайт, я повар и живу в Лондоне."
        },
        {
          "speaker": "A",
          "it": "Qual è il tuo numero di cellulare?",
          "translation": "Какой у тебя номер мобильного?"
        },
        {
          "speaker": "B",
          "it": "Il mio numero è 349 5574634.",
          "translation": "Мой номер 349 5574634."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Сказать своё имя и национальность",
          "expected_it": "Mi chiamo ... Sono ..."
        },
        {
          "cue": "Сказать, кем вы работаете",
          "expected_it": "Lavoro in ... / Sono ..."
        }
      ]
    },
    {
      "id": "D-A1L3-3-02",
      "title": "Qual è il tuo indirizzo email?",
      "register": "informal",
      "context": "Два человека обмениваются адресами электронной почты.",
      "turns": [
        {
          "speaker": "A",
          "it": "Qual è il tuo indirizzo email?",
          "translation": "Какой у тебя адрес электронной почты?"
        },
        {
          "speaker": "B",
          "it": "Il mio indirizzo email è mario.rossi@gmail.com.",
          "translation": "Мой адрес электронной почты mario.rossi@gmail.com."
        },
        {
          "speaker": "A",
          "it": "Come si scrive?",
          "translation": "Как это пишется?"
