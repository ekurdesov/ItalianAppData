  "lesson_info": {
    "id": "A1-L3-3",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Повторение: Dove abiti?",
      "Чтение: Mi presento",
      "Грамматика: глаголы на -ere, -ire",
      "Спрашивать и сообщать адрес электронной почты"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Правильные глаголы на -ere",
      "description": "Многие распространённые итальянские глаголы на -ere в настоящем времени имеют окончания -o, -i, -e, -iamo, -ete, -ono.",
      "conjugations": {
        "io": "scrivo",
        "tu": "scrivi",
        "lui/lei/Lei": "scrive",
        "noi": "scriviamo",
        "voi": "scrivete",
        "loro": "scrivono"
      },
      "examples": [
        {
          "it": "Mario scrive una lettera d'amore.",
          "translation": "Марио пишет любовное письмо."
        },
        {
          "it": "Giorgio vende molti gelati.",
          "translation": "Джорджо продаёт много мороженого."
        },
        {
          "it": "Noi prendiamo l'autobus delle 7.",
          "translation": "Мы садимся на автобус в семь."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Правильные глаголы на -ire",
      "description": "Правильные глаголы на -ire обычно образуют настоящее время по модели -o, -i, -e, -iamo, -ite, -ono.",
      "conjugations": {
        "io": "parto",
        "tu": "parti",
        "lui/lei/Lei": "parte",
        "noi": "partiamo",
        "voi": "partite",
        "loro": "partono"
      },
      "examples": [
        {
          "it": "Luca presenta gli amici all'insegnante.",
          "translation": "Лука представляет друзей преподавателю."
        },
        {
          "it": "Gli amici di Andrea arrivano alle 10.",
          "translation": "Друзья Андреа приходят к десяти."
        },
        {
          "it": "Io compio gli anni in America.",
          "translation": "Я праздную день рождения в Америке."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Как спросить и назвать электронный адрес",
      "description": "В итальянском адрес электронной почты обычно спрашивают через 'Qual è il tuo indirizzo email?' и сообщают через 'Il mio indirizzo email è...'.",
      "examples": [
        {
          "context": "неформально",
          "it": "Qual è il tuo indirizzo email?",
          "translation": "Какой у тебя адрес электронной почты?"
        },
        {
          "context": "ответ",
          "it": "Il mio indirizzo email è mario.rossi@gmail.com.",
          "translation": "Мой адрес электронной почты: mario.rossi@gmail.com."
        },
        {
          "context": "по буквам и символам",
          "it": "Chiocciola, punto, trattino basso.",
          "translation": "Собачка, точка, нижнее подчёркивание."
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Символы в электронном адресе",
      "description": "В уроке отрабатываются итальянские названия самых частых символов, нужных для диктовки e-mail.",
      "examples": [
        {
          "it": "chiocciola",
          "translation": "собачка, знак @"
        },
        {
          "it": "punto",
          "translation": "точка"
        },
        {
          "it": "trattino",
          "translation": "дефис"
        },
        {
          "it": "trattino basso",
          "translation": "нижнее подчёркивание"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Короткое представление о себе",
      "description": "На уровне A1 самопрезентация обычно объединяет имя, возраст, национальность, город, работу или учёбу и интересы.",
      "examples": [
        {
          "it": "Mi chiamo Oscar Bellini, sono argentino e lavoro in un'agenzia immobiliare.",
          "translation": "Меня зовут Оскар Беллини, я аргентинец и работаю в агентстве недвижимости."
        },
        {
          "it": "Sono Lidia White, sono cuoca e il mio numero di cellulare è 349 5574634.",
          "translation": "Я Лидия Уайт, я повар, и мой номер мобильного телефона 349 5574634."
        },
        {
          "it": "Mi chiamo Li Fang, il mio paese è la Cina e il mio nome utente è Lili08.",
          "translation": "Меня зовут Ли Фан, моя страна Китай, а мой логин Lili08."
        }
      ]
    }
  ],
