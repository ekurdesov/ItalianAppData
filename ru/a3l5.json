  "lesson_info": {
    "id": "A1-L3-5",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Повторение: Lingue e paesi",
      "Аудирование: Il mistero",
      "Грамматика: неопределённый артикль",
      "Выражать согласие и просить объяснение"
    ]
  },
  "language_rules": [
    {
      "category": "Прагматика",
      "rule": "Как выразить согласие",
      "description": "В разговоре по-итальянски есть короткие формулы, чтобы показать согласие или частичное согласие.",
      "examples": [
        {
          "it": "Hai ragione.",
          "translation": "Ты прав / права."
        },
        {
          "it": "Sono d'accordo.",
          "translation": "Я согласен / согласна."
        },
        {
          "it": "È vero.",
          "translation": "Это правда."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Как выразить сомнение и попросить пояснение",
      "description": "Если что-то непонятно, часто используются короткие формулы для просьбы повторить, объяснить или уточнить.",
      "examples": [
        {
          "it": "Perché?",
          "translation": "Почему?"
        },
        {
          "it": "Che vuoi dire?",
          "translation": "Что ты имеешь в виду?"
        },
        {
          "it": "Non ho capito.",
          "translation": "Я не понял / не поняла."
        },
        {
          "it": "Puoi ripetere, per favore?",
          "translation": "Можешь повторить, пожалуйста?"
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Повторение неопределённого артикля в связном тексте",
      "description": "В уроке снова отрабатывается неопределённый артикль внутри более длинных фраз и описаний в стиле загадки.",
      "examples": [
        {
          "it": "Anna ha un'amica di Parigi.",
          "translation": "У Анны есть подруга из Парижа."
        },
        {
          "it": "Lo spagnolo usa un articolo.",
          "translation": "В испанском используется артикль."
        },
        {
          "it": "Perché in abito parlo l'italiano Italia.",
          "translation": "Потому что в этом предложении я использую артикль с итальянским и Италией."
        }
      ]
    },
    {
      "category": "Аудирование",
      "rule": "Понимание короткого разговора-загадки",
      "description": "Задание на аудирование тренирует понимание простого разговора о подозрительной ситуации и поиск того, что произошло.",
      "examples": [
        {
          "it": "Bruno chiede informazioni sui vicini di casa di Anna.",
          "translation": "Бруно спрашивает о соседях Анны."
        },
        {
          "it": "Il signor Ferrari non è mai in casa.",
          "translation": "Синьор Феррари никогда не бывает дома."
        },
        {
          "it": "Tutti i pacchi arrivano dalla Svizzera.",
          "translation": "Все посылки приходят из Швейцарии."
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Слова для темы загадки и наблюдения",
      "description": "В уроке появляется бытовая лексика, связанная с загадкой, соседями, посылками и странным поведением.",
