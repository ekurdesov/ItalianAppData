  "dialogues": [
    {
      "id": "D-A1L3-5-01",
      "title": "Il mistero",
      "register": "neutral",
      "context": "Бруно и Анна обсуждают странные события в доме.",
      "turns": [
        {
          "speaker": "Bruno",
          "it": "Il signor Ferrari non è mai in casa. Tutti i pacchi arrivano dalla Svizzera.",
          "translation": "Синьор Феррари никогда не бывает дома. Все посылки приходят из Швейцарии."
        },
        {
          "speaker": "Anna",
          "it": "Hai ragione... è strano. Ma forse c'è una spiegazione.",
          "translation": "Ты прав... это странно. Но, возможно, этому есть объяснение."
        },
        {
          "speaker": "Bruno",
          "it": "Che vuoi dire?",
          "translation": "Что ты имеешь в виду?"
        },
        {
          "speaker": "Anna",
          "it": "Forse è un medico o un ingegnere e lavora fuori città.",
          "translation": "Может быть, он врач или инженер и работает за пределами города."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Сказать, что вы согласны",
          "expected_it": "Sono d'accordo."
        },
        {
          "cue": "Попросить объяснение",
          "expected_it": "Che vuoi dire?"
        }
      ]
    }
  ],
