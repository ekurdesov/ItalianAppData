  "lesson_info": {
    "id": "A1-L3-1",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Аудирование: Alla festa di Chiara",
      "Грамматика: предлоги di, a, in",
      "Спрашивать и говорить о месте жительства"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "Происхождение с di + город",
      "description": "Чтобы сказать, откуда человек родом, в итальянском обычно используется конструкция 'essere di' с названием города.",
      "examples": [
        {
          "it": "Sono di Casinalbo.",
          "translation": "Я из Казинальбо."
        },
        {
          "it": "Stefi è di Prato.",
          "translation": "Стефи из Прато."
        },
        {
          "it": "Di dov'è Alexia?",
          "translation": "Откуда Алексия?"
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Место жительства с a + город",
      "description": "Чтобы сказать, где кто-то живёт, в итальянском используется 'abitare a' с названиями городов.",
      "examples": [
        {
          "it": "Abito a Firenze.",
          "translation": "Я живу во Флоренции."
        },
        {
          "it": "Paolo abita a Roma.",
          "translation": "Паоло живёт в Риме."
        },
        {
          "it": "Patrick e John abitano a Londra.",
          "translation": "Патрик и Джон живут в Лондоне."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Место жительства с in + страна, регион, континент",
      "description": "Предлог 'in' употребляется со странами, регионами и континентами.",
      "examples": [
        {
          "it": "Abito in Italia.",
          "translation": "Я живу в Италии."
        },
        {
          "it": "Abito in Toscana.",
          "translation": "Я живу в Тоскане."
        },
        {
          "it": "Vivo in Africa.",
          "translation": "Я живу в Африке."
        },
        {
          "it": "In Inghilterra piove molto.",
          "translation": "В Англии много дождей."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Настоящее время глагола abitare",
      "description": "Глагол 'abitare' означает 'жить', 'проживать'.",
      "conjugations": {
        "io": "abito",
        "tu": "abiti",
        "lui/lei/Lei": "abita",
        "noi": "abitiamo",
        "voi": "abitate",
        "loro": "abitano"
      }
    },
    {
      "category": "Прагматика",
      "rule": "Как спросить и сказать, где человек живёт",
      "description": "В итальянском для вопроса о месте жительства используются формы 'Dove abiti?' и похожие конструкции. В ответ можно назвать город, регион и страну.",
      "examples": [
        {
          "context": "неформальный",
          "it": "Dove abiti?",
          "translation": "Где ты живёшь?"
        },
        {
          "context": "официальный / формальный",
          "it": "Dove abita?",
          "translation": "Где Вы живёте?"
        },
        {
          "context": "ответ",
          "it": "Abito a Pisa, in Toscana, in Italia.",
          "translation": "Я живу в Пизе, в Тоскане, в Италии."
        }
      ]
    }
  ],
