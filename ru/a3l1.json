  "dialogues": [
    {
      "id": "D-A1L3-1-01",
      "title": "Alla festa di Chiara",
      "register": "informal",
      "context": "Два студента знакомятся на вечеринке у Кьяры и говорят о происхождении, предмете учёбы и месте жительства.",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, io sono Claudio. Tu come ti chiami?",
          "translation": "Привет, я Клаудио. Как тебя зовут?"
        },
        {
          "speaker": "B",
          "it": "Stefi. Piacere.",
          "translation": "Стефи. Очень приятно."
        },
        {
          "speaker": "A",
          "it": "Che cosa studi?",
          "translation": "Что ты изучаешь?"
        },
        {
          "speaker": "B",
          "it": "Economia. E tu?",
          "translation": "Экономику. А ты?"
        },
        {
          "speaker": "A",
          "it": "Matematica. Di dove sei?",
          "translation": "Математику. Откуда ты?"
        },
        {
          "speaker": "B",
          "it": "Sono di Prato. E tu?",
          "translation": "Я из Прато. А ты?"
        },
        {
          "speaker": "A",
          "it": "Sono di Casinalbo, ma abito a Firenze, in Italia.",
          "translation": "Я из Казинальбо, но живу во Флоренции, в Италии."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросить, откуда человек",
          "expected_it": "Di dove sei?"
        },
        {
