  "lesson_info": {
    "id": "A1-L3-8",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": [
      "Повторение: Com'è?",
      "Аудирование: Nomi e cognomi italiani",
      "Грамматика: essere VS esserci",
      "Коммуникативная деятельность: Quante domande!"
    ]
  },
  "language_rules": [
    {
      "category": "Грамматика",
      "rule": "essere vs esserci — сравнение",
      "description": "«È/sono» указывает на местонахождение или идентифицирует уже известное. «C'è/ci sono» сообщает о существовании чего-либо.",
      "examples": [
        {
          "it": "L'orologio è nel cassetto.",
          "translation": "Часы в ящике."
        },
        {
          "it": "Nel cassetto c'è l'orologio.",
          "translation": "В ящике есть часы."
        },
        {
          "it": "Gli amici sono al bar.",
          "translation": "Друзья в баре."
        },
        {
          "it": "Al bar ci sono gli amici.",
          "translation": "В баре есть друзья."
        }
      ]
    },
    {
      "category": "Грамматика",
      "rule": "Вопросительные слова (interrogativi)",
      "description": "Итальянские вопросительные слова для вопросов о людях, предметах, местах, времени и причинах.",
      "examples": [
        {
          "it": "Come ti chiami?",
          "translation": "Как тебя зовут?"
        },
        {
          "it": "Chi è il nuovo professore?",
          "translation": "Кто новый преподаватель?"
        },
        {
          "it": "Di dove sei?",
          "translation": "Откуда ты?"
        },
        {
          "it": "Quanti anni hai?",
          "translation": "Сколько тебе лет?"
        },
        {
          "it": "Dove vivi?",
          "translation": "Где ты живёшь?"
        },
        {
          "it": "Che cosa studi?",
          "translation": "Что ты изучаешь?"
        },
        {
          "it": "Qual è il tuo numero di telefono?",
          "translation": "Какой у тебя номер телефона?"
        }
      ]
    },
    {
      "category": "Лексика",
      "rule": "Итальянские имена и фамилии",
      "description": "Распространённые итальянские имена и самые частые итальянские фамилии.",
      "examples": [
        {
          "it": "Luca, Marco, Francesco, Alessandro",
          "translation": "Распространённые мужские имена"
        },
        {
          "it": "Sofia, Giulia, Martina, Sara",
          "translation": "Распространённые женские имена"
        },
        {
          "it": "Rossi, Ferrari, Esposito, Bianchi",
          "translation": "Самые распространённые итальянские фамилии"
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Описание черт тела с помощью c'è",
      "description": "«C'è» используется для указания на конкретную особенность на теле человека.",
      "examples": [
        {
          "it": "Vicino al naso di Silvia c'è un piccolo neo.",
          "translation": "Рядом с носом Сильвии есть маленькая родинка."
        },
        {
          "it": "Sulla gamba destra di Luca c'è un piccolo tatuaggio.",
          "translation": "На правой ноге Луки есть маленькая татуировка."
        },
        {
          "it": "Il neo è vicino al naso di Silvia.",
          "translation": "Родинка находится рядом с носом Сильвии."
        }
      ]
    },
    {
      "category": "Прагматика",
      "rule": "Quante domande! — личные вопросы",
      "description": "Коммуникативное упражнение: студенты задают и отвечают на разнообразные личные вопросы, используя все изученные вопросительные слова.",
      "examples": [
        {
          "it": "Perché studi l'italiano?",
