          "translation": "Когда ты уезжаешь в отпуск?"
        },
        {
          "it": "Dove vai in vacanza quest'anno?",
          "translation": "Куда ты едешь в отпуск в этом году?"
        },
        {
          "it": "Qual è il tuo indirizzo?",
          "translation": "Какой у тебя адрес?"
        }
      ]
    }
