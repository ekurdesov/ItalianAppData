          "it": "Mi chiamo Marco.",
          "translation": "Меня зовут Марко."
        },
        {
          "speaker": "A",
          "it": "Di dove sei?",
          "translation": "Откуда ты?"
        },
        {
          "speaker": "B",
          "it": "Di Milano. E tu dove vivi?",
          "translation": "Из Милана. А ты где живёшь?"
        },
        {
          "speaker": "A",
          "it": "Vivo a Vigevano. Quanti anni hai?",
          "translation": "Я живу в Виджевано. Сколько тебе лет?"
        },
        {
          "speaker": "B",
          "it": "Ho 23 anni. Che cosa studi?",
          "translation": "Мне 23 года. Что ты изучаешь?"
        },
        {
          "speaker": "A",
          "it": "Studio Economia e commercio.",
          "translation": "Я изучаю экономику и коммерцию."
        }
      ],
      "practice_prompts": [
        {
          "cue": "Спросить, откуда человек",
          "expected_it": "Di dove sei?"
        },
        {
