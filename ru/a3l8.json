    {
      "id": "D-A1L3-8-01",
      "title": "Quante domande!",
      "register": "informal",
      "context": "Два студента задают друг другу личные вопросы, используя все вопросительные слова урока.",
      "turns": [
        {
          "speaker": "A",
          "it": "Come ti chiami?",
