{
  "lesson_info": {
    "id": "A1-L1-3",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Ripasso: salutare",
      "Pronomi personali",
      "Essere",
      "Chiamarsi",
      "Attività comunicativa: presentarsi",
      "Fonetica: lettera C"
    ]
  },
  "language_rules": [
    {
      "category": "Pragmatics",
      "rule": "Formal vs informal greetings",
      "description": "Italian uses different greeting and leave-taking forms depending on the situation and level of formality.",
      "examples": [
        { "context": "arrival informal", "it": "Ciao!", "en": "Hi!" },
        { "context": "arrival neutral/formal", "it": "Buongiorno! / Buon dì!", "en": "Good morning / good day!" },
        { "context": "arrival neutral/formal", "it": "Buonasera!", "en": "Good evening!" },
        { "context": "arrival formal", "it": "Salve!", "en": "Hello!" },
        { "context": "departure formal", "it": "ArrivederLa!", "en": "Goodbye (formal)" },
        { "context": "departure", "it": "Arrivederci!", "en": "Goodbye" },
        { "context": "departure", "it": "A presto! / A dopo!", "en": "See you soon / later!" }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Personal subject pronouns",
      "description": "The lesson practices the basic Italian subject pronouns used with 'essere' and 'chiamarsi'.",
      "examples": [
        { "it": "io", "en": "I" },
        { "it": "tu", "en": "you (informal singular)" },
        { "it": "lui / lei", "en": "he / she" },
        { "it": "noi", "en": "we" },
        { "it": "voi", "en": "you (plural)" },
        { "it": "loro", "en": "they" }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Present tense of essere",
      "description": "The verb 'essere' is used for identity and basic descriptions.",
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": "Grammar",
      "rule": "Present tense of chiamarsi",
      "description": "The reflexive verb 'chiamarsi' is used to ask and say names.",
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": "Pragmatics",
      "rule": "Introducing yourself and asking names",
      "description": "Italian uses different question and reaction forms for informal 'tu' and formal 'Lei'.",
      "examples": [
        { "context": "informal", "it": "Come ti chiami?", "en": "What is your name?" },
        { "context": "formal", "it": "Come si chiama?", "en": "What is your name? (formal)" },
        { "context": "statement", "it": "Mi chiamo Paolo.", "en": "My name is Paolo." },
        { "context": "statement", "it": "Sono Paolo.", "en": "I am Paolo." },
        { "context": "reaction informal", "it": "Piacere di conoscerti.", "en": "Nice to meet you." },
        { "context": "reaction formal", "it": "Piacere di conoscerla.", "en": "Nice to meet you. (formal)" }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Pronunciation of letter C",
      "description": "The sound of 'c' changes according to the following letter.",
      "sub_rules": [
        {
          "pattern": "c + a, o, u, consonant",
          "sound": "[k]",
          "examples": [
            { "it": "camera", "en": "room/camera" },
            { "it": "corpo", "en": "body" },
            { "it": "curare", "en": "to treat" },
            { "it": "amico", "en": "friend" }
          ]
        },
        {
          "pattern": "c + e, i",
          "sound": "[tʃ]",
          "examples": [
            { "it": "arrivederci", "en": "goodbye" },
            { "it": "cinema", "en": "cinema" },
            { "it": "piacere", "en": "pleasure" },
            { "it": "centro", "en": "center" }
          ]
        },
        {
          "pattern": "ch + e, i",
          "sound": "[k]",
          "examples": [
            { "it": "che", "en": "what / that" },
            { "it": "perché", "en": "why / because" },
            { "it": "macchina", "en": "car" },
            { "it": "forchetta", "en": "fork" }
          ]
        },
        {
          "pattern": "ci + a, o, u",
          "sound": "[tʃ]",
          "examples": [
            { "it": "ciao", "en": "hi" },
            { "it": "cioccolata", "en": "chocolate" },
            { "it": "calcio", "en": "football / soccer" },
            { "it": "faccia", "en": "face" }
          ]
        }
      ]
    }
  ],
