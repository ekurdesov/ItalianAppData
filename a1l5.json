  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Affirmative, interrogative, and negative sentences",
      "description": "In Italian, the interrogative sentence keeps the same word order as the affirmative sentence but uses rising intonation. Negative sentences are formed by placing 'non' before the verb.",
      "examples": [
        {
          "it": "Lui è italiano.",
          "en": "He is Italian."
        },
        {
          "it": "Lui è italiano?",
          "en": "Is he Italian?"
        },
        {
          "it": "Lui non è italiano.",
          "en": "He is not Italian."
        },
        {
          "it": "Sì. / No, lui non è italiano.",
          "en": "Yes. / No, he is not Italian."
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Noun gender by ending",
      "description": "Italian nouns often indicate gender through their final vowel.",
      "sub_rules": [
        {
          "pattern": "-o",
          "gender": "masculine",
          "description": "Nouns ending in -o are usually masculine.",
          "examples": [
            {
              "it": "il ragazzo",
              "en": "the boy"
            },
            {
              "it": "il treno",
              "en": "the train"
            }
          ]
        },
        {
          "pattern": "-a",
          "gender": "feminine",
          "description": "Nouns ending in -a are usually feminine.",
          "examples": [
            {
              "it": "la ragazza",
              "en": "the girl"
            },
            {
              "it": "la macchina",
              "en": "the car"
            }
          ]
        },
        {
          "pattern": "-e",
          "gender": "masculine or feminine",
          "description": "Nouns ending in -e can be either masculine or feminine.",
          "examples": [
            {
              "it": "il bicchiere",
              "en": "the glass"
            },
            {
              "it": "il pesce",
              "en": "the fish"
            },
            {
              "it": "la carne",
              "en": "the meat"
            },
            {
              "it": "la voce",
              "en": "the voice"
            },
            {
              "it": "l'insegnante",
              "en": "the teacher"
            }
          ]
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Noun gender by common suffix",
      "description": "Some noun endings strongly predict grammatical gender.",
      "sub_rules": [
        {
          "pattern": "-ore, -ale, -ile, -iere, -tore",
          "gender": "masculine",
          "examples": [
            {
              "it": "il cameriere",
              "en": "the waiter"
            },
            {
              "it": "il ventilatore",
              "en": "the fan"
            }
          ]
        },
        {
          "pattern": "-sione, -zione, -gione, -trice",
          "gender": "feminine",
          "examples": [
            {
              "it": "la colazione",
              "en": "breakfast"
            },
            {
              "it": "la direttrice",
              "en": "the female director"
            }
          ]
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Introducing yourself and asking names",
      "description": "Italian uses informal 'tu' and formal 'Lei' forms for introductions.",
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "en": "What is your name?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "en": "What is your name? (formal)"
        },
        {
          "context": "statement",
          "it": "Mi chiamo Paolo.",
          "en": "My name is Paolo."
        },
        {
          "context": "statement",
          "it": "Il mio nome è...",
          "en": "My name is..."
        },
        {
          "context": "statement",
          "it": "Il mio cognome è...",
          "en": "My surname is..."
        }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Talking about classmates and colleagues",
      "description": "Agreement in gender appears in role nouns and possessive phrases used in introductions.",
      "examples": [
        {
          "it": "studente d'italiano / studentessa d'italiano",
          "en": "male student of Italian / female student of Italian"
        },
        {
          "it": "il mio collega / la mia collega",
          "en": "my male colleague / my female colleague"
        },
        {
          "it": "il mio compagno di gruppo / la mia compagna di gruppo",
          "en": "my male groupmate / my female groupmate"
        }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Letters D and T",
      "description": "The lesson includes recognition and pronunciation practice for the consonants D and T.",
      "examples": [
        {
          "it": "D/T",
          "en": "contrast between the sounds d and t"
        }
      ]
    }
  ],
