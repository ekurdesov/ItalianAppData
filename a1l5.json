  "lesson_info": {
    "id": "A1-L1-5",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Comprensione orale: 'Lei è Gianni'",
      "Il sostantivo",
      "Attività comunicativa: 'Sei la mia collega?'",
      "Fonetica: lettere D/T"
    ]
