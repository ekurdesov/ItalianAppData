  "dialogues": [
    {
      "id": "D-A1L1-5-01",
      "title": "Buona lezione!",
      "register": "informal",
      "context": "Two students greet each other at the start of an Italian class",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, mi chiamo Anna.",
          "en": "Hi, my name is Anna."
        },
        {
          "speaker": "B",
          "it": "Ciao, Anna! Mi chiamo Luca. Buona lezione!",
          "en": "Hi, Anna! My name is Luca. Have a good lesson!"
        },
        {
          "speaker": "A",
          "it": "Grazie, Luca. Buona lezione anche a te!",
          "en": "Thanks, Luca. Have a good lesson too!"
        },
        {
          "speaker": "B",
          "it": "Grazie!",
          "en": "Thanks!"
        }
      ],
      "practice_prompts": [
        {
          "cue_en": "Introduce yourself at the start of a lesson",
          "expected_it": "Ciao, mi chiamo [nome]."
        },
        {
          "cue_en": "Wish someone a good lesson",
          "expected_it": "Buona lezione!"
        },
        {
          "cue_en": "Wish the same back",
          "expected_it": "Buona lezione anche a te!"
        }
      ]
    },
    {
      "id": "D-A1L1-5-02",
      "title": "Sei la mia collega?",
      "register": "informal",
      "context": "Two students in an Italian course introduce themselves and establish their role",
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, come ti chiami?",
          "en": "Hi, what's your name?"
        },
        {
          "speaker": "B",
          "it": "Mi chiamo Carla. E tu?",
          "en": "My name is Carla. And you?"
        },
        {
          "speaker": "A",
          "it": "Mi chiamo Stefano. Piacere. Tu sei studentessa d'italiano?",
          "en": "My name is Stefano. Pleased to meet you. Are you a student of Italian?"
        },
        {
          "speaker": "B",
          "it": "Sì, e tu sei il mio compagno di gruppo?",
          "en": "Yes, and are you my groupmate?"
        },
        {
          "speaker": "A",
          "it": "Sì. Piacere di conoscerti!",
          "en": "Yes. Nice to meet you!"
        }
      ],
      "practice_prompts": [
        {
          "cue_en": "Ask if someone is a student of Italian (informal)",
          "expected_it": "Tu sei studente/studentessa d'italiano?"
        },
        {
          "cue_en": "Ask if they are your groupmate",
          "expected_it": "Tu sei il mio compagno/la mia compagna di gruppo?"
        },
        {
          "cue_en": "Express pleasure at meeting them (informal)",
          "expected_it": "Piacere di conoscerti!"
        }
      ]
    }
  ]
