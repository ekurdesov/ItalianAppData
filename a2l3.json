  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Present tense of stare",
      "description": "The verb 'stare' is used to ask and say how someone is, and in some contexts to indicate a state or location.",
      "conjugations": {
        "io": "sto",
        "tu": "stai",
        "lui/lei/Lei": "sta",
        "noi": "stiamo",
        "voi": "state",
        "loro": "stanno"
      }
    },
    {
      "category": "Pragmatics",
      "rule": "Asking how someone is: formal vs informal",
      "description": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking how someone is.",
      "examples": [
        { "context": "informal", "it": "Come stai?", "en": "How are you?" },
        { "context": "informal", "it": "E tu?", "en": "And you?" },
        { "context": "formal", "it": "Come sta?", "en": "How are you?" },
        { "context": "formal", "it": "E Lei?", "en": "And you?" },
        { "context": "neutral", "it": "Come va?", "en": "How is it going?" }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Common responses to 'Come stai?' / 'Come va?'",
      "description": "There are several fixed expressions for answering questions about well-being.",
      "examples": [
        { "it": "Benissimo / Molto bene, grazie.", "en": "Very well, thank you." },
        { "it": "Abbastanza bene, grazie.", "en": "Quite well, thank you." },
        { "it": "Va bene, grazie.", "en": "I'm fine, thank you." },
        { "it": "Non c'è male, grazie.", "en": "Not bad, thank you." },
        { "it": "Così così. / Insomma.", "en": "So-so." },
        { "it": "Non mi lamento, grazie.", "en": "I can't complain, thank you." },
        { "it": "Si vive, grazie.", "en": "Surviving, thanks." }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Introducing someone: formal vs informal",
      "description": "Italian uses different introduction formulas depending on the level of formality.",
      "examples": [
        { "context": "informal", "it": "Ti presento Mario.", "en": "Let me introduce Mario to you." },
        { "context": "informal", "it": "Lui/Questo è Mario.", "en": "He/This is Mario." },
        { "context": "informal", "it": "Lei/Questa è Maria.", "en": "She/This is Maria." },
        { "context": "formal", "it": "Le presento il signor Bianchi.", "en": "Let me introduce Mr. Bianchi to you." },
        { "context": "formal", "it": "Lei/Questa è la signora Bianchi.", "en": "She/This is Mrs. Bianchi." }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Reacting to an introduction",
      "description": "Typical polite formulas used after being introduced to someone.",
      "examples": [
        { "it": "Piacere di conoscerti.", "en": "Nice to meet you. (informal)" },
        { "it": "Piacere di conoscerla.", "en": "Nice to meet you. (formal)" },
        { "it": "Molto lieto/a.", "en": "Very pleased." },
        { "it": "Piacere.", "en": "Pleasure." },
        { "it": "Piacere mio.", "en": "The pleasure is mine." },
        { "it": "Altrettanto.", "en": "Likewise." }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Pronunciation of 'sc'",
      "description": "The sound of 'sc' changes depending on the letters that follow it.",
      "sub_rules": [
        {
          "pattern": "sc + a, o, u, consonant",
          "sound": "[sk]",
          "examples": [
            { "it": "scarpe", "en": "shoes" },
