  "language_rules": [
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Agreeing with someone",
        "ru": "Как выразить согласие"
      },
      "description": {
        "en": "Italian has short expressions for showing agreement or partial agreement in conversation.",
        "ru": "В разговоре по-итальянски есть короткие формулы, чтобы показать согласие или частичное согласие."
      },
      "examples": [
        {
          "it": "Hai ragione.",
          "en": "You are right.",
          "ru": "Ты прав / права."
        },
        {
          "it": "Sono d'accordo.",
          "en": "I agree.",
          "ru": "Я согласен / согласна."
        },
        {
          "it": "È vero.",
          "en": "It's true.",
          "ru": "Это правда."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Expressing doubt or asking for clarification",
        "ru": "Как выразить сомнение и попросить пояснение"
      },
      "description": {
        "en": "When something is unclear, Italian often uses short formulas to ask for repetition, explanation, or confirmation.",
        "ru": "Если что-то непонятно, часто используются короткие формулы для просьбы повторить, объяснить или уточнить."
      },
      "examples": [
        {
          "it": "Perché?",
          "en": "Why?",
          "ru": "Почему?"
        },
        {
          "it": "Che vuoi dire?",
          "en": "What do you mean?",
          "ru": "Что ты имеешь в виду?"
        },
        {
          "it": "Non ho capito.",
          "en": "I didn't understand.",
          "ru": "Я не понял / не поняла."
        },
        {
          "it": "Puoi ripetere, per favore?",
          "en": "Can you repeat, please?",
          "ru": "Можешь повторить, пожалуйста?"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Indefinite article review in connected text",
        "ru": "Повторение неопределённого артикля в связном тексте"
      },
      "description": {
        "en": "The lesson revises the indefinite article inside longer sentences and short mystery-style descriptions.",
        "ru": "В уроке снова отрабатывается неопределённый артикль внутри более длинных фраз и описаний в стиле загадки."
      },
      "examples": [
        {
          "it": "Anna ha un'amica di Parigi.",
          "en": "Anna has a friend from Paris.",
          "ru": "У Анны есть подруга из Парижа."
        },
        {
          "it": "Lo spagnolo usa un articolo.",
          "en": "Spanish uses an article.",
          "ru": "В испанском используется артикль."
        },
        {
          "it": "Perché in abito parlo l'italiano Italia.",
          "en": "Because in the sentence I use the article with Italian and Italy.",
          "ru": "Потому что в этом предложении я использую артикль с итальянским и Италией."
        }
      ]
    },
    {
      "category": {
        "en": "Listening",
        "ru": "Аудирование"
      },
      "rule": {
        "en": "Understanding a short mystery conversation",
        "ru": "Понимание короткого разговора-загадки"
      },
      "description": {
        "en": "The listening task focuses on following a simple conversation about a suspicious situation and identifying what happened.",
        "ru": "Задание на аудирование тренирует понимание простого разговора о подозрительной ситуации и поиск того, что произошло."
      },
      "examples": [
        {
          "it": "Bruno chiede informazioni sui vicini di casa di Anna.",
          "en": "Bruno asks for information about Anna's neighbours.",
          "ru": "Бруно спрашивает о соседях Анны."
        },
        {
          "it": "Il signor Ferrari non è mai in casa.",
          "en": "Mr Ferrari is never at home.",
          "ru": "Синьор Феррари никогда не бывает дома."
        },
        {
          "it": "Tutti i pacchi arrivano dalla Svizzera.",
          "en": "All the packages arrive from Switzerland.",
          "ru": "Все посылки приходят из Швейцарии."
        }
      ]
    },
