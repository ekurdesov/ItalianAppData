  "dialogues": [
    {
      "id": "D-A1L3-5-01",
      "title": "Il mistero",
      "register": "neutral",
      "context": {
        "en": "Bruno and Anna discuss strange things happening in the building.",
        "ru": "Бруно и Анна обсуждают странные события в доме.",
        "es": "Bruno y Anna hablan sobre cosas extrañas que suceden en el edificio."
      },
      "turns": [
        {
          "speaker": "Bruno",
          "it": "Il signor Ferrari non è mai in casa. Tutti i pacchi arrivano dalla Svizzera.",
          "en": "Mr Ferrari is never at home. All the packages arrive from Switzerland.",
          "ru": "Синьор Феррари никогда не бывает дома. Все посылки приходят из Швейцарии.",
          "es": "El señor Ferrari nunca está en casa. Todos los paquetes llegan desde Suiza."
        },
        {
          "speaker": "Anna",
          "it": "Hai ragione... è strano. Ma forse c'è una spiegazione.",
          "en": "You're right... it's strange. But maybe there is an explanation.",
          "ru": "Ты прав... это странно. Но, возможно, этому есть объяснение.",
          "es": "Tienes razón... es extraño. Pero tal vez haya una explicación."
        },
        {
          "speaker": "Bruno",
          "it": "Che vuoi dire?",
          "en": "What do you mean?",
          "ru": "Что ты имеешь в виду?",
          "es": "¿Qué quieres decir?"
        },
        {
          "speaker": "Anna",
          "it": "Forse è un medico o un ingegnere e lavora fuori città.",
          "en": "Maybe he is a doctor or an engineer and works outside the city.",
          "ru": "Может быть, он врач или инженер и работает за пределами города.",
          "es": "Quizás sea médico o ingeniero y trabaje fuera de la ciudad."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Say that you agree",
            "ru": "Сказать, что вы согласны",
            "es": "Di que estás de acuerdo"
          },
          "expected_it": "Sono d'accordo."
        },
        {
          "cue": {
            "en": "Ask for an explanation",
            "ru": "Попросить объяснение",
            "es": "Pide una explicación"
          },
          "expected_it": "Che vuoi dire?"
        }
      ]
    }
  ],
