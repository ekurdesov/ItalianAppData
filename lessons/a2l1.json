        "Communicative activity: Where are you from?",
        "Phonetics: letter S"
      ],
      "ru": [
        "Аудирование: класс Карлы",
        "Прилагательные национальности",
        "Коммуникативное задание: di dove sei?",
        "Фонетика: буква S"
      ],
      "es": [
        "Comprensión auditiva: la clase de Carla",
        "Adjetivos de nacionalidad",
        "Actividad comunicativa: ¿De dónde eres?",
        "Fonética: letra S"
      ]
    }
