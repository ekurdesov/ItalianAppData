{
  "lesson_info": {
    "id": "A1-L2-1",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": {
      "it": [
        "Comprensione orale: La classe di Carla",
        "Aggettivi di nazionalità",
        "Attività comunicativa: Di dove sei?",
        "Fonetica: lettera S"
      ],
      "en": [
        "Listening comprehension: Carla's class",
        "Nationality adjectives",
        "Communicative activity: Where are you from?",
        "Phonetics: letter S"
      ],
      "ru": [
        "Аудирование: класс Карлы",
        "Прилагательные национальности",
        "Коммуникативное задание: di dove sei?",
        "Фонетика: буква S"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Asking and stating origin",
        "ru": "Вопрос о происхождении и ответ на него"
      },
      "description": {
        "en": "Italian distinguishes informal 'tu' and formal 'Lei' when asking where someone is from.",
        "ru": "Итальянский язык различает неформальную форму 'tu' и официальную 'Lei' при вопросе о том, откуда человек."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Di dove sei?",
          "en": "Where are you from?",
          "ru": "Откуда ты?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "en": "And you?",
          "ru": "А ты?"
        },
        {
          "context": "formal",
          "it": "Di dov'è?",
          "en": "Where are you from? (formal)",
          "ru": "Откуда вы? (формально)"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "en": "And you? (formal)",
          "ru": "А вы? (формально)"
        },
        {
          "context": "answer",
          "it": "Sono di Milano.",
          "en": "I am from Milan.",
          "ru": "Я из Милана."
        },
        {
          "context": "answer",
          "it": "Sono italiano.",
          "en": "I am Italian.",
          "ru": "Я итальянец."
        },
        {
          "context": "answer",
          "it": "Sono italiano, di Milano.",
          "en": "I am Italian, from Milan.",
          "ru": "Я итальянец, из Милана."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Nationality adjectives agree in gender",
        "ru": "Прилагательные национальности согласуются по роду"
      },
      "description": {
        "en": "Nationality adjectives change endings to agree with masculine or feminine nouns.",
        "ru": "Прилагательные национальности меняют окончания в соответствии с родом существительного — мужским или женским."
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Origin from cities uses 'di'",
        "ru": "Происхождение из города с предлогом 'di'"
      },
      "description": {
        "en": "To say where someone is from, Italian commonly uses 'essere di' plus a city or place.",
        "ru": "Для указания на то, откуда кто-то, в итальянском языке обычно используется 'essere di' с названием города или места."
      },
      "examples": [
        {
          "it": "Juan è di Madrid.",
          "en": "Juan is from Madrid.",
          "ru": "Хуан из Мадрида."
        },
        {
          "it": "John è di New York.",
          "en": "John is from New York.",
          "ru": "Джон из Нью-Йорка."
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Letter S can be voiced or voiceless",
        "ru": "Буква S может быть звонкой или глухой"
      },
      "description": {
        "en": "Italian 's' may be pronounced as [z] or [s] depending on the word.",
        "ru": "Итальянская 's' может произноситься как [z] или [s] в зависимости от слова."
      }
    }
  ],
