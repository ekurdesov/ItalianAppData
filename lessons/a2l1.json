  "dialogues": [
    {
      "id": "D-A1L2-1-01",
      "title": "Di dove sei? (informal)",
      "register": "informal",
      "context": {
        "en": "Two students in an Italian class exchange origins",
        "ru": "Двое студентов на уроке итальянского рассказывают друг другу о своём происхождении"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao! Mi chiamo Antonio. E tu?",
          "en": "Hi! My name is Antonio. And you?",
          "ru": "Привет! Меня зовут Антонио. А тебя?"
        },
        {
          "speaker": "B",
          "it": "Io sono Yuki. Piacere!",
          "en": "I am Yuki. Pleased to meet you!",
          "ru": "Я Юки. Приятно познакомиться!"
        },
        {
          "speaker": "A",
          "it": "Di dove sei, Yuki?",
          "en": "Where are you from, Yuki?",
          "ru": "Откуда ты, Юки?"
        },
        {
          "speaker": "B",
          "it": "Sono giapponese, di Tokyo. E tu?",
          "en": "I am Japanese, from Tokyo. And you?",
          "ru": "Я японка, из Токио. А ты?"
        },
        {
          "speaker": "A",
          "it": "Sono di Pechino. Sono cinese.",
          "en": "I am from Beijing. I am Chinese.",
          "ru": "Я из Пекина. Я китаец."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask where someone is from (informal)",
            "ru": "Спросите, откуда человек (неформально)"
          },
          "expected_it": "Di dove sei?"
        },
        {
          "cue": {
            "en": "Say your nationality and city of origin",
            "ru": "Назовите свою национальность и город происхождения"
          },
          "expected_it": "Sono [nazionalità], di [città]."
        },
        {
          "cue": {
            "en": "Ask back (informal)",
            "ru": "Спросите в ответ (неформально)"
          },
          "expected_it": "E tu?"
        }
      ]
    },
    {
      "id": "D-A1L2-1-02",
      "title": "Di dov'è? (formal)",
      "register": "formal",
      "context": {
        "en": "A formal exchange about nationality at a professional event",
        "ru": "Официальный разговор о национальности на профессиональном мероприятии"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno. Lei è straniero?",
          "en": "Good morning. Are you a foreigner?",
          "ru": "Доброе утро. Вы иностранец?"
        },
        {
          "speaker": "B",
          "it": "Sì, sono americano, di New York. E Lei?",
          "en": "Yes, I am American, from New York. And you?",
          "ru": "Да, я американец, из Нью-Йорка. А вы?"
        },
        {
          "speaker": "A",
          "it": "Sono italiano, di Roma.",
          "en": "I am Italian, from Rome.",
          "ru": "Я итальянец, из Рима."
        },
        {
          "speaker": "B",
          "it": "Roma! È una città bellissima!",
          "en": "Rome! It is a beautiful city!",
          "ru": "Рим! Это прекрасный город!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask where someone is from (formal)",
            "ru": "Спросите, откуда человек (официально)"
          },
          "expected_it": "Di dov'è?"
        },
        {
          "cue": {
            "en": "Say you are American from New York",
            "ru": "Скажите, что вы американец / американка из Нью-Йорка"
          },
          "expected_it": "Sono americano/a, di New York."
        },
        {
          "cue": {
            "en": "Ask back (formal)",
            "ru": "Спросите в ответ (официально)"
          },
          "expected_it": "E Lei?"
