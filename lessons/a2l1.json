  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Asking and stating origin",
        "ru": "Вопрос о происхождении и ответ на него",
        "es": "Preguntar y declarar origen"
      },
      "description": {
        "en": "Italian distinguishes informal 'tu' and formal 'Lei' when asking where someone is from.",
        "ru": "Итальянский язык различает неформальную форму 'tu' и официальную 'Lei' при вопросе о том, откуда человек.",
        "es": "El italiano distingue el 'tu' informal y el 'Lei' formal cuando se pregunta de dónde es alguien."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Di dove sei?",
          "en": "Where are you from?",
          "ru": "Откуда ты?",
          "es": "¿De dónde eres?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "en": "And you?",
          "ru": "А ты?",
          "es": "¿Y tú?"
        },
        {
          "context": "formal",
          "it": "Di dov'è?",
          "en": "Where are you from? (formal)",
          "ru": "Откуда вы? (формально)",
          "es": "¿De dónde eres? (formal)"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "en": "And you? (formal)",
          "ru": "А вы? (формально)",
          "es": "¿Y tú? (formal)"
        },
        {
          "context": "answer",
          "it": "Sono di Milano.",
          "en": "I am from Milan.",
          "ru": "Я из Милана.",
          "es": "Soy de Milán."
        },
        {
          "context": "answer",
          "it": "Sono italiano.",
          "en": "I am Italian.",
          "ru": "Я итальянец.",
          "es": "Soy italiano."
        },
        {
          "context": "answer",
          "it": "Sono italiano, di Milano.",
          "en": "I am Italian, from Milan.",
          "ru": "Я итальянец, из Милана.",
          "es": "Soy italiana, de Milán."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Nationality adjectives agree in gender",
        "ru": "Прилагательные национальности согласуются по роду",
        "es": "Los adjetivos de nacionalidad concuerdan en género."
      },
      "description": {
        "en": "Nationality adjectives change endings to agree with masculine or feminine nouns.",
        "ru": "Прилагательные национальности меняют окончания в соответствии с родом существительного — мужским или женским.",
        "es": "Los adjetivos de nacionalidad cambian las terminaciones para coincidir con los sustantivos masculinos o femeninos."
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Origin from cities uses 'di'",
        "ru": "Происхождение из города с предлогом 'di'",
        "es": "El origen de las ciudades usa 'di'"
      },
      "description": {
        "en": "To say where someone is from, Italian commonly uses 'essere di' plus a city or place.",
        "ru": "Для указания на то, откуда кто-то, в итальянском языке обычно используется 'essere di' с названием города или места.",
        "es": "Para decir de dónde es alguien, el italiano suele utilizar \"essere di\" más una ciudad o lugar."
      },
      "examples": [
        {
          "it": "Juan è di Madrid.",
          "en": "Juan is from Madrid.",
          "ru": "Хуан из Мадрида.",
          "es": "Juan es de Madrid."
        },
        {
          "it": "John è di New York.",
          "en": "John is from New York.",
          "ru": "Джон из Нью-Йорка.",
          "es": "John es de Nueva York."
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика",
        "es": "Fonética"
      },
      "rule": {
        "en": "Letter S can be voiced or voiceless",
        "ru": "Буква S может быть звонкой или глухой",
        "es": "La letra S puede ser sonora o sorda."
      },
      "description": {
        "en": "Italian 's' may be pronounced as [z] or [s] depending on the word.",
        "ru": "Итальянская 's' может произноситься как [z] или [s] в зависимости от слова.",
        "es": "La 's' italiana puede pronunciarse como [z] o [s] dependiendo de la palabra."
      }
    }
  ],
