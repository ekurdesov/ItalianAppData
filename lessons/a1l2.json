      "rule": {
        "en": "Present tense of stare",
        "ru": "Настоящее время глагола stare",
        "es": "Tiempo presente de mirar fijamente."
      },
      "description": {
        "en": "The verb 'stare' is used to ask and say how someone is, and in some contexts to indicate a state or location.",
        "ru": "Глагол «stare» используется для того, чтобы спросить и рассказать о самочувствии, а в некоторых контекстах — для обозначения состояния или местонахождения.",
        "es": "El verbo 'mirar' se usa para preguntar y decir cómo está alguien y, en algunos contextos, para indicar un estado o ubicación."
      },
      "conjugations": {
        "io": "sto",
        "tu": "stai",
        "lui/lei/Lei": "sta",
        "noi": "stiamo",
        "voi": "state",
        "loro": "stanno"
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Asking how someone is: formal vs informal",
        "ru": "Вопрос о самочувствии: официальный и разговорный стиль",
        "es": "Preguntar cómo es alguien: formal versus informal"
      },
      "description": {
        "en": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking how someone is.",
        "ru": "В итальянском языке различаются разговорная форма «tu» и официальная «Lei» при вопросе о самочувствии.",
        "es": "El italiano distingue entre 'tu' informal y 'Lei' formal cuando se pregunta cómo está alguien."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come stai?",
          "en": "How are you?",
          "ru": "Как дела?",
          "es": "¿Cómo estás?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "en": "And you?",
          "ru": "А ты?",
          "es": "¿Y tú?"
        },
        {
          "context": "formal",
          "it": "Come sta?",
          "en": "How are you?",
          "ru": "Как дела? (официально)",
          "es": "¿Cómo estás?"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "en": "And you?",
          "ru": "А Вы?",
          "es": "¿Y tú?"
        },
        {
          "context": "neutral",
          "it": "Come va?",
          "en": "How is it going?",
          "ru": "Как поживаете? / Как дела?",
          "es": "¿Cómo está yendo?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Common responses to 'Come stai?' / 'Come va?'",
        "ru": "Типичные ответы на «Come stai?» / «Come va?»",
        "es": "Respuestas comunes a '¿Come stai?' / '¿Vamos?'"
      },
      "description": {
        "en": "There are several fixed expressions for answering questions about well-being.",
