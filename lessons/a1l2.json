          "it": "Ciao, come stai?",
          "en": "Hi, how are you?",
          "ru": "Привет, как дела?",
          "es": "¿Hola, cómo estás?"
        },
        {
          "speaker": "B",
          "it": "Bene, grazie, e tu?",
          "en": "Good, thanks, and you?",
          "ru": "Хорошо, спасибо, а ты?",
          "es": "Bueno, gracias y tu?"
        },
        {
          "speaker": "A",
          "it": "Insomma.",
          "en": "So-so.",
          "ru": "Так себе.",
          "es": "Más o menos."
        },
        {
          "speaker": "B",
          "it": "Buona notte!",
          "en": "Good night!",
          "ru": "Спокойной ночи!",
          "es": "¡Buenas noches!"
        },
        {
          "speaker": "A",
          "it": "Buona notte a tutti!",
          "en": "Good night everyone!",
          "ru": "Спокойной ночи всем!",
          "es": "¡Buenas noches a todos!"
        }
      ],
