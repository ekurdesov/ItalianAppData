      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, mi chiamo Anna.",
          "en": "Hi, my name is Anna.",
          "ru": "Привет, меня зовут Анна.",
          "es": "Hola, mi nombre es Ana."
        },
        {
          "speaker": "B",
          "it": "Ciao, Anna! Mi chiamo Luca. Buona lezione!",
          "en": "Hi, Anna! My name is Luca. Have a good lesson!",
          "ru": "Привет, Анна! Меня зовут Лука. Хорошего урока!",
          "es": "Hola Ana! Mi nombre es Lucas. ¡Que tengas una buena lección!"
        },
        {
          "speaker": "A",
          "it": "Grazie, Luca. Buona lezione anche a te!",
          "en": "Thanks, Luca. Have a good lesson too!",
          "ru": "Спасибо, Лука. И тебе хорошего урока!",
          "es": "Gracias, luca. ¡Que tengas una buena lección también!"
