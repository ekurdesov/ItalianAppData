  "dialogues": [
    {
      "id": "D-A1L1-5-01",
      "title": "Buona lezione!",
      "register": "informal",
      "context": {
        "en": "Two students greet each other at the start of an Italian class",
        "ru": "Двое студентов приветствуют друг друга в начале урока итальянского"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, mi chiamo Anna.",
          "en": "Hi, my name is Anna.",
