        {
          "speaker": "A",
          "it": "Sì, buona idea.",
          "en": "Yes, good idea.",
          "ru": "Да, хорошая идея.",
          "es": "Sí, buena idea."
        },
        {
          "speaker": "B",
          "it": "Allora ci vediamo alle cinque.",
          "en": "Then see you at five.",
          "ru": "Тогда увидимся в пять.",
          "es": "Entonces nos vemos a las cinco."
        },
        {
          "speaker": "A",
          "it": "D'accordo.",
          "en": "Agreed.",
          "ru": "Договорились.",
          "es": "Acordado."
        },
        {
          "speaker": "B",
          "it": "A dopo, Stefano.",
          "en": "See you later, Stefano.",
          "ru": "До встречи, Стефано.",
          "es": "Hasta luego, Stefano."
        }
      ]
