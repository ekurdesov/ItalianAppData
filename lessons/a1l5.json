        "ru": "Два студента становятся партнёрами по заданию и распределяют работу.",
        "es": "Dos estudiantes se convierten en compañeros para una tarea de clase y dividen el trabajo."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, sei la mia compagna di gruppo?",
          "en": "Hi, are you my group partner?",
          "ru": "Привет, ты моя напарница?",
          "es": "Hola, ¿eres mi compañero de grupo?"
        },
        {
          "speaker": "B",
          "it": "Sì, credo di sì. Mi chiamo Carla.",
          "en": "Yes, I think so. My name is Carla.",
