    {
      "id": "D-A1L1-5-02",
      "title": "Sei la mia collega?",
      "register": "informal",
      "context": {
        "en": "Two students in an Italian course introduce themselves and establish their role",
        "ru": "Двое студентов на курсе итальянского знакомятся и выясняют свою роль",
        "es": "Dos estudiantes de un curso de italiano se presentan y establecen su rol"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, come ti chiami?",
          "en": "Hi, what's your name?",
          "ru": "Привет, как тебя зовут?",
          "es": "Hola, ¿cómo te llamas?"
        },
        {
          "speaker": "B",
          "it": "Mi chiamo Carla. E tu?",
          "en": "My name is Carla. And you?",
          "ru": "Меня зовут Карла. А тебя?",
          "es": "Mi nombre es Carla. ¿Y tú?"
        },
        {
          "speaker": "A",
          "it": "Mi chiamo Stefano. Piacere. Tu sei studentessa d'italiano?",
          "en": "My name is Stefano. Pleased to meet you. Are you a student of Italian?",
          "ru": "Меня зовут Стефано. Приятно познакомиться. Ты студентка итальянского?",
          "es": "Mi nombre es Stefano. Encantado de conocerte. ¿Eres estudiante de italiano?"
        },
        {
          "speaker": "B",
          "it": "Sì, e tu sei il mio compagno di gruppo?",
          "en": "Yes, and are you my groupmate?",
          "ru": "Да, а ты мой одногруппник?",
          "es": "Sí, ¿y eres mi compañero de grupo?"
        },
        {
          "speaker": "A",
          "it": "Sì. Piacere di conoscerti!",
          "en": "Yes. Nice to meet you!",
          "ru": "Да. Приятно познакомиться!",
          "es": "Sí. ¡Encantado de conocerlo!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask if someone is a student of Italian (informal)",
            "ru": "Спросите, является ли кто-то студентом итальянского (неформально)",
            "es": "Preguntar si alguien es estudiante de italiano (informal)"
          },
          "expected_it": "Tu sei studente/studentessa d'italiano?"
        },
        {
          "cue": {
            "en": "Ask if they are your groupmate",
            "ru": "Спросите, является ли собеседник вашим одногруппником",
            "es": "Pregúntale si es tu compañero de grupo."
          },
          "expected_it": "Tu sei il mio compagno/la mia compagna di gruppo?"
        },
        {
          "cue": {
            "en": "Express pleasure at meeting them (informal)",
            "ru": "Выразите радость от знакомства (неформально)",
            "es": "Expresar placer al conocerlos (informal)"
          },
          "expected_it": "Piacere di conoscerti!"
        }
      ]
    },
    {
      "id": "D-A1L1-5-03",
      "title": "Compagni di gruppo",
      "register": "informal",
      "context": {
