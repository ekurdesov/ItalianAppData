  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Affirmative, interrogative, and negative sentences",
        "ru": "Утвердительные, вопросительные и отрицательные предложения",
        "es": "Oraciones afirmativas, interrogativas y negativas."
      },
      "description": {
        "en": "In Italian, the interrogative sentence keeps the same word order as the affirmative sentence but uses rising intonation. Negative sentences are formed by placing 'non' before the verb.",
        "ru": "В итальянском языке вопросительное предложение сохраняет тот же порядок слов, что и утвердительное, но произносится с восходящей интонацией. Отрицательные предложения образуются путём постановки 'non' перед глаголом.",
        "es": "En italiano, la oración interrogativa mantiene el mismo orden de palabras que la oración afirmativa pero usa entonación ascendente. Las oraciones negativas se forman colocando \"non\" antes del verbo."
      },
      "examples": [
        {
          "it": "Lui è italiano.",
          "en": "He is Italian.",
          "ru": "Он итальянец.",
          "es": "El es italiano."
        },
        {
          "it": "Lui è italiano?",
          "en": "Is he Italian?",
          "ru": "Он итальянец?",
          "es": "¿Es italiano?"
        },
        {
          "it": "Lui non è italiano.",
          "en": "He is not Italian.",
          "ru": "Он не итальянец.",
          "es": "Él no es italiano."
        },
        {
          "it": "Sì. / No, lui non è italiano.",
          "en": "Yes. / No, he is not Italian.",
          "ru": "Да. / Нет, он не итальянец.",
          "es": "Sí. / No, no es italiano."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Noun gender by ending",
        "ru": "Род существительного по окончанию",
        "es": "Género sustantivo por terminación"
      },
      "description": {
        "en": "Italian nouns often indicate gender through their final vowel.",
        "ru": "В итальянском языке существительные часто указывают на род через последнюю гласную.",
        "es": "Los sustantivos italianos suelen indicar el género mediante su vocal final."
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Noun gender by common suffix",
        "ru": "Род существительного по типичным суффиксам",
        "es": "Género sustantivo por sufijo común"
      },
      "description": {
        "en": "Some noun endings strongly predict grammatical gender.",
        "ru": "Некоторые суффиксы существительных позволяют уверенно определить грамматический род.",
        "es": "Algunas terminaciones de sustantivos predicen fuertemente el género gramatical."
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Introducing yourself and asking names",
        "ru": "Знакомство и вопрос об имени",
        "es": "Presentarse y preguntar nombres"
      },
      "description": {
        "en": "Italian uses informal 'tu' and formal 'Lei' forms for introductions.",
        "ru": "В итальянском языке для знакомства используются неформальная форма 'tu' и формальная 'Lei'.",
        "es": "El italiano utiliza formas informales 'tu' y formales 'Lei' para las presentaciones."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "en": "What is your name?",
          "ru": "Как тебя зовут?",
          "es": "¿Cómo te llamas?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "en": "What is your name? (formal)",
          "ru": "Как вас зовут? (формально)",
          "es": "¿Cómo te llamas? (formal)"
        },
        {
          "context": "statement",
          "it": "Mi chiamo Paolo.",
          "en": "My name is Paolo.",
          "ru": "Меня зовут Паоло.",
          "es": "Mi nombre es Pablo."
        },
        {
          "context": "statement",
          "it": "Il mio nome è...",
          "en": "My name is...",
          "ru": "Моё имя — ...",
          "es": "Mi nombre es..."
        },
        {
          "context": "statement",
          "it": "Il mio cognome è...",
          "en": "My surname is...",
          "ru": "Моя фамилия — ...",
          "es": "Mi apellido es..."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Talking about classmates and colleagues",
