    "title": "I vicini di casa",
    "level": "A1",
    "objectives": {
      "it": [
        "Ripasso lessico: Parole, parole...",
        "Ripasso grammatica: A lezione",
        "Ripasso fonetica: Che confusione!",
        "Ripasso lezioni 1-3: In giro per Roma"
      ],
      "en": [
        "Vocabulary review: Words, words...",
        "Grammar review: In class",
        "Phonetics review: What a mess!",
        "Review of lessons 1-3: Around Rome"
      ],
      "ru": [
        "Повторение лексики: Parole, parole...",
        "Повторение грамматики: A lezione",
        "Повторение фонетики: Che confusione!",
        "Повторение уроков 1-3: In giro per Roma"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Review: question words",
        "ru": "Повторение: вопросительные слова"
      },
      "description": {
        "en": "Consolidation of all question words covered in lessons 1–3.",
        "ru": "Закрепление всех вопросительных слов, изученных в уроках 1–3."
      },
      "examples": [
        {
          "it": "Dove abiti? — Abito a Roma.",
          "en": "Where do you live? — I live in Rome.",
          "ru": "Где ты живёшь? — Я живу в Риме."
        },
        {
          "it": "Come ti chiami? — Mi chiamo Francesco.",
          "en": "What is your name? — My name is Francesco.",
          "ru": "Как тебя зовут? — Меня зовут Франческо."
        },
        {
          "it": "Perché studi l'italiano? — Perché è una lingua bellissima.",
          "en": "Why do you study Italian? — Because it is a beautiful language.",
          "ru": "Почему ты изучаешь итальянский? — Потому что это очень красивый язык."
        },
        {
          "it": "Che lingue parli? — Parlo inglese, russo e italiano.",
          "en": "What languages do you speak? — I speak English, Russian and Italian.",
          "ru": "На каких языках ты говоришь? — Я говорю по-английски, по-русски и по-итальянски."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Review: essere, avere, c'è/ci sono",
        "ru": "Повторение: essere, avere, c'è/ci sono"
      },
      "description": {
        "en": "Revision of the three core structures: essere for identity/description, avere for possession/age, c'è/ci sono for existence.",
        "ru": "Повторение трёх ключевых конструкций: essere для идентификации/описания, avere для обладания/возраста, c'è/ci sono для существования."
      },
      "examples": [
        {
          "it": "Ha 23 anni.",
          "en": "He/She is 23 years old.",
          "ru": "Ему/ей 23 года."
        },
        {
          "it": "Sono italiano.",
          "en": "I am Italian.",
          "ru": "Я итальянец."
        },
        {
          "it": "C'è un libro sul tavolo.",
          "en": "There is a book on the table.",
          "ru": "На столе лежит книга."
        },
        {
          "it": "Ci sono molti studenti in classe.",
          "en": "There are many students in class.",
          "ru": "В классе много студентов."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Vocabulary categories: school, nationalities, descriptions",
        "ru": "Тематические группы: школа, национальности, описания"
      },
      "description": {
        "en": "Review of three vocabulary groups: school-related words, nationality adjectives, and physical/personality descriptions.",
        "ru": "Повторение трёх лексических групп: слова, связанные со школой, прилагательные национальности, описание внешности и характера."
      },
      "examples": [
        {
          "it": "la classe, il banco, la lavagna, il quaderno",
          "en": "classroom, desk, blackboard, notebook",
          "ru": "класс, парта, доска, тетрадь"
        },
        {
          "it": "italiano, tedesco, francese, russo, cinese",
          "en": "Italian, German, French, Russian, Chinese",
          "ru": "итальянский, немецкий, французский, русский, китайский"
        },
        {
          "it": "alto, magro, biondo, simpatico",
          "en": "tall, thin, blond, nice",
          "ru": "высокий, худой, светловолосый, симпатичный"
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Elision: com'è, dov'è, quant'è vs qual è",
        "ru": "Элизия: com'è, dov'è, quant'è vs qual è"
      },
      "description": {
        "en": "Some Italian question words drop the final vowel before 'è' (elision), but 'qual' never takes an apostrophe before 'è'.",
        "ru": "Некоторые вопросительные слова теряют конечную гласную перед «è» (элизия), но «qual» никогда не пишется с апострофом перед «è»."
      },
      "examples": [
        {
          "it": "Com'è? (come + è)",
          "en": "What is it like?",
          "ru": "Какой он/она/оно?"
        },
        {
          "it": "Dov'è? (dove + è)",
          "en": "Where is it?",
          "ru": "Где это?"
        },
        {
          "it": "Quant'è? (quanto + è)",
          "en": "How much is it?",
          "ru": "Сколько стоит?"
        },
        {
          "it": "Qual è? (no apostrophe)",
          "en": "Which is? / What is?",
          "ru": "Какой? / Что это?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Talking about plans and preferences",
        "ru": "Планы и предпочтения"
      },
      "description": {
        "en": "Expressing what you plan to do or prefer using 'penso di + infinitive' and 'preferisco + infinitive'.",
        "ru": "Выражение планов и предпочтений с помощью «penso di + инфинитив» и «preferisco + инфинитив»."
      },
      "examples": [
        {
          "it": "Penso di dormire molto nel week-end.",
          "en": "I plan to sleep a lot at the weekend.",
          "ru": "Я планирую много спать на выходных."
        },
        {
          "it": "Una serata rilassante per me è…",
          "en": "A relaxing evening for me is…",
          "ru": "Расслабляющий вечер для меня — это…"
        },
        {
          "it": "Avete cose in comune?",
          "en": "Do you have things in common?",
          "ru": "У вас есть что-то общее?"
        }
      ]
    }
  ],
