  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Noun gender by common endings",
        "ru": "Род существительного по типичным окончаниям"
      },
      "description": {
        "en": "Some Italian noun endings strongly suggest grammatical gender.",
        "ru": "Некоторые окончания итальянских существительных уверенно указывают на грамматический род."
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Noun pluralization",
        "ru": "Образование множественного числа существительных"
      },
      "description": {
        "en": "Italian nouns usually change their final vowel in the plural.",
        "ru": "Итальянские существительные, как правило, меняют последнюю гласную во множественном числе."
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Adjectives in -o agree in gender and number",
        "ru": "Прилагательные на -o согласуются по роду и числу"
      },
      "description": {
        "en": "Adjectives ending in -o change to match the noun: masculine singular -o, feminine singular -a, masculine plural -i, feminine plural -e.",
        "ru": "Прилагательные, оканчивающиеся на -o, изменяются в соответствии с существительным: мужской род единственного числа -o, женский род единственного числа -a, мужской род множественного числа -i, женский род множественного числа -e."
      },
      "examples": [
        {
          "it": "un bambino piccolo",
          "en": "a small boy",
          "ru": "маленький мальчик"
        },
        {
          "it": "una ragazza educata",
          "en": "a polite girl",
          "ru": "воспитанная девочка"
        },
        {
          "it": "due ragazzi educati",
          "en": "two polite boys",
          "ru": "двое воспитанных мальчиков"
        },
        {
          "it": "due ragazze carine",
          "en": "two pretty girls",
          "ru": "две симпатичные девочки"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Present tense of essere",
        "ru": "Настоящее время глагола essere"
      },
      "description": {
        "en": "Used for identity and descriptions.",
        "ru": "Используется для выражения идентичности и описания."
      },
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Present tense of chiamarsi",
        "ru": "Настоящее время глагола chiamarsi"
      },
      "description": {
        "en": "Used to ask and say names.",
        "ru": "Используется для вопроса об имени и представления."
      },
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Introducing yourself and asking names",
        "ru": "Знакомство и вопрос об имени"
      },
      "description": {
        "en": "Italian uses different forms for informal (tu) and formal (Lei) introductions.",
        "ru": "В итальянском языке используются разные формы для неформального (tu) и официального (Lei) знакомства."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "en": "What is your name?",
          "ru": "Как тебя зовут?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "en": "What is your name?",
          "ru": "Как вас зовут?"
        },
        {
          "context": "statement",
          "it": "Mi chiamo Paolo.",
          "en": "My name is Paolo.",
          "ru": "Меня зовут Паоло."
        },
        {
          "context": "statement",
          "it": "Il mio cognome è...",
          "en": "My surname is...",
          "ru": "Моя фамилия..."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
