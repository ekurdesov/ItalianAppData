  "dialogues": [
    {
      "id": "D-A1L1-6-01",
      "title": "Quanti anni hai?",
      "register": "informal",
      "context": {
        "en": "Two people meet, greet each other and exchange basic personal information including age.",
        "ru": "Двое людей встречаются, приветствуют друг друга и обмениваются основной личной информацией, включая возраст."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno! Come ti chiami?",
          "en": "Good morning! What is your name?",
          "ru": "Доброе утро! Как тебя зовут?"
        },
        {
          "speaker": "B",
          "it": "Mi chiamo Elena. E tu?",
          "en": "My name is Elena. And you?",
          "ru": "Меня зовут Елена. А тебя?"
        },
        {
          "speaker": "A",
          "it": "Sono Pietro. Quanti anni hai?",
          "en": "I am Pietro. How old are you?",
          "ru": "Я Пьетро. Сколько тебе лет?"
        },
        {
          "speaker": "B",
          "it": "Ho ventidue anni. E tu?",
          "en": "I am twenty-two. And you?",
          "ru": "Мне двадцать два года. А тебе?"
        },
        {
          "speaker": "A",
          "it": "Ho ventotto anni. Sei italiana?",
          "en": "I am twenty-eight. Are you Italian?",
          "ru": "Мне двадцать восемь. Ты итальянка?"
        },
        {
          "speaker": "B",
          "it": "Sì, sono italiana, di Napoli.",
          "en": "Yes, I am Italian, from Naples.",
          "ru": "Да, я итальянка, из Неаполя."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask someone's age",
            "ru": "Спросить возраст"
          },
          "expected_it": "Quanti anni hai?"
        },
        {
          "cue": {
            "en": "Say your age",
            "ru": "Назвать свой возраст"
          },
          "expected_it": "Ho … anni."
        },
