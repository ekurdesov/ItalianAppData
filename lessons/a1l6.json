    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Present tense of chiamarsi",
        "ru": "Настоящее время глагола chiamarsi",
        "es": "Tiempo presente de chiamarsi"
      },
      "description": {
        "en": "Used to ask and say names.",
        "ru": "Используется для вопроса об имени и представления.",
        "es": "Solía ​​preguntar y decir nombres."
      },
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Introducing yourself and asking names",
        "ru": "Знакомство и вопрос об имени",
        "es": "Presentarse y preguntar nombres"
      },
      "description": {
        "en": "Italian uses different forms for informal (tu) and formal (Lei) introductions.",
        "ru": "В итальянском языке используются разные формы для неформального (tu) и официального (Lei) знакомства.",
        "es": "El italiano utiliza diferentes formas para presentaciones informales (tu) y formales (Lei)."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "en": "What is your name?",
          "ru": "Как тебя зовут?",
          "es": "¿Cómo te llamas?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "en": "What is your name?",
          "ru": "Как вас зовут?",
          "es": "¿Cómo te llamas?"
        },
        {
          "context": "statement",
          "it": "Mi chiamo Paolo.",
          "en": "My name is Paolo.",
          "ru": "Меня зовут Паоло.",
          "es": "Mi nombre es Pablo."
        },
        {
          "context": "statement",
          "it": "Il mio cognome è...",
          "en": "My surname is...",
          "ru": "Моя фамилия — ...",
          "es": "Mi apellido es..."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Greeting and leave-taking: formal vs informal",
        "ru": "Приветствие и прощание: официальное и неформальное",
        "es": "Saludo y despedida: formal versus informal"
      },
      "description": {
        "en": "Greeting formulas depend on time of day and level of formality.",
        "ru": "Формы приветствия зависят от времени суток и степени формальности.",
        "es": "Las fórmulas de saludo dependen de la hora del día y del nivel de formalidad."
      },
      "examples": [
        {
          "context": "arrival",
          "it": "Ciao!",
          "en": "Hi/bye!",
          "ru": "Привет! / Пока!",
          "es": "¡Hola/adiós!"
        },
        {
          "context": "arrival",
          "it": "Buongiorno!",
          "en": "Good morning / good day",
          "ru": "Доброе утро / добрый день",
          "es": "Buenos días/buen día"
        },
        {
          "context": "arrival",
          "it": "Buonasera!",
          "en": "Good evening",
          "ru": "Добрый вечер",
          "es": "Buenas noches"
        },
        {
          "context": "departure",
          "it": "Arrivederci!",
          "en": "Goodbye",
          "ru": "До свидания",
          "es": "Adiós"
        },
        {
          "context": "departure",
          "it": "Arrivederla!",
          "en": "Goodbye (formal)",
          "ru": "До свидания (формально)",
          "es": "Adiós (formal)"
        },
        {
          "context": "departure",
          "it": "A presto!",
          "en": "See you soon",
          "ru": "До скорого",
          "es": "Nos vemos pronto"
        }
      ]
    },
