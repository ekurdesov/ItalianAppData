{
  "lesson_info": {
    "id": "A1-L4-4",
    "title": "Un incontro",
    "level": "A1",
    "objectives": {
      "it": [
        "Ripasso: Chiedi e rispondo",
        "Comprensione orale: Offro io!",
        "Grammatica: verbi irregolari (bere)",
        "Attività comunicativa: Preferisci...?"
      ],
      "en": [
        "Ripasso: Chiedi e rispondo",
        "Comprensione orale: Offro io!",
        "Grammatica: verbi irregolari (bere)",
        "Attività comunicativa: Preferisci...?"
      ],
      "ru": [
        "Повторение: Chiedi e rispondo",
        "Аудирование: Offro io!",
        "Грамматика: неправильные глаголы (bere)",
        "Коммуникативная деятельность: Preferisci...?"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Irregular verb: bere",
        "ru": "Неправильный глагол: bere"
      },
      "description": {
        "en": "The verb 'bere' (to drink) is irregular. Its present-tense stem is 'bev-'.",
        "ru": "Глагол «bere» (пить) неправильный. Основа в настоящем времени — «bev-»."
      },
      "conjugations": {
        "io": "bevo",
        "tu": "bevi",
        "lui/lei/Lei": "beve",
        "noi": "beviamo",
        "voi": "bevete",
        "loro": "bevono"
      },
      "examples": [
        {
          "it": "Io bevo il caffè, e tu che cosa bevi?",
          "en": "I drink coffee, and what do you drink?",
          "ru": "Я пью кофе, а ты что пьёшь?"
        },
        {
          "it": "Noi beviamo delle bibite fresche.",
          "en": "We drink cold drinks.",
          "ru": "Мы пьём холодные напитки."
        },
        {
          "it": "Marisa a colazione beve solo tè e mai latte.",
          "en": "Marisa only drinks tea for breakfast and never milk.",
          "ru": "Мариса на завтрак пьёт только чай и никогда молоко."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Review: -isc- verbs (preferire, capire)",
        "ru": "Повторение: глаголы с -isc- (preferire, capire)"
      },
      "description": {
        "en": "Consolidation of -ire verbs with the -isc- infix.",
        "ru": "Закрепление глаголов на -ire с суффиксом -isc-."
      },
      "examples": [
        {
          "it": "Preferisci viaggiare in aereo o in treno?",
          "en": "Do you prefer to travel by plane or by train?",
          "ru": "Ты предпочитаешь путешествовать на самолёте или на поезде?"
        },
        {
          "it": "Capite il cinese?",
          "en": "Do you understand Chinese?",
          "ru": "Вы понимаете китайский?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Treating someone: Offro io!",
        "ru": "Угощать: Offro io!"
      },
      "description": {
        "en": "Expressions for offering to pay at the bar.",
        "ru": "Выражения для предложения заплатить в баре."
      },
      "examples": [
        {
          "it": "Oggi offro io.",
          "en": "Today it's my treat.",
          "ru": "Сегодня угощаю я."
        },
        {
          "it": "La prossima volta offri tu.",
          "en": "Next time it's your treat.",
          "ru": "В следующий раз угощаешь ты."
        },
        {
          "it": "Che cosa prende Paola?",
          "en": "What will Paola have?",
          "ru": "Что будет Паола?"
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Types of coffee and bar food",
        "ru": "Виды кофе и еда в баре"
      },
      "description": {
        "en": "More specific bar vocabulary for types of coffee and food combinations.",
        "ru": "Более конкретная лексика бара: виды кофе и сочетания блюд."
      },
      "examples": [
        {
          "it": "un caffè macchiato",
          "en": "espresso with a dash of milk",
          "ru": "эспрессо с каплей молока"
        },
        {
          "it": "un caffè doppio",
          "en": "double espresso",
          "ru": "двойной эспрессо"
        },
        {
          "it": "un caffè americano",
          "en": "Americano (long black)",
          "ru": "американо"
        },
        {
          "it": "un tè freddo con limone",
          "en": "iced tea with lemon",
          "ru": "холодный чай с лимоном"
        },
        {
          "it": "un tramezzino al tonno",
          "en": "tuna sandwich",
          "ru": "бутерброд с тунцом"
        },
        {
          "it": "un panino al prosciutto",
          "en": "ham roll",
          "ru": "булочка с ветчиной"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Expressing preferences: Preferisci…?",
        "ru": "Выражение предпочтений: Preferisci…?"
      },
      "description": {
        "en": "Using preferire to ask and state preferences between two options.",
        "ru": "Глагол «preferire» для вопросов и ответов о предпочтениях."
      },
      "examples": [
        {
          "context": "question",
          "it": "Preferisci il mare o la montagna?",
          "en": "Do you prefer the sea or the mountains?",
          "ru": "Ты предпочитаешь море или горы?"
        },
        {
          "context": "answer",
          "it": "Preferisco il mare.",
          "en": "I prefer the sea.",
          "ru": "Я предпочитаю море."
        },
        {
          "context": "formal",
          "it": "Preferisce il mare o la montagna?",
          "en": "Do you prefer the sea or the mountains? (formal)",
          "ru": "Вы предпочитаете море или горы?"
        }
      ]
    }
  ],
