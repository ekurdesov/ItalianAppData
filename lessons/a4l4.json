      },
      "rule": {
        "en": "Irregular verb: volere",
        "ru": "Неправильный глагол: volere",
        "es": "Verbo irregular: volere"
      },
      "description": {
        "en": "The verb 'volere' (to want) is irregular and is often used to order or express what someone wants to do.",
        "ru": "Глагол «volere» (хотеть) неправильный и часто используется, чтобы сделать заказ или сказать, что кто-то хочет сделать.",
        "es": "El verbo 'volere' (querer) es irregular y suele usarse para ordenar o expresar lo que alguien quiere hacer."
      },
      "conjugations": {
        "io": "voglio",
        "tu": "vuoi",
        "lui/lei/Lei": "vuole",
        "noi": "vogliamo",
        "voi": "volete",
        "loro": "vogliono"
      },
      "examples": [
        {
          "it": "Vuoi bere un caffè o un tè?",
          "en": "Do you want to drink a coffee or a tea?",
          "ru": "Ты хочешь выпить кофе или чай?",
          "es": "¿Quieres tomar un café o un té?"
        },
        {
          "it": "Noi vogliamo andare in pizzeria stasera.",
          "en": "We want to go to a pizzeria tonight.",
          "ru": "Мы хотим сегодня вечером пойти в пиццерию.",
          "es": "Queremos ir a una pizzería esta noche."
        },
        {
          "it": "I signori Rossi vogliono comprare un monolocale in centro.",
          "en": "Mr. and Mrs. Rossi want to buy a studio apartment in the city center.",
          "ru": "Супруги Росси хотят купить квартиру-студию в центре.",
          "es": "El señor y la señora Rossi quieren comprar un estudio en el centro de la ciudad."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Expressing preferences: Preferisci…?",
        "ru": "Выражение предпочтений: Preferisci…?",
        "es": "Expresar preferencias: Preferisci…?"
      },
      "description": {
        "en": "Using preferire to ask and state preferences between two options.",
        "ru": "Глагол «preferire» для вопросов и ответов о предпочтениях.",
        "es": "Usar preferire para preguntar y expresar preferencias entre dos opciones."
      },
      "examples": [
        {
          "context": "question",
          "it": "Preferisci il mare o la montagna?",
          "en": "Do you prefer the sea or the mountains?",
          "ru": "Ты предпочитаешь море или горы?",
          "es": "¿Prefieres el mar o la montaña?"
        },
        {
          "context": "answer",
          "it": "Preferisco il mare.",
          "en": "I prefer the sea.",
          "ru": "Я предпочитаю море.",
          "es": "Prefiero el mar."
        },
        {
          "context": "formal",
          "it": "Preferisce il mare o la montagna?",
          "en": "Do you prefer the sea or the mountains? (formal)",
          "ru": "Вы предпочитаете море или горы?",
          "es": "¿Prefieres el mar o la montaña? (formal)"
        }
      ]
    }
