{
  "lesson_info": {
    "id": "A1-L4-4",
    "title": "Un incontro",
    "level": "A1",
    "objectives": {
      "it": [
        "Lessico: bevande e spuntini",
        "Comprensione orale: Al bar",
        "Pragmatica: Offro io!",
        "Grammatica: verbi irregolari (bere, volere)",
        "Attività comunicativa: Per me... / Tu che cosa prendi?"
      ],
      "en": [
        "Vocabulary: drinks and snacks",
        "Listening comprehension: At the bar",
        "Pragmatics: It's my treat!",
        "Grammar: irregular verbs (bere, volere)",
        "Communicative activity: For me... / What are you having?"
      ],
      "ru": [
        "Лексика: напитки и перекусы",
        "Аудирование: В баре",
        "Прагматика: Offro io!",
        "Грамматика: неправильные глаголы (bere, volere)",
        "Коммуникативное задание: Per me... / Tu che cosa prendi?"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Irregular verb: bere",
        "ru": "Неправильный глагол: bere"
      },
      "description": {
        "en": "The verb 'bere' (to drink) is irregular. Its present-tense stem is 'bev-'.",
        "ru": "Глагол «bere» (пить) неправильный. Основа в настоящем времени — «bev-»."
      },
      "conjugations": {
        "io": "bevo",
        "tu": "bevi",
        "lui/lei/Lei": "beve",
        "noi": "beviamo",
        "voi": "bevete",
        "loro": "bevono"
      },
      "examples": [
        {
          "it": "Io bevo il caffè, e tu che cosa bevi?",
          "en": "I drink coffee, and what do you drink?",
          "ru": "Я пью кофе, а ты что пьёшь?"
        },
        {
          "it": "Noi beviamo delle bibite fresche.",
          "en": "We drink cold drinks.",
          "ru": "Мы пьём холодные напитки."
        },
        {
          "it": "Marisa a colazione beve solo tè e mai latte.",
          "en": "Marisa only drinks tea for breakfast and never milk.",
          "ru": "Мариса на завтрак пьёт только чай и никогда молоко."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Review: -isc- verbs (preferire, capire)",
        "ru": "Повторение: глаголы с -isc- (preferire, capire)"
      },
      "description": {
        "en": "Consolidation of -ire verbs with the -isc- infix.",
        "ru": "Закрепление глаголов на -ire с суффиксом -isc-."
      },
      "examples": [
        {
          "it": "Preferisci viaggiare in aereo o in treno?",
          "en": "Do you prefer to travel by plane or by train?",
          "ru": "Ты предпочитаешь путешествовать на самолёте или на поезде?"
        },
        {
          "it": "Capite il cinese?",
          "en": "Do you understand Chinese?",
          "ru": "Вы понимаете китайский?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Treating someone: Offro io!",
        "ru": "Угощать: Offro io!"
      },
      "description": {
        "en": "Expressions for offering to pay at the bar.",
        "ru": "Выражения для предложения заплатить в баре."
      },
      "examples": [
        {
          "it": "Oggi offro io.",
          "en": "Today it's my treat.",
          "ru": "Сегодня угощаю я."
        },
        {
          "it": "La prossima volta offri tu.",
          "en": "Next time it's your treat.",
          "ru": "В следующий раз угощаешь ты."
        },
        {
          "it": "Che cosa prende Paola?",
          "en": "What will Paola have?",
          "ru": "Что будет Паола?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Ordering at the bar",
        "ru": "Заказ в баре"
      },
      "description": {
        "en": "Useful phrases for ordering, asking the price, and paying at the bar.",
        "ru": "Полезные фразы для заказа, вопроса о цене и оплаты в баре."
      },
      "examples": [
        {
          "it": "Per me un cappuccino, per favore.",
          "en": "A cappuccino for me, please.",
          "ru": "Мне капучино, пожалуйста."
        },
        {
          "it": "Vorrei pagare subito.",
          "en": "I'd like to pay right away.",
          "ru": "Я бы хотел(а) заплатить сразу."
        },
        {
          "it": "Quant'è?",
          "en": "How much is it?",
          "ru": "Сколько с меня?"
        },
        {
          "it": "Ecco a Lei.",
          "en": "Here you are.",
          "ru": "Вот, пожалуйста."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Types of coffee and bar food",
        "ru": "Виды кофе и еда в баре"
