  "dialogues": [
    {
      "id": "D-A1L4-4-01",
      "title": "Offro io!",
      "register": "informal",
      "context": {
        "en": "Two friends at the bar order drinks and food; one offers to pay.",
        "ru": "Двое друзей в баре заказывают напитки и еду; один предлагает заплатить."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Allora, che cosa prendi?",
          "en": "So, what will you have?",
          "ru": "Ну что, что ты будешь?"
        },
        {
          "speaker": "B",
          "it": "Prendo un tramezzino con prosciutto cotto e un caffè macchiato.",
          "en": "I'll have a ham sandwich and a macchiato.",
          "ru": "Возьму бутерброд с варёной ветчиной и маккиато."
        },
        {
          "speaker": "A",
          "it": "Io prendo una piadina al formaggio e un succo di frutta.",
          "en": "I'll have a cheese flatbread and a fruit juice.",
          "ru": "Я возьму лепёшку с сыром и фруктовый сок."
        },
        {
          "speaker": "B",
          "it": "Quanto costa tutto?",
          "en": "How much does it all cost?",
          "ru": "Сколько всё стоит?"
        },
        {
          "speaker": "A",
          "it": "6,90 euro. Oggi offro io!",
          "en": "6.90 euros. Today it's my treat!",
          "ru": "6,90 евро. Сегодня угощаю я!"
        },
        {
          "speaker": "B",
          "it": "Grazie! La prossima volta offro io.",
          "en": "Thank you! Next time it's my treat.",
          "ru": "Спасибо! В следующий раз угощаю я."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Say you drink coffee",
            "ru": "Сказать, что пьёшь кофе"
          },
          "expected_it": "Bevo un caffè."
        },
        {
          "cue": {
            "en": "Offer to pay",
            "ru": "Предложить заплатить"
          },
          "expected_it": "Offro io!"
        },
        {
          "cue": {
            "en": "Ask what someone prefers",
            "ru": "Спросить, что кто-то предпочитает"
          },
          "expected_it": "Preferisci …?"
        }
      ]
    },
    {
      "id": "D-A1L4-4-02",
      "title": "Al bar",
      "register": "informal",
      "context": {
        "en": "Two customers order at the bar and ask to pay immediately.",
        "ru": "Двое посетителей делают заказ в баре и просят сразу рассчитаться."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno. Tu che cosa prendi?",
          "en": "Good morning. What are you having?",
          "ru": "Доброе утро. Что ты будешь?"
        },
        {
          "speaker": "B",
          "it": "Per me un caffè macchiato, per favore.",
          "en": "A macchiato for me, please.",
          "ru": "Мне маккиато, пожалуйста."
        },
        {
          "speaker": "A",
          "it": "E per me un cappuccino e un cornetto.",
          "en": "And for me a cappuccino and a croissant.",
          "ru": "А мне капучино и круассан."
        },
        {
          "speaker": "B",
          "it": "Vorrei pagare subito. Quant'è?",
          "en": "I'd like to pay right away. How much is it?",
          "ru": "Я бы хотел(а) заплатить сразу. Сколько с меня?"
        },
        {
          "speaker": "C",
          "it": "Sono quattro euro. Ecco a Lei.",
          "en": "It's four euros. Here you are.",
          "ru": "С вас четыре евро. Вот, пожалуйста."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Order a cappuccino",
