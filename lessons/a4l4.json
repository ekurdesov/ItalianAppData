  "dialogues": [
    {
      "id": "D-A1L4-4-01",
      "title": "Offro io!",
      "register": "informal",
      "context": {
        "en": "Two friends at the bar order drinks and food; one offers to pay.",
        "ru": "Двое друзей в баре заказывают напитки и еду; один предлагает заплатить.",
        "es": "Dos amigos en el bar piden bebidas y comida; uno se ofrece a pagar."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Allora, che cosa prendi?",
          "en": "So, what will you have?",
          "ru": "Ну что, что ты будешь?",
          "es": "Entonces, ¿qué tendrás?"
        },
        {
          "speaker": "B",
          "it": "Prendo un tramezzino con prosciutto cotto e un caffè macchiato.",
          "en": "I'll have a ham sandwich and a macchiato.",
          "ru": "Возьму бутерброд с варёной ветчиной и маккиато.",
          "es": "Tomaré un sándwich de jamón y un macchiato."
        },
        {
          "speaker": "A",
          "it": "Io prendo una piadina al formaggio e un succo di frutta.",
          "en": "I'll have a cheese flatbread and a fruit juice.",
          "ru": "Я возьму лепёшку с сыром и фруктовый сок.",
          "es": "Tomaré un pan plano de queso y un jugo de frutas."
        },
        {
          "speaker": "B",
          "it": "Quanto costa tutto?",
          "en": "How much does it all cost?",
          "ru": "Сколько всё стоит?",
          "es": "¿Cuánto cuesta todo?"
        },
        {
          "speaker": "A",
          "it": "6,90 euro. Oggi offro io!",
          "en": "6.90 euros. Today it's my treat!",
          "ru": "6,90 евро. Сегодня угощаю я!",
          "es": "6,90€. ¡Hoy es mi regalo!"
        },
        {
          "speaker": "B",
          "it": "Grazie! La prossima volta offro io.",
          "en": "Thank you! Next time it's my treat.",
          "ru": "Спасибо! В следующий раз угощаю я.",
          "es": "¡Gracias! La próxima vez te invito yo."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Say you drink coffee",
            "ru": "Сказать, что пьёшь кофе",
            "es": "Di que bebes café"
          },
          "expected_it": "Bevo un caffè."
        },
        {
          "cue": {
            "en": "Offer to pay",
            "ru": "Предложить заплатить",
            "es": "oferta para pagar"
          },
          "expected_it": "Offro io!"
        },
        {
          "cue": {
            "en": "Ask what someone prefers",
            "ru": "Спросить, что кто-то предпочитает",
            "es": "Preguntar qué prefiere alguien"
          },
          "expected_it": "Preferisci …?"
        }
      ]
    },
    {
      "id": "D-A1L4-4-02",
      "title": "Al bar",
      "register": "informal",
      "context": {
        "en": "Two customers order at the bar and ask to pay immediately.",
        "ru": "Двое посетителей делают заказ в баре и просят сразу рассчитаться.",
        "es": "Dos clientes hacen un pedido en la barra y piden pagar inmediatamente."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno. Tu che cosa prendi?",
          "en": "Good morning. What are you having?",
          "ru": "Доброе утро. Что ты будешь?",
          "es": "Buen día. ¿Qué estás tomando?"
        },
        {
          "speaker": "B",
          "it": "Per me un caffè macchiato, per favore.",
          "en": "A macchiato for me, please.",
          "ru": "Мне маккиато, пожалуйста.",
          "es": "Un macchiato para mí, por favor."
        },
        {
          "speaker": "A",
          "it": "E per me un cappuccino e un cornetto.",
          "en": "And for me a cappuccino and a croissant.",
          "ru": "А мне капучино и круассан.",
          "es": "Y para mí un capuchino y un croissant."
        },
        {
          "speaker": "B",
          "it": "Vorrei pagare subito. Quant'è?",
          "en": "I'd like to pay right away. How much is it?",
          "ru": "Я бы хотел(а) заплатить сразу. Сколько с меня?",
          "es": "Me gustaría pagar de inmediato. ¿Cuánto cuesta?"
        },
        {
          "speaker": "C",
          "it": "Sono quattro euro. Ecco a Lei.",
          "en": "It's four euros. Here you are.",
          "ru": "С вас четыре евро. Вот, пожалуйста.",
          "es": "Son cuatro euros. Aquí tiene."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Order a cappuccino",
            "ru": "Заказать капучино",
            "es": "pedir un capuchino"
          },
          "expected_it": "Per me un cappuccino, per favore."
        },
        {
          "cue": {
            "en": "Ask the price",
            "ru": "Спросить цену",
            "es": "Pregunta el precio"
          },
          "expected_it": "Quant'è?"
        },
        {
          "cue": {
            "en": "Say you want to pay right away",
            "ru": "Сказать, что хочешь сразу заплатить",
            "es": "Di que quieres pagar de inmediato"
          },
          "expected_it": "Vorrei pagare subito."
        }
      ]
    },
    {
      "id": "D-A1L4-4-03",
      "title": "Offro io",
      "register": "informal",
      "context": {
        "en": "Two friends politely argue about who pays at the bar.",
        "ru": "Двое друзей вежливо спорят, кто платит в баре.",
        "es": "Dos amigos discuten educadamente sobre quién paga en el bar."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Per me un caffè e una brioche.",
          "en": "For me a coffee and a brioche.",
          "ru": "Мне кофе и бриошь.",
          "es": "Para mí un café y un brioche."
        },
        {
          "speaker": "B",
          "it": "Io prendo un tè e un cornetto.",
          "en": "I'll have a tea and a croissant.",
          "ru": "Я возьму чай и круассан.",
          "es": "Tomaré un té y un croissant."
        },
        {
          "speaker": "A",
          "it": "Vuoi anche acqua?",
          "en": "Do you also want water?",
          "ru": "Хочешь ещё воду?",
          "es": "¿También quieres agua?"
        },
        {
          "speaker": "B",
          "it": "Sì, grazie. Acqua naturale.",
          "en": "Yes, thanks. Still water.",
          "ru": "Да, спасибо. Негазированную.",
          "es": "Sí, gracias. Agua sin gas."
        },
        {
          "speaker": "A",
          "it": "Bene. Pago io.",
          "en": "Good. I'll pay.",
          "ru": "Хорошо. Я плачу.",
          "es": "Bien. Yo pagaré."
        },
        {
          "speaker": "B",
          "it": "No, no, pago io.",
          "en": "No, no, I'll pay.",
          "ru": "Нет, нет, я плачу.",
          "es": "No, no, yo pagaré."
        },
        {
          "speaker": "A",
          "it": "Dai, oggi offro io.",
          "en": "Come on, today it's my treat.",
          "ru": "Давай, сегодня угощаю я.",
          "es": "Vamos, hoy te invito yo."
        },
        {
          "speaker": "B",
          "it": "Sei sicuro?",
          "en": "Are you sure?",
          "ru": "Ты уверен?",
          "es": "¿Está seguro?"
        },
        {
          "speaker": "A",
          "it": "Sì, certo.",
          "en": "Yes, of course.",
          "ru": "Да, конечно.",
          "es": "Sí, claro."
        },
        {
          "speaker": "B",
          "it": "Allora grazie.",
          "en": "Then thanks.",
          "ru": "Тогда спасибо.",
          "es": "Entonces gracias."
        },
        {
          "speaker": "A",
          "it": "Prego. La prossima volta offri tu.",
          "en": "You're welcome. Next time it's your treat.",
          "ru": "Пожалуйста. В следующий раз угощаешь ты.",
          "es": "De nada. La próxima vez será tu regalo."
        },
        {
          "speaker": "B",
          "it": "Va bene, la prossima volta offro io.",
          "en": "Okay, next time it's my treat.",
          "ru": "Хорошо, в следующий раз угощаю я.",
          "es": "Vale, la próxima vez invito yo."
        },
        {
          "speaker": "A",
          "it": "Dopo il bar torni a casa?",
          "en": "After the bar are you going home?",
          "ru": "После бара ты идёшь домой?",
          "es": "¿Después del bar te vas a casa?"
        },
        {
          "speaker": "B",
          "it": "No, vado in biblioteca.",
          "en": "No, I'm going to the library.",
          "ru": "Нет, иду в библиотеку.",
          "es": "No, voy a la biblioteca."
        },
        {
          "speaker": "A",
          "it": "Perché?",
          "en": "Why?",
          "ru": "Почему?",
          "es": "¿Por qué?"
        },
        {
          "speaker": "B",
          "it": "Perché devo studiare italiano.",
          "en": "Because I have to study Italian.",
          "ru": "Потому что мне нужно учить итальянский.",
          "es": "Porque tengo que estudiar italiano."
        },
        {
          "speaker": "A",
          "it": "Posso venire con te?",
          "en": "Can I come with you?",
          "ru": "Можно мне пойти с тобой?",
          "es": "¿Puedo ir contigo?"
        },
        {
          "speaker": "B",
          "it": "Certo, studiamo insieme.",
          "en": "Sure, let's study together.",
          "ru": "Конечно, будем учиться вместе.",
          "es": "Claro, estudiemos juntos."
        },
        {
          "speaker": "A",
          "it": "Perfetto. Hai il libro?",
          "en": "Perfect. Do you have the book?",
          "ru": "Отлично. У тебя есть учебник?",
          "es": "Perfecto. Tienes el libro?"
        },
        {
          "speaker": "B",
          "it": "Sì, ho il libro e gli appunti.",
          "en": "Yes, I have the book and the notes.",
          "ru": "Да, у меня есть учебник и конспекты.",
          "es": "Sí, tengo el libro y las notas."
        },
        {
          "speaker": "A",
          "it": "Bene, allora finiamo il caffè.",
          "en": "Good, then let's finish the coffee.",
          "ru": "Хорошо, тогда допьём кофе.",
          "es": "Bien, entonces terminemos el café."
        },
        {
          "speaker": "B",
          "it": "Sì, poi andiamo.",
          "en": "Yes, then let's go.",
          "ru": "Да, потом пойдём.",
          "es": "Sí, entonces vámonos."
        }
      ]
    }
