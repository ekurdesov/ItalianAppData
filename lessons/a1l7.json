  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Preposition 'di'",
        "ru": "Предлог 'di'"
      },
      "description": {
        "en": "The preposition 'di' is used for possession, belonging, and specification.",
        "ru": "Предлог 'di' используется для выражения принадлежности, владения и уточнения."
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Demonstratives: questo, questa, questi, queste",
        "ru": "Указательные местоимения: questo, questa, questi, queste"
      },
      "description": {
        "en": "Demonstratives agree with the gender and number of the noun they modify.",
        "ru": "Указательные местоимения согласуются с родом и числом существительного, к которому относятся."
      },
      "examples": [
        {
          "it": "questo libro",
          "en": "this book",
          "ru": "эта книга"
        },
        {
          "it": "questa valigia",
          "en": "this suitcase",
          "ru": "этот чемодан"
        },
        {
          "it": "questi ragazzi",
          "en": "these boys",
          "ru": "эти мальчики"
        },
        {
          "it": "queste scarpe",
          "en": "these shoes",
          "ru": "эти туфли"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Prepositions 'a' and 'in'",
        "ru": "Предлоги 'a' и 'in'"
      },
      "description": {
        "en": "The lesson introduces the location prepositions 'a' and 'in', especially in talking about cities, regions, and places in Italy.",
        "ru": "Урок знакомит с предлогами места 'a' и 'in', особенно в контексте разговора о городах, регионах и местах в Италии."
      },
      "examples": [
        {
          "it": "a Roma",
          "en": "in/to Rome",
          "ru": "в Риме / в Рим"
        },
        {
          "it": "in Italia",
          "en": "in Italy",
          "ru": "в Италии"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking for a phone number: formal vs informal",
        "ru": "Запрос номера телефона: официальная и неформальная формы"
      },
      "description": {
        "en": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking for a phone or cellphone number.",
        "ru": "В итальянском языке различаются неформальная форма 'tu' и официальная форма 'Lei' при вопросе о номере телефона или мобильного."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Qual è il tuo numero di telefono?",
          "en": "What is your telephone number?",
          "ru": "Какой у тебя номер телефона?"
        },
        {
          "context": "formal",
          "it": "Qual è il Suo numero di telefono?",
          "en": "What is your telephone number? (formal)",
          "ru": "Какой у вас номер телефона? (формально)"
        },
        {
          "context": "informal",
          "it": "Qual è il tuo numero di cellulare?",
          "en": "What is your cellphone number?",
          "ru": "Какой у тебя номер мобильного?"
        },
        {
          "context": "formal",
          "it": "Qual è il Suo numero di cellulare?",
          "en": "What is your cellphone number? (formal)",
          "ru": "Какой у вас номер мобильного? (формально)"
        },
        {
          "context": "answer",
          "it": "Il mio numero di telefono è...",
          "en": "My telephone number is...",
          "ru": "Мой номер телефона — ..."
        },
        {
          "context": "answer",
          "it": "Il mio numero di cellulare è...",
          "en": "My cellphone number is...",
          "ru": "Мой номер мобильного — ..."
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Letter Q and related qu/gu combinations",
        "ru": "Буква Q и сочетания qu/gu"
      },
      "description": {
        "en": "In the lesson, 'qu' and some 'gu' combinations before vowels are practiced with a [kw] or [gw] sound.",
        "ru": "На уроке отрабатываются сочетания 'qu' и некоторые сочетания 'gu' перед гласными, которые произносятся как [kw] или [gw]."
      },
      "examples": [
        {
          "it": "questo",
          "en": "this",
          "ru": "этот / эта"
        },
        {
          "it": "quello",
          "en": "that",
          "ru": "тот / та"
        },
        {
          "it": "qui",
          "en": "here",
          "ru": "здесь"
        },
        {
          "it": "acqua",
          "en": "water",
          "ru": "вода"
        },
        {
          "it": "quartiere",
          "en": "neighborhood",
          "ru": "район"
        },
        {
          "it": "guardare",
          "en": "to look",
          "ru": "смотреть"
        },
        {
          "it": "guidare",
          "en": "to drive",
          "ru": "водить машину"
        }
      ]
    }
  ],
