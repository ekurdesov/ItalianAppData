  "dialogues": [
    {
      "id": "D-A1L1-7-01",
      "title": "Qual è il numero di telefono?",
      "register": "informal",
      "context": {
        "en": "One student asks another for a third person's phone number",
        "ru": "Один студент спрашивает другого о номере телефона третьего человека"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, Paola! Qual è il numero di telefono di Fabrizio?",
          "en": "Hi, Paola! What is Fabrizio's phone number?",
          "ru": "Привет, Паола! Какой номер телефона у Фабрицио?"
        },
        {
          "speaker": "B",
          "it": "Ciao, Giorgio! Il numero di telefono di Fabrizio è zero tre due, cinque sei sette, otto nove uno.",
          "en": "Hi, Giorgio! Fabrizio's phone number is 032 567 891.",
          "ru": "Привет, Джорджо! Номер телефона Фабрицио: 032 567 891."
        },
        {
          "speaker": "A",
          "it": "Grazie!",
          "en": "Thank you!",
          "ru": "Спасибо!"
        },
        {
          "speaker": "B",
          "it": "Prego!",
          "en": "You're welcome!",
          "ru": "Пожалуйста!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask for someone's phone number (informal)",
            "ru": "Спросите чей-то номер телефона (неформально)"
          },
          "expected_it": "Qual è il tuo numero di telefono?"
        },
        {
          "cue": {
            "en": "Ask for a third person's phone number",
            "ru": "Спросите номер телефона третьего человека"
          },
          "expected_it": "Qual è il numero di telefono di [nome]?"
        },
        {
          "cue": {
            "en": "Give a phone number",
            "ru": "Назовите номер телефона"
          },
          "expected_it": "Il mio numero di telefono è [numero]."
        }
      ]
    },
    {
      "id": "D-A1L1-7-02",
      "title": "Qual è il Suo numero? (formale)",
      "register": "formal",
      "context": {
        "en": "A formal exchange asking for a cellphone number",
        "ru": "Официальный обмен с просьбой назвать номер мобильного телефона"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Buongiorno. Qual è il Suo numero di cellulare?",
          "en": "Good morning. What is your cellphone number?",
          "ru": "Доброе утро. Какой у вас номер мобильного телефона?"
        },
        {
          "speaker": "B",
          "it": "Il mio numero di cellulare è tre tre tre, uno due tre, quattro cinque sei.",
          "en": "My cellphone number is 333 123 456.",
          "ru": "Мой номер мобильного: 333 123 456."
        },
        {
          "speaker": "A",
          "it": "Grazie mille.",
          "en": "Thank you very much.",
          "ru": "Большое спасибо."
        },
        {
          "speaker": "B",
          "it": "Prego.",
          "en": "You're welcome.",
          "ru": "Пожалуйста."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask for someone's cellphone number (formal)",
            "ru": "Спросите номер мобильного телефона (официально)"
          },
          "expected_it": "Qual è il Suo numero di cellulare?"
        },
        {
          "cue": {
            "en": "Give your cellphone number",
            "ru": "Назовите свой номер мобильного"
          },
          "expected_it": "Il mio numero di cellulare è [numero]."
        }
      ]
    }
  ],
