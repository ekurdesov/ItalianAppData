        "Le preposizioni",
        "Attività comunicativa: Qual è il tuo numero?",
        "Fonetica: lettera Q"
      ],
      "en": [
        "Listening comprehension: Around Italy",
        "Prepositions",
        "Communicative activity: What is your number?",
        "Phonetics: letter Q"
      ],
      "ru": [
        "Аудирование: In giro per l'Italia",
        "Предлоги",
        "Коммуникативное задание: Qual è il tuo numero?",
        "Фонетика: буква Q"
      ]
    }
