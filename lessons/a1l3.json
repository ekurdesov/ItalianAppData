  "language_rules": [
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Formal vs informal greetings",
        "ru": "Официальные и разговорные приветствия",
        "es": "Saludos formales versus informales"
      },
      "description": {
        "en": "Italian uses different greeting and leave-taking forms depending on the situation and level of formality.",
        "ru": "В итальянском языке формы приветствия и прощания различаются в зависимости от ситуации и степени официальности.",
        "es": "El italiano utiliza diferentes formas de saludo y despedida según la situación y el nivel de formalidad."
      },
      "examples": [
        {
          "context": "arrival informal",
          "it": "Ciao!",
          "en": "Hi!",
          "ru": "Привет!",
          "es": "¡Hola!"
        },
        {
          "context": "arrival neutral/formal",
          "it": "Buongiorno! / Buon dì!",
          "en": "Good morning / good day!",
          "ru": "Доброе утро / добрый день!",
          "es": "¡Buenos días/buen día!"
        },
        {
          "context": "arrival neutral/formal",
          "it": "Buonasera!",
          "en": "Good evening!",
          "ru": "Добрый вечер!",
          "es": "¡Buenas noches!"
        },
        {
          "context": "arrival formal",
          "it": "Salve!",
          "en": "Hello!",
          "ru": "Здравствуйте!",
          "es": "¡Hola!"
        },
        {
          "context": "departure formal",
          "it": "ArrivederLa!",
          "en": "Goodbye (formal)",
          "ru": "До свидания (официально)",
          "es": "Adiós (formal)"
        },
        {
          "context": "departure",
          "it": "Arrivederci!",
          "en": "Goodbye",
          "ru": "До свидания",
          "es": "Adiós"
        },
        {
          "context": "departure",
          "it": "A presto! / A dopo!",
          "en": "See you soon / later!",
          "ru": "До скорого / до встречи!",
          "es": "¡Hasta pronto/más tarde!"
        }
      ]
    },
    {
      "category": {
