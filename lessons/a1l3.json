      },
      "rule": {
        "en": "Present tense of chiamarsi",
        "ru": "Настоящее время глагола chiamarsi",
        "es": "Tiempo presente de chiamarsi"
      },
      "description": {
        "en": "The reflexive verb 'chiamarsi' is used to ask and say names.",
        "ru": "Возвратный глагол «chiamarsi» используется для того, чтобы спросить и сказать имя.",
        "es": "El verbo reflexivo 'chiamarsi' se utiliza para preguntar y decir nombres."
      },
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Introducing yourself and asking names",
        "ru": "Знакомство и вопрос об имени",
        "es": "Presentarse y preguntar nombres"
      },
      "description": {
        "en": "Italian uses different question and reaction forms for informal 'tu' and formal 'Lei'.",
        "ru": "В итальянском языке используются разные формулы вопроса и реакции для разговорного «tu» и официального «Lei».",
        "es": "El italiano utiliza diferentes formas de preguntas y reacciones para el 'tu' informal y el 'Lei' formal."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "en": "What is your name?",
          "ru": "Как тебя зовут?",
          "es": "¿Cómo te llamas?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "en": "What is your name? (formal)",
          "ru": "Как Вас зовут? (официально)",
          "es": "¿Cómo te llamas? (formal)"
        },
        {
          "context": "statement",
          "it": "Mi chiamo Paolo.",
          "en": "My name is Paolo.",
          "ru": "Меня зовут Паоло.",
          "es": "Mi nombre es Pablo."
        },
        {
          "context": "statement",
          "it": "Sono Paolo.",
          "en": "I am Paolo.",
          "ru": "Я Паоло.",
          "es": "Soy Pablo."
        },
        {
          "context": "reaction informal",
          "it": "Piacere di conoscerti.",
          "en": "Nice to meet you.",
          "ru": "Приятно познакомиться.",
          "es": "Encantado de conocerlo."
        },
        {
          "context": "reaction formal",
          "it": "Piacere di conoscerla.",
          "en": "Nice to meet you. (formal)",
          "ru": "Приятно познакомиться. (официально)",
          "es": "Encantado de conocerlo. (formal)"
        }
      ]
    },
