  "dialogues": [
    {
      "id": "D-A1L1-3-01",
      "title": "Come ti chiami?",
      "register": "informal",
      "context": {
        "en": "Two students introduce themselves using essere and chiamarsi.",
        "ru": "Два студента знакомятся, используя essere и chiamarsi."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao! Come ti chiami?",
          "en": "Hi! What is your name?",
          "ru": "Привет! Как тебя зовут?"
        },
        {
          "speaker": "B",
          "it": "Mi chiamo Anna. E tu, come ti chiami?",
          "en": "My name is Anna. And you, what is your name?",
          "ru": "Меня зовут Анна. А тебя как зовут?"
        },
        {
          "speaker": "A",
          "it": "Io mi chiamo Marco. Sono italiano. E tu?",
          "en": "My name is Marco. I am Italian. And you?",
          "ru": "Меня зовут Марко. Я итальянец. А ты?"
        },
        {
          "speaker": "B",
          "it": "Sono russa, di Mosca.",
          "en": "I am Russian, from Moscow.",
          "ru": "Я русская, из Москвы."
        },
        {
          "speaker": "A",
          "it": "Piacere, Anna!",
          "en": "Nice to meet you, Anna!",
          "ru": "Приятно познакомиться, Анна!"
        },
        {
          "speaker": "B",
          "it": "Piacere, Marco!",
          "en": "Nice to meet you, Marco!",
          "ru": "Приятно познакомиться, Марко!"
        }
      ],
