  "language_rules": [
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Formal vs informal greetings",
        "ru": "Официальные и разговорные приветствия"
      },
      "description": {
        "en": "Italian uses different greeting and leave-taking forms depending on the situation and level of formality.",
        "ru": "В итальянском языке формы приветствия и прощания различаются в зависимости от ситуации и степени официальности."
      },
      "examples": [
        {
          "context": "arrival informal",
          "it": "Ciao!",
          "en": "Hi!",
          "ru": "Привет!"
        },
        {
          "context": "arrival neutral/formal",
          "it": "Buongiorno! / Buon dì!",
          "en": "Good morning / good day!",
          "ru": "Доброе утро / добрый день!"
        },
        {
          "context": "arrival neutral/formal",
          "it": "Buonasera!",
          "en": "Good evening!",
          "ru": "Добрый вечер!"
        },
        {
          "context": "arrival formal",
          "it": "Salve!",
          "en": "Hello!",
          "ru": "Здравствуйте!"
        },
        {
          "context": "departure formal",
          "it": "ArrivederLa!",
          "en": "Goodbye (formal)",
          "ru": "До свидания (официально)"
        },
        {
          "context": "departure",
          "it": "Arrivederci!",
          "en": "Goodbye",
          "ru": "До свидания"
        },
        {
          "context": "departure",
          "it": "A presto! / A dopo!",
          "en": "See you soon / later!",
          "ru": "До скорого / до встречи!"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Personal subject pronouns",
        "ru": "Личные местоимения-подлежащие"
      },
      "description": {
        "en": "The lesson practices the basic Italian subject pronouns used with 'essere' and 'chiamarsi'.",
        "ru": "В уроке отрабатываются основные итальянские местоимения-подлежащие, используемые с глаголами «essere» и «chiamarsi»."
      },
      "examples": [
        {
          "it": "io",
          "en": "I",
          "ru": "я"
        },
        {
          "it": "tu",
          "en": "you (informal singular)",
          "ru": "ты (неформально, ед. ч.)"
        },
        {
          "it": "lui / lei",
          "en": "he / she",
          "ru": "он / она"
        },
        {
          "it": "noi",
          "en": "we",
          "ru": "мы"
        },
        {
          "it": "voi",
          "en": "you (plural)",
          "ru": "вы (множественное число)"
        },
        {
          "it": "loro",
          "en": "they",
          "ru": "они"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Present tense of essere",
        "ru": "Настоящее время глагола essere"
      },
      "description": {
        "en": "The verb 'essere' is used for identity and basic descriptions.",
        "ru": "Глагол «essere» используется для обозначения идентичности и основных характеристик."
      },
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Present tense of chiamarsi",
        "ru": "Настоящее время глагола chiamarsi"
      },
      "description": {
        "en": "The reflexive verb 'chiamarsi' is used to ask and say names.",
        "ru": "Возвратный глагол «chiamarsi» используется для того, чтобы спросить и сказать имя."
      },
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Introducing yourself and asking names",
        "ru": "Знакомство и вопрос об имени"
      },
      "description": {
        "en": "Italian uses different question and reaction forms for informal 'tu' and formal 'Lei'.",
        "ru": "В итальянском языке используются разные формулы вопроса и реакции для разговорного «tu» и официального «Lei»."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "en": "What is your name?",
          "ru": "Как тебя зовут?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "en": "What is your name? (formal)",
          "ru": "Как Вас зовут? (официально)"
        },
        {
          "context": "statement",
          "it": "Mi chiamo Paolo.",
          "en": "My name is Paolo.",
          "ru": "Меня зовут Паоло."
        },
        {
          "context": "statement",
          "it": "Sono Paolo.",
          "en": "I am Paolo.",
          "ru": "Я Паоло."
        },
        {
          "context": "reaction informal",
          "it": "Piacere di conoscerti.",
          "en": "Nice to meet you.",
          "ru": "Приятно познакомиться."
        },
        {
          "context": "reaction formal",
          "it": "Piacere di conoscerla.",
          "en": "Nice to meet you. (formal)",
          "ru": "Приятно познакомиться. (официально)"
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Pronunciation of letter C",
        "ru": "Произношение буквы C"
      },
      "description": {
        "en": "The sound of 'c' changes according to the following letter.",
        "ru": "Звучание буквы «c» меняется в зависимости от следующей за ней буквы."
      }
    }
