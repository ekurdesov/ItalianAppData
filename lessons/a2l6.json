{
  "lesson_info": {
    "id": "A1-L2-6",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": {
      "it": [
        "Ripasso: i numeri da 10 a 100",
        "Ripasso: verbi avere ed essere",
        "Ripasso e ampliamento: avere + sensazioni fisiche ed emotive",
        "Attività comunicativa: Come ti chiami? — formale e informale",
        "Attività comunicativa: Quante domande! — Qual è il tuo/Suo...?",
        "Fonetica: lettera Z"
      ],
      "en": [
        "Review: numbers from 10 to 100",
        "Review: avere and essere",
        "Review and expansion: avere + physical and emotional sensations",
        "Communicative activity: What is your name? - formal and informal",
        "Communicative activity: So many questions! - What is your...?",
        "Phonetics: letter Z"
      ],
      "ru": [
        "Повторение: числа от 10 до 100",
        "Повторение: avere и essere",
        "Повторение и расширение: avere + физические и эмоциональные ощущения",
        "Коммуникативное задание: Come ti chiami? - формально и неформально",
        "Коммуникативное задание: Quante domande! - Qual è il tuo/Suo...?",
        "Фонетика: буква Z"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "avere voglia di + infinitive",
        "ru": "avere voglia di + инфинитив"
      },
      "description": {
        "en": "'Avere voglia di' means 'to feel like doing something'. It is followed by an infinitive. The negative form 'non avere voglia di' means 'not to feel like'.",
        "ru": "«Avere voglia di» означает «хотеть что-то делать; быть в настроении». После него следует инфинитив. Отрицательная форма «non avere voglia di» означает «не хотеть; не быть в настроении»."
      },
      "examples": [
        {
          "it": "Ho voglia di andare al mare.",
          "en": "I feel like going to the sea.",
          "ru": "Мне хочется пойти на море."
        },
        {
          "it": "Hai voglia di ripassare?",
          "en": "Do you feel like reviewing?",
          "ru": "Тебе хочется повторить материал?"
        },
        {
          "it": "Non ha voglia di studiare.",
          "en": "He/she doesn't feel like studying.",
          "ru": "Ему/ей не хочется учиться."
        },
        {
          "it": "Non ho voglia di niente.",
          "en": "I don't feel like anything.",
          "ru": "Мне ничего не хочется."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "avere paura di + noun/infinitive",
        "ru": "avere paura di + существительное/инфинитив"
      },
      "description": {
        "en": "'Avere paura di' means 'to be afraid of'. It is followed by a noun (with di + article contracting as needed) or an infinitive.",
        "ru": "«Avere paura di» означает «бояться чего-то/кого-то». После него следует существительное (с предлогом di + артикль в слитной форме) или инфинитив."
      },
      "examples": [
        {
          "it": "Ho paura di parlare in italiano.",
          "en": "I am afraid of speaking Italian.",
          "ru": "Я боюсь говорить по-итальянски."
        },
        {
          "it": "Ha paura della moglie.",
          "en": "He is afraid of his wife.",
          "ru": "Он боится своей жены."
        },
        {
          "it": "Hai paura del professore?",
          "en": "Are you afraid of the teacher?",
          "ru": "Ты боишься преподавателя?"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "avere mal di + body part",
        "ru": "avere mal di + часть тела"
      },
      "description": {
        "en": "'Avere mal di' is used to express a specific pain or ache. Followed directly by the body part (no article needed for common expressions).",
        "ru": "«Avere mal di» используется для выражения конкретной боли. После него следует название части тела (в устойчивых выражениях артикль не нужен)."
      },
      "examples": [
        {
          "it": "Ho mal di testa.",
          "en": "I have a headache.",
          "ru": "У меня болит голова."
        },
        {
          "it": "Ha mal di stomaco.",
          "en": "He/she has a stomachache.",
          "ru": "У него/неё болит живот."
        },
        {
          "it": "Hai mal di gola?",
          "en": "Do you have a sore throat?",
          "ru": "У тебя болит горло?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Qual è il tuo/Suo...? — asking for personal details",
        "ru": "Qual è il tuo/Suo...? — запрос личных данных"
      },
      "description": {
        "en": "'Qual è' means 'what is' for identity-type questions. Used with possessives to ask for name, surname, or phone number. 'Tuo/tua' is informal; 'Suo/Sua' (capitalised) is formal.",
        "ru": "«Qual è» означает «что такое / какой» в вопросах об идентификации. Используется с притяжательными местоимениями для запроса имени, фамилии или номера телефона. «Tuo/tua» — неформально; «Suo/Sua» (с заглавной буквы) — официально."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Qual è il tuo nome?",
          "en": "What is your first name?",
          "ru": "Как тебя зовут?"
        },
        {
          "context": "informal",
          "it": "Qual è il tuo cognome?",
          "en": "What is your surname?",
          "ru": "Какая твоя фамилия?"
        },
        {
          "context": "informal",
          "it": "Qual è il tuo numero di cellulare?",
          "en": "What is your mobile number?",
          "ru": "Какой у тебя номер мобильного?"
        },
        {
          "context": "formal",
          "it": "Qual è il Suo nome?",
          "en": "What is your first name? (formal)",
          "ru": "Как вас зовут? (официально)"
        },
        {
          "context": "formal",
          "it": "Qual è il Suo cognome?",
          "en": "What is your surname? (formal)",
          "ru": "Какая ваша фамилия? (официально)"
        },
        {
          "context": "formal",
          "it": "Qual è il Suo numero di cellulare?",
          "en": "What is your mobile number? (formal)",
          "ru": "Какой у вас номер мобильного? (официально)"
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Lettera Z — [dz] vs [ts]",
        "ru": "Буква Z — [dz] и [ts]"
      },
      "description": {
        "en": "The letter Z in Italian can represent two sounds: [dz] (voiced) and [ts] (unvoiced). The sound depends on the word and spelling pattern.",
        "ru": "Буква Z в итальянском языке может обозначать два звука: [dz] (звонкий) и [ts] (глухой). Звук зависит от слова и модели написания."
      }
    }
  ],
