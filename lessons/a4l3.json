{
  "lesson_info": {
    "id": "A1-L4-3",
    "title": "Un incontro",
    "level": "A1",
    "objectives": {
      "it": [
        "Ripasso: Perché vai al bar?",
        "Lessico: Bevande e spuntini",
        "Comprensione orale: Al bar",
        "Attività comunicativa: E tu che cosa prendi?"
      ],
      "en": [
        "Review: Why do you go to the bar?",
        "Vocabulary: drinks and snacks",
        "Listening comprehension: At the bar",
        "Communicative activity: And what are you having?"
      ],
      "ru": [
        "Повторение: Perché vai al bar?",
        "Лексика: bevande e spuntini",
        "Аудирование: Al bar",
        "Коммуникативное задание: E tu che cosa prendi?"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Verbs in -ire with -isc- infix",
        "ru": "Глаголы на -ire с суффиксом -isc-"
      },
      "description": {
        "en": "Some -ire verbs insert -isc- between the stem and the ending in all singular forms and the 3rd person plural. Common examples: preferire, capire, finire, pulire.",
        "ru": "Некоторые глаголы на -ire вставляют -isc- между основой и окончанием во всех формах единственного числа и в 3-м лице множественного. Примеры: preferire, capire, finire, pulire."
      },
      "conjugations": {
        "io": "preferisco",
        "tu": "preferisci",
        "lui/lei/Lei": "preferisce",
        "noi": "preferiamo",
        "voi": "preferite",
        "loro": "preferiscono"
      },
      "examples": [
        {
          "it": "Preferisci un succo di frutta o una spremuta d'arancia?",
          "en": "Do you prefer a fruit juice or a fresh orange juice?",
          "ru": "Ты предпочитаешь фруктовый сок или свежевыжатый апельсиновый?"
        },
        {
          "it": "I miei amici preferiscono andare in discoteca.",
          "en": "My friends prefer going to the disco.",
          "ru": "Мои друзья предпочитают ходить на дискотеку."
        },
        {
          "it": "A che ora finisce la lezione?",
          "en": "What time does the lesson finish?",
          "ru": "В котором часу заканчивается урок?"
        },
        {
          "it": "Non capisco questa parola.",
          "en": "I don't understand this word.",
          "ru": "Я не понимаю это слово."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Review: prendere at the bar",
        "ru": "Повторение: prendere в баре"
      },
      "description": {
        "en": "The verb 'prendere' is the standard way to order at a bar in Italian.",
        "ru": "Глагол «prendere» — стандартный способ сделать заказ в итальянском баре."
      },
      "conjugations": {
        "io": "prendo",
        "tu": "prendi",
        "lui/lei/Lei": "prende",
        "noi": "prendiamo",
        "voi": "prendete",
        "loro": "prendono"
      },
      "examples": [
        {
          "it": "Allora ragazzi, che cosa prendete?",
          "en": "So, what will you all have?",
          "ru": "Ну что, ребята, что будете?"
        },
        {
          "it": "Io prendo un tramezzino.",
          "en": "I'll have a triangular sandwich.",
          "ru": "Я возьму треугольный бутерброд."
        },
        {
          "it": "Tu, Stefano, che cosa prendi?",
          "en": "Stefano, what will you have?",
          "ru": "Стефано, что ты будешь?"
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Identifying the odd one out: l'intruso",
        "ru": "Найди лишнее: l'intruso"
      },
      "description": {
        "en": "A vocabulary exercise where students identify which word does not belong to a category and explain why.",
        "ru": "Лексическое упражнение: студенты определяют, какое слово не подходит к группе, и объясняют почему."
      },
      "examples": [
        {
          "it": "caffè - tè - panino - acqua - coca-cola - cappuccino",
          "en": "L'intruso è panino perché è uno spuntino, non una bevanda.",
          "ru": "Лишнее — panino, потому что это закуска, а не напиток."
        },
        {
          "it": "tè - panino - piadina - tramezzino - toast",
          "en": "L'intruso è tè perché è una bevanda, non uno spuntino.",
          "ru": "Лишнее — tè, потому что это напиток, а не закуска."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Expressing preferences: Preferisci…?",
        "ru": "Выражение предпочтений: Preferisci…?"
      },
      "description": {
        "en": "Use 'preferire' to ask and state preferences between two options.",
        "ru": "Глагол «preferire» используется для вопросов и ответов о предпочтениях между двумя вариантами."
      },
      "examples": [
        {
          "context": "question",
          "it": "Preferisci il mare o la montagna?",
          "en": "Do you prefer the sea or the mountains?",
          "ru": "Ты предпочитаешь море или горы?"
        },
        {
          "context": "answer",
          "it": "Preferisco il mare.",
          "en": "I prefer the sea.",
          "ru": "Я предпочитаю море."
        },
        {
          "context": "agreement",
          "it": "Anch'io!",
          "en": "Me too!",
          "ru": "Я тоже!"
        },
        {
          "context": "disagreement",
          "it": "Io invece preferisco la montagna.",
          "en": "I on the other hand prefer the mountains.",
          "ru": "А я, наоборот, предпочитаю горы."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Daily routine verbs",
        "ru": "Глаголы повседневной жизни"
      },
      "description": {
        "en": "Common verbs used to describe a daily routine, from the homework solutions slide.",
        "ru": "Распространённые глаголы для описания распорядка дня."
      },
      "examples": [
        {
          "it": "Lavoro, torno, dormo, guardo, leggo, navigo, mangio, viaggio.",
          "en": "I work, I return, I sleep, I watch, I read, I browse, I eat, I travel.",
          "ru": "Я работаю, возвращаюсь, сплю, смотрю, читаю, сижу в интернете, ем, путешествую."
        }
      ]
    }
  ],
