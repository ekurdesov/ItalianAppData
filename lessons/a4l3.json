  "dialogues": [
    {
      "id": "D-A1L4-3-01",
      "title": "Preferisci il tè o il caffè?",
      "register": "informal",
      "context": {
        "en": "Two students practise expressing preferences using preferire.",
        "ru": "Два студента тренируются выражать предпочтения с помощью глагола preferire.",
        "es": "Dos estudiantes practican expresar preferencias usando preferire."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Preferisci il mare o la montagna?",
          "en": "Do you prefer the sea or the mountains?",
          "ru": "Ты предпочитаешь море или горы?",
          "es": "¿Prefieres el mar o la montaña?"
        },
        {
          "speaker": "B",
          "it": "Preferisco il mare. E tu?",
          "en": "I prefer the sea. And you?",
          "ru": "Я предпочитаю море. А ты?",
          "es": "Prefiero el mar. ¿Y tú?"
        },
        {
          "speaker": "A",
          "it": "Anch'io!",
          "en": "Me too!",
          "ru": "Я тоже!",
          "es": "¡Yo también!"
        },
        {
          "speaker": "A",
          "it": "E al bar, preferisci il caffè o il tè?",
          "en": "And at the bar, do you prefer coffee or tea?",
          "ru": "А в баре ты предпочитаешь кофе или чай?",
          "es": "Y en la barra, ¿prefieres café o té?"
        },
        {
          "speaker": "B",
          "it": "Preferisco il caffè. Non capisco come le persone bevono il tè la mattina!",
          "en": "I prefer coffee. I don't understand how people drink tea in the morning!",
          "ru": "Я предпочитаю кофе. Не понимаю, как люди пьют чай по утрам!",
          "es": "Prefiero el café. ¡No entiendo cómo la gente bebe té por la mañana!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask if someone prefers the sea or the mountains",
            "ru": "Спросить, что кто-то предпочитает: море или горы",
            "es": "Pregunta si alguien prefiere el mar o la montaña."
          },
          "expected_it": "Preferisci il mare o la montagna?"
        },
        {
          "cue": {
            "en": "Say you prefer something",
            "ru": "Сказать, что предпочитаешь",
            "es": "Di que prefieres algo"
          },
          "expected_it": "Preferisco …"
        },
        {
          "cue": {
            "en": "Say you don't understand a word",
            "ru": "Сказать, что не понимаешь слово",
            "es": "Di que no entiendes una palabra"
          },
          "expected_it": "Non capisco questa parola."
        }
      ]
    }
  ],
