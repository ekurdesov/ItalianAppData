      ],
      "en": [
        "Listening comprehension: meetings",
        "Introducing a person",
        "Verb stare",
        "Communicative activity: how is it going?",
        "Phonetics: sc"
      ],
      "ru": [
        "Аудирование: встречи",
        "Представление человека",
        "Глагол stare",
        "Коммуникативное задание: come va?",
        "Фонетика: sc"
      ]
    }
