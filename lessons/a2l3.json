  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Present tense of stare",
        "ru": "Настоящее время глагола stare"
      },
      "description": {
        "en": "The verb 'stare' is used to ask and say how someone is, and in some contexts to indicate a state or location.",
        "ru": "Глагол «stare» используется, чтобы спросить и сказать, как дела у кого-либо, а в некоторых контекстах — чтобы указать на состояние или местонахождение."
      },
      "conjugations": {
        "io": "sto",
        "tu": "stai",
        "lui/lei/Lei": "sta",
        "noi": "stiamo",
        "voi": "state",
        "loro": "stanno"
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking how someone is: formal vs informal",
        "ru": "Вопрос «как дела»: официально и неформально"
      },
      "description": {
        "en": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking how someone is.",
        "ru": "В итальянском языке различаются неформальное «tu» и официальное «Lei» при вопросе о самочувствии."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come stai?",
          "en": "How are you?",
          "ru": "Как дела?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "en": "And you?",
          "ru": "А ты?"
        },
        {
          "context": "formal",
          "it": "Come sta?",
          "en": "How are you?",
          "ru": "Как дела? (официально)"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "en": "And you?",
          "ru": "А вы?"
        },
        {
          "context": "neutral",
          "it": "Come va?",
          "en": "How is it going?",
          "ru": "Как дела?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Common responses to 'Come stai?' / 'Come va?'",
        "ru": "Типичные ответы на «Come stai?» / «Come va?»"
      },
      "description": {
        "en": "There are several fixed expressions for answering questions about well-being.",
        "ru": "Существует несколько устойчивых выражений для ответа на вопросы о самочувствии."
      },
      "examples": [
        {
          "it": "Benissimo / Molto bene, grazie.",
          "en": "Very well, thank you.",
          "ru": "Очень хорошо, спасибо."
        },
        {
          "it": "Abbastanza bene, grazie.",
          "en": "Quite well, thank you.",
          "ru": "Довольно хорошо, спасибо."
        },
        {
          "it": "Va bene, grazie.",
          "en": "I'm fine, thank you.",
          "ru": "Всё хорошо, спасибо."
        },
        {
          "it": "Non c'è male, grazie.",
          "en": "Not bad, thank you.",
          "ru": "Неплохо, спасибо."
        },
        {
          "it": "Così così. / Insomma.",
          "en": "So-so.",
          "ru": "Так себе."
        },
        {
          "it": "Non mi lamento, grazie.",
          "en": "I can't complain, thank you.",
          "ru": "Не жалуюсь, спасибо."
        },
        {
          "it": "Si vive, grazie.",
          "en": "Surviving, thanks.",
          "ru": "Живём, спасибо."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Introducing someone: formal vs informal",
        "ru": "Представление кого-либо: официально и неформально"
      },
      "description": {
        "en": "Italian uses different introduction formulas depending on the level of formality.",
        "ru": "В итальянском языке используются разные формулы представления в зависимости от степени формальности."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Ti presento Mario.",
          "en": "Let me introduce Mario to you.",
          "ru": "Познакомься, это Марио."
        },
        {
          "context": "informal",
          "it": "Lui/Questo è Mario.",
          "en": "He/This is Mario.",
          "ru": "Он / Это Марио."
        },
        {
          "context": "informal",
          "it": "Lei/Questa è Maria.",
          "en": "She/This is Maria.",
          "ru": "Она / Это Мария."
        },
        {
          "context": "formal",
          "it": "Le presento il signor Bianchi.",
          "en": "Let me introduce Mr. Bianchi to you.",
          "ru": "Позвольте представить господина Бьянки."
        },
        {
          "context": "formal",
          "it": "Lei/Questa è la signora Bianchi.",
          "en": "She/This is Mrs. Bianchi.",
          "ru": "Она / Это госпожа Бьянки."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Reacting to an introduction",
        "ru": "Реакция на представление"
      },
      "description": {
        "en": "Typical polite formulas used after being introduced to someone.",
        "ru": "Типичные вежливые фразы, используемые после представления."
      },
      "examples": [
        {
          "it": "Piacere di conoscerti.",
          "en": "Nice to meet you. (informal)",
          "ru": "Приятно познакомиться. (неформально)"
        },
        {
          "it": "Piacere di conoscerla.",
          "en": "Nice to meet you. (formal)",
          "ru": "Приятно познакомиться. (официально)"
        },
        {
          "it": "Molto lieto/a.",
          "en": "Very pleased.",
          "ru": "Очень рад / очень рада."
        },
        {
          "it": "Piacere.",
          "en": "Pleasure.",
          "ru": "Приятно."
        },
        {
          "it": "Piacere mio.",
          "en": "The pleasure is mine.",
          "ru": "Мне тоже приятно."
        },
        {
          "it": "Altrettanto.",
          "en": "Likewise.",
          "ru": "Взаимно."
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Pronunciation of 'sc'",
        "ru": "Произношение «sc»"
      },
      "description": {
        "en": "The sound of 'sc' changes depending on the letters that follow it.",
        "ru": "Звук «sc» меняется в зависимости от следующих за ним букв."
      }
    }
  ],
