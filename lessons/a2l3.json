  "dialogues": [
    {
      "id": "D-A1L1-2-01",
      "title": "Come stai? (informal, evening)",
      "register": "informal",
      "context": {
        "en": "Two friends run into each other in the evening",
        "ru": "Два друга случайно встречаются вечером"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, come stai?",
          "en": "Hi, how are you?",
          "ru": "Привет, как ты?"
        },
        {
          "speaker": "B",
          "it": "Bene, grazie, e tu?",
          "en": "Good, thanks, and you?",
          "ru": "Хорошо, спасибо, а ты?"
        },
        {
          "speaker": "A",
          "it": "Insomma.",
          "en": "So-so.",
          "ru": "Так себе."
        },
        {
          "speaker": "B",
          "it": "Buona notte!",
          "en": "Good night!",
          "ru": "Спокойной ночи!"
        },
        {
          "speaker": "A",
          "it": "Buona notte a tutti!",
          "en": "Good night everyone!",
          "ru": "Спокойной ночи всем!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask how your friend is (informal)",
