  "dialogues": [
    {
      "id": "D-A1L2-7-01",
      "title": "L'italiano nel mondo",
      "register": "informal",
      "context": {
        "en": "Two students discuss Italian around the world and practise definite articles.",
        "ru": "Два студента обсуждают итальянский язык в мире и тренируют определённые артикли."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Sai che l'italiano è parlato in molti paesi del mondo?",
          "en": "Did you know that Italian is spoken in many countries of the world?",
          "ru": "Ты знаешь, что на итальянском говорят во многих странах мира?"
        },
        {
          "speaker": "B",
          "it": "Sì! Per esempio, in Argentina ci sono molti italiani.",
          "en": "Yes! For example, in Argentina there are many Italians.",
          "ru": "Да! Например, в Аргентине много итальянцев."
        },
        {
          "speaker": "A",
          "it": "E anche negli Stati Uniti. Il cognome Ferrari è molto famoso.",
          "en": "And also in the United States. The surname Ferrari is very famous.",
          "ru": "И в США тоже. Фамилия Феррари очень известна."
        },
        {
          "speaker": "B",
          "it": "È vero. Hai il libro di italiano?",
          "en": "That's true. Do you have the Italian book?",
          "ru": "Это правда. У тебя есть учебник итальянского?"
        },
        {
          "speaker": "A",
          "it": "Sì, ho il libro e il dizionario.",
          "en": "Yes, I have the book and the dictionary.",
          "ru": "Да, у меня есть учебник и словарь."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask if someone has the book",
            "ru": "Спросить, есть ли у кого-то книга"
          },
          "expected_it": "Hai il libro?"
        },
        {
          "cue": {
            "en": "Say you have the book and the dictionary",
            "ru": "Сказать, что у тебя есть книга и словарь"
          },
          "expected_it": "Ho il libro e il dizionario."
        },
        {
          "cue": {
            "en": "Use the definite article with a masculine noun",
            "ru": "Использовать определённый артикль с существительным мужского рода"
          },
          "expected_it": "il / lo / l' + noun"
        }
      ]
    }
  ],
