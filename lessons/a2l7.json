  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "essere vs avere in everyday descriptions",
        "ru": "essere и avere в повседневных описаниях",
        "es": "essere vs avere en las descripciones cotidianas"
      },
      "description": {
        "en": "Italian uses 'essere' with adjectives and 'avere' with many physical or emotional states expressed as nouns.",
        "ru": "В итальянском языке 'essere' употребляется с прилагательными, а 'avere' — со многими физическими и эмоциональными состояниями, выраженными существительными.",
        "es": "El italiano utiliza 'essere' con adjetivos y 'avere' con muchos estados físicos o emocionales expresados ​​como sustantivos."
      },
      "examples": [
        {
          "it": "Sono triste.",
          "en": "I am sad.",
          "ru": "Мне грустно.",
          "es": "Estoy triste."
        },
        {
          "it": "Sono contento/a.",
          "en": "I am happy.",
          "ru": "Я рад / рада.",
          "es": "Yo estoy feliz."
        },
        {
          "it": "Ho fame.",
          "en": "I am hungry.",
          "ru": "Я голоден / голодна.",
          "es": "Estoy hambriento."
        },
        {
          "it": "Hai sete?",
          "en": "Are you thirsty?",
          "ru": "Ты хочешь пить?",
          "es": "¿Tienes sed?"
        },
        {
          "it": "Abbiamo fretta.",
          "en": "We are in a hurry.",
          "ru": "Мы спешим.",
          "es": "Tenemos prisa."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Definite articles in the singular",
        "ru": "Определённые артикли в единственном числе",
        "es": "Artículos definidos en singular."
      },
      "description": {
        "en": "Italian definite articles agree with the noun in gender and number. In the singular, the main forms are 'il', 'lo', 'la' and 'l''.",
        "ru": "Итальянские определённые артикли согласуются с существительным по роду и числу. В единственном числе основные формы: 'il', 'lo', 'la' и 'l''.",
        "es": "Los artículos definidos italianos concuerdan con el sustantivo en género y número. En singular, las formas principales son 'il', 'lo', 'la' y 'l''."
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Definite articles in the plural",
        "ru": "Определённые артикли во множественном числе",
        "es": "Artículos definidos en plural."
      },
      "description": {
        "en": "Plural definite articles also agree with the noun. The main forms are 'i', 'gli' and 'le'.",
        "ru": "Во множественном числе определённые артикли тоже согласуются с существительным. Основные формы: 'i', 'gli' и 'le'.",
        "es": "Los artículos definidos en plural también concuerdan con el sustantivo. Las formas principales son 'i', 'gli' y 'le'."
      }
    },
    {
      "category": {
        "en": "Culture",
        "ru": "Культура",
        "es": "Cultura"
      },
      "rule": {
        "en": "Italian in the world",
        "ru": "Итальянский язык в мире",
        "es": "italiano en el mundo"
      },
      "description": {
        "en": "The lesson presents Italian as a world language connected with travel, culture, design, food, music and art.",
        "ru": "В уроке итальянский язык представлен как мировой язык, связанный с путешествиями, культурой, дизайном, едой, музыкой и искусством.",
        "es": "La lección presenta el italiano como un idioma mundial relacionado con los viajes, la cultura, el diseño, la comida, la música y el arte."
      },
      "examples": [
        {
          "it": "L'italiano è parlato in tutto il mondo.",
          "en": "Italian is spoken all over the world.",
          "ru": "На итальянском говорят по всему миру.",
          "es": "El italiano se habla en todo el mundo."
        },
        {
          "it": "L'italiano è parlato in Europa, in America, in Africa, in Australia e in Giappone.",
          "en": "Italian is spoken in Europe, America, Africa, Australia and Japan.",
          "ru": "На итальянском говорят в Европе, Америке, Африке, Австралии и Японии.",
          "es": "El italiano se habla en Europa, América, África, Australia y Japón."
        },
        {
          "it": "L'italiano è importante per il design, la letteratura, il cinema e la musica.",
          "en": "Italian is important for design, literature, cinema and music.",
          "ru": "Итальянский важен для дизайна, литературы, кино и музыки.",
          "es": "El italiano es importante para el diseño, la literatura, el cine y la música."
        }
      ]
    }
