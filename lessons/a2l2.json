  "lesson_info": {
    "id": "A1-L2-2",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": {
      "it": [
        "Comprensione orale: Ciao, io sono Alice",
        "Aggettivi di nazionalità al plurale",
        "Attività comunicativa: presentare",
        "Fonetica: gli - gn, sc"
      ],
      "en": [
        "Listening comprehension: Hi, I'm Alice",
        "Plural nationality adjectives",
        "Communicative activity: introducing someone",
        "Phonetics: gli - gn, sc"
      ],
      "ru": [
        "Аудирование: 'Ciao, io sono Alice'",
        "Прилагательные национальности во множественном числе",
        "Коммуникативное задание: представить кого-то",
        "Фонетика: gli - gn, sc"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Nationality adjectives in the plural",
        "ru": "Прилагательные национальности во множественном числе"
      },
      "description": {
        "en": "Nationality adjectives agree with the noun in gender and number, including plural forms.",
        "ru": "Прилагательные национальности согласуются с существительным по роду и числу, в том числе во множественном числе."
      },
      "examples": [
        {
          "it": "tedeschi / tedesche",
          "en": "German men / German women",
          "ru": "немцы / немки"
        },
        {
          "it": "italiani / italiane",
          "en": "Italian men / Italian women",
          "ru": "итальянцы / итальянки"
        },
        {
          "it": "francesi",
          "en": "French (plural)",
          "ru": "французы / француженки (множественное число)"
        },
        {
          "it": "inglesi",
          "en": "English (plural)",
          "ru": "англичане / англичанки (множественное число)"
        },
        {
          "it": "americani / americane",
          "en": "American men / American women",
          "ru": "американцы / американки"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Asking and stating origin",
        "ru": "Вопрос о происхождении и ответ на него"
      },
      "description": {
        "en": "Italian distinguishes informal 'tu' and formal 'Lei' when asking where someone is from.",
        "ru": "В итальянском языке различаются неформальное обращение «tu» и формальное «Lei» при вопросе о происхождении."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Di dove sei?",
          "en": "Where are you from?",
          "ru": "Откуда ты?"
        },
        {
          "context": "formal",
          "it": "Di dov'è?",
          "en": "Where are you from? (formal)",
          "ru": "Откуда вы? (официально)"
        },
        {
          "context": "answer",
          "it": "Sono italiano.",
          "en": "I am Italian.",
          "ru": "Я итальянец."
        },
        {
          "context": "answer",
          "it": "Sono di Milano.",
          "en": "I am from Milan.",
          "ru": "Я из Милана."
        },
        {
          "context": "answer",
          "it": "Sono italiano, di Milano.",
          "en": "I am Italian, from Milan.",
          "ru": "Я итальянец, из Милана."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Demonstratives: questo, questa, questi, queste",
        "ru": "Указательные местоимения: questo, questa, questi, queste"
      },
      "description": {
        "en": "Italian demonstratives agree in gender and number with the noun they refer to.",
        "ru": "Указательные местоимения в итальянском языке согласуются с существительным по роду и числу."
      },
      "examples": [
        {
          "it": "Questo è Mario.",
          "en": "This is Mario.",
          "ru": "Это Марио."
        },
        {
          "it": "Questi sono Mario e Valerio.",
          "en": "These are Mario and Valerio.",
          "ru": "Это Марио и Валерио."
        },
        {
          "it": "Questa è Stefania.",
          "en": "This is Stefania.",
          "ru": "Это Стефания."
        },
        {
          "it": "Queste sono Stefania e Sofia.",
          "en": "These are Stefania and Sofia.",
          "ru": "Это Стефания и София."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Introducing people: formal vs informal",
        "ru": "Представление людей: официально и неформально"
      },
      "description": {
        "en": "Italian uses different formulas for presenting someone in informal and formal situations.",
        "ru": "В итальянском языке используются разные формулы представления в неформальных и официальных ситуациях."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Ti presento Mario.",
          "en": "Let me introduce Mario to you.",
          "ru": "Познакомься, это Марио."
        },
        {
          "context": "informal",
          "it": "Lui/Questo è Mario.",
          "en": "He/This is Mario.",
          "ru": "Он / Это Марио."
        },
        {
          "context": "informal",
          "it": "Lei/Questa è Maria.",
          "en": "She/This is Maria.",
          "ru": "Она / Это Мария."
        },
        {
          "context": "formal",
          "it": "Le presento il signor Bianchi.",
          "en": "Let me introduce Mr. Bianchi to you.",
          "ru": "Позвольте представить господина Бьянки."
        },
        {
          "context": "formal",
          "it": "Lei/Questa è la signora Bianchi.",
          "en": "She/This is Mrs. Bianchi.",
          "ru": "Она / Это госпожа Бьянки."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Titles of courtesy",
        "ru": "Вежливые обращения"
      },
      "description": {
        "en": "Use 'signor' and 'signora' as polite titles before surnames or in formal address.",
        "ru": "«Signor» и «signora» используются как вежливые обращения перед фамилией или при официальном обращении."
      },
      "examples": [
        {
          "it": "Questo è il signor Rossi.",
          "en": "This is Mr. Rossi.",
          "ru": "Это господин Росси."
        },
        {
          "it": "Questa è la signora Rossi.",
          "en": "This is Mrs. Rossi.",
          "ru": "Это госпожа Росси."
        },
        {
          "it": "Buonasera, signor Rossi!",
          "en": "Good evening, Mr. Rossi!",
          "ru": "Добрый вечер, господин Росси!"
        },
        {
          "it": "Buonasera, signora Rossi!",
          "en": "Good evening, Mrs. Rossi!",
          "ru": "Добрый вечер, госпожа Росси!"
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Sounds of l, gli, gn, and nasal n before c/q/g",
        "ru": "Звуки l, gli, gn и носовой n перед c/q/g"
      },
      "description": {
        "en": "The lesson contrasts plain 'l', palatal 'gli', palatal nasal 'gn', and nasal assimilation before certain consonants.",
        "ru": "На занятии сравниваются обычный звук «l», палатальный «gli», палатальный носовой «gn» и носовая ассимиляция перед определёнными согласными."
      }
    }
  ],
