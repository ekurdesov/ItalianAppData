  "dialogues": [
    {
      "id": "D-A1L2-2-01",
      "title": "È una città bellissima!",
      "register": "informal",
      "context": {
        "en": "Two students meet for the first time and talk about their origins — the key model dialogue from the lesson",
        "ru": "Два студента встречаются впервые и говорят о своём происхождении — ключевой диалог-образец из урока",
        "es": "Dos estudiantes se encuentran por primera vez y hablan sobre sus orígenes: el diálogo modelo clave de la lección."
      },
      "turns": [
        {
          "speaker": "Pierre",
          "it": "Ciao, mi chiamo Pierre. E tu, come ti chiami?",
          "en": "Hi, my name is Pierre. And you, what's your name?",
          "ru": "Привет, меня зовут Пьер. А тебя как зовут?",
          "es": "Hola, mi nombre es Pierre. Y tú, ¿cómo te llamas?"
        },
        {
          "speaker": "Mariana",
          "it": "Io sono Mariana. Piacere.",
          "en": "I am Mariana. Pleased to meet you.",
          "ru": "Я Мариана. Приятно познакомиться.",
          "es": "Soy mariana. Encantado de conocerte."
        },
        {
          "speaker": "Pierre",
          "it": "Di dove sei?",
          "en": "Where are you from?",
          "ru": "Откуда ты?",
          "es": "¿De dónde eres?"
        },
        {
          "speaker": "Mariana",
          "it": "Sono italiana, di Livorno. E tu? Non sei italiano, vero?",
          "en": "I am Italian, from Livorno. And you? You're not Italian, right?",
          "ru": "Я итальянка, из Ливорно. А ты? Ты ведь не итальянец, правда?",
          "es": "Soy italiana, de Livorno. ¿Y tú? No eres italiano, ¿verdad?"
        },
        {
          "speaker": "Pierre",
          "it": "No, sono francese, di Parigi.",
          "en": "No, I am French, from Paris.",
          "ru": "Нет, я француз, из Парижа.",
          "es": "No, soy francesa, de París."
        },
        {
          "speaker": "Mariana",
          "it": "Parigi?! È una città bellissima!",
          "en": "Paris?! It is a beautiful city!",
          "ru": "Париж?! Это очень красивый город!",
          "es": "¡¿París?! ¡Es una ciudad hermosa!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask where they are from using a negative tag question",
            "ru": "Спросите, откуда человек, используя разделительный вопрос с отрицанием",
            "es": "Pregunte de dónde son utilizando una pregunta de etiqueta negativa."
          },
          "expected_it": "Non sei [nazionalità], vero?"
        },
        {
          "cue": {
            "en": "Confirm your nationality and city",
            "ru": "Подтвердите свою национальность и город",
            "es": "Confirma tu nacionalidad y ciudad"
          },
          "expected_it": "No, sono [nazionalità], di [città]."
        },
        {
          "cue": {
            "en": "Exclaim that a city is beautiful",
            "ru": "Воскликните, что какой-то город очень красивый",
            "es": "Exclamar que una ciudad es hermosa"
          },
          "expected_it": "[Città]?! È una città bellissima!"
        }
      ]
    },
    {
      "id": "D-A1L2-2-02",
      "title": "Ti presento Giorgio (informale)",
      "register": "informal",
      "context": {
        "en": "A friend introduces a third person informally",
        "ru": "Друг неформально представляет третьего человека",
        "es": "Un amigo presenta a una tercera persona de manera informal."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, Vittoria! Ti presento Giorgio. È italiano, di Milano.",
          "en": "Hi, Vittoria! Let me introduce Giorgio. He is Italian, from Milan.",
          "ru": "Привет, Витториа! Познакомься, это Джорджо. Он итальянец, из Милана.",
          "es": "Hola Vitoria! Déjame presentarte a Giorgio. Es italiano, de Milán."
        },
        {
          "speaker": "Vittoria",
          "it": "Ciao, Giorgio! Piacere di conoscerti!",
          "en": "Hi, Giorgio! Nice to meet you!",
          "ru": "Привет, Джорджо! Приятно познакомиться!",
          "es": "Hola Giorgio! ¡Encantado de conocerlo!"
        },
        {
          "speaker": "Giorgio",
          "it": "Piacere mio!",
          "en": "The pleasure is mine!",
          "ru": "Мне тоже приятно!",
          "es": "¡El placer es mío!"
        }
      ],
      "practice_prompts": [
