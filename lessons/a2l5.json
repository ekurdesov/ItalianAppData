          "es": "tu profesor (informal)"
        },
        {
          "it": "la sua borsa",
          "en": "his/her bag; your bag (formal)",
          "ru": "его/её сумка; ваша сумка (официально)",
          "es": "su bolso; tu bolso (formal)"
