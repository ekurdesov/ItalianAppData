  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "avere + noun for physical/emotional states",
        "ru": "avere + существительное для выражения физических и эмоциональных состояний"
      },
      "description": {
        "en": "Italian uses 'avere' (to have) + a noun to express physical sensations and emotions that English expresses with 'to be'. Literal translation: 'to have hunger', 'to have cold', etc.",
        "ru": "В итальянском языке «avere» (иметь) + существительное используется для выражения физических ощущений и эмоций, которые в русском языке передаются глаголами состояния. Дословный перевод: «иметь голод», «иметь холод» и т. д."
      },
      "examples": [
        {
          "it": "Ho fame.",
          "en": "I am hungry.",
          "ru": "Я хочу есть. (дословно: у меня голод)"
        },
        {
          "it": "Hai sete?",
          "en": "Are you thirsty?",
          "ru": "Ты хочешь пить?"
        },
        {
          "it": "Ha freddo?",
          "en": "Are you cold? (formal)",
          "ru": "Вам холодно? (официально)"
        },
        {
          "it": "Ho fretta!",
          "en": "I am in a hurry!",
          "ru": "Я тороплюсь!"
        },
        {
          "it": "Ha paura.",
          "en": "She/he is afraid.",
          "ru": "Она/он боится."
        },
        {
          "it": "Ho sonno.",
          "en": "I am sleepy.",
          "ru": "Я хочу спать."
        },
        {
          "it": "Non ho tempo.",
          "en": "I don't have time.",
          "ru": "У меня нет времени."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "essere vs avere for states — adjective vs noun",
        "ru": "essere и avere для состояний — прилагательное и существительное"
      },
      "description": {
        "en": "Use 'essere' with adjectives (sono stanco) and 'avere' with nouns for sensations (ho fame). Both express states but the structure differs.",
        "ru": "«Essere» используется с прилагательными (sono stanco), а «avere» — с существительными для ощущений (ho fame). Оба выражают состояния, но структура различается."
      },
      "examples": [
        {
          "it": "Sono stanco.",
          "en": "I am tired.",
          "ru": "Я устал."
        },
        {
          "it": "Sei arrabbiata?",
          "en": "Are you angry?",
          "ru": "Ты злишься?"
        },
        {
          "it": "È annoiato.",
          "en": "He is bored.",
          "ru": "Ему скучно."
        },
        {
          "it": "Siete contenti?",
          "en": "Are you (all) happy?",
          "ru": "Вы (все) довольны?"
        },
        {
          "it": "Ho fame.",
          "en": "I am hungry. (lit. I have hunger)",
          "ru": "Я хочу есть. (дословно: у меня голод)"
        },
        {
          "it": "Ha caldo.",
          "en": "He is hot. (lit. He has heat)",
          "ru": "Ему жарко. (дословно: у него жара)"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Possessive adjectives — singular (il mio, il tuo, il suo)",
        "ru": "Притяжательные прилагательные — единственное число (il mio, il tuo, il suo)"
      },
      "description": {
        "en": "Italian possessive adjectives agree in gender and number with the noun they modify, not with the owner. They are preceded by the definite article.",
        "ru": "Притяжательные прилагательные в итальянском языке согласуются в роде и числе с существительным, которое они определяют, а не с владельцем. Перед ними ставится определённый артикль."
      },
      "examples": [
        {
          "it": "il mio numero",
          "en": "my number",
          "ru": "мой номер"
        },
        {
          "it": "il tuo cognome",
          "en": "your surname (informal)",
          "ru": "твоя фамилия (неформально)"
        },
        {
          "it": "il suo numero",
          "en": "his/her number; your number (formal)",
          "ru": "его/её номер; ваш номер (официально)"
        },
        {
          "it": "la mia classe",
          "en": "my class",
          "ru": "мой класс"
        },
        {
          "it": "la tua professoressa",
          "en": "your professor (informal)",
          "ru": "твоя преподавательница (неформально)"
        },
        {
          "it": "la sua borsa",
          "en": "his/her bag; your bag (formal)",
          "ru": "его/её сумка; ваша сумка (официально)"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Vorrei — polite desire",
        "ru": "Vorrei — вежливое выражение желания"
      },
      "description": {
        "en": "'Vorrei' is the conditional form of 'volere' (to want), used to politely express desire. Equivalent to 'I would like'.",
        "ru": "«Vorrei» — форма условного наклонения глагола «volere» (хотеть), используемая для вежливого выражения желания. Соответствует русскому «Я бы хотел(а)»."
      },
      "examples": [
        {
          "it": "Vorrei una pizza.",
          "en": "I would like a pizza.",
          "ru": "Я бы хотел(а) пиццу."
        },
        {
          "it": "Vorrei andare a letto.",
          "en": "I would like to go to bed.",
          "ru": "Я бы хотел(а) лечь спать."
        },
        {
          "it": "Vorrei un caffè caldo.",
          "en": "I would like a hot coffee.",
          "ru": "Я бы хотел(а) горячий кофе."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking for personal details — formal vs informal",
        "ru": "Запрос личных данных — официально и неформально"
      },
      "description": {
        "en": "Italian uses different question forms depending on register when asking for name, age, or phone number.",
        "ru": "В итальянском языке используются разные формы вопроса в зависимости от регистра при запросе имени, возраста или номера телефона."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Come ti chiami?",
          "en": "What is your name?",
          "ru": "Как тебя зовут?"
        },
        {
          "context": "formal",
          "it": "Come si chiama?",
          "en": "What is your name? (formal)",
          "ru": "Как вас зовут? (официально)"
        },
        {
          "context": "informal",
          "it": "E di cognome?",
          "en": "And your surname?",
          "ru": "А фамилия?"
        },
        {
          "context": "informal",
          "it": "Che numero di cellulare hai?",
          "en": "What is your mobile number?",
          "ru": "Какой у тебя номер телефона?"
        },
        {
          "context": "formal",
          "it": "Che numero di cellulare ha?",
          "en": "What is your mobile number? (formal)",
          "ru": "Какой у вас номер телефона? (официально)"
        },
        {
          "context": "answer",
          "it": "Il mio numero è ...",
          "en": "My number is ...",
          "ru": "Мой номер ..."
        },
        {
          "context": "answer (formal)",
          "it": "Il suo numero è ...",
          "en": "His/her/your number is ...",
          "ru": "Его/её/ваш номер ..."
        }
      ]
    }
  ],
