  "dialogues": [
    {
      "id": "D-A1L3-3-01",
      "title": "Mi presento",
      "register": "neutral",
      "context": {
        "en": "Two classmates exchange a short self-introduction.",
        "ru": "Два однокурсника кратко представляются друг другу."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, mi chiamo Oscar Bellini. Sono argentino e lavoro in un'agenzia immobiliare.",
          "en": "Hi, my name is Oscar Bellini. I am Argentinian and I work in an estate agency.",
          "ru": "Привет, меня зовут Оскар Беллини. Я аргентинец и работаю в агентстве недвижимости."
        },
        {
          "speaker": "B",
          "it": "Piacere. Io sono Lidia White, sono cuoca e abito a Londra.",
          "en": "Nice to meet you. I am Lidia White, I am a cook and I live in London.",
          "ru": "Очень приятно. Я Лидия Уайт, я повар и живу в Лондоне."
        },
        {
          "speaker": "A",
          "it": "Qual è il tuo numero di cellulare?",
          "en": "What is your mobile number?",
          "ru": "Какой у тебя номер мобильного?"
        },
        {
          "speaker": "B",
          "it": "Il mio numero è 349 5574634.",
          "en": "My number is 349 5574634.",
          "ru": "Мой номер 349 5574634."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Say your name and nationality",
            "ru": "Сказать своё имя и национальность"
