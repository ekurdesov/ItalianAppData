      ],
      "en": [
        "Ripasso: Dove abiti?",
        "Comprensione scritta: Mi presento",
        "Grammatica: verbi in -ere, -ire",
        "Chiedere e dire l'indirizzo email"
      ],
      "ru": [
        "Повторение: Dove abiti?",
        "Чтение: Mi presento",
        "Грамматика: глаголы на -ere, -ire",
        "Спрашивать и сообщать адрес электронной почты"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Regular verbs in -ere",
        "ru": "Правильные глаголы на -ere"
      },
      "description": {
        "en": "Many common Italian verbs ending in -ere follow the present-tense pattern -o, -i, -e, -iamo, -ete, -ono.",
        "ru": "Многие распространённые итальянские глаголы на -ere в настоящем времени имеют окончания -o, -i, -e, -iamo, -ete, -ono."
      },
      "conjugations": {
        "io": "scrivo",
        "tu": "scrivi",
        "lui/lei/Lei": "scrive",
        "noi": "scriviamo",
        "voi": "scrivete",
        "loro": "scrivono"
      },
      "examples": [
        {
          "it": "Mario scrive una lettera d'amore.",
          "en": "Mario writes a love letter.",
          "ru": "Марио пишет любовное письмо."
        },
        {
          "it": "Giorgio vende molti gelati.",
          "en": "Giorgio sells many ice creams.",
          "ru": "Джорджо продаёт много мороженого."
        },
        {
          "it": "Noi prendiamo l'autobus delle 7.",
          "en": "We take the bus at seven.",
          "ru": "Мы садимся на автобус в семь."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Regular verbs in -ire",
        "ru": "Правильные глаголы на -ire"
      },
      "description": {
        "en": "Regular verbs in -ire commonly form the present with -o, -i, -e, -iamo, -ite, -ono.",
        "ru": "Правильные глаголы на -ire обычно образуют настоящее время по модели -o, -i, -e, -iamo, -ite, -ono."
      },
      "conjugations": {
        "io": "parto",
        "tu": "parti",
        "lui/lei/Lei": "parte",
        "noi": "partiamo",
        "voi": "partite",
        "loro": "partono"
      },
      "examples": [
        {
          "it": "Luca presenta gli amici all'insegnante.",
          "en": "Luca introduces the friends to the teacher.",
          "ru": "Лука представляет друзей преподавателю."
        },
        {
          "it": "Gli amici di Andrea arrivano alle 10.",
          "en": "Andrea's friends arrive at ten.",
          "ru": "Друзья Андреа приходят к десяти."
        },
        {
          "it": "Io compio gli anni in America.",
          "en": "I celebrate my birthday in America.",
          "ru": "Я праздную день рождения в Америке."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking and giving an email address",
        "ru": "Как спросить и назвать электронный адрес"
      },
      "description": {
        "en": "Italian commonly asks for an email with 'Qual è il tuo indirizzo email?' and states it with 'Il mio indirizzo email è...'.",
        "ru": "В итальянском адрес электронной почты обычно спрашивают через 'Qual è il tuo indirizzo email?' и сообщают через 'Il mio indirizzo email è...'."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Qual è il tuo indirizzo email?",
          "en": "What is your email address?",
          "ru": "Какой у тебя адрес электронной почты?"
        },
        {
          "context": "informal",
          "it": "Il mio indirizzo email è mario.rossi@gmail.com.",
          "en": "My email address is mario.rossi@gmail.com.",
          "ru": "Мой адрес электронной почты: mario.rossi@gmail.com."
        },
        {
          "context": "spelling",
          "it": "Chiocciola, punto, trattino basso.",
          "en": "At sign, dot, underscore.",
          "ru": "Собачка, точка, нижнее подчёркивание."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Symbols used in email addresses",
        "ru": "Символы в электронном адресе"
      },
      "description": {
        "en": "This lesson teaches the Italian names of the most common symbols needed to spell an email address.",
        "ru": "В уроке отрабатываются итальянские названия самых частых символов, нужных для диктовки e-mail."
      },
      "examples": [
        {
          "it": "chiocciola",
          "en": "at sign",
          "ru": "собачка, знак @"
        },
        {
          "it": "punto",
          "en": "dot",
          "ru": "точка"
        },
        {
          "it": "trattino",
          "en": "hyphen",
          "ru": "дефис"
        },
        {
          "it": "trattino basso",
          "en": "underscore",
          "ru": "нижнее подчёркивание"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Introducing yourself in a short profile",
        "ru": "Короткое представление о себе"
      },
      "description": {
        "en": "A simple self-introduction at A1 level often combines name, age, nationality, city, job or study, and interests.",
        "ru": "На уровне A1 самопрезентация обычно объединяет имя, возраст, национальность, город, работу или учёбу и интересы."
      },
      "examples": [
        {
          "it": "Mi chiamo Oscar Bellini, sono argentino e lavoro in un'agenzia immobiliare.",
          "en": "My name is Oscar Bellini, I am Argentinian and I work in an estate agency.",
          "ru": "Меня зовут Оскар Беллини, я аргентинец и работаю в агентстве недвижимости."
        },
        {
          "it": "Sono Lidia White, sono cuoca e il mio numero di cellulare è 349 5574634.",
          "en": "I am Lidia White, I am a cook and my mobile number is 349 5574634.",
          "ru": "Я Лидия Уайт, я повар, и мой номер мобильного телефона 349 5574634."
        },
        {
          "it": "Mi chiamo Li Fang, il mio paese è la Cina e il mio nome utente è Lili08.",
          "en": "My name is Li Fang, my country is China and my username is Lili08.",
          "ru": "Меня зовут Ли Фан, моя страна Китай, а мой логин Lili08."
        }
      ]
    }
