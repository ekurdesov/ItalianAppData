    {
      "id": "D-A1L3-3-04",
      "title": "Perché vai in biblioteca?",
      "register": "informal",
      "context": {
        "en": "Two students discuss why they go places and what they do there.",
        "ru": "Два студента обсуждают, куда они ходят и что там делают."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Dove vai adesso?",
          "en": "Where are you going now?",
          "ru": "Куда ты сейчас идёшь?"
        },
        {
          "speaker": "B",
          "it": "Vado in biblioteca.",
          "en": "I'm going to the library.",
          "ru": "Иду в библиотеку."
        },
        {
          "speaker": "A",
          "it": "Perché vai in biblioteca?",
          "en": "Why are you going to the library?",
          "ru": "Почему ты идёшь в библиотеку?"
        },
        {
          "speaker": "B",
          "it": "Perché studio italiano.",
          "en": "Because I'm studying Italian.",
          "ru": "Потому что учу итальянский."
        },
        {
          "speaker": "A",
          "it": "Che cosa fai lì?",
          "en": "What do you do there?",
          "ru": "Что ты там делаешь?"
        },
        {
          "speaker": "B",
          "it": "Leggo, scrivo e prendo appunti.",
          "en": "I read, write, and take notes.",
          "ru": "Читаю, пишу и делаю заметки."
        },
        {
          "speaker": "A",
          "it": "Io vado al bar.",
          "en": "I'm going to the bar.",
          "ru": "Я иду в бар."
        },
        {
          "speaker": "B",
          "it": "Perché vai al bar?",
          "en": "Why are you going to the bar?",
          "ru": "Почему ты идёшь в бар?"
        },
        {
          "speaker": "A",
          "it": "Perché prendo un caffè e faccio i compiti.",
          "en": "Because I get a coffee and do homework.",
          "ru": "Потому что беру кофе и делаю домашнее задание."
        },
        {
          "speaker": "B",
          "it": "Il bar è tranquillo?",
          "en": "Is the bar quiet?",
          "ru": "В баре тихо?"
        },
        {
          "speaker": "A",
          "it": "A volte sì, a volte no.",
          "en": "Sometimes yes, sometimes no.",
          "ru": "Иногда да, иногда нет."
        },
        {
          "speaker": "B",
          "it": "Allora forse la biblioteca è meglio.",
          "en": "Then maybe the library is better.",
          "ru": "Тогда, может, библиотека лучше."
        },
        {
          "speaker": "A",
          "it": "Hai ragione.",
          "en": "You're right.",
          "ru": "Ты прав."
        },
        {
          "speaker": "B",
          "it": "Vieni con me?",
          "en": "Come with me?",
          "ru": "Пойдёшь со мной?"
        },
        {
          "speaker": "A",
          "it": "Sì, ma prima prendo un caffè.",
          "en": "Yes, but first I'll get a coffee.",
          "ru": "Да, но сначала возьму кофе."
        },
        {
          "speaker": "B",
          "it": "Va bene. Io ti aspetto.",
          "en": "Okay. I'll wait for you.",
          "ru": "Хорошо. Я тебя подожду."
        },
        {
          "speaker": "A",
          "it": "Dove mi aspetti?",
          "en": "Where will you wait for me?",
          "ru": "Где ты меня подождёшь?"
        },
        {
          "speaker": "B",
          "it": "Davanti alla biblioteca.",
          "en": "In front of the library.",
          "ru": "Перед библиотекой."
        },
        {
          "speaker": "A",
          "it": "A che ora?",
          "en": "At what time?",
          "ru": "Во сколько?"
        },
        {
          "speaker": "B",
          "it": "Alle quattro.",
          "en": "At four.",
          "ru": "В четыре."
        },
        {
          "speaker": "A",
          "it": "Perfetto. Porto il libro.",
          "en": "Perfect. I'll bring the book.",
          "ru": "Отлично. Возьму учебник."
