  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Review: fare expressions",
        "ru": "Повторение: выражения с fare",
        "es": "Revisión: expresiones de tarifas"
      },
      "description": {
        "en": "The verb 'fare' is used in many fixed expressions about daily activities. Review of all key 'fare + noun' combinations.",
        "ru": "Глагол «fare» используется во многих устойчивых выражениях о повседневных делах. Повторение всех ключевых сочетаний «fare + существительное».",
        "es": "El verbo 'fare' se utiliza en muchas expresiones fijas sobre las actividades diarias. Revisión de todas las combinaciones clave de 'tarifa + sustantivo'."
      },
      "examples": [
        {
          "it": "Fate colazione con il caffè o con il tè?",
          "en": "Do you have breakfast with coffee or tea?",
          "ru": "Вы завтракаете с кофе или чаем?",
          "es": "¿Desayunas con café o té?"
        },
        {
          "it": "Fate la doccia la mattina o la sera?",
          "en": "Do you take a shower in the morning or in the evening?",
          "ru": "Вы принимаете душ утром или вечером?",
          "es": "¿Te duchas por la mañana o por la noche?"
        },
        {
          "it": "Fate la spesa al mercato o al supermercato?",
          "en": "Do you do the shopping at the market or at the supermarket?",
          "ru": "Вы делаете покупки на рынке или в супермаркете?",
          "es": "¿Haces las compras en el mercado o en el supermercado?"
        },
        {
          "it": "Fate molte foto in vacanza?",
          "en": "Do you take many photos on holiday?",
          "ru": "Вы много фотографируете в отпуске?",
          "es": "¿Haces muchas fotos en vacaciones?"
        }
      ]
    },
