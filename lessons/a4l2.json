  "dialogues": [
    {
      "id": "D-A1L4-2-01",
      "title": "Al bar",
      "register": "informal",
      "context": {
        "en": "Two friends are at the bar and order drinks and snacks.",
        "ru": "Двое друзей в баре заказывают напитки и закуски.",
        "es": "Dos amigos están en el bar y piden bebidas y bocadillos."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Allora, che cosa prendi?",
          "en": "So, what will you have?",
          "ru": "Ну что, что ты будешь?",
          "es": "Entonces, ¿qué tendrás?"
        },
        {
          "speaker": "B",
          "it": "Prendo un cappuccino e un cornetto. E tu?",
          "en": "I'll have a cappuccino and a croissant. And you?",
          "ru": "Я возьму капучино и круассан. А ты?",
          "es": "Tomaré un capuchino y un croissant. ¿Y tú?"
        },
        {
          "speaker": "A",
          "it": "Io prendo un caffè e un tramezzino al tonno.",
          "en": "I'll have an espresso and a tuna sandwich.",
          "ru": "Я возьму эспрессо и бутерброд с тунцом.",
          "es": "Tomaré un espresso y un sándwich de atún."
        },
        {
          "speaker": "B",
          "it": "Paghiamo alla cassa?",
          "en": "Shall we pay at the till?",
          "ru": "Платим в кассе?",
          "es": "¿Pagamos en caja?"
        },
        {
          "speaker": "A",
          "it": "Sì, oggi offro io!",
          "en": "Yes, today it's my treat!",
          "ru": "Да, сегодня угощаю я!",
          "es": "¡Sí, hoy es mi regalo!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask what someone will have",
            "ru": "Спросить, что кто-то будет",
            "es": "Preguntar qué tendrá alguien"
          },
          "expected_it": "Che cosa prendi?"
        },
        {
          "cue": {
            "en": "Order a drink and a snack",
            "ru": "Заказать напиток и закуску",
            "es": "Pide una bebida y un snack"
          },
          "expected_it": "Prendo un/una … e un/una …"
        },
        {
          "cue": {
            "en": "Say it is your treat",
            "ru": "Сказать, что угощаешь",
            "es": "Di que es tu regalo"
          },
          "expected_it": "Oggi offro io!"
        }
      ]
    }
  ],
