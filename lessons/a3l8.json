        "Listening comprehension: Italian first and last names",
        "Grammar: essere vs esserci",
        "Communicative activity: So many questions!"
      ],
      "ru": [
        "Повторение: Com'è?",
        "Аудирование: Nomi e cognomi italiani",
        "Грамматика: essere vs esserci",
        "Коммуникативное задание: Quante domande!"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "essere vs esserci — contrast",
        "ru": "essere vs esserci — сравнение"
      },
      "description": {
        "en": "'È/sono' locates or identifies something already known. 'C'è/ci sono' introduces or announces the existence of something.",
        "ru": "«È/sono» указывает на местонахождение или идентифицирует уже известное. «C'è/ci sono» сообщает о существовании чего-либо."
      },
      "examples": [
        {
          "it": "L'orologio è nel cassetto.",
          "en": "The watch is in the drawer.",
          "ru": "Часы в ящике."
        },
        {
          "it": "Nel cassetto c'è l'orologio.",
          "en": "There is a watch in the drawer.",
          "ru": "В ящике есть часы."
        },
        {
          "it": "Gli amici sono al bar.",
          "en": "The friends are at the bar.",
          "ru": "Друзья в баре."
        },
        {
          "it": "Al bar ci sono gli amici.",
          "en": "There are friends at the bar.",
          "ru": "Друзья в баре."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Question words (interrogativi)",
        "ru": "Вопросительные слова (interrogativi)"
      },
      "description": {
        "en": "Italian question words used to ask about people, things, places, time, and reasons.",
        "ru": "Итальянские вопросительные слова для вопросов о людях, предметах, местах, времени и причинах."
      },
      "examples": [
        {
          "it": "Come ti chiami?",
          "en": "What is your name?",
          "ru": "Как тебя зовут?"
        },
        {
          "it": "Chi è il nuovo professore?",
          "en": "Who is the new professor?",
          "ru": "Кто новый преподаватель?"
        },
        {
          "it": "Di dove sei?",
          "en": "Where are you from?",
          "ru": "Откуда ты?"
        },
        {
          "it": "Quanti anni hai?",
          "en": "How old are you?",
          "ru": "Сколько тебе лет?"
        },
        {
          "it": "Dove vivi?",
          "en": "Where do you live?",
          "ru": "Где ты живёшь?"
        },
        {
          "it": "Che cosa studi?",
          "en": "What do you study?",
          "ru": "Что ты изучаешь?"
        },
        {
          "it": "Qual è il tuo numero di telefono?",
          "en": "What is your phone number?",
          "ru": "Какой у тебя номер телефона?"
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Italian names and surnames",
        "ru": "Итальянские имена и фамилии"
      },
      "description": {
        "en": "Common Italian first names and the most widespread Italian surnames.",
        "ru": "Распространённые итальянские имена и самые частые итальянские фамилии."
      },
      "examples": [
        {
          "it": "Luca, Marco, Francesco, Alessandro",
          "en": "Common Italian male names",
          "ru": "Распространённые мужские имена"
        },
        {
          "it": "Sofia, Giulia, Martina, Sara",
          "en": "Common Italian female names",
          "ru": "Распространённые женские имена"
        },
        {
          "it": "Rossi, Ferrari, Esposito, Bianchi",
          "en": "Most common Italian surnames",
          "ru": "Самые распространённые итальянские фамилии"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Describing body features with c'è",
        "ru": "Описание черт тела с помощью c'è"
      },
      "description": {
        "en": "Use 'c'è' to point out a specific feature on a person's body.",
        "ru": "«C'è» используется для указания на конкретную особенность на теле человека."
      },
      "examples": [
        {
          "it": "Vicino al naso di Silvia c'è un piccolo neo.",
          "en": "Near Silvia's nose there is a small mole.",
          "ru": "Рядом с носом Сильвии есть маленькая родинка."
        },
        {
          "it": "Sulla gamba destra di Luca c'è un piccolo tatuaggio.",
          "en": "On Luca's right leg there is a small tattoo.",
          "ru": "На правой ноге Луки есть маленькая татуировка."
        },
        {
          "it": "Il neo è vicino al naso di Silvia.",
          "en": "The mole is near Silvia's nose.",
          "ru": "Родинка находится рядом с носом Сильвии."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Quante domande! — asking personal questions",
        "ru": "Quante domande! — личные вопросы"
      },
      "description": {
        "en": "A communicative activity where students ask and answer a range of personal questions using all the question words learned.",
        "ru": "Коммуникативное упражнение: студенты задают и отвечают на разнообразные личные вопросы, используя все изученные вопросительные слова."
      },
      "examples": [
        {
          "it": "Perché studi l'italiano?",
          "en": "Why do you study Italian?",
          "ru": "Почему ты изучаешь итальянский?"
        },
        {
          "it": "Quando parti per le vacanze?",
          "en": "When do you leave for the holidays?",
          "ru": "Когда ты уезжаешь в отпуск?"
        },
        {
          "it": "Dove vai in vacanza quest'anno?",
          "en": "Where are you going on holiday this year?",
          "ru": "Куда ты едешь в отпуск в этом году?"
        },
        {
          "it": "Qual è il tuo indirizzo?",
          "en": "What is your address?",
          "ru": "Какой у тебя адрес?"
        }
      ]
    }
  ],
