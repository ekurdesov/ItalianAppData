    {
      "id": "D-A1L2-4-01",
      "title": "Quanti anni hai? (informal)",
      "register": "informal",
      "context": {
        "en": "Two students compare their ages during a class break",
        "ru": "Два студента сравнивают возраст во время перерыва на уроке",
        "es": "Dos estudiantes comparan sus edades durante un receso de clase"
