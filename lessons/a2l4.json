{
  "lesson_info": {
    "id": "A1-L2-4",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": {
      "it": [
        "Comprensione orale: Ha il ragazzo?",
        "Grammatica: verbo avere",
        "Lessico: i numeri da 10 a 100",
        "Attività comunicativa: Quanti anni hai?"
      ],
      "en": [
        "Listening comprehension: Does she have a boyfriend?",
        "Grammar: verb avere",
        "Vocabulary: numbers from 10 to 100",
        "Communicative activity: How old are you?"
      ],
      "ru": [
        "Аудирование: 'Ha il ragazzo?'",
        "Грамматика: глагол avere",
        "Лексика: числа от 10 до 100",
        "Коммуникативное задание: quanti anni hai?"
      ],
      "es": [
        "Comprensión auditiva: ¿Tiene novio?",
        "Gramática: verbo avere",
        "Vocabulario: números del 10 al 100",
        "Actividad comunicativa: ¿Cuántos años tienes?"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Present tense of avere",
        "ru": "Настоящее время глагола avere",
        "es": "Tiempo presente de avere"
      },
      "description": {
        "en": "The verb 'avere' is used to express possession and age.",
        "ru": "Глагол «avere» используется для выражения обладания и возраста.",
        "es": "El verbo 'avere' se utiliza para expresar posesión y edad."
      },
      "conjugations": {
        "io": "ho",
        "tu": "hai",
        "lui/lei/Lei": "ha",
        "noi": "abbiamo",
        "voi": "avete",
        "loro": "hanno"
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Essere vs avere",
        "ru": "Essere и avere",
        "es": "Essere vs avere"
      },
      "description": {
        "en": "Italian uses 'essere' for identity and description, and 'avere' for possession and age.",
        "ru": "В итальянском языке «essere» используется для описания тождества и характеристик, а «avere» — для обладания и возраста.",
        "es": "El italiano utiliza \"essere\" para identidad y descripción, y \"avere\" para posesión y edad."
      },
      "examples": [
        {
          "it": "Carla è bella.",
          "en": "Carla is beautiful.",
          "ru": "Карла красивая.",
          "es": "Carla es hermosa."
        },
        {
          "it": "Carla ha 27 anni.",
          "en": "Carla is 27 years old.",
          "ru": "Карле 27 лет.",
          "es": "Carla tiene 27 años."
        },
        {
          "it": "Ho vent'anni.",
          "en": "I am twenty years old.",
          "ru": "Мне двадцать лет.",
          "es": "Tengo veinte años."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Asking and saying age: formal vs informal",
        "ru": "Вопрос о возрасте и ответ на него: официально и неформально",
        "es": "Preguntar y decir edad: formal vs informal"
      },
      "description": {
        "en": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking age.",
        "ru": "В итальянском языке различаются неформальное «tu» и официальное «Lei» при вопросе о возрасте.",
        "es": "El italiano distingue entre 'tu' informal y 'Lei' formal cuando se pregunta la edad."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Quanti anni hai?",
          "en": "How old are you?",
          "ru": "Сколько тебе лет?",
          "es": "¿Cuántos años tiene?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "en": "And you?",
          "ru": "А ты?",
          "es": "¿Y tú?"
        },
        {
          "context": "formal",
          "it": "Quanti anni ha?",
          "en": "How old are you? (formal)",
          "ru": "Сколько вам лет? (официально)",
          "es": "¿Cuántos años tiene? (formal)"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "en": "And you? (formal)",
          "ru": "А вы? (официально)",
          "es": "¿Y tú? (formal)"
        },
        {
          "context": "answer",
          "it": "Ho ... anni.",
          "en": "I am ... years old.",
          "ru": "Мне ... лет.",
          "es": "Tengo... años."
        },
        {
          "context": "answer",
          "it": "Ne ho ...",
          "en": "I am ... years old.",
          "ru": "Мне ... лет.",
          "es": "Tengo... años."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика",
        "es": "Vocabulario"
      },
      "rule": {
        "en": "Talking about same age and age groups",
        "ru": "Выражения об одном возрасте и возрастных группах",
        "es": "Hablando de la misma edad y grupos de edad."
      },
      "description": {
        "en": "Italian has common expressions for being the same age and describing age.",
        "ru": "В итальянском языке есть распространённые выражения для описания одинакового возраста и характеристики возраста.",
        "es": "El italiano tiene expresiones comunes para tener la misma edad y describir la edad."
      },
      "examples": [
        {
          "it": "coetaneo / coetanea",
          "en": "peer; person of the same age",
          "ru": "ровесник / ровесница; человек одного возраста",
          "es": "par; persona de la misma edad"
        },
        {
          "it": "Siamo coetanei.",
          "en": "We are the same age.",
          "ru": "Мы ровесники.",
          "es": "Tenemos la misma edad."
        },
        {
          "it": "Abbiamo la stessa età.",
          "en": "We are the same age.",
          "ru": "Мы одного возраста.",
          "es": "Tenemos la misma edad."
        },
        {
          "it": "giovane / anziano",
          "en": "young / elderly",
          "ru": "молодой / пожилой",
          "es": "joven / anciano"
        }
      ]
    }
  ],
