  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Present tense of avere",
        "ru": "Настоящее время глагола avere"
      },
      "description": {
        "en": "The verb 'avere' is used to express possession and age.",
        "ru": "Глагол «avere» используется для выражения обладания и возраста."
      },
      "conjugations": {
        "io": "ho",
        "tu": "hai",
        "lui/lei/Lei": "ha",
        "noi": "abbiamo",
        "voi": "avete",
        "loro": "hanno"
      }
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Essere vs avere",
        "ru": "Essere и avere"
      },
      "description": {
        "en": "Italian uses 'essere' for identity and description, and 'avere' for possession and age.",
        "ru": "В итальянском языке «essere» используется для описания тождества и характеристик, а «avere» — для обладания и возраста."
      },
      "examples": [
        {
          "it": "Carla è bella.",
          "en": "Carla is beautiful.",
          "ru": "Карла красивая."
        },
        {
          "it": "Carla ha 27 anni.",
          "en": "Carla is 27 years old.",
          "ru": "Карле 27 лет."
        },
        {
          "it": "Ho vent'anni.",
          "en": "I am twenty years old.",
          "ru": "Мне двадцать лет."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking and saying age: formal vs informal",
        "ru": "Вопрос о возрасте и ответ на него: официально и неформально"
      },
      "description": {
        "en": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking age.",
        "ru": "В итальянском языке различаются неформальное «tu» и официальное «Lei» при вопросе о возрасте."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Quanti anni hai?",
          "en": "How old are you?",
          "ru": "Сколько тебе лет?"
        },
        {
          "context": "informal",
          "it": "E tu?",
          "en": "And you?",
          "ru": "А ты?"
        },
        {
          "context": "formal",
          "it": "Quanti anni ha?",
          "en": "How old are you? (formal)",
          "ru": "Сколько вам лет? (официально)"
        },
        {
          "context": "formal",
          "it": "E Lei?",
          "en": "And you? (formal)",
          "ru": "А вы? (официально)"
        },
        {
          "context": "answer",
          "it": "Ho ... anni.",
          "en": "I am ... years old.",
          "ru": "Мне ... лет."
        },
        {
          "context": "answer",
          "it": "Ne ho ...",
          "en": "I am ... years old.",
          "ru": "Мне ... лет."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Talking about same age and age groups",
        "ru": "Выражения об одном возрасте и возрастных группах"
      },
      "description": {
        "en": "Italian has common expressions for being the same age and describing age.",
        "ru": "В итальянском языке есть распространённые выражения для описания одинакового возраста и характеристики возраста."
      },
      "examples": [
        {
          "it": "coetaneo / coetanea",
          "en": "peer; person of the same age",
          "ru": "ровесник / ровесница; человек одного возраста"
        },
        {
          "it": "Siamo coetanei.",
          "en": "We are the same age.",
          "ru": "Мы ровесники."
        },
        {
          "it": "Abbiamo la stessa età.",
          "en": "We are the same age.",
          "ru": "Мы одного возраста."
        },
        {
          "it": "giovane / anziano",
          "en": "young / elderly",
          "ru": "молодой / пожилой"
        }
      ]
    }
  ],
