        {
          "speaker": "A",
          "it": "Quanti anni hai?",
          "en": "How old are you?",
          "ru": "Сколько тебе лет?",
          "es": "¿Cuántos años tiene?"
        },
        {
          "speaker": "B",
          "it": "Ho venticinque anni. E tu?",
          "en": "I am twenty-five. And you?",
          "ru": "Мне двадцать пять. А тебе?",
          "es": "Tengo veinticinco años. ¿Y tú?"
        },
        {
          "speaker": "A",
          "it": "Ho ventisei anni. Siamo quasi coetanei!",
          "en": "I am twenty-six. We are almost the same age!",
          "ru": "Мне двадцать шесть. Мы почти ровесники!",
          "es": "Tengo veintiséis años. ¡Tenemos casi la misma edad!"
        },
        {
          "speaker": "B",
          "it": "Sì, abbiamo quasi la stessa età!",
          "en": "Yes, we are almost the same age!",
          "ru": "Да, мы почти одного возраста!",
          "es": "¡Sí, tenemos casi la misma edad!"
        }
      ],
      "practice_prompts": [
