        {
          "speaker": "Bruno",
          "it": "Sì, è molto bella e carina.",
          "en": "Yes, she is very beautiful and pretty.",
          "ru": "Да, она очень красивая и милая.",
          "es": "Sí, ella es muy hermosa y bonita."
        },
        {
          "speaker": "Gianni",
          "it": "Quanti anni ha?",
          "en": "How old is she?",
          "ru": "Сколько ей лет?",
          "es": "¿Qué edad tiene ella?"
        },
        {
          "speaker": "Bruno",
          "it": "Mah... 26-27. Boh, perché?",
          "en": "Hmm... 26-27. I don't know, why?",
