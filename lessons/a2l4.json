  "dialogues": [
    {
      "id": "D-A1L2-4-01",
      "title": "Quanti anni hai? (informal)",
      "register": "informal",
      "context": {
        "en": "Two students compare their ages during a class break",
        "ru": "Два студента сравнивают возраст во время перерыва на уроке"
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Quanti anni hai?",
          "en": "How old are you?",
          "ru": "Сколько тебе лет?"
        },
        {
          "speaker": "B",
          "it": "Ho venticinque anni. E tu?",
          "en": "I am twenty-five. And you?",
          "ru": "Мне двадцать пять. А тебе?"
        },
        {
          "speaker": "A",
          "it": "Ho ventisei anni. Siamo quasi coetanei!",
          "en": "I am twenty-six. We are almost the same age!",
          "ru": "Мне двадцать шесть. Мы почти ровесники!"
        },
        {
          "speaker": "B",
          "it": "Sì, abbiamo quasi la stessa età!",
          "en": "Yes, we are almost the same age!",
          "ru": "Да, мы почти одного возраста!"
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask how old someone is (informal)",
            "ru": "Спросите, сколько кому-то лет (неформально)"
          },
          "expected_it": "Quanti anni hai?"
        },
        {
          "cue": {
            "en": "Say your age using 'ho'",
            "ru": "Назовите свой возраст с помощью «ho»"
          },
          "expected_it": "Ho [numero] anni."
        },
        {
          "cue": {
            "en": "Say you are (almost) the same age",
            "ru": "Скажите, что вы (почти) ровесники"
          },
          "expected_it": "Siamo coetanei! / Abbiamo la stessa età."
        }
      ]
    },
    {
      "id": "D-A1L2-4-02",
      "title": "Ha il ragazzo? — Carla",
      "register": "informal",
      "context": {
        "en": "Two male friends talk about Carla — the listening dialogue from the lesson",
        "ru": "Двое друзей-мужчин разговаривают о Карле — диалог для аудирования из урока"
      },
      "turns": [
        {
          "speaker": "Gianni",
          "it": "Bella Carla, no?",
          "en": "Carla is beautiful, isn't she?",
          "ru": "Карла красивая, правда?"
        },
        {
          "speaker": "Bruno",
          "it": "Sì, è molto bella e carina.",
          "en": "Yes, she is very beautiful and pretty.",
          "ru": "Да, она очень красивая и милая."
        },
        {
          "speaker": "Gianni",
          "it": "Quanti anni ha?",
          "en": "How old is she?",
          "ru": "Сколько ей лет?"
        },
        {
          "speaker": "Bruno",
          "it": "Mah... 26-27. Boh, perché?",
          "en": "Hmm... 26-27. I don't know, why?",
          "ru": "Хм... 26–27. Не знаю, а почему?"
        },
        {
