{
  "lesson_info": {
    "id": "A1-L3-6",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": {
      "it": [
        "Ripasso: Presentiamoci!",
        "Comprensione orale: Indovina chi...",
        "Grammatica: nome + aggettivo",
        "Descrivere l'aspetto fisico: Com'è?"
      ],
      "en": [
        "Review: Let's introduce ourselves!",
        "Listening comprehension: Guess who...",
        "Grammar: noun + adjective",
        "Describing physical appearance: what is he/she like?"
      ],
      "ru": [
        "Повторение: Presentiamoci!",
        "Аудирование: Indovina chi...",
        "Грамматика: существительное + прилагательное",
        "Описывать внешность: Com'è?"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Noun + adjective agreement",
        "ru": "Согласование существительного и прилагательного"
      },
      "description": {
        "en": "In Italian, adjectives agree in gender and number with the noun they describe. Masculine adjectives typically end in -o (singular) / -i (plural); feminine in -a (singular) / -e (plural).",
        "ru": "В итальянском прилагательные согласуются с существительным в роде и числе. Мужской род: -o (ед.ч.) / -i (мн.ч.); женский: -a (ед.ч.) / -e (мн.ч.)."
      },
      "examples": [
        {
          "it": "un ragazzo alto",
          "en": "a tall boy",
          "ru": "высокий парень"
        },
        {
          "it": "una ragazza alta",
          "en": "a tall girl",
          "ru": "высокая девушка"
        },
        {
          "it": "i capelli lunghi",
          "en": "long hair",
          "ru": "длинные волосы"
        },
        {
          "it": "gli occhi neri",
          "en": "black eyes",
          "ru": "чёрные глаза"
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Physical appearance adjectives",
        "ru": "Прилагательные для описания внешности"
      },
      "description": {
        "en": "Key adjectives for describing a person's build, height, and general appearance.",
        "ru": "Основные прилагательные для описания телосложения, роста и общего вида человека."
      },
      "examples": [
        {
          "it": "alto / basso",
          "en": "tall / short",
          "ru": "высокий / низкий"
        },
        {
          "it": "magro / grasso",
          "en": "thin / fat",
          "ru": "худой / толстый"
        },
        {
          "it": "giovane / anziano",
          "en": "young / elderly",
          "ru": "молодой / пожилой"
        },
        {
          "it": "calvo",
          "en": "bald",
          "ru": "лысый"
        },
        {
          "it": "di media statura",
          "en": "of medium height",
          "ru": "среднего роста"
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Hair and eye descriptions",
        "ru": "Описание волос и глаз"
      },
      "description": {
        "en": "Italian uses 'avere' to describe hair and eyes, and adjectives must agree with the noun.",
        "ru": "Для описания волос и глаз используется глагол avere, прилагательные согласуются с существительным."
      },
      "examples": [
        {
          "it": "Ha i capelli biondi / castani / neri / rossi.",
          "en": "He/She has blond / brown / black / red hair.",
          "ru": "У него/неё светлые / каштановые / чёрные / рыжие волосы."
        },
        {
          "it": "Ha i capelli ricci / lisci / corti / lunghi.",
          "en": "He/She has curly / straight / short / long hair.",
          "ru": "У него/неё кудрявые / прямые / короткие / длинные волосы."
        },
        {
          "it": "Ha gli occhi azzurri / verdi / marroni / castani.",
          "en": "He/She has blue / green / brown / hazel eyes.",
          "ru": "У него/неё голубые / зелёные / карие / каштановые глаза."
        },
        {
          "it": "Ha i baffi.",
          "en": "He has a moustache.",
          "ru": "У него усы."
        },
        {
          "it": "Ha il pizzetto.",
          "en": "He has a goatee.",
          "ru": "У него козлиная бородка."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking and describing appearance: Com'è?",
        "ru": "Как спросить и описать внешность: Com'è?"
      },
      "description": {
        "en": "Use 'Com'è?' to ask what someone looks like. Answers combine essere + adjective and avere + body feature.",
        "ru": "Вопрос «Com'è?» означает «Как он/она выглядит?». Ответ строится через essere + прилагательное и avere + часть тела."
      },
      "examples": [
        {
          "context": "question",
          "it": "Com'è?",
          "en": "What does he/she look like?",
          "ru": "Как он/она выглядит?"
        },
        {
          "context": "answer",
          "it": "È alto, magro, ha i capelli corti e il pizzetto.",
          "en": "He is tall, thin, has short hair and a goatee.",
          "ru": "Он высокий, худой, с короткими волосами и козлиной бородкой."
        },
        {
          "context": "answer",
          "it": "È una ragazza giovane, di media statura con gli occhi neri e i capelli neri e corti.",
          "en": "She is a young girl, of medium height with black eyes and short black hair.",
          "ru": "Это молодая девушка среднего роста с чёрными глазами и короткими чёрными волосами."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Guessing game: Indovina chi",
        "ru": "Игра «Угадай кто»: Indovina chi"
      },
      "description": {
        "en": "A common classroom activity where students describe a person and others guess who it is, using yes/no questions.",
        "ru": "Распространённое упражнение: один студент описывает человека, другие угадывают, кто это, задавая вопросы «да/нет»."
      },
      "examples": [
        {
          "it": "È alto? — Sì.",
          "en": "Is he tall? — Yes.",
          "ru": "Он высокий? — Да."
        },
        {
          "it": "È grasso? — No.",
          "en": "Is he fat? — No.",
          "ru": "Он толстый? — Нет."
        },
        {
          "it": "Ha i capelli corti? — Sì.",
          "en": "Does he have short hair? — Yes.",
          "ru": "У него короткие волосы? — Да."
        },
        {
          "it": "È Marco? — Sì, hai indovinato!",
          "en": "Is it Marco? — Yes, you guessed it!",
          "ru": "Это Марко? — Да, ты угадал!"
        }
      ]
    }
  ],
