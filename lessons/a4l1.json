{
  "lesson_info": {
    "id": "A1-L4-1",
    "title": "Un incontro",
    "level": "A1",
    "objectives": {
      "it": [
        "Comprensione scritta: Vado al bar",
        "Grammatica: verbi in -are, -ere, -ire, verbi irregolari andare/fare",
        "Chiedere e dire perché andiamo al bar"
      ],
      "en": [
        "Comprensione scritta: Vado al bar",
        "Grammatica: verbi in -are, -ere, -ire, verbi irregolari andare/fare",
        "Chiedere e dire perché andiamo al bar"
      ],
      "ru": [
        "Чтение: Vado al bar",
        "Грамматика: глаголы на -are, -ere, -ire, неправильные глаголы andare/fare",
        "Спрашивать и говорить, зачем мы идём в бар"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Regular verbs in -are (review)",
        "ru": "Правильные глаголы на -are (повторение)"
      },
      "description": {
        "en": "Regular -are verbs follow the pattern -o, -i, -a, -iamo, -ate, -ano in the present tense.",
        "ru": "Правильные глаголы на -are в настоящем времени имеют окончания -o, -i, -a, -iamo, -ate, -ano."
      },
      "conjugations": {
        "io": "lavoro",
        "tu": "lavori",
        "lui/lei/Lei": "lavora",
        "noi": "lavoriamo",
        "voi": "lavorate",
        "loro": "lavorano"
      },
      "examples": [
        {
          "it": "Stefano lavora al bar.",
          "en": "Stefano works at the bar.",
          "ru": "Стефано работает в баре."
        },
        {
          "it": "Monica arriva tardi in ufficio.",
          "en": "Monica arrives late at the office.",
          "ru": "Моника приходит в офис поздно."
        },
        {
          "it": "I vicini di casa litigano spesso.",
          "en": "The neighbours argue often.",
          "ru": "Соседи часто ссорятся."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Regular verbs in -ere (review)",
        "ru": "Правильные глаголы на -ere (повторение)"
      },
      "description": {
        "en": "Regular -ere verbs follow the pattern -o, -i, -e, -iamo, -ete, -ono.",
        "ru": "Правильные глаголы на -ere в настоящем времени имеют окончания -o, -i, -e, -iamo, -ete, -ono."
      },
      "conjugations": {
        "io": "prendo",
        "tu": "prendi",
        "lui/lei/Lei": "prende",
        "noi": "prendiamo",
        "voi": "prendete",
        "loro": "prendono"
      },
      "examples": [
        {
          "it": "Stefano prende l'autobus per andare al lavoro.",
          "en": "Stefano takes the bus to go to work.",
          "ru": "Стефано едет на автобусе на работу."
        },
        {
          "it": "Il bar chiude alle 8.",
          "en": "The bar closes at 8.",
          "ru": "Бар закрывается в 8."
        },
        {
          "it": "La mia famiglia riceve molti pacchi.",
          "en": "My family receives many parcels.",
          "ru": "Моя семья получает много посылок."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Irregular verb: andare",
        "ru": "Неправильный глагол: andare"
      },
      "description": {
        "en": "The verb 'andare' (to go) is irregular in the present tense.",
        "ru": "Глагол «andare» (идти/ехать) неправильный в настоящем времени."
      },
      "conjugations": {
        "io": "vado",
        "tu": "vai",
        "lui/lei/Lei": "va",
        "noi": "andiamo",
        "voi": "andate",
        "loro": "vanno"
      },
      "examples": [
        {
          "it": "La mattina Piero va in ufficio alle nove.",
          "en": "In the morning Piero goes to the office at nine.",
          "ru": "Утром Пьеро идёт в офис в девять."
        },
        {
          "it": "Ogni sera vado in piscina con Marina.",
          "en": "Every evening I go to the pool with Marina.",
          "ru": "Каждый вечер я хожу в бассейн с Мариной."
        },
        {
          "it": "Andate a cena al ristorante sabato?",
          "en": "Are you going to dinner at the restaurant on Saturday?",
          "ru": "Вы идёте ужинать в ресторан в субботу?"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Irregular verb: fare",
        "ru": "Неправильный глагол: fare"
      },
      "description": {
        "en": "The verb 'fare' (to do / to make) is irregular. It is used in many fixed expressions.",
        "ru": "Глагол «fare» (делать) неправильный. Используется во многих устойчивых выражениях."
      },
      "conjugations": {
        "io": "faccio",
        "tu": "fai",
        "lui/lei/Lei": "fa",
        "noi": "facciamo",
        "voi": "fate",
        "loro": "fanno"
      },
      "examples": [
        {
          "it": "Tutte le mattine Roberto fa colazione con un cornetto e un cappuccino.",
          "en": "Every morning Roberto has breakfast with a croissant and a cappuccino.",
          "ru": "Каждое утро Роберто завтракает круассаном и капучино."
        },
        {
          "it": "Noi facciamo belle fotografie.",
          "en": "We take beautiful photos.",
          "ru": "Мы делаем красивые фотографии."
        },
        {
          "it": "Cosa fate dopo cena?",
          "en": "What do you do after dinner?",
          "ru": "Что вы делаете после ужина?"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Saying why you go to the bar",
        "ru": "Сказать, зачем идёшь в бар"
      },
      "description": {
        "en": "Use 'Vado al bar per + infinitive' to explain the purpose of going to the bar.",
        "ru": "Конструкция «Vado al bar per + инфинитив» объясняет цель похода в бар."
      },
      "examples": [
        {
          "it": "Vado al bar per fare colazione.",
          "en": "I go to the bar to have breakfast.",
          "ru": "Я иду в бар позавтракать."
        },
        {
          "it": "Vado al bar per incontrare gli amici.",
          "en": "I go to the bar to meet friends.",
          "ru": "Я иду в бар встретиться с друзьями."
        },
        {
          "it": "Vado al bar per fare una pausa.",
          "en": "I go to the bar to take a break.",
          "ru": "Я иду в бар сделать перерыв."
        },
        {
          "it": "Vado al bar per leggere il giornale.",
          "en": "I go to the bar to read the newspaper.",
          "ru": "Я иду в бар почитать газету."
        }
      ]
    }
  ],
