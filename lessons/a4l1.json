{
  "lesson_info": {
    "id": "A1-L4-1",
    "title": "Un incontro",
    "level": "A1",
    "objectives": {
      "it": [
        "Comprensione scritta: Vado al bar",
        "Grammatica: verbi in -are, -ere, -ire, verbi irregolari andare/fare",
        "Chiedere e dire perché andiamo al bar"
      ],
      "en": [
        "Reading comprehension: I'm going to the bar",
        "Grammar: verbs in -are, -ere, -ire, irregular verbs andare/fare",
        "Asking and saying why we go to the bar"
      ],
      "ru": [
        "Чтение: Vado al bar",
        "Грамматика: глаголы на -are, -ere, -ire, неправильные глаголы andare/fare",
        "Спрашивать и говорить, зачем мы идём в бар"
      ],
      "es": [
        "Comprensión lectora: voy al bar",
        "Gramática: verbos en -are, -ere, -ire, verbos irregulares andare/fare",
        "Preguntar y decir por qué vamos al bar."
      ]
    }
  },
  "language_rules": [
