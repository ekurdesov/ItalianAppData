  "dialogues": [
    {
      "id": "D-A1L4-1-01",
      "title": "Vado al bar per...",
      "register": "informal",
      "context": {
        "en": "Students discuss why they go to the bar, using 'per + infinitive'.",
        "ru": "Студенты обсуждают, зачем ходят в бар, используя конструкцию «per + инфинитив».",
        "es": "Los estudiantes discuten por qué van al bar usando 'per + infinitivo'."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Perché vai al bar?",
          "en": "Why do you go to the bar?",
          "ru": "Зачем ты ходишь в бар?",
          "es": "¿Por qué vas al bar?"
        },
        {
          "speaker": "B",
          "it": "Vado al bar per fare colazione e leggere il giornale. E tu?",
          "en": "I go to the bar to have breakfast and read the newspaper. And you?",
          "ru": "Я хожу в бар позавтракать и почитать газету. А ты?",
          "es": "Voy al bar a desayunar y leer el periódico. ¿Y tú?"
        },
        {
          "speaker": "A",
          "it": "Io vado al bar per incontrare gli amici e prendere un aperitivo.",
          "en": "I go to the bar to meet friends and have an aperitif.",
          "ru": "Я хожу в бар встретиться с друзьями и выпить аперитив.",
          "es": "Voy al bar a quedar con amigos y tomar un aperitivo."
        },
        {
          "speaker": "B",
          "it": "Andate spesso al bar?",
          "en": "Do you go to the bar often?",
          "ru": "Вы часто ходите в бар?",
          "es": "¿Vas a menudo al bar?"
        },
        {
          "speaker": "A",
          "it": "Sì, andiamo quasi ogni giorno.",
          "en": "Yes, we go almost every day.",
          "ru": "Да, мы ходим почти каждый день.",
          "es": "Sí, vamos casi todos los días."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Say you go to the bar to have breakfast",
            "ru": "Сказать, что идёшь в бар позавтракать",
            "es": "Di que vas al bar a desayunar"
          },
          "expected_it": "Vado al bar per fare colazione."
        },
        {
          "cue": {
            "en": "Ask where someone goes in the morning",
            "ru": "Спросить, куда кто-то идёт утром",
            "es": "Preguntar adónde va alguien por la mañana."
          },
          "expected_it": "Dove vai la mattina?"
        },
        {
          "cue": {
            "en": "Say what you do after dinner",
            "ru": "Сказать, что делаешь после ужина",
            "es": "Di lo que haces después de cenar."
          },
          "expected_it": "Dopo cena faccio …"
        }
      ]
    },
    {
      "id": "D-A1L4-1-02",
      "title": "Al bar",
      "register": "informal",
      "context": {
        "en": "Two friends go to a bar, order drinks and snacks, and discuss preferences.",
        "ru": "Двое друзей идут в бар, заказывают напитки и перекусы и обсуждают предпочтения.",
        "es": "Dos amigos van a un bar, piden bebidas y bocadillos y discuten sus preferencias."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, dove vai dopo la lezione?",
          "en": "Hi, where are you going after the lesson?",
          "ru": "Привет, куда ты идёшь после урока?",
          "es": "Hola, ¿adónde irás después de la lección?"
        },
        {
          "speaker": "B",
          "it": "Vado al bar. E tu?",
          "en": "I'm going to the bar. And you?",
          "ru": "Иду в бар. А ты?",
          "es": "Voy al bar. ¿Y tú?"
        },
        {
          "speaker": "A",
          "it": "Anch'io vado al bar.",
          "en": "I'm going to the bar too.",
          "ru": "Я тоже иду в бар.",
          "es": "Yo también voy al bar."
        },
        {
          "speaker": "B",
          "it": "Perché vai al bar?",
          "en": "Why are you going to the bar?",
          "ru": "Почему ты идёшь в бар?",
          "es": "¿Por qué vas al bar?"
        },
        {
          "speaker": "A",
          "it": "Perché ho sonno e voglio un caffè.",
          "en": "Because I'm sleepy and I want a coffee.",
          "ru": "Потому что хочу спать и хочу кофе.",
          "es": "Porque tengo sueño y quiero un café."
        },
        {
          "speaker": "B",
          "it": "Io ho fame e voglio un tramezzino.",
          "en": "I'm hungry and I want a sandwich.",
          "ru": "Я голодный и хочу бутерброд.",
          "es": "Tengo hambre y quiero un sándwich."
        },
        {
          "speaker": "A",
          "it": "Che cosa prendi di solito?",
          "en": "What do you usually get?",
          "ru": "Что ты обычно берёшь?",
          "es": "¿Qué sueles conseguir?"
        },
        {
          "speaker": "B",
          "it": "Prendo un cappuccino e una brioche.",
          "en": "I get a cappuccino and a brioche.",
          "ru": "Беру капучино и бриошь.",
          "es": "Pido un capuchino y un brioche."
        },
        {
          "speaker": "A",
          "it": "Io prendo un caffè macchiato.",
          "en": "I get a macchiato.",
          "ru": "Я беру маккиато.",
          "es": "Consigo un macchiato."
        },
        {
          "speaker": "B",
          "it": "Vuoi anche acqua?",
          "en": "Do you also want water?",
          "ru": "Хочешь ещё воду?",
          "es": "¿También quieres agua?"
