      ],
      "en": [
        "Review: double interview",
        "Grammar: Where do you live?",
        "Listening comprehension: A strange couple",
        "Asking for and giving an address and civil status"
      ],
      "ru": [
        "Повторение: Intervista doppia",
        "Грамматика: Dove abiti?",
        "Аудирование: Una strana coppia",
        "Спрашивать и говорить об адресе и семейном положении"
      ],
      "es": [
        "Reseña: doble entrevista",
        "Gramática: ¿Dónde vives?",
        "Comprensión auditiva: Una pareja extraña",
        "Pedir y dar dirección y estado civil"
      ]
    }
