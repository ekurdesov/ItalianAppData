  "language_rules": [
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Asking about civil status",
        "ru": "Как спрашивать о семейном положении",
        "es": "Preguntar sobre el estado civil"
      },
      "description": {
        "en": "Italian uses adjective-based questions to ask whether someone is married, single, engaged, separated, divorced or widowed.",
        "ru": "В итальянском для вопроса о семейном положении используются формы с прилагательными: женат / замужем, не женат / не замужем, помолвлен / помолвлена, в разводе, вдовец / вдова.",
        "es": "El italiano utiliza preguntas basadas en adjetivos para preguntar si alguien está casado, soltero, comprometido, separado, divorciado o viudo."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Sei sposato/a?",
          "en": "Are you married?",
          "ru": "Ты женат / замужем?",
          "es": "¿Está casado?"
        },
        {
          "context": "formal",
          "it": "È sposato/a?",
          "en": "Are you married? (formal)",
          "ru": "Вы женаты / замужем?",
          "es": "¿Está casado? (formal)"
        },
        {
          "it": "Sono sposata con Marco da vent'anni.",
          "en": "I have been married to Marco for twenty years.",
          "ru": "Я замужем за Марко уже двадцать лет.",
          "es": "Estoy casada con Marco desde hace veinte años."
        },
        {
          "it": "Ho un ragazzo. / Ho una ragazza.",
          "en": "I have a boyfriend. / I have a girlfriend.",
          "ru": "У меня есть парень. / У меня есть девушка.",
          "es": "Tengo novio. / Tengo novia."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Asking for an address: informal vs formal",
        "ru": "Как спросить адрес: неформально и официально",
        "es": "Solicitar una dirección: informal versus formal"
      },
      "description": {
        "en": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking where someone lives and what their address is.",
        "ru": "В итальянском различаются неформальное 'tu' и официальное 'Lei', когда спрашивают, где человек живёт и каков его адрес.",
        "es": "El italiano distingue entre 'tu' informal y 'Lei' formal cuando se pregunta dónde vive alguien y cuál es su dirección."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Dove abiti?",
          "en": "Where do you live?",
          "ru": "Где ты живёшь?",
          "es": "¿Dónde vive?"
        },
        {
          "context": "formal",
          "it": "Dove abita?",
          "en": "Where do you live? (formal)",
          "ru": "Где Вы живёте?",
          "es": "¿Dónde vive? (formal)"
        },
        {
          "context": "informal",
          "it": "Qual è il tuo indirizzo?",
          "en": "What is your address?",
          "ru": "Какой у тебя адрес?",
          "es": "¿Cuál es su dirección?"
        },
        {
          "context": "formal",
          "it": "Qual è il Suo indirizzo?",
          "en": "What is your address? (formal)",
          "ru": "Какой у Вас адрес?",
          "es": "¿Cuál es su dirección? (formal)"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Saying an address",
        "ru": "Как назвать адрес",
        "es": "diciendo una dirección"
      },
      "description": {
        "en": "Addresses are commonly given with the pattern 'abitare a + city + in + street + number' or by stating the address directly.",
        "ru": "Адрес часто сообщается по модели 'abitare a + город + in + улица + номер' или прямой формулой с 'indirizzo'.",
        "es": "Las direcciones se dan comúnmente con el patrón 'abitare a + ciudad + en + calle + número' o indicando la dirección directamente."
      },
      "examples": [
        {
          "it": "Abito a Roma in via Garibaldi, 8.",
          "en": "I live in Rome at Via Garibaldi 8.",
          "ru": "Я живу в Риме, на улице Гарибальди, дом 8.",
          "es": "Vivo en Roma en Via Garibaldi 8."
        },
        {
          "it": "Il mio indirizzo è via Garibaldi, 8.",
          "en": "My address is Via Garibaldi 8.",
          "ru": "Мой адрес: улица Гарибальди, дом 8.",
          "es": "Mi dirección es Via Garibaldi 8."
        },
        {
          "it": "Alice abita a Roma in via Brescia, 68.",
          "en": "Alice lives in Rome at Via Brescia 68.",
          "ru": "Аличе живёт в Риме, на улице Брешиа, дом 68.",
          "es": "Alice vive en Roma en Via Brescia 68."
        }
      ]
    },
