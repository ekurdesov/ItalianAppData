  "dialogues": [
    {
      "id": "D-A1L3-2-01",
      "title": "Intervista doppia",
      "register": "neutral",
      "context": {
        "en": "Two people answer questions about civil status and relationship situation.",
        "ru": "Два человека отвечают на вопросы о семейном положении и отношениях."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Sei sposata?",
          "en": "Are you married?",
          "ru": "Ты замужем?"
        },
        {
          "speaker": "B",
          "it": "Sì, sono sposata con Marco da vent'anni.",
          "en": "Yes, I have been married to Marco for twenty years.",
          "ru": "Да, я замужем за Марко уже двадцать лет."
        },
        {
          "speaker": "A",
          "it": "E tua sorella?",
          "en": "And your sister?",
          "ru": "А твоя сестра?"
        },
        {
          "speaker": "B",
          "it": "No, è single, ma ha un ragazzo.",
          "en": "No, she is single, but she has a boyfriend.",
          "ru": "Нет, она не замужем, но у неё есть парень."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask if someone is married",
            "ru": "Спросить, женат ли человек"
          },
          "expected_it": "Sei sposato/a?"
        },
        {
          "cue": {
            "en": "Say you are single",
            "ru": "Сказать, что вы не в браке"
          },
          "expected_it": "Sono single."
        },
        {
          "cue": {
            "en": "Say you have a boyfriend/girlfriend",
            "ru": "Сказать, что у вас есть парень или девушка"
          },
          "expected_it": "Ho un ragazzo. / Ho una ragazza."
        }
      ]
    },
    {
      "id": "D-A1L3-2-02",
      "title": "Dove abiti? Qual è il tuo indirizzo?",
      "register": "informal",
      "context": {
        "en": "Two neighbours exchange address details.",
        "ru": "Два соседа обмениваются адресами."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Dove abiti?",
          "en": "Where do you live?",
          "ru": "Где ты живёшь?"
        },
        {
          "speaker": "B",
          "it": "Abito a Torino, in corso Umberto 10.",
          "en": "I live in Turin, at Corso Umberto 10.",
          "ru": "Я живу в Турине, на проспекте Умберто, 10."
        },
        {
          "speaker": "A",
          "it": "Qual è il tuo indirizzo a Milano?",
          "en": "What is your address in Milan?",
          "ru": "Какой у тебя адрес в Милане?"
        },
        {
          "speaker": "B",
          "it": "Il mio indirizzo è via Canonica 7.",
          "en": "My address is Via Canonica 7.",
          "ru": "Мой адрес: улица Каноника, 7."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask for someone's address",
            "ru": "Спросить адрес"
          },
          "expected_it": "Qual è il tuo indirizzo?"
        },
        {
          "cue": {
            "en": "State your address",
            "ru": "Назвать свой адрес"
          },
          "expected_it": "Il mio indirizzo è [via/piazza/corso], [numero]."
        }
      ]
    }
  ],
