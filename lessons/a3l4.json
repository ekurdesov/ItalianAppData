    {
      "category": {
        "en": "Reading",
        "ru": "Чтение"
      },
      "rule": {
        "en": "Short ads and profile-style texts",
        "ru": "Короткие объявления и профили"
      },
      "description": {
        "en": "Classified-style descriptions usually combine age, city, job, language skills, and what a person is looking for.",
        "ru": "Текст формата объявления обычно сочетает возраст, город, работу, языки и то, что человек ищет."
      },
      "examples": [
        {
          "it": "Mi chiamo David. Ho 28 anni e sono australiano, ma abito e lavoro a Roma.",
          "en": "My name is David. I am 28 and I am Australian, but I live and work in Rome.",
          "ru": "Меня зовут Давид. Мне 28 лет, я австралиец, но живу и работаю в Риме."
        },
        {
          "it": "Ciao, mi chiamo Cristina. Ho 27 anni, sono tedesca e cerco una ragazza italiana per uno scambio italo-tedesco.",
          "en": "Hi, my name is Cristina. I am 27, I am German and I am looking for an Italian girl for an Italian-German exchange.",
          "ru": "Привет, меня зовут Кристина. Мне 27 лет, я немка и ищу итальянскую девушку для итало-немецкого обмена."
        }
      ]
    }
