  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Indefinite articles in Italian",
        "ru": "Неопределённые артикли в итальянском"
      },
      "description": {
        "en": "Italian uses different indefinite articles depending on gender and the sound at the start of the noun.",
        "ru": "В итальянском используются разные формы неопределённого артикля в зависимости от рода и начального звука существительного."
      },
      "examples": [
        {
          "it": "un ragazzo",
          "en": "a boy",
          "ru": "мальчик"
        },
        {
          "it": "uno studente",
          "en": "a student",
          "ru": "студент"
        },
        {
          "it": "una ragazza",
          "en": "a girl",
          "ru": "девушка"
        },
        {
          "it": "un autobus",
          "en": "a bus",
          "ru": "автобус"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "Choosing un, uno, una, un'",
        "ru": "Когда выбирать un, uno, una, un'"
      },
      "description": {
        "en": "Use 'un' before most masculine nouns, 'uno' before masculine nouns starting with s+consonant, z, ps, gn, x, and 'una' or 'un'' before feminine nouns.",
        "ru": "Форма 'un' употребляется перед большинством мужских существительных, 'uno' перед s + согласная, z, ps, gn, x, а 'una' и 'un'' перед женскими существительными."
      },
      "examples": [
        {
          "it": "uno straniero",
          "en": "a foreigner",
          "ru": "иностранец"
        },
        {
          "it": "uno zoo",
          "en": "a zoo",
          "ru": "зоопарк"
        },
        {
          "it": "una signora",
          "en": "a lady",
          "ru": "дама, женщина"
        },
        {
          "it": "un'amica",
          "en": "a female friend",
          "ru": "подруга"
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking which languages someone speaks",
        "ru": "Как спросить, на каких языках говорит человек"
      },
      "description": {
        "en": "To ask about languages, Italian commonly uses 'Che lingue parli?' or 'Che lingue studia?'.",
        "ru": "Чтобы спросить о языках, по-итальянски обычно говорят 'Che lingue parli?' или 'Che lingue studia?'."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Che lingue parli?",
          "en": "What languages do you speak?",
          "ru": "На каких языках ты говоришь?"
        },
        {
          "context": "answer",
          "it": "Parlo l'italiano, il tedesco e un po' lo spagnolo.",
          "en": "I speak Italian, German and a little Spanish.",
          "ru": "Я говорю по-итальянски, по-немецки и немного по-испански."
        },
        {
          "context": "answer",
          "it": "Parlo bene il francese, ma non lo spagnolo.",
          "en": "I speak French well, but not Spanish.",
          "ru": "Я хорошо говорю по-французски, но не по-испански."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Family and personal profile words",
        "ru": "Слова о семье и личном профиле"
      },
      "description": {
        "en": "This lesson reuses personal-description language together with simple family references.",
        "ru": "В уроке повторяются слова для описания человека и базовая семейная лексика."
      },
      "examples": [
        {
          "it": "padre",
          "en": "father",
          "ru": "отец"
        },
        {
