{
  "lesson_info": {
    "id": "A1-L1-1",
    "title": "Piacere!",
    "level": "A1",
    "objectives": {
      "it": [
        "Fare conoscenza",
        "Parole e lettere",
        "Fonetica: le vocali"
      ],
      "en": [
        "Getting acquainted",
        "Words and letters",
        "Phonetics: vowels"
      ],
      "ru": [
        "Знакомство",
        "Слова и буквы",
        "Фонетика: гласные"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Italian vowel contrast",
        "ru": "Различение итальянских гласных"
      },
      "description": {
        "en": "Italian vowels must be pronounced clearly because small vowel changes can change meaning or even gender.",
        "ru": "Итальянские гласные необходимо произносить чётко, поскольку небольшие изменения в звучании гласной могут менять смысл слова или даже его род."
      },
      "examples": [
        {
          "it": "colore / calore",
          "en": "color / heat",
          "ru": "цвет / тепло"
        },
        {
          "it": "Paolo / Paola",
          "en": "male name / female name",
          "ru": "мужское имя / женское имя"
        }
      ]
    },
    {
      "category": {
        "en": "Phonetics",
        "ru": "Фонетика"
      },
      "rule": {
        "en": "Stressed final vowels with accents",
        "ru": "Ударные конечные гласные с акцентом"
      },
      "description": {
        "en": "Some Italian words carry a written accent on the final vowel, which signals the stressed syllable.",
        "ru": "Некоторые итальянские слова имеют письменный акцент на последней гласной, который указывает на ударный слог."
      },
      "examples": [
        {
          "it": "caffè",
          "en": "coffee",
          "ru": "кофе"
        },
        {
          "it": "città",
          "en": "city",
          "ru": "город"
        }
      ]
    },
    {
      "category": {
        "en": "Orthography",
        "ru": "Орфография"
      },
      "rule": {
        "en": "Italian spelling names letters and double consonants explicitly",
        "ru": "Итальянское написание: буквы и двойные согласные"
      },
      "description": {
        "en": "When spelling aloud, Italian uses letter names and marks double consonants with 'doppia' plus the consonant name.",
        "ru": "При произнесении по буквам в итальянском используются названия букв, а двойные согласные обозначаются словом «doppia» и названием согласной."
      },
      "examples": [
        {
          "it": "cappuccino",
          "en": "cappuccino",
          "ru": "капучино"
        },
        {
          "it": "Bologna",
          "en": "Bologna",
          "ru": "Болонья"
        }
      ]
    },
    {
      "category": {
        "en": "Orthography",
        "ru": "Орфография"
      },
      "rule": {
        "en": "The sound of 'ci' in number words",
        "ru": "Звучание «ci» в числительных"
      },
      "description": {
        "en": "In words like 'cinque', 'dieci', 'undici' and 'dodici', 'ci' is pronounced with the [tʃ] sound.",
        "ru": "В словах «cinque», «dieci», «undici» и «dodici» сочетание «ci» произносится как звук [tʃ]."
      },
      "examples": [
        {
          "it": "cinque",
          "en": "five",
          "ru": "пять"
        },
        {
          "it": "dieci",
          "en": "ten",
          "ru": "десять"
        },
        {
          "it": "undici",
          "en": "eleven",
          "ru": "одиннадцать"
        },
        {
          "it": "dodici",
          "en": "twelve",
          "ru": "двенадцать"
        }
      ]
    }
  ],
