  "dialogues": [
    {
      "id": "D-A1L1-1-01",
      "title": "Piacere!",
      "register": "informal",
      "context": {
        "en": "Two people meet for the first time and introduce themselves.",
        "ru": "Двое людей встречаются впервые и знакомятся."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao! Mi chiamo Luca. E tu?",
          "en": "Hi! My name is Luca. And you?",
          "ru": "Привет! Меня зовут Лука. А тебя?"
        },
        {
          "speaker": "B",
          "it": "Ciao! Io sono Sofia. Piacere!",
          "en": "Hi! I am Sofia. Nice to meet you!",
          "ru": "Привет! Я Софья. Приятно познакомиться!"
        },
        {
          "speaker": "A",
          "it": "Piacere mio!",
          "en": "The pleasure is mine!",
          "ru": "Мне тоже приятно!"
        },
        {
          "speaker": "B",
          "it": "Di dove sei, Luca?",
          "en": "Where are you from, Luca?",
          "ru": "Откуда ты, Лука?"
        },
        {
          "speaker": "A",
          "it": "Sono italiano, di Roma. E tu?",
          "en": "I am Italian, from Rome. And you?",
          "ru": "Я итальянец, из Рима. А ты?"
        },
        {
          "speaker": "B",
          "it": "Sono spagnola, di Madrid.",
          "en": "I am Spanish, from Madrid.",
          "ru": "Я испанка, из Мадрида."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Introduce yourself",
            "ru": "Представиться"
          },
          "expected_it": "Mi chiamo … / Sono …"
        },
        {
          "cue": {
            "en": "Say nice to meet you",
            "ru": "Сказать «приятно познакомиться»"
          },
          "expected_it": "Piacere!"
        },
        {
          "cue": {
            "en": "Say where you are from",
            "ru": "Сказать, откуда ты"
          },
          "expected_it": "Sono di …"
        }
      ]
    },
    {
      "id": "D-A1L1-1-02",
      "title": "Primo giorno nel corso di italiano",
      "register": "informal",
      "context": {
        "en": "Two students meet on the first day of Italian class, introduce themselves, and talk about origin and language level.",
        "ru": "Два студента знакомятся в первый день курса итальянского, представляются и говорят о происхождении и уровне языка."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, buongiorno! Sei nella classe di italiano?",
          "en": "Hi, good morning! Are you in the Italian class?",
          "ru": "Привет, доброе утро! Ты в классе итальянского?"
        },
        {
          "speaker": "B",
          "it": "Sì, sono nella classe A1. E tu?",
          "en": "Yes, I'm in the A1 class. And you?",
          "ru": "Да, я в классе A1. А ты?"
        },
        {
          "speaker": "A",
          "it": "Anch'io. Mi chiamo Luca.",
          "en": "Me too. My name is Luca.",
          "ru": "Я тоже. Меня зовут Лука."
        },
        {
          "speaker": "B",
          "it": "Piacere, Luca. Io mi chiamo Anna.",
          "en": "Nice to meet you, Luca. My name is Anna.",
          "ru": "Приятно познакомиться, Лука. Меня зовут Анна."
        },
        {
          "speaker": "A",
          "it": "Piacere mio, Anna. Sei nuova qui?",
          "en": "My pleasure, Anna. Are you new here?",
          "ru": "Мне тоже приятно, Анна. Ты здесь новенькая?"
        },
        {
          "speaker": "B",
          "it": "Sì, sono nuova. E tu?",
          "en": "Yes, I'm new. And you?",
          "ru": "Да, я новенькая. А ты?"
        },
        {
          "speaker": "A",
          "it": "Sì, anche io sono nuovo.",
          "en": "Yes, I'm new too.",
          "ru": "Да, я тоже новенький."
        },
        {
          "speaker": "B",
          "it": "Di dove sei?",
          "en": "Where are you from?",
          "ru": "Откуда ты?"
        },
        {
          "speaker": "A",
          "it": "Sono italiano, di Roma. E tu?",
          "en": "I'm Italian, from Rome. And you?",
          "ru": "Я итальянец, из Рима. А ты?"
        },
        {
          "speaker": "B",
          "it": "Sono russa, di Mosca.",
          "en": "I'm Russian, from Moscow.",
          "ru": "Я русская, из Москвы."
        },
        {
          "speaker": "A",
          "it": "Mosca è una città molto grande, vero?",
          "en": "Moscow is a very big city, right?",
          "ru": "Москва — очень большой город, правда?"
        },
        {
          "speaker": "B",
          "it": "Sì, è grande e interessante. Roma è bella?",
          "en": "Yes, it's big and interesting. Is Rome beautiful?",
          "ru": "Да, большой и интересный. Рим красивый?"
        },
        {
          "speaker": "A",
          "it": "Sì, Roma è bellissima, ma è anche caotica.",
          "en": "Yes, Rome is very beautiful, but also chaotic.",
          "ru": "Да, Рим очень красивый, но и хаотичный."
        },
        {
          "speaker": "B",
          "it": "Capisco. Parli inglese?",
          "en": "I see. Do you speak English?",
          "ru": "Понятно. Ты говоришь по-английски?"
        },
        {
          "speaker": "A",
          "it": "Sì, parlo inglese e un po' spagnolo.",
          "en": "Yes, I speak English and a little Spanish.",
          "ru": "Да, говорю по-английски и немного по-испански."
        },
        {
          "speaker": "B",
          "it": "Io parlo russo, inglese e poco italiano.",
          "en": "I speak Russian, English, and a little Italian.",
          "ru": "Я говорю по-русски, по-английски и немного по-итальянски."
        },
        {
          "speaker": "A",
          "it": "Studi italiano da molto tempo?",
          "en": "Have you been studying Italian for a long time?",
          "ru": "Ты давно учишь итальянский?"
        },
        {
          "speaker": "B",
          "it": "No, studio italiano da due settimane.",
          "en": "No, I've been studying Italian for two weeks.",
          "ru": "Нет, я учу итальянский две недели."
        },
        {
          "speaker": "A",
          "it": "Allora parli già bene.",
          "en": "Then you already speak well.",
          "ru": "Тогда ты уже хорошо говоришь."
        },
        {
          "speaker": "B",
          "it": "Grazie, ma faccio molti errori.",
          "en": "Thanks, but I make many mistakes.",
          "ru": "Спасибо, но я делаю много ошибок."
        },
        {
          "speaker": "A",
          "it": "Anch'io. Gli errori sono normali.",
          "en": "Me too. Mistakes are normal.",
          "ru": "Я тоже. Ошибки — это нормально."
        },
        {
          "speaker": "B",
          "it": "Hai il libro?",
          "en": "Do you have the book?",
          "ru": "У тебя есть учебник?"
        },
        {
          "speaker": "A",
          "it": "Sì, ho il libro e il quaderno.",
          "en": "Yes, I have the book and the notebook.",
          "ru": "Да, у меня есть учебник и тетрадь."
        },
        {
          "speaker": "B",
          "it": "Io ho il libro, ma non ho una penna.",
          "en": "I have the book, but I don't have a pen.",
          "ru": "У меня есть учебник, но нет ручки."
        },
        {
          "speaker": "A",
          "it": "Vuoi una penna?",
          "en": "Do you want a pen?",
          "ru": "Хочешь ручку?"
        },
        {
          "speaker": "B",
          "it": "Sì, grazie mille.",
          "en": "Yes, thank you very much.",
          "ru": "Да, большое спасибо."
        },
        {
          "speaker": "A",
          "it": "Prego. Vuoi sederti qui?",
          "en": "You're welcome. Do you want to sit here?",
          "ru": "Пожалуйста. Хочешь сесть здесь?"
        },
        {
          "speaker": "B",
          "it": "Sì, volentieri.",
          "en": "Yes, gladly.",
          "ru": "Да, с удовольствием."
        },
        {
          "speaker": "A",
          "it": "Bene, comincia la lezione.",
          "en": "Good, the lesson is starting.",
          "ru": "Хорошо, урок начинается."
        },
        {
          "speaker": "B",
          "it": "Buona lezione, Luca!",
          "en": "Have a good lesson, Luca!",
          "ru": "Хорошего урока, Лука!"
        }
      ]
