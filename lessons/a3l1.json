  "dialogues": [
    {
      "id": "D-A1L3-1-01",
      "title": "Alla festa di Chiara",
      "register": "informal",
      "context": {
        "en": "Two students meet at Chiara's party and talk about origin, university subject and where they live.",
        "ru": "Два студента знакомятся на вечеринке у Кьяры и говорят о происхождении, предмете учёбы и месте жительства."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, io sono Claudio. Tu come ti chiami?",
          "en": "Hi, I'm Claudio. What is your name?",
          "ru": "Привет, я Клаудио. Как тебя зовут?"
        },
        {
          "speaker": "B",
          "it": "Stefi. Piacere.",
          "en": "Stefi. Nice to meet you.",
          "ru": "Стефи. Очень приятно."
        },
        {
          "speaker": "A",
          "it": "Che cosa studi?",
          "en": "What do you study?",
          "ru": "Что ты изучаешь?"
        },
        {
          "speaker": "B",
          "it": "Economia. E tu?",
          "en": "Economics. And you?",
          "ru": "Экономику. А ты?"
        },
        {
          "speaker": "A",
          "it": "Matematica. Di dove sei?",
          "en": "Mathematics. Where are you from?",
          "ru": "Математику. Откуда ты?"
        },
        {
          "speaker": "B",
          "it": "Sono di Prato. E tu?",
          "en": "I am from Prato. And you?",
          "ru": "Я из Прато. А ты?"
        },
        {
          "speaker": "A",
          "it": "Sono di Casinalbo, ma abito a Firenze, in Italia.",
          "en": "I am from Casinalbo, but I live in Florence, in Italy.",
          "ru": "Я из Казинальбо, но живу во Флоренции, в Италии."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask where someone is from",
            "ru": "Спросить, откуда человек"
          },
          "expected_it": "Di dove sei?"
        },
        {
          "cue": {
            "en": "Say where you are from",
            "ru": "Сказать, откуда вы"
          },
          "expected_it": "Sono di [città]."
        },
        {
          "cue": {
            "en": "Say where you live",
            "ru": "Сказать, где вы живёте"
          },
          "expected_it": "Abito a [città], in [Paese/regione]."
        }
      ]
    },
    {
      "id": "D-A1L3-1-02",
      "title": "Dove abiti?",
      "register": "neutral",
      "context": {
        "en": "Practising city, region and country in a short exchange.",
        "ru": "Короткий диалог для практики города, региона и страны."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Dove abiti?",
          "en": "Where do you live?",
          "ru": "Где ты живёшь?"
        },
        {
          "speaker": "B",
          "it": "Abito a Pisa, in Toscana, in Italia.",
          "en": "I live in Pisa, in Tuscany, in Italy.",
          "ru": "Я живу в Пизе, в Тоскане, в Италии."
        },
        {
          "speaker": "A",
          "it": "E di dove sei?",
          "en": "And where are you from?",
          "ru": "А откуда ты?"
        },
        {
          "speaker": "B",
          "it": "Sono di Lione, ma adesso abito a Firenze.",
          "en": "I am from Lyon, but now I live in Florence.",
          "ru": "Я из Лиона, но сейчас живу во Флоренции."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Ask where someone lives",
            "ru": "Спросить, где человек живёт"
          },
          "expected_it": "Dove abiti?"
        },
        {
          "cue": {
            "en": "Answer with city, region and country",
