        }
      ]
    },
    {
      "id": "D-A1L3-1-03",
      "title": "Dove abiti?",
      "register": "informal",
      "context": {
        "en": "Two neighbors meet and exchange address, floor, and personal details.",
        "ru": "Два соседа знакомятся и обмениваются адресами, этажами и личными данными."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Ciao, sei nuovo nel palazzo?",
          "en": "Hi, are you new in the building?",
          "ru": "Привет, ты новенький в доме?"
        },
        {
          "speaker": "B",
          "it": "Sì, mi chiamo Matteo.",
          "en": "Yes, my name is Matteo.",
          "ru": "Да, меня зовут Маттео."
        },
        {
          "speaker": "A",
          "it": "Piacere, Matteo. Io sono Chiara.",
          "en": "Nice to meet you, Matteo. I'm Chiara.",
          "ru": "Приятно познакомиться, Маттео. Я Кьяра."
        },
        {
          "speaker": "B",
          "it": "Piacere, Chiara. Tu abiti qui?",
          "en": "Nice to meet you, Chiara. Do you live here?",
          "ru": "Приятно, Кьяра. Ты здесь живёшь?"
        },
        {
          "speaker": "A",
          "it": "Sì, abito al terzo piano.",
          "en": "Yes, I live on the third floor.",
          "ru": "Да, живу на третьем этаже."
        },
        {
          "speaker": "B",
          "it": "Io abito al secondo piano.",
          "en": "I live on the second floor.",
          "ru": "Я живу на втором этаже."
        },
        {
          "speaker": "A",
          "it": "Qual è il tuo interno?",
          "en": "What's your apartment number?",
          "ru": "Какой у тебя номер квартиры?"
        },
        {
          "speaker": "B",
          "it": "Interno quattro. E il tuo?",
          "en": "Apartment four. And yours?",
          "ru": "Квартира четыре. А твой?"
        },
        {
          "speaker": "A",
          "it": "Interno sette.",
          "en": "Apartment seven.",
          "ru": "Квартира семь."
        },
        {
          "speaker": "B",
          "it": "Allora siamo vicini di casa.",
          "en": "Then we're neighbors.",
          "ru": "Тогда мы соседи."
        },
        {
          "speaker": "A",
          "it": "Sì. Qual è il tuo indirizzo completo?",
          "en": "Yes. What's your full address?",
          "ru": "Да. Какой у тебя полный адрес?"
        },
        {
          "speaker": "B",
          "it": "Via Garibaldi, numero quindici.",
          "en": "Via Garibaldi, number fifteen.",
          "ru": "Улица Гарибальди, номер пятнадцать."
        },
        {
          "speaker": "A",
          "it": "Anche il mio. Da quanto tempo abiti qui?",
          "en": "Mine too. How long have you lived here?",
          "ru": "У меня тоже. Как давно ты здесь живёшь?"
        },
        {
          "speaker": "B",
          "it": "Da una settimana.",
          "en": "For a week.",
          "ru": "Неделю."
        },
        {
          "speaker": "A",
          "it": "Ti piace il quartiere?",
          "en": "Do you like the neighborhood?",
          "ru": "Тебе нравится район?"
        },
        {
          "speaker": "B",
          "it": "Sì, mi piace molto.",
          "en": "Yes, I like it a lot.",
          "ru": "Да, мне очень нравится."
        },
        {
          "speaker": "A",
          "it": "Qui vicino c'è un bar buono.",
          "en": "There's a good bar nearby.",
          "ru": "Рядом есть хороший бар."
        },
        {
          "speaker": "B",
          "it": "Davvero? Dov'è?",
          "en": "Really? Where is it?",
          "ru": "Правда? Где он?"
        },
        {
