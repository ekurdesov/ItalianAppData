  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Origin with di + city",
        "ru": "Происхождение с di + город",
        "es": "Origen con di + ciudad"
      },
      "description": {
        "en": "To say where a person is from, Italian commonly uses 'essere di' followed by a city.",
        "ru": "Чтобы сказать, откуда человек родом, в итальянском обычно используется конструкция 'essere di' с названием города.",
        "es": "Para decir de dónde es una persona, el italiano suele utilizar \"essere di\" seguido de una ciudad."
      },
      "examples": [
        {
          "it": "Sono di Casinalbo.",
          "en": "I am from Casinalbo.",
          "ru": "Я из Казинальбо.",
          "es": "Soy de Casinalbo."
        },
        {
          "it": "Stefi è di Prato.",
          "en": "Stefi is from Prato.",
          "ru": "Стефи из Прато.",
          "es": "Stefi es de Prato."
        },
        {
          "it": "Di dov'è Alexia?",
          "en": "Where is Alexia from?",
          "ru": "Откуда Алексия?",
          "es": "¿De dónde es Alexia?"
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Residence with a + city",
        "ru": "Место жительства с a + город",
        "es": "Residencia con una + ciudad"
      },
      "description": {
        "en": "To say where someone lives, Italian uses 'abitare a' with cities.",
        "ru": "Чтобы сказать, где кто-то живёт, в итальянском используется 'abitare a' с названиями городов.",
        "es": "Para decir dónde vive alguien, el italiano usa 'abitare a' con ciudades."
      },
      "examples": [
        {
          "it": "Abito a Firenze.",
          "en": "I live in Florence.",
          "ru": "Я живу во Флоренции.",
          "es": "Vivo en Florencia."
        },
        {
          "it": "Paolo abita a Roma.",
          "en": "Paolo lives in Rome.",
          "ru": "Паоло живёт в Риме.",
          "es": "Paolo vive en Roma."
        },
        {
          "it": "Patrick e John abitano a Londra.",
          "en": "Patrick and John live in London.",
          "ru": "Патрик и Джон живут в Лондоне.",
          "es": "Patrick y John viven en Londres."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Residence with in + country, region, continent",
        "ru": "Место жительства с in + страна, регион, континент",
        "es": "Residencia con en + país, región, continente"
      },
      "description": {
        "en": "Use 'in' with countries, regions and continents.",
        "ru": "Предлог 'in' употребляется со странами, регионами и континентами.",
        "es": "Utilice 'in' con países, regiones y continentes."
      },
      "examples": [
        {
          "it": "Abito in Italia.",
          "en": "I live in Italy.",
          "ru": "Я живу в Италии.",
          "es": "Vivo en Italia."
        },
        {
          "it": "Abito in Toscana.",
          "en": "I live in Tuscany.",
          "ru": "Я живу в Тоскане.",
          "es": "Vivo en la Toscana."
        },
        {
          "it": "Vivo in Africa.",
          "en": "I live in Africa.",
          "ru": "Я живу в Африке.",
          "es": "Vivo en África."
        },
        {
          "it": "In Inghilterra piove molto.",
          "en": "In England it rains a lot.",
          "ru": "В Англии много дождей.",
          "es": "En Inglaterra llueve mucho."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика",
        "es": "Gramática"
      },
      "rule": {
        "en": "Present tense of abitare",
        "ru": "Настоящее время глагола abitare",
        "es": "Tiempo presente de abitare"
      },
      "description": {
        "en": "The verb 'abitare' means 'to live' or 'to reside'.",
        "ru": "Глагол 'abitare' означает 'жить', 'проживать'.",
        "es": "El verbo abitare significa vivir o residir."
      },
      "conjugations": {
        "io": "abito",
        "tu": "abiti",
        "lui/lei/Lei": "abita",
        "noi": "abitiamo",
        "voi": "abitate",
        "loro": "abitano"
      }
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика",
        "es": "Pragmática"
      },
      "rule": {
        "en": "Asking and stating residence",
        "ru": "Как спросить и сказать, где человек живёт",
        "es": "Preguntar y declarar residencia"
      },
      "description": {
        "en": "Italian uses 'Dove abiti?' and related forms to ask where someone lives. Answers can include city, region and country.",
        "ru": "В итальянском для вопроса о месте жительства используются формы 'Dove abiti?' и похожие конструкции. В ответ можно назвать город, регион и страну.",
        "es": "El italiano utiliza 'Dove abiti?' y formularios relacionados para preguntar dónde vive alguien. Las respuestas pueden incluir ciudad, región y país."
      },
      "examples": [
        {
          "context": "informal",
          "it": "Dove abiti?",
          "en": "Where do you live?",
          "ru": "Где ты живёшь?",
          "es": "¿Dónde vive?"
        },
        {
          "context": "formal",
          "it": "Dove abita?",
          "en": "Where do you live? (formal)",
          "ru": "Где Вы живёте?",
          "es": "¿Dónde vive? (formal)"
        },
        {
          "context": "answer",
          "it": "Abito a Pisa, in Toscana, in Italia.",
          "en": "I live in Pisa, in Tuscany, in Italy.",
          "ru": "Я живу в Пизе, в Тоскане, в Италии.",
          "es": "Vivo en Pisa, en Toscana, en Italia."
        }
      ]
    }
  ],
