{
  "lesson_info": {
    "id": "A1-L3-7",
    "title": "I vicini di casa",
    "level": "A1",
    "objectives": {
      "it": [
        "Lessico: Com'è?",
        "Comprensione orale: Alla festa",
        "Grammatica: c'è / ci sono",
        "Descrivere l'aspetto fisico: È alto, è moro, ha gli occhiali"
      ],
      "en": [
        "Vocabulary: what is he/she like?",
        "Listening comprehension: At the party",
        "Grammar: c'è / ci sono",
        "Describing physical appearance: He is tall, dark-haired, and wears glasses"
      ],
      "ru": [
        "Лексика: Com'è?",
        "Аудирование: Alla festa",
        "Грамматика: c'è / ci sono",
        "Описание внешности: È alto, è moro, ha gli occhiali"
      ]
    }
  },
  "language_rules": [
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "c'è and ci sono",
        "ru": "c'è и ci sono"
      },
      "description": {
        "en": "'C'è' (ci + è) means 'there is' for a single item; 'ci sono' (ci + sono) means 'there are' for multiple items.",
        "ru": "«C'è» (ci + è) означает «есть» для одного предмета; «ci sono» (ci + sono) — «есть» для нескольких."
      },
      "examples": [
        {
          "it": "In questa foto c'è un signore calvo.",
          "en": "In this photo there is a bald man.",
          "ru": "На этой фотографии изображён лысый мужчина."
        },
        {
          "it": "In questa foto ci sono due persone anziane.",
          "en": "In this photo there are two elderly people.",
          "ru": "На этой фотографии изображены двое пожилых людей."
        },
        {
          "it": "Nella borsa c'è la chiave di casa.",
          "en": "In the bag there is the house key.",
          "ru": "В сумке есть ключ от дома."
        },
        {
          "it": "Sul banco ci sono i quaderni di Lucia.",
          "en": "On the desk there are Lucia's notebooks.",
          "ru": "На парте лежат тетради Лючии."
        }
      ]
    },
    {
      "category": {
        "en": "Grammar",
        "ru": "Грамматика"
      },
      "rule": {
        "en": "essere vs esserci",
        "ru": "essere vs esserci"
      },
      "description": {
        "en": "Use 'è/sono' to say what something IS or WHERE it is (known location). Use 'c'è/ci sono' to announce the EXISTENCE of something.",
        "ru": "«È/sono» используется, чтобы сказать, что что-то ЕСТЬ или ГДЕ оно находится (известное место). «C'è/ci sono» — чтобы сообщить о СУЩЕСТВОВАНИИ чего-либо."
      },
      "examples": [
        {
          "it": "Il libro è sul tavolo.",
          "en": "The book is on the table.",
          "ru": "Книга лежит на столе."
        },
        {
          "it": "Sul tavolo c'è un libro.",
          "en": "There is a book on the table.",
          "ru": "На столе лежит книга."
        },
        {
          "it": "I soldi sono nel portafoglio.",
          "en": "The money is in the wallet.",
          "ru": "Деньги в кошельке."
        },
        {
          "it": "Nel portafoglio ci sono i soldi.",
          "en": "There is money in the wallet.",
          "ru": "В кошельке есть деньги."
        }
      ]
    },
    {
      "category": {
        "en": "Vocabulary",
        "ru": "Лексика"
      },
      "rule": {
        "en": "Describing mood and emotional state",
        "ru": "Описание настроения и эмоционального состояния"
      },
      "description": {
        "en": "Italian uses 'essere' + adjective to describe how someone feels.",
        "ru": "В итальянском для описания состояния используется essere + прилагательное."
      },
      "examples": [
        {
          "it": "È arrabbiato.",
          "en": "He is angry.",
          "ru": "Он злой."
        },
        {
          "it": "È felice.",
          "en": "He/She is happy.",
          "ru": "Он/она счастлив(а)."
        },
        {
          "it": "È stanco.",
          "en": "He is tired.",
          "ru": "Он устал."
        },
        {
          "it": "È triste.",
          "en": "He/She is sad.",
          "ru": "Он/она грустный(-ая)."
        },
        {
          "it": "È preoccupata.",
          "en": "She is worried.",
          "ru": "Она обеспокоена."
        },
        {
          "it": "È annoiata.",
          "en": "She is bored.",
          "ru": "Ей скучно."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Describing a person at a party",
        "ru": "Описание человека на вечеринке"
      },
      "description": {
        "en": "Combining physical description with c'è/ci sono to identify people in a group.",
        "ru": "Сочетание описания внешности с c'è/ci sono для идентификации людей в группе."
      },
      "examples": [
        {
          "it": "Il padrone di casa è il signore calvo, con i baffi.",
          "en": "The host is the bald man with the moustache.",
          "ru": "Хозяин — лысый мужчина с усами."
        },
        {
          "it": "Marco è quello con il maglione a righe e i capelli lunghi.",
          "en": "Marco is the one with the striped jumper and long hair.",
          "ru": "Марко — тот, что в полосатом свитере с длинными волосами."
        },
        {
          "it": "Luisa è la ragazza bionda, con i capelli lunghi.",
          "en": "Luisa is the blond girl with long hair.",
          "ru": "Луиза — блондинка с длинными волосами."
        },
        {
          "it": "Sara è quella con gli occhiali e i capelli corti e ricci.",
          "en": "Sara is the one with glasses and short curly hair.",
          "ru": "Сара — та, что в очках с короткими кудрявыми волосами."
        }
      ]
    },
    {
      "category": {
        "en": "Pragmatics",
        "ru": "Прагматика"
      },
      "rule": {
        "en": "Asking about mood: Di che umore sei?",
        "ru": "Спросить о настроении: Di che umore sei?"
      },
      "description": {
        "en": "A common question to ask how someone is feeling today.",
        "ru": "Распространённый вопрос о том, в каком настроении человек сегодня."
      },
      "examples": [
        {
          "context": "question",
          "it": "Di che umore sei oggi?",
          "en": "What mood are you in today?",
          "ru": "В каком ты сегодня настроении?"
        },
        {
          "context": "answer",
          "it": "Sono stanco/a.",
          "en": "I am tired.",
          "ru": "Я устал(а)."
        },
        {
          "context": "answer",
          "it": "Sono di buon umore.",
          "en": "I am in a good mood.",
          "ru": "Я в хорошем настроении."
        }
      ]
    }
  ],
