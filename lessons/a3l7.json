  "dialogues": [
    {
      "id": "D-A1L3-7-01",
      "title": "Alla festa",
      "register": "informal",
      "context": {
        "en": "Two people at a party identify the other guests by their appearance.",
        "ru": "Двое людей на вечеринке узнают других гостей по внешности."
      },
      "turns": [
        {
          "speaker": "A",
          "it": "Chi è il padrone di casa?",
          "en": "Who is the host?",
          "ru": "Кто хозяин?"
        },
        {
          "speaker": "B",
          "it": "È il signore calvo, con i baffi.",
          "en": "He is the bald man with the moustache.",
          "ru": "Это лысый мужчина с усами."
        },
        {
          "speaker": "A",
          "it": "E quella ragazza bionda con i capelli lunghi, chi è?",
          "en": "And that blond girl with long hair, who is she?",
          "ru": "А та блондинка с длинными волосами, кто это?"
        },
        {
          "speaker": "B",
          "it": "È Luisa.",
          "en": "She is Luisa.",
          "ru": "Это Луиза."
        },
        {
          "speaker": "A",
          "it": "C'è anche Marco?",
          "en": "Is Marco here too?",
          "ru": "Марко тоже здесь?"
        },
        {
          "speaker": "B",
          "it": "Sì, è quello con il maglione a righe e i capelli lunghi.",
          "en": "Yes, he is the one with the striped jumper and long hair.",
          "ru": "Да, это тот, что в полосатом свитере с длинными волосами."
        }
      ],
      "practice_prompts": [
        {
          "cue": {
            "en": "Say there is one person",
            "ru": "Сказать, что есть один человек"
          },
          "expected_it": "C'è un/una …"
        },
        {
          "cue": {
            "en": "Say there are several people",
            "ru": "Сказать, что есть несколько людей"
          },
          "expected_it": "Ci sono … persone."
        },
        {
          "cue": {
            "en": "Identify someone by appearance",
            "ru": "Описать кого-то по внешности"
          },
          "expected_it": "È quello/quella con … / È il/la … con …"
        }
      ]
    }
  ],
