{
  "lesson_info": {
    "id": "A1-L1-7",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Comprensione orale: In giro per l'Italia",
      "Le preposizioni",
      "Attività comunicativa: Qual è il tuo numero?",
      "Fonetica: lettera Q"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Preposition 'di'",
      "description": "The preposition 'di' is used for possession, belonging, and specification.",
      "sub_rules": [
        {
          "usage": "possesso, appartenenza",
          "examples": [
            { "it": "il gatto di Fiona", "en": "Fiona's cat" },
            { "it": "il cellulare di Stefano", "en": "Stefano's cellphone" }
          ]
        },
        {
          "usage": "specificazione",
          "examples": [
            { "it": "il corso d'italiano", "en": "the Italian course" },
            { "it": "il numero di telefono", "en": "the telephone number" }
          ]
        }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Demonstratives: questo, questa, questi, queste",
      "description": "Demonstratives agree with the gender and number of the noun they modify.",
      "examples": [
        { "it": "questo libro", "en": "this book", "gender_number": "masculine singular" },
        { "it": "questa valigia", "en": "this suitcase", "gender_number": "feminine singular" },
        { "it": "questi ragazzi", "en": "these boys", "gender_number": "masculine plural" },
        { "it": "queste scarpe", "en": "these shoes", "gender_number": "feminine plural" }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Prepositions 'a' and 'in'",
      "description": "The lesson introduces the location prepositions 'a' and 'in', especially in talking about cities, regions, and places in Italy.",
      "examples": [
        { "it": "a Roma", "en": "in/to Rome" },
        { "it": "in Italia", "en": "in Italy" }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking for a phone number: formal vs informal",
      "description": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking for a phone or cellphone number.",
      "examples": [
        { "context": "informal", "it": "Qual è il tuo numero di telefono?", "en": "What is your telephone number?" },
        { "context": "formal", "it": "Qual è il Suo numero di telefono?", "en": "What is your telephone number? (formal)" },
        { "context": "informal", "it": "Qual è il tuo numero di cellulare?", "en": "What is your cellphone number?" },
        { "context": "formal", "it": "Qual è il Suo numero di cellulare?", "en": "What is your cellphone number? (formal)" },
        { "context": "answer", "it": "Il mio numero di telefono è...", "en": "My telephone number is..." },
        { "context": "answer", "it": "Il mio numero di cellulare è...", "en": "My cellphone number is..." }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Letter Q and related qu/gu combinations",
      "description": "In the lesson, 'qu' and some 'gu' combinations before vowels are practiced with a [kw] or [gw] sound.",
      "examples": [
        { "it": "questo", "en": "this" },
        { "it": "quello", "en": "that" },
        { "it": "qui", "en": "here" },
        { "it": "acqua", "en": "water" },
        { "it": "quartiere", "en": "neighborhood" },
        { "it": "guardare", "en": "to look" },
        { "it": "guidare", "en": "to drive" }
      ]
    }
  ],
