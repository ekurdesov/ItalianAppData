
{
  "lesson_info": {
    "id": "A1-L2-2",
    "title": "La classe di Carla",
    "level": "A1",
    "objectives": [
      "Comprensione orale: Ciao, io sono Alice",
      "Aggettivi di nazionalità al plurale",
      "Attività comunicativa: presentare",
      "Fonetica: gli - gn, sc"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Nationality adjectives in the plural",
      "description": "Nationality adjectives agree with the noun in gender and number, including plural forms.",
      "examples": [
        { "it": "tedeschi / tedesche", "en": "German men / German women" },
        { "it": "italiani / italiane", "en": "Italian men / Italian women" },
        { "it": "francesi", "en": "French (plural)" },
        { "it": "inglesi", "en": "English (plural)" },
        { "it": "americani / americane", "en": "American men / American women" }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Asking and stating origin",
      "description": "Italian distinguishes informal 'tu' and formal 'Lei' when asking where someone is from.",
      "examples": [
        { "context": "informal", "it": "Di dove sei?", "en": "Where are you from?" },
        { "context": "formal", "it": "Di dov'è?", "en": "Where are you from? (formal)" },
        { "context": "answer", "it": "Sono italiano.", "en": "I am Italian." },
        { "context": "answer", "it": "Sono di Milano.", "en": "I am from Milan." },
        { "context": "answer", "it": "Sono italiano, di Milano.", "en": "I am Italian, from Milan." }
      ]
    },
    {
      "category": "Grammar",
      "rule": "Demonstratives: questo, questa, questi, queste",
      "description": "Italian demonstratives agree in gender and number with the noun they refer to.",
      "examples": [
        { "it": "Questo è Mario.", "en": "This is Mario.", "gender_number": "masculine singular" },
        { "it": "Questi sono Mario e Valerio.", "en": "These are Mario and Valerio.", "gender_number": "masculine plural" },
        { "it": "Questa è Stefania.", "en": "This is Stefania.", "gender_number": "feminine singular" },
        { "it": "Queste sono Stefania e Sofia.", "en": "These are Stefania and Sofia.", "gender_number": "feminine plural" }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Introducing people: formal vs informal",
      "description": "Italian uses different formulas for presenting someone in informal and formal situations.",
      "examples": [
        { "context": "informal", "it": "Ti presento Mario.", "en": "Let me introduce Mario to you." },
        { "context": "informal", "it": "Lui/Questo è Mario.", "en": "He/This is Mario." },
        { "context": "informal", "it": "Lei/Questa è Maria.", "en": "She/This is Maria." },
        { "context": "formal", "it": "Le presento il signor Bianchi.", "en": "Let me introduce Mr. Bianchi to you." },
        { "context": "formal", "it": "Lei/Questa è la signora Bianchi.", "en": "She/This is Mrs. Bianchi." }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Titles of courtesy",
      "description": "Use 'signor' and 'signora' as polite titles before surnames or in formal address.",
      "examples": [
        { "it": "Questo è il signor Rossi.", "en": "This is Mr. Rossi." },
        { "it": "Questa è la signora Rossi.", "en": "This is Mrs. Rossi." },
        { "it": "Buonasera, signor Rossi!", "en": "Good evening, Mr. Rossi!" },
        { "it": "Buonasera, signora Rossi!", "en": "Good evening, Mrs. Rossi!" }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Sounds of l, gli, gn, and nasal n before c/q/g",
      "description": "The lesson contrasts plain 'l', palatal 'gli', palatal nasal 'gn', and nasal assimilation before certain consonants.",
      "sub_rules": [
        {
          "pattern": "l",
          "sound": "[l]",
          "examples": [
            { "it": "alunno", "en": "pupil" },
            { "it": "parlare", "en": "to speak" },
            { "it": "classe", "en": "class" }
          ]
        },
        {
          "pattern": "gli",
          "sound": "[ʎ]",
          "examples": [
            { "it": "famiglia", "en": "family" },
            { "it": "figlio / figlia", "en": "son / daughter" },
            { "it": "bottiglia", "en": "bottle" }
          ]
        },
        {
          "pattern": "gn",
          "sound": "[ɲ]",
          "examples": [
            { "it": "signora", "en": "madam" },
            { "it": "bagno", "en": "bathroom" },
            { "it": "insegnante", "en": "teacher" }
          ]
        },
        {
          "pattern": "n + c, q, g",
          "sound": "[ŋ]",
          "examples": [
            { "it": "banca", "en": "bank" },
            { "it": "lingua", "en": "language" },
            { "it": "incontrare", "en": "to meet" }
          ]
        }
      ]
    }
  ],
