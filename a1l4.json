{
  "lesson_info": {
    "id": "A1-L1-4",
    "title": "Piacere!",
    "level": "A1",
    "objectives": [
      "Ripasso: essere e chiamarsi",
      "Comprensione orale: 'Scusi, Lei come si chiama?'",
      "Attività comunicativa: presentarsi",
      "Fonetica: lettera G"
    ]
  },
  "language_rules": [
    {
      "category": "Grammar",
      "rule": "Present tense of essere",
      "description": "The verb 'essere' is used to identify people and state who someone is.",
      "conjugations": {
        "io": "sono",
        "tu": "sei",
        "lui/lei/Lei": "è",
        "noi": "siamo",
        "voi": "siete",
        "loro": "sono"
      }
    },
    {
      "category": "Grammar",
      "rule": "Present tense of chiamarsi",
      "description": "The reflexive verb 'chiamarsi' is used to ask and say names.",
      "conjugations": {
        "io": "mi chiamo",
        "tu": "ti chiami",
        "lui/lei/Lei": "si chiama",
        "noi": "ci chiamiamo",
        "voi": "vi chiamate",
        "loro": "si chiamano"
      }
    },
    {
      "category": "Grammar",
      "rule": "Italian personal pronouns",
      "description": "The lesson reviews the core subject pronouns used with 'essere' and 'chiamarsi'.",
      "examples": [
        { "it": "io", "en": "I" },
        { "it": "tu", "en": "you (informal singular)" },
        { "it": "lui / lei / Lei", "en": "he / she / you (formal)" },
        { "it": "noi", "en": "we" },
        { "it": "voi", "en": "you (plural)" },
        { "it": "loro", "en": "they" }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Asking and giving names: formal vs informal",
      "description": "Italian distinguishes between informal 'tu' and formal 'Lei' when asking for someone's name and surname.",
      "examples": [
        { "context": "informal", "it": "Come ti chiami?", "en": "What is your name?" },
        { "context": "formal", "it": "Come si chiama?", "en": "What is your name? (formal)" },
        { "context": "informal", "it": "E di cognome?", "en": "And your surname?" },
        { "context": "formal", "it": "E il Suo?", "en": "And yours? (formal)" },
        { "context": "statement", "it": "Il mio nome è...", "en": "My name is..." },
        { "context": "statement", "it": "Il mio cognome è...", "en": "My surname is..." }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Reacting during introductions",
      "description": "Standard formulas are used when meeting someone for the first time.",
      "examples": [
        { "it": "Piacere di conoscerti.", "en": "Nice to meet you. (informal)" },
        { "it": "Piacere di conoscerla.", "en": "Nice to meet you. (formal)" },
        { "it": "Molto lieto/a.", "en": "Very pleased." },
        { "it": "Piacere.", "en": "Pleasure." },
        { "it": "Piacere mio.", "en": "The pleasure is mine." },
        { "it": "Altrettanto.", "en": "Likewise." }
      ]
    },
    {
      "category": "Pragmatics",
      "rule": "Formal vs informal greetings",
      "description": "Greetings and leave-taking expressions vary by time of day and level of formality.",
      "examples": [
        { "context": "arrival informal", "it": "Ciao!", "en": "Hi!" },
        { "context": "arrival formal", "it": "Buongiorno! / Buon dì!", "en": "Good morning / good day!" },
        { "context": "arrival formal", "it": "Buonasera!", "en": "Good evening!" },
        { "context": "arrival formal", "it": "Salve!", "en": "Hello!" },
        { "context": "departure formal", "it": "ArrivederLa!", "en": "Goodbye (formal)" },
        { "context": "departure", "it": "Arrivederci!", "en": "Goodbye" },
        { "context": "departure", "it": "Buona giornata! / Buona serata!", "en": "Have a nice day / evening!" }
      ]
    },
    {
      "category": "Phonetics",
      "rule": "Pronunciation of letter G",
      "description": "The sound of 'g' changes according to the letters that follow it.",
      "sub_rules": [
        {
          "pattern": "g + a, o, u, consonant",
          "sound": "[g]",
          "examples": [
            { "it": "gamba", "en": "leg" },
            { "it": "gatto", "en": "cat" },
            { "it": "gusto", "en": "taste" },
            { "it": "grande", "en": "big" }
          ]
        },
        {
          "pattern": "g + e, i",
          "sound": "[dʒ]",
          "examples": [
            { "it": "gente", "en": "people" },
            { "it": "girare", "en": "to turn" },
            { "it": "ginnastica", "en": "gymnastics" },
            { "it": "Genova", "en": "Genoa" }
          ]
        },
        {
          "pattern": "gh + e, i",
          "sound": "[g]",
          "examples": [
            { "it": "ghetto", "en": "ghetto" },
            { "it": "laghi", "en": "lakes" },
            { "it": "ghirlanda", "en": "garland" },
            { "it": "ghiro", "en": "dormouse" }
          ]
        },
        {
          "pattern": "gi + a, o, u",
          "sound": "[dʒ]",
          "examples": [
            { "it": "già", "en": "already" },
            { "it": "giorno", "en": "day" },
            { "it": "giusto", "en": "right, correct" },
            { "it": "giocare", "en": "to play" }
          ]
        }
      ]
    }
  ],
